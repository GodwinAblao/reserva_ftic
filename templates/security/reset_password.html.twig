{% extends 'base.html.twig' %}

{% block title %}Reset Password - Reserva{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
    <header class="header">
        <div class="header-inner">
            <div class="header-logo">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('images/R-Logo.png') }}" alt="R Logo">
                </a>
            </div>

            <nav class="header-nav">
                <a href="{{ path('app_home') }}#about">About us</a>
                <a href="{{ path('app_home') }}#faq">FAQ</a>
            </nav>

            <div class="header-auth">
                <a href="{{ path('app_login') }}" class="btn-login" data-turbo="false" target="_self">Login</a>
                <a href="{{ path('app_register') }}" class="btn-signup" data-turbo="false" target="_self">Sign in</a>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="logo-side">
            <img src="{{ asset('images/R-Logo.png') }}" alt="Reserva Logo" class="logo-image" />
        </div>

        <div class="form-side">
            <div class="form-wrapper">
                <div class="form-header">
                    <h1 class="form-title">Reset Password</h1>
                    <p class="form-subtitle">Create a new password for your account</p>
                </div>

                {% if errors|length > 0 %}
                    <div class="alert alert-danger" style="margin-bottom: 1rem; color: #dc2626;">
                        {% for error in errors %}
                            {{ error }}{% if not loop.last %}<br>{% endif %}
                        {% endfor %}
                    </div>
                {% endif %}

                <form method="post" action="{{ path('app_reset_password', {'token': token}) }}" data-turbo="false" class="form">
                    <div class="form-group">
                        <label for="password" class="form-label">New Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" id="password" name="password" class="form-input" required />
                            <button type="button" class="password-toggle" data-password-toggle="password" aria-label="Show password" title="Show password" data-eye-state="off"><span class="password-eye" aria-hidden="true">👁</span></button>
                        </div>
                        <small style="display: block; margin-top: 0.5rem; color: #6b7280; font-size: 0.875rem;">Password must be 8+ chars with uppercase, lowercase, number, special char. Cannot reuse old password.</small>
                    </div>

                    <div class="form-group">
                        <label for="passwordRepeat" class="form-label">Confirm Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" id="passwordRepeat" name="passwordRepeat" class="form-input" required />
                            <button type="button" class="password-toggle" data-password-toggle="passwordRepeat" aria-label="Show password" title="Show password" data-eye-state="off"><span class="password-eye" aria-hidden="true">👁</span></button>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

                    <button type="submit" class="submit-button">Change Password</button>

                    <div class="login-link-container">
                        <p class="login-text">
                            <a href="{{ path('app_login') }}" class="login-link" data-turbo="false" target="_self">Back to Login</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <style>
        .strength-bar {
            width: 100%;
            height: 4px;
            background: #ddd;
            border-radius: 2px;
            overflow: hidden;
            margin-top: 5px;
        }
        #strength-fill {
            height: 100%;
            transition: width 0.3s ease;
            border-radius: 2px;
        }
        .weak { background: #ff4757; }
        .medium { background: #ffa502; }
        .strong { background: #2ed573; }
        .password-input-wrapper {
            position: relative;
        }
        .password-input-wrapper input {
            width: 100%;
            padding-right: 2.7rem;
        }
        .password-toggle {
            position: absolute;
            right: 0.7rem;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            line-height: 1;
            color: #6b7280;
        }
        .password-toggle:hover {
            color: #16a34a;
        }
    </style>

    <script>
        const passwordField = document.getElementById('password');
        const strengthFill = document.getElementById('strength-fill');
        const strengthText = document.getElementById('strength-text');

        function getStrength(password) {
            let score = 0;
            if (password.length >= 8) score++;
            if (/[a-z]/.test(password)) score++;
            if (/[A-Z]/.test(password)) score++;
            if (/\\d/.test(password)) score++;
            if (/[@$!%*?&]/.test(password)) score++;
            return score;
        }

        passwordField.addEventListener('input', function() {
            const strength = getStrength(this.value);
            let strengthClass, text, width;
            switch (strength) {
                case 0:
                case 1: strengthClass = 'weak'; text = 'Weak'; width = '20%'; break;
                case 2:
                case 3: strengthClass = 'medium'; text = 'Medium'; width = '60%'; break;
                default: strengthClass = 'strong'; text = 'Strong'; width = '100%'; break;
            }
            strengthFill.className = strengthClass;
            strengthFill.style.width = width;
            strengthText.textContent = text;
        });

        document.querySelectorAll('[data-password-toggle]').forEach(function(toggleButton) {
            toggleButton.addEventListener('click', function() {
                const targetId = toggleButton.getAttribute('data-password-toggle');
                const input = document.getElementById(targetId);
                if (!input) {
                    return;
                }

                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                toggleButton.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
                toggleButton.setAttribute('title', isPassword ? 'Hide password' : 'Show password');
                toggleButton.dataset.eyeState = isPassword ? 'on' : 'off';

            });
        });
    </script>
{% endblock %}
