{% extends 'base.html.twig' %}

{% block title %}Reset Password | Reserva FTIC{% endblock %}

{% block body_class %}page-login{% endblock %}

{% block body %}
    <div class="login-card">
        <div class="login-brand">
            <img src="{{ asset('images/Reserva-Logo.png') }}" alt="Reserva Logo">
        </div>

        <h2>Reset Password</h2>

        {% if errors|length > 0 %}
            <div class="alert alert-danger">
                <ul>
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_reset_password', {'token': token}) }}" data-turbo="false">
            <div class="form-group">
                <label for="password">New Password</label>
                <input type="password" id="password" name="password" required>
            </div>

            <div class="form-group">
                <label for="passwordRepeat">Confirm Password</label>
                <input type="password" id="passwordRepeat" name="passwordRepeat" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">

            <button class="btn-primary" type="submit">Change Password</button>
        </form>
    </div>
{% endblock %}
