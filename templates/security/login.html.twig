{% extends 'base.html.twig' %}

{% block title %}Reserva - Login{% endblock %}

{% block body_class %}page-auth{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/styles/login.css?v=20250625-10">
{% endblock %}

{% block importmap %}{% endblock %}

{% block body %}
    <header class="header">
        <div class="header-inner">
            <div class="header-logo">
                <a href="{{ path('app_home') }}" data-logo-slide-link data-logo-slide-direction="left" data-turbo="false" target="_self">
                    <img src="{{ asset('images/R-Logo.png') }}" alt="R Logo">
                </a>
            </div>

            <nav class="header-nav">
                <a href="{{ path('app_home') }}">Home</a>
                <a href="{{ path('app_home') }}#about">About us</a>
                <a href="{{ path('app_home') }}#faq">FAQ</a>
            </nav>

            <div class="header-auth">
                <a href="{{ path('app_login') }}" class="btn-login" data-turbo="false" target="_self">Login</a>
                <a href="{{ path('app_register') }}" class="btn-signup" data-turbo="false" target="_self">Sign up</a>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="logo-side">
            <img src="{{ asset('images/R-Logo.png') }}" alt="Reserva Logo" class="logo-image" />
        </div>

        <div class="form-side">
            <div class="form-wrapper">
                <div class="form-header">
                    <h1 class="form-title">Welcome back!</h1>
                    <p class="form-subtitle">Log in to your account</p>
                </div>

                {# Backend Logic: Flash Messages and Errors #}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success" style="margin-bottom: 1rem; color: #0D9B00;">{{ message }}</div>
                {% endfor %}
                {% set auth_error = app.session.flashbag.get('login_error')|first %}
                {% if auth_error %}
                    <div class="alert alert-error" style="background-color: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; font-weight: 500;">
                        {{ auth_error }}
                    </div>
                {% elseif error %}
                    <div class="alert alert-error" style="background-color: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; font-weight: 500;">
                        {% if error.messageKey is defined %}
                            {{ error.messageKey|trans(error.messageData|default({}), 'security') }}
                        {% elseif error.message is defined %}
                            {{ error.message }}
                        {% else %}
                            {{ error }}
                        {% endif %}
                    </div>
                {% endif %}

                <form class="form" method="post" action="{{ path('app_login') }}" id="loginForm" data-turbo="false">
                    <div class="form-group">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="email" value="{{ last_username }}" class="form-input" required autofocus />
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" id="password" name="password" class="form-input" required />
                <button type="button" class="password-toggle" data-password-toggle="password" aria-label="Show password" title="Show password" data-eye-state="off"> <span class="password-eye" aria-hidden="true">👁</span></button>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="forgot-password">
                        <a href="#" class="forgot-password-link" onclick="showForgotPassword(); return false;">Forgot password?</a>
                    </div>

                    <button type="submit" class="submit-button" id="loginSubmitButton">
                        Log in
                    </button>

                    <div class="signup-link-container">
                        <p class="signup-text">
                            You don't have an account?
                            <a href="{{ path('app_register') }}" class="signup-link" data-turbo="false" target="_self">Sign up</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Modal for Forgot Password #}
    <div id="forgotPasswordModal" class="modal" style="display:none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 1000;">
        <div class="modal-content" style="background: white; padding: 2.5rem; border-radius: 1rem; width: 100%; max-width: 400px; position: relative;">
            <button type="button" onclick="hideForgotPassword()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
            <h3 style="margin-bottom: 1.5rem; color: #0D9B00;">Forgot Password</h3>
            <form method="post" action="{{ path('app_forgot_password') }}" class="form" id="forgotPasswordForm">
                <div id="forgotPasswordError" class="alert alert-danger" style="display: none; margin-bottom: 1rem; background-color: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 0.75rem; border-radius: 0.5rem; font-size: 0.875rem;"></div>
                <div class="form-group">
                    <input type="email" name="email" class="form-input" placeholder="Enter your email" id="forgotPasswordEmail" required style="transition: border-color 0.2s;">
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">
                <button class="submit-button" type="submit" id="sendOtpButton">Send OTP</button>
            </form>
        </div>
    </div>

    {# Modal for OTP Verification #}
    <div id="otpModal" class="modal" style="display:none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 1000;">
        <div class="modal-content" style="background: white; padding: 2.5rem; border-radius: 1rem; width: 100%; max-width: 400px; position: relative;">
            <button type="button" onclick="hideOtpModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
            <h3 style="margin-bottom: 1.5rem; color: #0D9B00;">Verify OTP</h3>
            <div id="otpErrorAlert" class="alert alert-danger" style="display: none; margin-bottom: 1rem;"></div>
            <form method="post" id="otpForm" class="form">
                <div class="form-group">
                    <label for="otp" class="form-label">6-Digit OTP</label>
                    <input type="text" id="otp" name="otp" class="form-input" maxlength="6" placeholder="000000" required autofocus>
                    <small style="color: #6b7280; font-size: 0.875rem;">Check your email (including spam) for the OTP. Expires in 10 minutes.</small>
                </div>
                <input type="hidden" name="_csrf_token" id="otpCsrfToken" value="">
                <input type="hidden" name="token" id="otpToken" value="">
                <button class="submit-button" type="submit" id="verifyOtpButton">Verify OTP</button>
            </form>
            <div style="text-align: center; margin-top: 1rem;">
                <a href="#" onclick="showForgotPassword(); return false;" style="color: #0D9B00; font-weight: 600; text-decoration: none;">Back to Forgot Password</a>
            </div>
        </div>
    </div>

    {# Modal for Account Verification (Super Admin-created accounts) #}
    <div id="accountVerifyModal" class="modal" style="display:none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px);">
        <div class="modal-content" style="background: white; padding: 2.5rem; border-radius: 1rem; width: 100%; max-width: 420px; position: relative; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
            <div style="text-align:center; margin-bottom:1.5rem;">
                <div style="width:56px;height:56px;background:rgba(13,155,0,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#0D9B00" style="width:28px;height:28px;"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
                </div>
                <h3 style="margin:0 0 0.5rem; color:#111827; font-size:1.2rem; font-weight:700;">Verify Your Account</h3>
                <p id="accountVerifySubtitle" style="color:#6b7280; font-size:0.875rem; margin:0;">A 6-digit verification code has been sent to your email address.</p>
            </div>
            <div id="accountVerifyError" style="display:none; margin-bottom:1rem; background:#fef2f2; border:1px solid #fecaca; color:#991b1b; padding:0.75rem; border-radius:0.5rem; font-size:0.875rem;"></div>
            <div id="accountVerifySuccess" style="display:none; margin-bottom:1rem; background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; padding:0.75rem; border-radius:0.5rem; font-size:0.875rem;"></div>
            <form id="accountVerifyForm" method="post" action="{{ path('app_login_verify_account') }}">
                <div class="form-group" style="margin-bottom:1.25rem;">
                    <label for="accountVerifyCode" class="form-label">Verification Code</label>
                    <input type="text" id="accountVerifyCode" name="otp" class="form-input" maxlength="6" placeholder="000000" autocomplete="one-time-code" inputmode="numeric" required style="letter-spacing:0.3em; font-size:1.2rem; text-align:center;">
                    <small style="display:block; margin-top:6px; color:#6b7280; font-size:0.8rem;">Check your email (including spam). Code expires in 10 minutes.</small>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('account_verify') }}">
                <button type="submit" id="accountVerifySubmitBtn" class="submit-button" style="width:100%;">Verify &amp; Continue</button>
            </form>
            <div style="text-align:center; margin-top:1rem;">
                <span style="color:#6b7280; font-size:0.875rem;">Didn't receive the code? </span>
                <a href="#" id="accountVerifyResendLink" onclick="resendAccountVerifyOtp(); return false;" style="color:#0D9B00; font-weight:600; text-decoration:none; font-size:0.875rem;">Resend code</a>
                <span id="accountVerifyCooldown" style="display:none; color:#9ca3af; font-size:0.875rem;"> (wait <span id="accountVerifyCooldownSecs">120</span>s)</span>
            </div>
            <input type="hidden" id="accountVerifyResendCsrf" value="{{ csrf_token('account_verify_resend') }}">
        </div>
    </div>

    {# Modal for Reset Password #}
    <div id="resetPasswordModal" class="modal" style="display:none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 1000;">
        <div class="modal-content" style="background: white; padding: 2.5rem; border-radius: 1rem; width: 100%; max-width: 420px; position: relative;">
            <button type="button" onclick="hideResetPasswordModal()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
            <h3 style="margin-bottom: 1.5rem; color: #0D9B00;">Reset Password</h3>
            <div id="resetPasswordErrorAlert" class="alert alert-danger" style="display: none; margin-bottom: 1rem;"></div>
            <div id="resetPasswordSuccessAlert" class="alert alert-success" style="display: none; margin-bottom: 1rem;"></div>
            <form method="post" id="resetPasswordForm" class="form">
                <div class="form-group">
                    <label for="resetPasswordNew" class="form-label">New Password</label>
                    <div class="password-input-wrapper">
                        <input type="password" id="resetPasswordNew" name="password" class="form-input" required>
                        <button type="button" class="password-toggle" data-password-toggle="resetPasswordNew" aria-label="Show password" title="Show password" data-eye-state="off"><span class="password-eye" aria-hidden="true">👁</span></button>
                    </div>
                    <ul class="password-requirements" aria-live="polite">
                        <li data-reset-password-rule="length">At least 8 characters</li>
                        <li data-reset-password-rule="digit">At least 1 digit</li>
                        <li data-reset-password-rule="lowercase">At least 1 lower case letter</li>
                        <li data-reset-password-rule="uppercase">At least 1 upper case letter</li>
                        <li data-reset-password-rule="special">At least 1 special character such as *, -, or #</li>
                        <li data-reset-password-rule="allowed">Only letters, digits, and approved symbols</li>
                        <li data-reset-password-rule="common">Not a common password</li>
                    </ul>
                    <small style="display:block; margin-top: 6px; color: #6b7280; font-size: 0.78rem;">Cannot reuse old password.</small>
                </div>
                <div class="form-group">
                    <label for="resetPasswordRepeat" class="form-label">Confirm Password</label>
                    <div class="password-input-wrapper">
                        <input type="password" id="resetPasswordRepeat" name="passwordRepeat" class="form-input" required>
                        <button type="button" class="password-toggle" data-password-toggle="resetPasswordRepeat" aria-label="Show password" title="Show password" data-eye-state="off"><span class="password-eye" aria-hidden="true">👁</span></button>
                    </div>
                    <ul class="password-requirements password-requirements--confirm" aria-live="polite">
                        <li data-reset-password-rule="match">Passwords match</li>
                    </ul>
                </div>
                <input type="hidden" name="_csrf_token" id="resetPasswordCsrfToken" value="">
                <input type="hidden" name="token" id="resetPasswordToken" value="">
                <button class="submit-button" type="submit" id="changePasswordButton">Change Password</button>
            </form>
            <div style="text-align: center; margin-top: 1rem;">
                <a href="#" onclick="showOtpModal(document.getElementById('otpToken').value, document.getElementById('otpCsrfToken').value); return false;" style="color: #0D9B00; font-weight: 600; text-decoration: none;">Back to OTP</a>
            </div>
        </div>
    </div>

{# ORIGINAL SCRIPTS RESTORED #}
<script>
    window.__reservaMinimumLoadingMs = window.__reservaMinimumLoadingMs || 450;
    var minimumLoadingMs = window.__reservaMinimumLoadingMs;

    (function appendPasswordToggleStyles() {
        const styleTag = document.createElement('style');
        styleTag.textContent = `
            .password-input-wrapper { position: relative; }
            .password-input-wrapper .form-input { padding-right: 2.7rem; }
            .password-toggle {
                position: absolute;
                right: 0.7rem;
                top: 50%;
                transform: translateY(-50%);
                background: transparent;
                border: none;
                cursor: pointer;
                font-size: 1rem;
                line-height: 1;
                color: #6b7280;
                padding: 0.5rem;
                z-index: 10;
                pointer-events: auto;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .password-toggle:hover { color: #0D9B00; }
            .password-eye { pointer-events: none; }
            .password-input-wrapper input::-ms-reveal,
            .password-input-wrapper input::-ms-clear {
                display: none;
            }
            .password-input-wrapper input::-webkit-credentials-auto-fill-button {
                visibility: hidden;
                display: none !important;
            }
            .password-requirements {
                list-style: none;
                margin: 0.15rem 0 0;
                padding: 0;
                display: grid;
                gap: 0.25rem;
                color: #6b7280;
                font-size: 0.78rem;
                line-height: 1.25;
            }
            .password-requirements li {
                display: flex;
                align-items: flex-start;
                gap: 0.4rem;
                transition: color 0.2s ease;
            }
            .password-requirements li::before {
                content: "";
                width: 0.48rem;
                height: 0.48rem;
                margin-top: 0.24rem;
                border: 1px solid currentColor;
                border-radius: 9999px;
                flex: 0 0 auto;
                transition: background-color 0.2s ease, border-color 0.2s ease;
            }
            .password-requirements li.is-valid {
                color: #0D9B00;
                font-weight: 600;
            }
            .password-requirements li.is-valid::before {
                background: #0D9B00;
                border-color: #0D9B00;
            }
            .password-requirements li.is-invalid {
                color: #991b1b;
            }
            .password-requirements--confirm {
                margin-top: 0.15rem;
            }
        `;
        document.head.appendChild(styleTag);
    })();

    function setButtonLoading(button, isLoading, loadingText) {
        if (!button) {
            return;
        }

        if (isLoading) {
            if (!button.dataset.defaultLabel) {
                button.dataset.defaultLabel = button.textContent;
            }

            button.disabled = true;
            button.innerHTML = '<span class="button-loading-spinner" aria-hidden="true"></span>' + loadingText;
            return;
        }

        button.disabled = false;
        button.textContent = button.dataset.defaultLabel || button.textContent;
    }

    function finishButtonLoading(button, loadingText, loadingStartAt) {
        const elapsed = Date.now() - loadingStartAt;
        const remaining = Math.max(0, minimumLoadingMs - elapsed);
        window.setTimeout(function() {
            setButtonLoading(button, false, loadingText);
        }, remaining);
    }

    function initializePasswordToggles() {
        document.querySelectorAll('[data-password-toggle]').forEach(function(toggleButton) {
            if (toggleButton.dataset.toggleBound === 'true') {
                return;
            }

            toggleButton.dataset.toggleBound = 'true';
            toggleButton.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const targetId = toggleButton.getAttribute('data-password-toggle');
                const input = document.getElementById(targetId);
                if (!input) return;

                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                toggleButton.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
                toggleButton.setAttribute('title', isPassword ? 'Hide password' : 'Show password');
                toggleButton.dataset.eyeState = isPassword ? 'on' : 'off';
            });
        });
    }

    document.addEventListener('DOMContentLoaded', initializePasswordToggles);
    document.addEventListener('turbo:load', initializePasswordToggles);
    initializePasswordToggles();

    function initializeResetPasswordValidationChecklist() {
        const passwordInput = document.getElementById('resetPasswordNew');
        const confirmInput = document.getElementById('resetPasswordRepeat');
        const form = document.getElementById('resetPasswordForm');
        if (!passwordInput || !confirmInput || !form || passwordInput.dataset.validationChecklistBound === 'true') {
            return;
        }

        passwordInput.dataset.validationChecklistBound = 'true';

        const commonPasswords = ['123456', 'password', '12345678', 'qwerty', 'abc123', 'admin', 'letmein'];
        const rules = {
            length: function(value) {
                return value.length >= 8;
            },
            digit: function(value) {
                return /\d/.test(value);
            },
            lowercase: function(value) {
                return /[a-z]/.test(value);
            },
            uppercase: function(value) {
                return /[A-Z]/.test(value);
            },
            special: function(value) {
                return /[^A-Za-z0-9]/.test(value);
            },
            allowed: function(value) {
                return /^[A-Za-z0-9@$!%*?&#^_.\-~+=|\\\/:;,(){}\[\]<>"']*$/.test(value);
            },
            common: function(value) {
                return value === '' || !commonPasswords.includes(value.toLowerCase());
            }
        };

        function setRuleState(ruleName, isValid, shouldMarkInvalid) {
            const item = document.querySelector('[data-reset-password-rule="' + ruleName + '"]');
            if (!item) {
                return;
            }

            item.classList.toggle('is-valid', shouldMarkInvalid && isValid);
            item.classList.toggle('is-invalid', shouldMarkInvalid && !isValid);
        }

        function updatePasswordChecklist() {
            const value = passwordInput.value;
            const hasStarted = value.length > 0;
            let firstFailedRule = '';

            Object.keys(rules).forEach(function(ruleName) {
                const isValid = rules[ruleName](value);
                setRuleState(ruleName, isValid, hasStarted);
                if (!isValid && !firstFailedRule) {
                    firstFailedRule = ruleName;
                }
            });

            passwordInput.setCustomValidity(!hasStarted || !firstFailedRule ? '' : 'Please complete the password requirements.');
            updateConfirmChecklist();
        }

        function updateConfirmChecklist() {
            const hasConfirmValue = confirmInput.value.length > 0;
            const matches = passwordInput.value !== '' && passwordInput.value === confirmInput.value;
            setRuleState('match', matches, hasConfirmValue);
            confirmInput.setCustomValidity(!hasConfirmValue || matches ? '' : 'Passwords must match.');
        }

        passwordInput.addEventListener('input', updatePasswordChecklist);
        confirmInput.addEventListener('input', updateConfirmChecklist);
        form.addEventListener('reset', function() {
            window.setTimeout(updatePasswordChecklist, 0);
        });
        updatePasswordChecklist();
    }

    document.addEventListener('DOMContentLoaded', initializeResetPasswordValidationChecklist);
    document.addEventListener('turbo:load', initializeResetPasswordValidationChecklist);
    initializeResetPasswordValidationChecklist();

    {% if show_account_verify_modal is defined and show_account_verify_modal %}
    document.addEventListener('DOMContentLoaded', function() {
        showAccountVerifyModal();
    });
    {% endif %}

    document.getElementById('loginForm')?.addEventListener('submit', function() {
        const loginSubmitButton = document.getElementById('loginSubmitButton');
        setButtonLoading(loginSubmitButton, true, 'Signing in...');
    });

    function showForgotPassword(){ 
        const loginEmail = document.getElementById('email').value;
        const forgotPasswordEmail = document.getElementById('forgotPasswordEmail');
        const forgotPasswordForm = document.getElementById('forgotPasswordForm');
        const errorDiv = document.getElementById('forgotPasswordError');
        
        // Clear any previous errors
        errorDiv.style.display = 'none';
        errorDiv.textContent = '';
        forgotPasswordEmail.style.borderColor = '';
        
        // If email exists in login form, auto-fill and auto-submit
        if (loginEmail && loginEmail.trim() !== '') {
            forgotPasswordEmail.value = loginEmail;
            // Hide forgot password modal, show loading via form submission
            document.getElementById('forgotPasswordModal').style.display='none';
            document.getElementById('otpModal').style.display='none';
            // Auto-submit the form
            forgotPasswordForm.dispatchEvent(new Event('submit'));
        } else {
            // No email in login form, show forgot password modal for manual entry
            document.getElementById('forgotPasswordModal').style.display='flex';
            document.getElementById('otpModal').style.display='none';
            forgotPasswordEmail.focus();
        }
    }
    function hideForgotPassword(){ 
        document.getElementById('forgotPasswordModal').style.display='none';
        // Clear errors when closing modal
        const errorDiv = document.getElementById('forgotPasswordError');
        const emailInput = document.getElementById('forgotPasswordEmail');
        errorDiv.style.display = 'none';
        errorDiv.textContent = '';
        emailInput.style.borderColor = '';
    }
    function showOtpModal(token, csrfToken){ 
        document.getElementById('otpToken').value = token;
        document.getElementById('otpCsrfToken').value = csrfToken;
        document.getElementById('otpErrorAlert').style.display = 'none';
        document.getElementById('otpErrorAlert').textContent = '';
        document.getElementById('resetPasswordModal').style.display='none';
        document.getElementById('otpModal').style.display='flex';
        document.getElementById('forgotPasswordModal').style.display='none';
        document.getElementById('otp').focus();
    }
    function hideOtpModal(){ document.getElementById('otpModal').style.display='none' }
    function showResetPasswordModal(token){
        document.getElementById('resetPasswordToken').value = token;
        document.getElementById('resetPasswordCsrfToken').value = '{{ csrf_token("reset_password") }}';
        document.getElementById('resetPasswordErrorAlert').style.display = 'none';
        document.getElementById('resetPasswordErrorAlert').textContent = '';
        document.getElementById('resetPasswordSuccessAlert').style.display = 'none';
        document.getElementById('resetPasswordSuccessAlert').textContent = '';
        document.getElementById('resetPasswordModal').style.display='flex';
        document.getElementById('otpModal').style.display='none';
        document.getElementById('resetPasswordNew').focus();
    }
    function hideResetPasswordModal(){ document.getElementById('resetPasswordModal').style.display='none' }
    
    window.addEventListener('click', function(e){ 
        const forgotModal = document.getElementById('forgotPasswordModal'); 
        if(e.target===forgotModal) hideForgotPassword();
        // OTP and Reset Password modals do NOT close on outside click
        // User must use X button or complete the flow
    });

    // Handle Forgot Password Form Submission
    document.getElementById('forgotPasswordForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const email = document.getElementById('forgotPasswordEmail').value;
        const csrfToken = this.querySelector('input[name="_csrf_token"]').value;
        const sendOtpButton = document.getElementById('sendOtpButton');
        const loadingStartAt = Date.now();

        setButtonLoading(sendOtpButton, true, 'Sending OTP...');
        
        fetch('{{ path("app_forgot_password") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json'
            },
            body: 'email=' + encodeURIComponent(email) + '&_csrf_token=' + encodeURIComponent(csrfToken)
        })
        .then(async response => {
            const data = await response.json().catch(() => ({}));
            const errorDiv = document.getElementById('forgotPasswordError');
            const emailInput = document.getElementById('forgotPasswordEmail');
            
            if (!response.ok || !data.success) {
                // Show inline error
                errorDiv.textContent = data.error || 'Failed to send OTP';
                errorDiv.style.display = 'block';
                emailInput.style.borderColor = '#ef4444';
                throw new Error(data.error || 'Failed to send OTP');
            }
            
            // Clear any previous errors
            errorDiv.style.display = 'none';
            errorDiv.textContent = '';
            emailInput.style.borderColor = '';
            
            return data;
        })
        .then(data => {
            if (data.success && data.token) {
                showOtpModal(data.token, csrfToken);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            // Error already displayed inline, no alert needed
        })
        .finally(() => {
            finishButtonLoading(sendOtpButton, 'Sending OTP...', loadingStartAt);
        });
    });

    // Handle OTP Form Submission
    document.getElementById('otpForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const otp = document.getElementById('otp').value;
        const token = document.getElementById('otpToken').value;
        const csrfToken = document.getElementById('otpCsrfToken').value;
        const verifyOtpButton = document.getElementById('verifyOtpButton');
        const loadingStartAt = Date.now();

        setButtonLoading(verifyOtpButton, true, 'Verifying...');
        
        fetch('{{ path("app_otp_reset", {"token": "TOKEN_PLACEHOLDER"}) }}'.replace('TOKEN_PLACEHOLDER', token), {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json'
            },
            body: 'otp=' + encodeURIComponent(otp) + '&_csrf_token=' + encodeURIComponent(csrfToken)
        })
        .then(async response => {
            const data = await response.json().catch(() => ({}));
            if (!response.ok) {
                throw new Error(data.error || 'Invalid OTP. Please try again.');
            }
            return data;
        })
        .then(data => {
            if (data.success && data.token) {
                showResetPasswordModal(data.token);
            } else if (data.redirectTo) {
                window.location.href = data.redirectTo;
            }
        })
        .catch(error => {
            document.getElementById('otpErrorAlert').style.display = 'block';
            document.getElementById('otpErrorAlert').textContent = error.message || 'Invalid OTP. Please try again.';
        })
        .finally(() => {
            finishButtonLoading(verifyOtpButton, 'Verifying...', loadingStartAt);
        });
    });

    document.getElementById('resetPasswordForm').addEventListener('submit', function(e) {
        e.preventDefault();
        if (!this.checkValidity()) {
            this.reportValidity();
            return;
        }

        const password = document.getElementById('resetPasswordNew').value;
        const passwordRepeat = document.getElementById('resetPasswordRepeat').value;
        const token = document.getElementById('resetPasswordToken').value;
        const csrfToken = document.getElementById('resetPasswordCsrfToken').value;
        const changePasswordButton = document.getElementById('changePasswordButton');
        const loadingStartAt = Date.now();

        setButtonLoading(changePasswordButton, true, 'Changing password...');

        fetch('{{ path("app_reset_password", {"token": "TOKEN_PLACEHOLDER"}) }}'.replace('TOKEN_PLACEHOLDER', token), {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json'
            },
            body: 'password=' + encodeURIComponent(password) + '&passwordRepeat=' + encodeURIComponent(passwordRepeat) + '&_csrf_token=' + encodeURIComponent(csrfToken)
        })
        .then(async response => {
            const data = await response.json().catch(() => ({}));
            if (!response.ok) {
                throw new Error(data.error || 'Password reset failed');
            }
            return data;
        })
        .then(() => {
            document.getElementById('resetPasswordSuccessAlert').style.display = 'block';
            document.getElementById('resetPasswordSuccessAlert').textContent = 'Password reset successfully. You can now sign in.';
            document.getElementById('resetPasswordErrorAlert').style.display = 'none';
            document.getElementById('resetPasswordForm').reset();
            setTimeout(function() {
                hideResetPasswordModal();
            }, 1500);
        })
        .catch(error => {
            document.getElementById('resetPasswordErrorAlert').style.display = 'block';
            document.getElementById('resetPasswordErrorAlert').textContent = error.message || 'Password reset failed';
            document.getElementById('resetPasswordSuccessAlert').style.display = 'none';
        })
        .finally(() => {
            finishButtonLoading(changePasswordButton, 'Changing password...', loadingStartAt);
        });
    });

    // ── Account Verify Modal ────────────────────────────────────────────────
    function showAccountVerifyModal() {
        document.getElementById('accountVerifyModal').style.display = 'flex';
        setTimeout(function() { document.getElementById('accountVerifyCode').focus(); }, 100);
        startAccountVerifyCooldown(120);
    }

    var _acvCooldownTimer = null;
    function startAccountVerifyCooldown(secs) {
        var remaining = secs;
        var resendLink = document.getElementById('accountVerifyResendLink');
        var cooldownEl = document.getElementById('accountVerifyCooldown');
        var secsEl     = document.getElementById('accountVerifyCooldownSecs');
        if (!resendLink) return;

        resendLink.style.display = 'none';
        cooldownEl.style.display = 'inline';
        secsEl.textContent = remaining;

        if (_acvCooldownTimer) clearInterval(_acvCooldownTimer);
        _acvCooldownTimer = setInterval(function() {
            remaining--;
            secsEl.textContent = remaining;
            if (remaining <= 0) {
                clearInterval(_acvCooldownTimer);
                resendLink.style.display = 'inline';
                cooldownEl.style.display = 'none';
            }
        }, 1000);
    }

    function resendAccountVerifyOtp() {
        var csrf = document.getElementById('accountVerifyResendCsrf').value;
        var errDiv = document.getElementById('accountVerifyError');
        var sucDiv = document.getElementById('accountVerifySuccess');
        errDiv.style.display = 'none';
        sucDiv.style.display = 'none';

        fetch('{{ path("app_login_resend_account_otp") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
            body: '_csrf_token=' + encodeURIComponent(csrf)
        })
        .then(function(res) { return res.json().catch(function() { return {}; }).then(function(d) { d._status = res.status; return d; }); })
        .then(function(data) {
            if (data.success) {
                sucDiv.textContent = 'A new verification code has been sent to your email.';
                sucDiv.style.display = 'block';
                startAccountVerifyCooldown(data.cooldownRemaining || 120);
            } else {
                errDiv.textContent = data.error || 'Could not resend code. Please try again.';
                errDiv.style.display = 'block';
            }
        })
        .catch(function() {
            errDiv.textContent = 'Network error. Please try again.';
            errDiv.style.display = 'block';
        });
    }

    document.getElementById('accountVerifyForm')?.addEventListener('submit', function(e) {
        e.preventDefault();
        var otp        = document.getElementById('accountVerifyCode').value.trim();
        var csrf       = this.querySelector('input[name="_csrf_token"]').value;
        var submitBtn  = document.getElementById('accountVerifySubmitBtn');
        var errDiv     = document.getElementById('accountVerifyError');
        var sucDiv     = document.getElementById('accountVerifySuccess');
        var loadingStartAt = Date.now();

        errDiv.style.display = 'none';
        sucDiv.style.display = 'none';
        setButtonLoading(submitBtn, true, 'Verifying...');

        fetch('{{ path("app_login_verify_account") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
            body: 'otp=' + encodeURIComponent(otp) + '&_csrf_token=' + encodeURIComponent(csrf)
        })
        .then(function(res) { return res.json().catch(function() { return {}; }).then(function(d) { d._status = res.status; return d; }); })
        .then(function(data) {
            if (data.success) {
                sucDiv.textContent = 'Account verified! Signing you in...';
                sucDiv.style.display = 'block';
                setTimeout(function() {
                    window.location.href = data.redirectTo || '{{ path("app_login") }}';
                }, 800);
            } else {
                errDiv.textContent = data.error || 'Invalid code. Please try again.';
                errDiv.style.display = 'block';
                finishButtonLoading(submitBtn, 'Verifying...', loadingStartAt);
            }
        })
        .catch(function() {
            errDiv.textContent = 'Network error. Please try again.';
            errDiv.style.display = 'block';
            finishButtonLoading(submitBtn, 'Verifying...', loadingStartAt);
        });
    });
    // ── End Account Verify Modal ─────────────────────────────────────────────

    let isLogoNavigating = false;
    document.querySelectorAll('[data-logo-slide-link]').forEach(function(link) {
        link.addEventListener('click', function(e) {
            if (isLogoNavigating) return;
            const logoSide = document.querySelector('.logo-side');
            const formSide = document.querySelector('.form-side');
            const transitionOverlay = document.getElementById('pageTransitionOverlay');
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

            e.preventDefault();
            isLogoNavigating = true;
            document.body.classList.add('is-page-transitioning');
            if (transitionOverlay) {
                transitionOverlay.style.display = 'flex';
            }
            logoSide?.classList.remove('logo-fade-out');
            formSide?.classList.remove('form-fade-out');
            void formSide?.offsetWidth;

            window.requestAnimationFrame(function() {
                logoSide?.classList.add('logo-fade-out');
                formSide?.classList.add('form-fade-out');
            });

            window.setTimeout(function() {
                window.location.href = link.href;
            }, 280);
        });
    });
</script>

    <div id="pageTransitionOverlay" class="page-transition-overlay" style="display: none;" aria-hidden="true">
        <span class="page-transition-spinner" aria-hidden="true"></span>
        <span class="page-transition-text">Loading...</span>
    </div>
{% endblock %}
