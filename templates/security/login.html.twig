{% extends 'base.html.twig' %}

{% block title %}Log in | Reserva FTIC{% endblock %}
{% block body_class %}page-login{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
<div class="login-layout">
    <section class="form-side">
        <div class="form-wrapper">
            <div class="form-header">
                <h1 class="form-title">Welcome back!</h1>
                <p class="form-subtitle">Sign in your account</p>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}" class="login-form" data-turbo="false">
                <div class="field">
                    <label class="field-label" for="login_email">Email</label>
                    <input class="input" id="login_email" type="email" name="email" value="{{ last_username }}" required>
                </div>

                <div class="field">
                    <label class="field-label" for="login_password">Password</label>
                    <input class="input" id="login_password" type="password" name="password" required>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="forgot-password">
                    <a class="forgot" href="#" onclick="showForgotPassword();return false;">Forgot password?</a>
                </div>

                <button class="btn btn-primary" type="submit">Sign in</button>

                <p class="login-foot">You don't have an account? <a class="btn-link" href="{{ path('app_register') }}" data-logo-slide-link data-logo-slide-direction="left">Sign up here</a></p>
            </form>
        </div>
    </section>

    <section class="logo-side" aria-hidden="true">
        <img src="{{ asset('images/R-Logo.png') }}" alt="Reserva Logo" class="logo-image">
    </section>
</div>

<!-- MODAL -->
<div id="forgotPasswordModal" class="modal">
    <div class="modal-content">
        <button class="close" onclick="hideForgotPassword()">&times;</button>
        <h3>Forgot Password</h3>
        <form method="post" action="{{ path('app_forgot_password') }}">
            <input type="email" name="email" placeholder="Enter your email" required>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">
            <button class="btn btn-primary" type="submit">Send OTP</button>
        </form>
    </div>
</div>

<script>
    function showForgotPassword(){ document.getElementById('forgotPasswordModal').style.display='flex' }
    function hideForgotPassword(){ document.getElementById('forgotPasswordModal').style.display='none' }
    window.addEventListener('click', function(e){ const modal = document.getElementById('forgotPasswordModal'); if(e.target===modal) hideForgotPassword(); });

    document.querySelectorAll('[data-logo-slide-link]').forEach(function(link) {
        link.addEventListener('click', function(e) {
            const logo = document.querySelector('.logo-image');
            const formSide = document.querySelector('.form-side');

            if (!logo || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) {
                return;
            }

            e.preventDefault();
            const direction = link.dataset.logoSlideDirection || 'left';
            logo.classList.remove('logo-slide-left', 'logo-slide-right');
            formSide?.classList.remove('form-fade-out');
            void logo.offsetWidth;

            logo.addEventListener('animationend', function() {
                window.location.href = link.href;
            }, { once: true });

            window.requestAnimationFrame(function() {
                logo.classList.add('logo-slide-' + direction);
                formSide?.classList.add('form-fade-out');
            });
        });
    });
</script>
    {% endblock %}
