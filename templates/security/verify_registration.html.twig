{% extends 'base.html.twig' %}

{% block title %}Verify Registration | Reserva FTIC{% endblock %}

{% block body_class %}page-login{% endblock %}
{% block body %}
    <div class="login-card verify-card">
        <div class="login-brand verify-card__header">
            <img src="{{ asset('images/Reserva-Logo.png') }}" alt="Reserva Logo">
            <h1>Confirm your institutional email</h1>
            <p>Enter the code we sent to your institutional address to complete registration.</p>
        </div>

        {% if errors is not empty %}
            <div class="verify-alert verify-alert--error">
                {% for error in errors %}
                    <span>{{ error }}</span>
                {% endfor %}
            </div>
        {% endif %}

        <div class="verify-summary">
            <span class="verify-summary__label">Institutional email</span>
            <strong>{{ data.email ?: 'Not available' }}</strong>
        </div>

        <form method="post" action="{{ path('app_verify_registration') }}" data-turbo="false" class="verify-form">
            <input type="hidden" name="email" value="{{ data.email }}">

            <label class="verify-field" for="verificationCode">
                <span>Verification code</span>
                <input type="text" id="verificationCode" name="verificationCode" value="{{ data.verificationCode }}" inputmode="numeric" autocomplete="one-time-code" maxlength="6" placeholder="Enter 6-digit code" required>
            </label>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('verify_registration') }}">

            <button class="verify-button verify-button--primary" type="submit">Verify account</button>
        </form>

        <div class="verify-divider"><span>Didn't receive it?</span></div>

        <form
            method="post"
            action="{{ path('app_resend_verification_code') }}"
            class="verify-resend"
            data-controller="resend-cooldown"
            data-resend-cooldown-remaining-value="{{ resendCooldownRemaining|default(0) }}"
            data-resend-cooldown-label-value="Resend code"
        >
            <input type="hidden" name="email" value="{{ data.email }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verification') }}">

            <button class="verify-button verify-button--secondary" type="submit" data-resend-cooldown-target="button">Resend code</button>
            <p class="verify-resend__status" data-resend-cooldown-target="status"></p>
        </form>

        <p class="verify-footer">
            Already verified? <a href="{{ path('app_login') }}" data-turbo="false" target="_self">Log in here</a>.
        </p>
    </div>
{% endblock %}
