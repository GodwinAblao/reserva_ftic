{% extends 'base.html.twig' %}

{% block title %}Verify Registration - Reserva{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
    <header class="header">
        <div class="header-inner">
            <div class="header-logo">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('images/R-Logo.png') }}" alt="R Logo">
                </a>
            </div>

            <nav class="header-nav">
                <a href="{{ path('app_home') }}#about">About us</a>
                <a href="{{ path('app_home') }}#faq">FAQ</a>
            </nav>

            <div class="header-auth">
                <a href="{{ path('app_login') }}" class="btn-login" data-turbo="false" target="_self">Login</a>
                <a href="{{ path('app_register') }}" class="btn-signup" data-turbo="false" target="_self">Sign in</a>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="logo-side">
            <img src="{{ asset('images/R-Logo.png') }}" alt="Reserva Logo" class="logo-image" />
        </div>

        <div class="form-side">
            <div class="form-wrapper">
                <div class="form-header">
                    <h1 class="form-title">Verify Email</h1>
                    <p class="form-subtitle">Confirm the code sent to your email</p>
                </div>

                {% if errors is not empty %}
                    <div class="alert alert-danger" style="margin-bottom: 1rem; color: #dc2626;">
                        {% for error in errors %}
                            <div>{{ error }}</div>
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="verify-summary" style="margin-bottom: 1.5rem; padding: 1rem; background-color: #f3f4f6; border-radius: 0.5rem;">
                    <span style="color: #6b7280; font-size: 0.875rem;">Email: <strong>{{ data.email ?: 'Not available' }}</strong></span>
                </div>

                <form method="post" action="{{ path('app_verify_registration') }}" data-turbo="false" class="form">
                    <input type="hidden" name="email" value="{{ data.email }}">

                    <div class="form-group">
                        <label for="verificationCode" class="form-label">6-Digit Code</label>
                        <input type="text" id="verificationCode" name="verificationCode" value="{{ data.verificationCode }}" class="form-input" inputmode="numeric" autocomplete="one-time-code" maxlength="6" placeholder="000000" required autofocus>
                        <small style="color: #6b7280; font-size: 0.875rem; display: block; margin-top: 0.5rem;">Check your email (including spam) for the verification code.</small>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('verify_registration') }}">

                    <button type="submit" class="submit-button">Verify Account</button>

                    <div class="login-link-container" style="margin-top: 1.5rem; text-align: center; border-top: 1px solid #e5e7eb; padding-top: 1rem;">
                        <p class="login-text" style="margin-bottom: 0.75rem;">Didn't receive the code?</p>
                        <form method="post" action="{{ path('app_resend_verification_code') }}" style="display: inline-block;">
                            <input type="hidden" name="email" value="{{ data.email }}">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verification') }}">
                            <button type="submit" class="login-link" style="background: none; border: none; cursor: pointer; color: #16a34a; font-weight: 600; text-decoration: none; padding: 0;">Resend code</button>
                        </form>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
