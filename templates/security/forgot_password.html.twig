{% extends 'base.html.twig' %}

{% block title %}Forgot Password - Reserva{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
    <header class="header">
        <div class="header-inner">
            <div class="header-logo">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('images/R-Logo.png') }}" alt="R Logo">
                </a>
            </div>

            <nav class="header-nav">
                <a href="{{ path('app_home') }}#about">About us</a>
                <a href="{{ path('app_home') }}#faq">FAQ</a>
            </nav>

            <div class="header-auth">
                <a href="{{ path('app_login') }}" class="btn-login" data-turbo="false" target="_self">Login</a>
                <a href="{{ path('app_register') }}" class="btn-signup" data-turbo="false" target="_self">Sign in</a>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="logo-side">
            <img src="{{ asset('images/R-Logo.png') }}" alt="Reserva Logo" class="logo-image" />
        </div>

        <div class="form-side">
            <div class="form-wrapper">
                <div class="form-header">
                    <h1 class="form-title">Forgot Password?</h1>
                    <p class="form-subtitle">We'll send you a code to reset it</p>
                </div>

                {% if errors|length > 0 %}
                    <div class="alert alert-danger" style="margin-bottom: 1rem; color: #dc2626;">
                        {% for error in errors %}
                            {{ error }}{% if not loop.last %}<br>{% endif %}
                        {% endfor %}
                    </div>
                {% endif %}

                {% for message in app.flashes('success') %}
                    <div class="alert alert-success" style="margin-bottom: 1rem; color: #15803d;">{{ message }}</div>
                {% endfor %}

                <form method="post" action="{{ path('app_forgot_password') }}" data-turbo="false" class="form">
                    <div class="form-group">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="email" value="{{ email }}" class="form-input" required autofocus />
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">

                    <button type="submit" class="submit-button">Send OTP</button>

                    <div class="login-link-container">
                        <p class="login-text">
                            Remember your password?
                            <a href="{{ path('app_login') }}" class="login-link" data-turbo="false" target="_self">Back to Login</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
