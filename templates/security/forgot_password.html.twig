{% extends 'base.html.twig' %}

{% block title %}Forgot Password | Reserva FTIC{% endblock %}

{% block body_class %}page-login{% endblock %}

{% block body %}
    <div class="login-card">
        <div class="login-brand">
            <img src="{{ asset('images/Reserva-Logo.png') }}" alt="Reserva Logo">
        </div>

        <h2>Forgot Password</h2>

        {% if errors|length > 0 %}
            <div class="alert alert-danger">
                <ul>
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" action="{{ path('app_forgot_password') }}" data-turbo="false">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="{{ email }}" required autofocus>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">

            <button class="btn-primary" type="submit">Send OTP</button>
            <a href="{{ path('app_login') }}" class="btn-link">Back to Login</a>
        </form>
    </div>
{% endblock %}
