{% extends 'base.html.twig' %}

{% block title %}Register | Reserva FTIC{% endblock %}
{% block body_class %}page-login{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/register.css') }}">
{% endblock %}

{% block body %}
<div class="register-layout">
    <section class="logo-side" aria-hidden="true">
        <img src="{{ asset('images/R-Logo.png') }}" alt="Reserva Logo" class="logo-image">
    </section>

    <section class="form-side">
        <div class="form-wrapper">
            <div class="form-header">
                <h1 class="form-title">Get Started with Reserva</h1>
                <p class="form-subtitle">Create an account to continue.</p>
            </div>

            {% if errors is not empty %}
                <div class="alert alert-error">
                    <ul>
                        {% for error in errors %}
                            <li>{{ error }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <form class="form" method="post" action="{{ path('app_register') }}" data-turbo="false">
                <div class="form-row">
                    <div class="form-group">
                        <label for="first_name" class="form-label">First Name</label>
                        <input id="first_name" class="form-input" type="text" name="firstName" value="{{ data.firstName }}" required>
                    </div>

                    <div class="form-group">
                        <label for="middle_name" class="form-label">Middle Name</label>
                        <input id="middle_name" class="form-input" type="text" name="middleName" value="{{ data.middleName }}">
                    </div>
                </div>

                <div class="form-group-full">
                    <label for="last_name" class="form-label">Last Name</label>
                    <input id="last_name" class="form-input" type="text" name="lastName" value="{{ data.lastName }}" required>
                </div>

                <div class="form-group-full">
                    <label for="institutional_email" class="form-label">Institutional Email</label>
                    <input id="institutional_email" class="form-input" type="email" name="institutionalEmail" value="{{ data.institutionalEmail }}" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="password" class="form-label">Password</label>
                        <input id="password" class="form-input" type="password" name="password" required>
                    </div>

                    <div class="form-group">
                        <label for="password_repeat" class="form-label">Confirm Password</label>
                        <input id="password_repeat" class="form-input" type="password" name="passwordRepeat" required>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">

                <button type="submit" class="submit-button">Sign up</button>

                <div class="login-link-container">
                    <p class="login-text">Already have an account? <a href="{{ path('app_login') }}" class="login-link" data-logo-slide-link data-logo-slide-direction="right">Log in here</a></p>
                </div>
            </form>
        </div>
    </section>
</div>

<script>
    document.querySelectorAll('[data-logo-slide-link]').forEach(function(link) {
        link.addEventListener('click', function(e) {
            const logo = document.querySelector('.logo-image');
            const formSide = document.querySelector('.form-side');

            if (!logo || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) {
                return;
            }

            e.preventDefault();
            const direction = link.dataset.logoSlideDirection || 'right';
            logo.classList.remove('logo-slide-left', 'logo-slide-right');
            formSide?.classList.remove('form-fade-out');
            void logo.offsetWidth;

            logo.addEventListener('animationend', function() {
                window.location.href = link.href;
            }, { once: true });

            window.requestAnimationFrame(function() {
                logo.classList.add('logo-slide-' + direction);
                formSide?.classList.add('form-fade-out');
            });
        });
    });
</script>

{% endblock %}
