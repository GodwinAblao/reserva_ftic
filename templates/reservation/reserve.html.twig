</style>

<script>
    // Auto-hide success messages after 3 seconds
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-success, .alert-success, .success-message');
        flashMessages.forEach(function(msg) {
            msg.style.transition = 'opacity 0.5s ease-out';
            msg.style.opacity = '0';
            setTimeout(function() {
                msg.style.display = 'none';
            }, 500);
        });
    }, 3000);

    // Original script continues...
(() => {
    if (typeof window.__reservaReservationCalendarCleanup === 'function') {
        window.__reservaReservationCalendarCleanup();
    }

    const cleanupTasks = [];
    function addManagedEvent(target, type, handler, options) {
        target.addEventListener(type, handler, options);
        cleanupTasks.push(() => target.removeEventListener(type, handler, options));
    }
    function addManagedInterval(handler, delay) {
        const id = window.setInterval(handler, delay);
        cleanupTasks.push(() => window.clearInterval(id));
        return id;
    }

    let bookedTimesData = (() => {
        const raw = {{ bookedTimes|raw }};
        if (typeof raw === 'string') {
            try {
                return JSON.parse(raw);
            } catch (error) {
                return {};
            }
        }
        return raw || {};
    })();
    let pendingTimesData = (() => {
        const raw = {{ pendingTimes|raw }};
        if (typeof raw === 'string') {
            try {
                return JSON.parse(raw);
            } catch (error) {
                return {};
            }
        }
        return raw || {};
    })();
    let classTimesData = (() => {
        const raw = {{ classTimes|raw }};
        if (typeof raw === 'string') {
            try {
                return JSON.parse(raw);
            } catch (error) {
                return {};
            }
        }
        return raw || {};
    })();
    let blockedTimesData = (() => {
        const raw = {{ blockedTimes|raw }};
        if (typeof raw === 'string') {
            try {
                return JSON.parse(raw);
            } catch (error) {
                return {};
            }
        }
        return raw || {};
    })();
    let maintenanceTimesData = (() => {
        const raw = {{ maintenanceTimes|raw }};
        if (typeof raw === 'string') {
            try {
                return JSON.parse(raw);
            } catch (error) {
                return {};
            }
        }
        return raw || {};
    })();
    let currentMonth = new Date();
    let selectedDate = null;
    let selectedStartTime = null;
    let selectedEndTime = null;
    let availabilityRefreshController = null;
    let knownScheduleRevision = {{ scheduleRevision|default('')|json_encode|raw }};
    const availabilityUrl = '{{ path('facility_reserve_availability', {'id': facility.id}) }}';
    const scheduleRevisionUrl = '{{ path('facility_schedule_revision') }}';
    let scheduleSyncStatusTimer = null;
    let calendarCleanedUp = false;

    window.__reservaReservationCalendarCleanup = () => {
        if (calendarCleanedUp) {
            return;
        }
        calendarCleanedUp = true;
        while (cleanupTasks.length > 0) {
            const cleanup = cleanupTasks.pop();
            try {
                cleanup();
            } catch (error) {}
        }
        if (availabilityRefreshController) {
            availabilityRefreshController.abort();
            availabilityRefreshController = null;
        }
        if (scheduleSyncStatusTimer) {
            window.clearTimeout(scheduleSyncStatusTimer);
            scheduleSyncStatusTimer = null;
        }
        const container = document.querySelector('.reservation-container');
        if (container) {
            delete container.dataset.calendarInit;
        }
        if (window.switchFacility === switchFacility) {
            delete window.switchFacility;
        }
    };

    // Helper function to format time (HH:mm to readable format)
    function formatTime(timeStr) {
        const [hours, minutes] = timeStr.split(':').map(Number);
        const period = hours >= 12 ? 'PM' : 'AM';
        const displayHours = hours % 12 || 12;
        return `${displayHours}:${minutes.toString().padStart(2, '0')} ${period}`;
    }

    // Restore existing selection when coming back from suggest-alternatives page
    function restoreExistingSelection() {
        const dateInput = document.getElementById('reservation_date');
        const startTimeInput = document.getElementById('reservation_start_time');
        const endTimeInput = document.getElementById('reservation_end_time');
        const selectedDateEl = document.getElementById('selectedDate');
        const selectedTimeEl = document.getElementById('selectedTime');

        if (dateInput && dateInput.value) {
            selectedDate = new Date(dateInput.value + 'T00:00:00');
            currentMonth = new Date(selectedDate);
            if (selectedDateEl) {
                selectedDateEl.textContent = selectedDate.toLocaleDateString('en-US', {
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                });
            }
        }

        if (startTimeInput && startTimeInput.value && endTimeInput && endTimeInput.value) {
            selectedStartTime = startTimeInput.value;
            selectedEndTime = endTimeInput.value;
            if (selectedTimeEl) {
                selectedTimeEl.textContent = formatTime(selectedStartTime) + ' - ' + formatTime(selectedEndTime);
            }
            // Re-render calendar to highlight the selected date and time slots
            renderCalendar();
        }
    }

    function initReservationCalendar() {
        const container = document.querySelector('.reservation-container');
        if (!container || container.dataset.calendarInit === '1') {
            return;
        }
        container.dataset.calendarInit = '1';

        const prevButton = document.getElementById('prevMonth');
        const nextButton = document.getElementById('nextMonth');
        const form = document.getElementById('reservationForm');

        if (!prevButton || !nextButton || !form) {
            return;
        }

        // PH Contact Number live validation
        const phoneInput = document.getElementById('contact');
        if (phoneInput) {
            addManagedEvent(phoneInput, 'input', function() {
                let v = this.value.replace(/[^0-9+]/g, '');
                if (v.length > 0 && v[0] !== '+' && v[0] !== '0') v = '0' + v;
                if (v.startsWith('+') && v.length > 13) v = v.slice(0, 13);
                if (v.startsWith('0') && v.length > 11) v = v.slice(0, 11);
                this.value = v;
                const re = /^(\+?63|0)9\d{9}$/;
                if (v.length > 3 && !re.test(v)) {
                    this.style.borderColor = '#dc3545';
                } else {
                    this.style.borderColor = '#e0e0e0';
                }
            });
            addManagedEvent(phoneInput, 'keydown', function(e) {
                if (e.key.length === 1 && !/[0-9+]/.test(e.key) && !e.ctrlKey && !e.metaKey) e.preventDefault();
            });
        }

        // Event Purpose dropdown - show/hide "other" text field
        const eventPurposeSelect = document.getElementById('eventPurpose');
        const eventPurposeOtherContainer = document.getElementById('eventPurposeOtherContainer');
        const eventPurposeOtherInput = document.getElementById('eventPurposeOther');

        function toggleEventPurposeOther() {
            if (eventPurposeSelect && eventPurposeOtherContainer) {
                if (eventPurposeSelect.value === 'others') {
                    eventPurposeOtherContainer.style.display = 'flex';
                    if (eventPurposeOtherInput) {
                        eventPurposeOtherInput.required = true;
                    }
                } else {
                    eventPurposeOtherContainer.style.display = 'none';
                    if (eventPurposeOtherInput) {
                        eventPurposeOtherInput.required = false;
                        eventPurposeOtherInput.value = '';
                    }
                }
            }
        }

        if (eventPurposeSelect) {
            addManagedEvent(eventPurposeSelect, 'change', toggleEventPurposeOther);
            // Check initial state on page load
            toggleEventPurposeOther();
        }

        renderCalendar();
        refreshAvailabilityData();

        // Restore selected date/time display if form has existing values (from suggest-alternatives page)
        restoreExistingSelection();

        // Month navigation
        addManagedEvent(prevButton, 'click', () => {
            currentMonth.setMonth(currentMonth.getMonth() - 1);
            renderCalendar();
            refreshAvailabilityData(false);
        });

        addManagedEvent(nextButton, 'click', () => {
            currentMonth.setMonth(currentMonth.getMonth() + 1);
            renderCalendar();
            refreshAvailabilityData(false);
        });

        // Form submission
        addManagedEvent(form, 'submit', submitReservation);

        // Sync with admin Import & Sync (poll + same-browser event)
        pollScheduleRevision();
        addManagedInterval(pollScheduleRevision, 30000);  // Reduced from 4s to 30s to prevent slowness
        addManagedEvent(window, 'classScheduleUpdated', () => refreshAvailabilityData(false));
        addManagedEvent(window, 'storage', (event) => {
            if (event.key === 'classScheduleRevision' && event.newValue && event.newValue !== knownScheduleRevision) {
                knownScheduleRevision = event.newValue;
                refreshAvailabilityData(false);
            }
        });

        // Also refresh availability every 60 seconds (reservations / manual blocks) - reduced frequency to prevent slowness
        addManagedInterval(() => {
            if (!document.hidden) {
                refreshAvailabilityData(false);
            }
        }, 60000);

        addManagedEvent(document, 'visibilitychange', () => {
            if (!document.hidden) {
                pollScheduleRevision();
                refreshAvailabilityData(false);
            }
        });

        addManagedEvent(window, 'focus', () => {
            pollScheduleRevision();
            refreshAvailabilityData(false);
        });
    }

    addManagedEvent(document, 'DOMContentLoaded', initReservationCalendar);
    addManagedEvent(document, 'turbo:load', initReservationCalendar);
    addManagedEvent(document, 'turbo:before-cache', () => {
        window.__reservaReservationCalendarCleanup();
    });

    function renderCalendar() {
        const calendar = document.getElementById('calendar');
        const monthYear = document.getElementById('monthYear');
        const year = currentMonth.getFullYear();
        const month = currentMonth.getMonth();

        monthYear.textContent = currentMonth.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
        calendar.innerHTML = '';

        // Day headers
        const dayHeaders = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
        dayHeaders.forEach(day => {
            const header = document.createElement('div');
            header.className = 'day-header';
            header.textContent = day;
            calendar.appendChild(header);
        });

        // Get first day of month
        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);
        const prevLastDay = new Date(year, month, 0);

        // Previous month dates
        for (let i = firstDay.getDay() - 1; i >= 0; i--) {
            const cell = createDateCell(new Date(year, month - 1, prevLastDay.getDate() - i), true);
            calendar.appendChild(cell);
        }

        // Current month dates
        for (let day = 1; day <= lastDay.getDate(); day++) {
            const date = new Date(year, month, day);
            const cell = createDateCell(date);
            calendar.appendChild(cell);
        }

        // Next month dates
        const remainingCells = 42 - calendar.children.length;
        for (let day = 1; day <= remainingCells; day++) {
            const cell = createDateCell(new Date(year, month + 1, day), true);
            calendar.appendChild(cell);
        }
    }

    function createDateCell(date, isOtherMonth = false) {
        const cell = document.createElement('div');
        cell.className = 'date-cell';
        cell.textContent = date.getDate();

        if (isOtherMonth) {
            cell.classList.add('disabled');
        } else {
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            if (date.getDay() === 0) {
                cell.classList.add('disabled');
                cell.title = 'Sundays are unavailable';
            } else if (isPastDate(date, today)) {
                cell.classList.add('past');
            } else {
                const dateStr = formatLocalDate(date);
                const hasBooking = (bookedTimesData[dateStr] && bookedTimesData[dateStr].length > 0) ||
                                   (classTimesData[dateStr] && classTimesData[dateStr].length > 0) ||
                                   (pendingTimesData[dateStr] && pendingTimesData[dateStr].length > 0) ||
                                   (blockedTimesData[dateStr] && blockedTimesData[dateStr].length > 0) ||
                                   (maintenanceTimesData[dateStr] && maintenanceTimesData[dateStr].length > 0);
                if (hasBooking) {
                    cell.classList.add('has-booking');
                }

                cell.addEventListener('click', () => selectDate(date, cell));
            }
        }

        return cell;
    }

    function selectDate(date, element) {
        // Remove previous selection
        document.querySelectorAll('.date-cell.selected').forEach(el => el.classList.remove('selected'));
        element.classList.add('selected');

        selectedDate = date;
        selectedStartTime = null;
        selectedEndTime = null;
        document.getElementById('reservation_date').value = formatLocalDate(date);
        document.getElementById('selectedDate').textContent = date.toLocaleDateString('en-US', 
            { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        document.getElementById('selectedTime').textContent = 'Not selected';
        document.getElementById('reservation_start_time').value = '';
        document.getElementById('reservation_end_time').value = '';

        renderTimeSlots(date);
    }

    function buildSelectableTimeSlots() {
        const slots = [];
        for (let hour = 8; hour <= 17; hour++) {
            slots.push(minutesToTime(hour * 60)); // :00
            if (hour < 17) {
                slots.push(minutesToTime(hour * 60 + 30)); // :30
            }
        }
        return slots;
    }

    function minutesToTimeAMPM(totalMinutes) {
        const hours = Math.floor(totalMinutes / 60);
        const minutes = totalMinutes % 60;
        const ampm = hours >= 12 ? 'PM' : 'AM';
        const displayHours = hours % 12 || 12;
        return `${displayHours}:${String(minutes).padStart(2, '0')} ${ampm}`;
    }

    function renderTimeSlots(date) {
        const timeGrid = document.getElementById('timeGrid');
        timeGrid.innerHTML = '';
        const dateStr = formatLocalDate(date);
        const bookedRanges = bookedTimesData[dateStr] || [];
        const pendingRanges = pendingTimesData[dateStr] || [];
        const classRanges = classTimesData[dateStr] || [];
        const blockedRanges = blockedTimesData[dateStr] || [];
        const maintenanceRanges = maintenanceTimesData[dateStr] || [];
        const slots = buildSelectableTimeSlots();

        // Check if selected date is today and calculate current time in minutes
        const today = new Date();
        const isToday = date.getFullYear() === today.getFullYear() &&
                       date.getMonth() === today.getMonth() &&
                       date.getDate() === today.getDate();
        const currentTimeMinutes = isToday ? (today.getHours() * 60 + today.getMinutes()) : -1;

        slots.forEach(timeStr => {
            const slot = document.createElement('button');
            slot.type = 'button';
            slot.className = 'time-slot';
            slot.textContent = minutesToTimeAMPM(timeToMinutes(timeStr));
            const slotMinutes = timeToMinutes(timeStr);

            // Check if this time slot is in the past (for today only)
            const isPastTime = isToday && slotMinutes <= currentTimeMinutes;

            if (isPastTime) {
                slot.classList.add('disabled');
                slot.disabled = true;
                slot.title = 'This time has already passed';
            } else if (isTimeBooked(timeStr, classRanges)) {
                slot.classList.add('class');
                slot.disabled = true;
                slot.title = 'Scheduled class (same as admin calendar)';
            } else if (isTimeBooked(timeStr, maintenanceRanges)) {
                slot.classList.add('maintenance');
                slot.disabled = true;
                slot.title = 'Maintenance';
            } else if (isTimeBooked(timeStr, blockedRanges)) {
                slot.classList.add('blocked');
                slot.disabled = true;
                slot.title = 'Blocked';
            } else if (isTimeBooked(timeStr, bookedRanges)) {
                slot.classList.add('booked');
                slot.disabled = true;
                slot.title = 'Booked';
            } else if (isTimeBooked(timeStr, pendingRanges)) {
                slot.classList.add('pending');
                slot.disabled = true;
                slot.title = 'Pending reservation request';
            } else {
                slot.classList.add('available');
                slot.addEventListener('click', (e) => {
                    e.preventDefault();
                    selectTimeRange(timeStr, slot, slots);
                });
            }

            timeGrid.appendChild(slot);
        });

        // Re-apply selected highlight if there's a selection for this date
        if (selectedStartTime && selectedDate) {
            const slots = buildSelectableTimeSlots();
            highlightSelectedRange(slots);
        }
    }

    function selectTimeRange(timeStr, element, slots) {
        const minutes = timeToMinutes(timeStr);
        if (!selectedStartTime || (selectedStartTime && selectedEndTime)) {
            selectedStartTime = timeStr;
            selectedEndTime = null;
        } else if (minutes <= timeToMinutes(selectedStartTime)) {
            selectedStartTime = timeStr;
            selectedEndTime = null;
        } else {
            selectedEndTime = timeStr;
        }

        let rangeUnavailable = false;
        if (selectedStartTime && selectedEndTime && isSelectedRangeUnavailable()) {
            rangeUnavailable = true;
            selectedEndTime = null;
            document.getElementById('reservation_end_time').value = '';
            showError('That selected time range overlaps with an unavailable schedule. Please choose another time.');
        }

        document.getElementById('reservation_start_time').value = selectedStartTime || '';
        document.getElementById('reservation_end_time').value = selectedEndTime || '';

        updateSelectedTimeDisplay();
        highlightSelectedRange(slots);
        if (!rangeUnavailable) {
            document.getElementById('errorMessage').style.display = 'none';
        }
    }

    let isSubmitting = false;

    async function submitReservation(e) {
        e.preventDefault();

        if (isSubmitting) return;
        isSubmitting = true;

        const submitBtn = document.querySelector('#reservationForm button[type="submit"]');
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Submitting…'; }

        await refreshAvailabilityData(false);

        // Validate selections
        if (!selectedDate || !selectedStartTime || !selectedEndTime) {
            showError('Please select a start and end time');
            isSubmitting = false;
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Reservation'; }
            return;
        }

        // Validate time is between 8 AM and 5 PM
        const startMinutes = timeToMinutes(selectedStartTime);
        const endMinutes = timeToMinutes(selectedEndTime);
        if (startMinutes < timeToMinutes('08:00') || endMinutes > timeToMinutes('17:00')) {
            showError('Reservation time must be between 8:00 AM and 5:00 PM');
            return;
        }

        if (endMinutes <= startMinutes) {
            showError('End time must be later than start time');
            return;
        }

        // Validate that reservation is not in the past
        const today = new Date();
        const isToday = selectedDate.getFullYear() === today.getFullYear() &&
                       selectedDate.getMonth() === today.getMonth() &&
                       selectedDate.getDate() === today.getDate();
        if (isToday) {
            const currentTimeMinutes = today.getHours() * 60 + today.getMinutes();
            if (startMinutes <= currentTimeMinutes) {
                showError('Cannot create reservations for past time slots. Please select a future time.');
                isSubmitting = false;
                if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Reservation'; }
                return;
            }
        }

        if (isSelectedRangeUnavailable()) {
            showError('This time range is unavailable because it overlaps with a reservation, pending request, class schedule, or manual block.');
            renderTimeSlots(selectedDate);
            isSubmitting = false;
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Reservation'; }
            return;
        }

        // Validate capacity
        const capacity = parseInt(document.getElementById('capacity').value);
        const maxCapacity = {{ facility.capacity }};
        if (capacity > maxCapacity) {
            showError(`Capacity cannot exceed facility maximum of ${maxCapacity}`);
            isSubmitting = false;
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Reservation'; }
            return;
        }

        // Submit form
        const form = document.getElementById('reservationForm');
        const formData = new FormData(form);
        
        // Debug: Log CSRF token
        const csrfToken = formData.get('csrf_token');
        console.log('DEBUG: Submitting reservation with CSRF token:', csrfToken ? 'Present' : 'MISSING');
        
        fetch('{{ path('facility_reserve', {'id': facility.id}) }}', {
            method: 'POST',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
            },
            body: formData,
            credentials: 'same-origin',
        })
        .then(async response => {
            console.log('DEBUG: Response status:', response.status);
            const text = await response.text();
            console.log('DEBUG: Response text length:', text.length);
            
            const contentType = response.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json') || contentType.includes('application/problem+json');

            if (!isJson) {
                console.error('DEBUG: Non-JSON response:', text.substring(0, 500));
                const message = text.replace(/<[^>]+>/g, '').trim().slice(0, 240) || 'Server returned an unexpected response.';
                throw new Error(message);
            }

            const data = text ? JSON.parse(text) : {};
            console.log('DEBUG: Parsed response:', data);
            const errorMessage = data.error || data.message || data.title || 'Submission failed';

            // Handle error responses (including our custom 200 with error)
            if (data.error) {
                if (Array.isArray(data.alternatives) && data.alternatives.length > 0) {
                    showAlternatives(data.alternatives, errorMessage);
                    return null;
                }
                throw new Error(errorMessage);
            }

            return data;
        })
        .then(data => {
            if (!data) {
                return;
            }

            if (!data.success) {
                const errorMessage = data.error || data.message || data.title || 'Submission failed';
                showError(errorMessage);
                return;
            }

            if (data.redirect) {
                window.location.href = data.redirect;
            } else {
                alert('Reservation submitted successfully! Your request is pending approval.');
                window.location.href = '{{ path('user_reservations') }}';
            }
        })
        .catch(error => {
            console.error('Reservation submit failed:', error);
            showError(error.message);
            isSubmitting = false;
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Reservation'; }
        });
    }

    function showAlternatives(alternatives, errorMessage) {
        const errorDiv = document.getElementById('errorMessage');
        errorDiv.innerHTML = `
            <div class="error-with-alternatives">
                <p class="error-text">${errorMessage}</p>
                <div class="alternatives-container">
                    <h4>Alternative Facilities Available:</h4>
                    <div class="alternatives-grid">
                        ${alternatives.map(alt => `
                            <div class="alternative-card">
                                <div class="alt-name">${alt.name}</div>
                                <div class="alt-capacity">Capacity: ${alt.capacity} people</div>
                                <button type="button" class="btn btn-small" onclick="switchFacility(${alt.id})">
                                    Reserve This Instead
                                </button>
                            </div>
                        `).join('')}
                    </div>
                </div>
            </div>
        `;
        errorDiv.style.display = 'block';
        errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function switchFacility(facilityId) {
        window.location.href = `{{ path('facility_reserve', {'id': '__id__'}) }}`.replace('__id__', facilityId) + 
            `?date=${document.getElementById('reservation_date').value}&` +
            `start=${document.getElementById('reservation_start_time').value}&` +
            `end=${document.getElementById('reservation_end_time').value}`;
    }
    window.switchFacility = switchFacility;

    function showError(message) {
        const errorDiv = document.getElementById('errorMessage');
        errorDiv.textContent = message;
        errorDiv.style.display = 'block';
    }

    function buildTimeSlots(start, end, stepMinutes) {
        const slots = [];
        let current = timeToMinutes(start);
        const endMinutes = timeToMinutes(end);

        while (current <= endMinutes) {
            slots.push(minutesToTime(current));
            current += stepMinutes;
        }

        return slots;
    }

    function normalizeTimeStr(timeStr) {
        const parts = String(timeStr || '').split(':');
        if (parts.length < 2) {
            return '00:00';
        }
        return `${String(parseInt(parts[0], 10)).padStart(2, '0')}:${String(parseInt(parts[1], 10)).padStart(2, '0')}`;
    }

    function timeToMinutes(timeStr) {
        const normalized = normalizeTimeStr(timeStr);
        const [hours, minutes] = normalized.split(':').map(Number);
        return hours * 60 + minutes;
    }

    function minutesToTime(totalMinutes) {
        const hours = Math.floor(totalMinutes / 60);
        const minutes = totalMinutes % 60;
        return String(hours).padStart(2, '0') + ':' + String(minutes).padStart(2, '0');
    }

    function formatLocalDate(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    function isPastDate(date, today) {
        if (date.getFullYear() !== today.getFullYear()) {
            return date.getFullYear() < today.getFullYear();
        }
        if (date.getMonth() !== today.getMonth()) {
            return date.getMonth() < today.getMonth();
        }
        return date.getDate() < today.getDate();
    }

    function isTimeBooked(timeStr, bookedRanges) {
        const minutes = timeToMinutes(timeStr);
        return bookedRanges.some(range => {
            const start = timeToMinutes(range.start);
            const end = timeToMinutes(range.end);
            // Block start times that fall inside an occupied range, including the end time slot.
            return minutes >= start && minutes <= end;
        });
    }

    function isSelectedRangeUnavailable() {
        if (!selectedDate || !selectedStartTime || !selectedEndTime) {
            return false;
        }

        const dateStr = formatLocalDate(selectedDate);
        const selectedStart = timeToMinutes(selectedStartTime);
        const selectedEnd = timeToMinutes(selectedEndTime);
        const ranges = [
            ...(bookedTimesData[dateStr] || []),
            ...(pendingTimesData[dateStr] || []),
            ...(classTimesData[dateStr] || []),
            ...(blockedTimesData[dateStr] || []),
            ...(maintenanceTimesData[dateStr] || []),
        ];

        return ranges.some(range => selectedStart < timeToMinutes(range.end) && selectedEnd > timeToMinutes(range.start));
    }

    function getAvailabilityFetchParams() {
        const monthStart = new Date(currentMonth.getFullYear(), currentMonth.getMonth(), 1);
        const monthEnd = new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 0);

        return {
            start: formatLocalDate(monthStart),
            days: Math.min(120, monthEnd.getDate() + 14),
        };
    }

    function showScheduleSyncNotice(message) {
        const info = document.querySelector('.calendar-section .info-text');
        if (!info) {
            return;
        }
        const original = info.dataset.defaultText || info.innerHTML;
        info.dataset.defaultText = original;
        info.innerHTML = message;
        clearTimeout(scheduleSyncStatusTimer);
        scheduleSyncStatusTimer = window.setTimeout(() => {
            info.innerHTML = info.dataset.defaultText || original;
        }, 5000);
    }

    async function pollScheduleRevision() {
        if (document.hidden) {
            return;
        }

        try {
            const response = await fetch(scheduleRevisionUrl, {
                cache: 'no-store',
                headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            });
            if (!response.ok) {
                return;
            }
            const data = await response.json();
            if (knownScheduleRevision && data.revision && data.revision !== knownScheduleRevision) {
                knownScheduleRevision = data.revision;
                showScheduleSyncNotice('Schedule updated from admin calendar. Refreshing available times...');
                await refreshAvailabilityData(false);
            } else if (data.revision) {
                knownScheduleRevision = data.revision;
            }
        } catch (error) {
            // ignore network errors during background poll
        }
    }

    async function refreshAvailabilityData(resetInvalidSelection = true) {
        if (availabilityRefreshController) {
            availabilityRefreshController.abort();
        }

        availabilityRefreshController = new AbortController();
        const { start, days } = getAvailabilityFetchParams();

        try {
            const response = await fetch(`${availabilityUrl}?start=${encodeURIComponent(start)}&days=${days}`, {
                cache: 'no-store',
                signal: availabilityRefreshController.signal,
                headers: {
                    'Accept': 'application/json',
                },
            });

            if (!response.ok) {
                return;
            }

            const data = await response.json();
            if (data.scheduleRevision) {
                knownScheduleRevision = data.scheduleRevision;
            }
            bookedTimesData = data.bookedTimes || {};
            pendingTimesData = data.pendingTimes || {};
            classTimesData = data.classTimes || {};
            blockedTimesData = data.blockedTimes || {};
            maintenanceTimesData = data.maintenanceTimes || {};
            renderCalendar();

            if (selectedDate) {
                renderTimeSlots(selectedDate);
                if (resetInvalidSelection && isSelectedRangeUnavailable()) {
                    selectedStartTime = null;
                    selectedEndTime = null;
                    document.getElementById('reservation_start_time').value = '';
                    document.getElementById('reservation_end_time').value = '';
                    updateSelectedTimeDisplay();
                    showError('Your selected time became unavailable. Please choose another slot.');
                }
            }
        } catch (error) {}
    }

    function highlightSelectedRange(slots) {
        const slotButtons = document.querySelectorAll('.time-slot');
        slotButtons.forEach((button, index) => {
            button.classList.remove('selected');
            if (!selectedStartTime) {
                return;
            }

            const timeStr = slots[index];
            const minutes = timeToMinutes(timeStr);
            const start = timeToMinutes(selectedStartTime);
            const end = selectedEndTime ? timeToMinutes(selectedEndTime) : start;

            if (minutes === start || (selectedEndTime && minutes > start && minutes <= end)) {
                button.classList.add('selected');
            }
        });
    }

    function updateSelectedTimeDisplay() {
        const display = document.getElementById('selectedTime');
        if (!selectedStartTime) {
            display.textContent = 'Not selected';
            return;
        }
        if (!selectedEndTime) {
            display.textContent = minutesToTimeAMPM(timeToMinutes(selectedStartTime)) + ' -';
            return;
        }
        display.textContent = minutesToTimeAMPM(timeToMinutes(selectedStartTime)) + ' - ' + minutesToTimeAMPM(timeToMinutes(selectedEndTime));
    }
})();
</script>
{% endblock %}
