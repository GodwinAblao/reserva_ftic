{% extends "layouts/app.html.twig" %}

{% block title %}My Reservations - Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/user_reservations.css') }}">
{% endblock %}

{% block content %}
    <div class="reservations-page-layout">
        <!-- Main Content Column -->
        <div class="reservations-main-column">

    <!-- Reservation Status Overview - Dashboard Style -->
    <div class="dashboard-stats-grid">
        <div class="dashboard-stat-card stat-success">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
                <span class="dashboard-stat-title">Approved</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Approved']|length }}</div>
            <div class="dashboard-stat-foot">Approved reservations</div>
        </div>

        <div class="dashboard-stat-card stat-warning">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></span>
                <span class="dashboard-stat-title">Pending</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Pending']|length }}</div>
            <div class="dashboard-stat-foot">Pending approval</div>
        </div>

        <div class="dashboard-stat-card stat-danger">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></span>
                <span class="dashboard-stat-title">Rejected</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Rejected']|length }}</div>
            <div class="dashboard-stat-foot">Rejected requests</div>
        </div>

        <div class="dashboard-stat-card stat-muted">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11H7v-2h10v2z"/></svg></span>
                <span class="dashboard-stat-title">Cancelled</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Cancelled']|length }}</div>
            <div class="dashboard-stat-foot">Cancelled reservations</div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="filter-tabs-container">
        <button class="filter-tab active" data-filter="approved">
            <span class="tab-text">Approved Reservation</span>
          
        </button>
        <button class="filter-tab pending-tab" data-filter="pending">
            <span class="tab-text">Pending Reservations</span>
        </button>
        <button class="filter-tab rejected-tab" data-filter="rejected">
            <span class="tab-text">Rejected Reservation</span>
        </button>
        <button class="filter-tab cancelled-tab" data-filter="cancelled">
            <span class="tab-text">Cancelled Reservation</span>
        </button>
    </div>

    <!-- Reservation Details Cards Section -->
    <div class="reservation-details-section">
        
        <!-- Approved Reservations Card -->
        <div class="reservation-detail-card" id="approved-card">
            <div class="detail-card-header approved-header">
                <div class="detail-card-title">
                    <span class="detail-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
                    <h3>Approved Reservations</h3>
                    <span class="detail-count">{{ reservations['Approved']|length }}</span>
                </div>
            </div>
            <div class="detail-card-body">
                {% if reservations['Approved']|length > 0 %}
                    <div class="reservations-grid">
                        {% for reservation in reservations['Approved'] %}
                            <div class="reservation-card-new">
                                <div class="card-title">{{ reservation.facility.name }}</div>
                                <div class="card-divider"></div>
                                <div class="card-info-grid">
                                    <div class="info-item">
                                        <span class="info-label">Reservation Holder</span>
                                        <span class="info-value">{{ reservation.user ? reservation.user.firstName ~ ' ' ~ reservation.user.lastName : 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">{{ reservation.user.email ?? reservation.contact ?? 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Status</span>
                                        <span class="info-value status-approved">Approved</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Event Name</span>
                                        <span class="info-value">{{ reservation.eventName ?: 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Participants</span>
                                        <span class="info-value">{{ reservation.capacity }} people</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Starting Time</span>
                                        <span class="info-value">{{ reservation.reservationStartTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">End Time</span>
                                        <span class="info-value">{{ reservation.reservationEndTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Date</span>
                                        <span class="info-value">{{ reservation.reservationDate|date('M d Y') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Reserved at</span>
                                        <span class="info-value">{{ reservation.createdAt ? reservation.createdAt|date('M d Y, h:i a') : 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-info-footer">
                                    <div class="info-item wide">
                                        <span class="info-label">Event Objectives</span>
                                        <span class="info-value">{{ reservation.purpose ?: 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-actions">
                                    <button type="button" class="btn btn-danger-small" onclick="openCancelModal({{ reservation.id }}, 'approved', '{{ csrf_token('cancel_reservation_' ~ reservation.id) }}')">Cancel</button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-mini-state">
                        <p>No approved reservations</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Pending Reservations Card -->
        <div class="reservation-detail-card hidden" id="pending-card">
            <div class="detail-card-header pending-header">
                <div class="detail-card-title">
                    <span class="detail-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></span>
                    <h3>Pending Reservations</h3>
                    <span class="detail-count">{{ reservations['Pending']|length }}</span>
                </div>
            </div>
            <div class="detail-card-body">
                {% if reservations['Pending']|length > 0 %}
                    <p class="section-description">Your request is under review by the Super Admin.</p>
                    <div class="reservations-grid">
                        {% for reservation in reservations['Pending'] %}
                            <div class="reservation-card-new">
                                <div class="card-title">{{ reservation.facility.name }}</div>
                                <div class="card-divider"></div>
                                <div class="card-info-grid">
                                    <div class="info-item">
                                        <span class="info-label">Reservation Holder</span>
                                        <span class="info-value">{{ reservation.user ? reservation.user.firstName ~ ' ' ~ reservation.user.lastName : 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">{{ reservation.user.email ?? reservation.contact ?? 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Status</span>
                                        <span class="info-value status-pending">Pending Approval</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Event Name</span>
                                        <span class="info-value">{{ reservation.eventName ?: 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Participants</span>
                                        <span class="info-value">{{ reservation.capacity }} people</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Starting Time</span>
                                        <span class="info-value">{{ reservation.reservationStartTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">End Time</span>
                                        <span class="info-value">{{ reservation.reservationEndTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Date</span>
                                        <span class="info-value">{{ reservation.reservationDate|date('M d Y') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Reserved at</span>
                                        <span class="info-value">{{ reservation.createdAt ? reservation.createdAt|date('M d Y, h:i a') : 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-info-footer">
                                    <div class="info-item wide">
                                        <span class="info-label">Event Objectives</span>
                                        <span class="info-value">{{ reservation.purpose ?: 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-actions">
                                    <button type="button" class="btn btn-danger-small" onclick="openCancelModal({{ reservation.id }}, 'pending', '{{ csrf_token('cancel_reservation_' ~ reservation.id) }}')">Cancel</button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-mini-state">
                        <p>No pending reservations</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Rejected Reservations Card -->
        <div class="reservation-detail-card hidden" id="rejected-card">
            <div class="detail-card-header rejected-header">
                <div class="detail-card-title">
                    <span class="detail-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></span>
                    <h3>Rejected Reservations</h3>
                    <span class="detail-count">{{ reservations['Rejected']|length }}</span>
                </div>
            </div>
            <div class="detail-card-body">
                {% if reservations['Rejected']|length > 0 %}
                    <div class="reservations-grid">
                        {% for reservation in reservations['Rejected'] %}
                            <div class="reservation-card-new">
                                <div class="card-title">{{ reservation.facility.name }}</div>
                                <div class="card-divider"></div>
                                <div class="card-info-grid">
                                    <div class="info-item">
                                        <span class="info-label">Reservation Holder</span>
                                        <span class="info-value">{{ reservation.user ? reservation.user.firstName ~ ' ' ~ reservation.user.lastName : 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">{{ reservation.user.email ?? reservation.contact ?? 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Status</span>
                                        <span class="info-value status-rejected">Rejected</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Event Name</span>
                                        <span class="info-value">{{ reservation.eventName ?: 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Participants</span>
                                        <span class="info-value">{{ reservation.capacity }} people</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Starting Time</span>
                                        <span class="info-value">{{ reservation.reservationStartTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">End Time</span>
                                        <span class="info-value">{{ reservation.reservationEndTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Date</span>
                                        <span class="info-value">{{ reservation.reservationDate|date('M d Y') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Reserved at</span>
                                        <span class="info-value">{{ reservation.createdAt ? reservation.createdAt|date('M d Y, h:i a') : 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-info-footer">
                                    <div class="info-item wide">
                                        <span class="info-label">Event Objectives</span>
                                        <span class="info-value">{{ reservation.purpose ?: 'N/A' }}</span>
                                    </div>
                                    {% if reservation.rejectionReason %}
                                    <div class="info-item wide">
                                        <span class="info-label">Rejection Reason</span>
                                        <span class="info-value status-rejected">{{ reservation.rejectionReason }}</span>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-mini-state">
