{% extends "layouts/app.html.twig" %}

{% block title %}My Reservations - Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/user_reservations.css') }}">
{% endblock %}

{% block content %}
    <div class="reservations-page-layout">
        <!-- Main Content Column -->
        <div class="reservations-main-column">

    <!-- Reservation Status Overview - Dashboard Style -->
    <div class="dashboard-stats-grid">
        <div class="dashboard-stat-card stat-success">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
                <span class="dashboard-stat-title">Approved</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Approved']|length }}</div>
            <div class="dashboard-stat-foot">Approved reservations</div>
        </div>

        <div class="dashboard-stat-card stat-warning">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></span>
                <span class="dashboard-stat-title">Pending</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Pending']|length }}</div>
            <div class="dashboard-stat-foot">Pending approval</div>
        </div>

        <div class="dashboard-stat-card stat-purple">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg></span>
                <span class="dashboard-stat-title">Suggested</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Suggested']|length }}</div>
            <div class="dashboard-stat-foot">Suggested alternatives</div>
        </div>

        <div class="dashboard-stat-card stat-danger">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></span>
                <span class="dashboard-stat-title">Rejected</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Rejected']|length }}</div>
            <div class="dashboard-stat-foot">Rejected requests</div>
        </div>

        <div class="dashboard-stat-card stat-muted">
            <div class="dashboard-stat-top">
                <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11H7v-2h10v2z"/></svg></span>
                <span class="dashboard-stat-title">Cancelled</span>
            </div>
            <div class="dashboard-stat-value">{{ reservations['Cancelled']|length }}</div>
            <div class="dashboard-stat-foot">Cancelled reservations</div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="filter-tabs-container">
        <button class="filter-tab active" data-filter="approved">
            <span class="tab-text">Approved Reservation</span>
            <span class="tab-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
        </button>
        <button class="filter-tab pending-tab" data-filter="pending">
            <span class="tab-text">Pending Reservations</span>
        </button>
        <button class="filter-tab rejected-tab" data-filter="rejected">
            <span class="tab-text">Rejected Reservation</span>
        </button>
        <button class="filter-tab cancelled-tab" data-filter="cancelled">
            <span class="tab-text">Cancelled Reservation</span>
        </button>
    </div>

    <!-- Reservation Details Cards Section -->
    <div class="reservation-details-section">
        
        <!-- Approved Reservations Card -->
        <div class="reservation-detail-card" id="approved-card">
            <div class="detail-card-header approved-header">
                <div class="detail-card-title">
                    <span class="detail-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
                    <h3>Approved Reservations</h3>
                    <span class="detail-count">{{ reservations['Approved']|length }}</span>
                </div>
            </div>
            <div class="detail-card-body">
                {% if reservations['Approved']|length > 0 %}
                    <div class="reservations-grid">
                        {% for reservation in reservations['Approved'] %}
                            <div class="reservation-card-new">
                                <div class="card-title">{{ reservation.facility.name }}</div>
                                <div class="card-divider"></div>
                                <div class="card-info-grid">
                                    <div class="info-item">
                                        <span class="info-label">Reservation Holder</span>
                                        <span class="info-value">{{ reservation.user ? reservation.user.firstName ~ ' ' ~ reservation.user.lastName : 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">{{ reservation.user.email ?? reservation.contact ?? 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Status</span>
                                        <span class="info-value status-approved">Approved</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Event Name</span>
                                        <span class="info-value">{{ reservation.eventName ?: 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Participants</span>
                                        <span class="info-value">{{ reservation.capacity }} people</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Starting Time</span>
                                        <span class="info-value">{{ reservation.reservationStartTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">End Time</span>
                                        <span class="info-value">{{ reservation.reservationEndTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Date</span>
                                        <span class="info-value">{{ reservation.reservationDate|date('M d Y') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Reserved at</span>
                                        <span class="info-value">{{ reservation.createdAt ? reservation.createdAt|date('M d Y, h:i a') : 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-info-footer">
                                    <div class="info-item wide">
                                        <span class="info-label">Event Description & Purpose</span>
                                        <span class="info-value">{{ reservation.purpose ?: 'N/A' }}</span>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-mini-state">
                        <p>No approved reservations</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Pending Reservations Card -->
        <div class="reservation-detail-card hidden" id="pending-card" style="display: none;">
            <div class="detail-card-header pending-header">
                <div class="detail-card-title">
                    <span class="detail-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></span>
                    <h3>Pending Reservations</h3>
                    <span class="detail-count">{{ reservations['Pending']|length }}</span>
                </div>
            </div>
            <div class="detail-card-body">
                {% if reservations['Pending']|length > 0 %}
                    <p class="section-description">Your request is under review by the Super Admin.</p>
                    <div class="reservations-grid">
                        {% for reservation in reservations['Pending'] %}
                            <div class="reservation-card-new">
                                <div class="card-title">{{ reservation.facility.name }}</div>
                                <div class="card-divider"></div>
                                <div class="card-info-grid">
                                    <div class="info-item">
                                        <span class="info-label">Reservation Holder</span>
                                        <span class="info-value">{{ reservation.user ? reservation.user.firstName ~ ' ' ~ reservation.user.lastName : 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">{{ reservation.user.email ?? reservation.contact ?? 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Status</span>
                                        <span class="info-value status-pending">Pending Approval</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Event Name</span>
                                        <span class="info-value">{{ reservation.eventName ?: 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Participants</span>
                                        <span class="info-value">{{ reservation.capacity }} people</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Starting Time</span>
                                        <span class="info-value">{{ reservation.reservationStartTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">End Time</span>
                                        <span class="info-value">{{ reservation.reservationEndTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Date</span>
                                        <span class="info-value">{{ reservation.reservationDate|date('M d Y') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Reserved at</span>
                                        <span class="info-value">{{ reservation.createdAt ? reservation.createdAt|date('M d Y, h:i a') : 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-info-footer">
                                    <div class="info-item wide">
                                        <span class="info-label">Event Description & Purpose</span>
                                        <span class="info-value">{{ reservation.purpose ?: 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-actions">
                                    <form method="POST" action="{{ path('cancel_reservation', {'id': reservation.id}) }}" style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('cancel_reservation_' ~ reservation.id) }}">
                                        <button type="submit" class="btn btn-danger-small" onclick="return confirm('Cancel this reservation?')">Cancel</button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-mini-state">
                        <p>No pending reservations</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Rejected Reservations Card -->
        <div class="reservation-detail-card hidden" id="rejected-card" style="display: none;">
            <div class="detail-card-header rejected-header">
                <div class="detail-card-title">
                    <span class="detail-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></span>
                    <h3>Rejected Reservations</h3>
                    <span class="detail-count">{{ reservations['Rejected']|length }}</span>
                </div>
            </div>
            <div class="detail-card-body">
                {% if reservations['Rejected']|length > 0 %}
                    <div class="reservations-grid">
                        {% for reservation in reservations['Rejected'] %}
                            <div class="reservation-card-new">
                                <div class="card-title">{{ reservation.facility.name }}</div>
                                <div class="card-divider"></div>
                                <div class="card-info-grid">
                                    <div class="info-item">
                                        <span class="info-label">Reservation Holder</span>
                                        <span class="info-value">{{ reservation.user ? reservation.user.firstName ~ ' ' ~ reservation.user.lastName : 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">{{ reservation.user.email ?? reservation.contact ?? 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Status</span>
                                        <span class="info-value status-rejected">Rejected</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Event Name</span>
                                        <span class="info-value">{{ reservation.eventName ?: 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Participants</span>
                                        <span class="info-value">{{ reservation.capacity }} people</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Starting Time</span>
                                        <span class="info-value">{{ reservation.reservationStartTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">End Time</span>
                                        <span class="info-value">{{ reservation.reservationEndTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Date</span>
                                        <span class="info-value">{{ reservation.reservationDate|date('M d Y') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Reserved at</span>
                                        <span class="info-value">{{ reservation.createdAt ? reservation.createdAt|date('M d Y, h:i a') : 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-info-footer">
                                    <div class="info-item wide">
                                        <span class="info-label">Event Description & Purpose</span>
                                        <span class="info-value">{{ reservation.purpose ?: 'N/A' }}</span>
                                    </div>
                                    {% if reservation.rejectionReason %}
                                    <div class="info-item wide">
                                        <span class="info-label">Rejection Reason</span>
                                        <span class="info-value status-rejected">{{ reservation.rejectionReason }}</span>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-mini-state">
                        <p>No rejected reservations</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Cancelled Reservations Card -->
        <div class="reservation-detail-card hidden" id="cancelled-card" style="display: none;">
            <div class="detail-card-header cancelled-header">
                <div class="detail-card-title">
                    <span class="detail-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11H7v-2h10v2z"/></svg></span>
                    <h3>Cancelled Reservations</h3>
                    <span class="detail-count">{{ reservations['Cancelled']|length }}</span>
                </div>
            </div>
            <div class="detail-card-body">
                {% if reservations['Cancelled']|length > 0 %}
                    <div class="reservations-grid">
                        {% for reservation in reservations['Cancelled'] %}
                            <div class="reservation-card-new">
                                <div class="card-title">{{ reservation.facility.name }}</div>
                                <div class="card-divider"></div>
                                <div class="card-info-grid">
                                    <div class="info-item">
                                        <span class="info-label">Reservation Holder</span>
                                        <span class="info-value">{{ reservation.user ? reservation.user.firstName ~ ' ' ~ reservation.user.lastName : 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">{{ reservation.user.email ?? reservation.contact ?? 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Status</span>
                                        <span class="info-value status-cancelled">Cancelled</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Event Name</span>
                                        <span class="info-value">{{ reservation.eventName ?: 'N/A' }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Participants</span>
                                        <span class="info-value">{{ reservation.capacity }} people</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Starting Time</span>
                                        <span class="info-value">{{ reservation.reservationStartTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">End Time</span>
                                        <span class="info-value">{{ reservation.reservationEndTime|date('h:i a') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Date</span>
                                        <span class="info-value">{{ reservation.reservationDate|date('M d Y') }}</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Reserved at</span>
                                        <span class="info-value">{{ reservation.createdAt ? reservation.createdAt|date('M d Y, h:i a') : 'N/A' }}</span>
                                    </div>
                                </div>
                                <div class="card-info-footer">
                                    <div class="info-item wide">
                                        <span class="info-label">Event Description & Purpose</span>
                                        <span class="info-value">{{ reservation.purpose ?: 'N/A' }}</span>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-mini-state">
                        <p>No cancelled reservations</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Empty State Message -->
    {% if reservations['Approved']|length == 0 and reservations['Pending']|length == 0 
        and reservations['Suggested']|length == 0 and reservations['Rejected']|length == 0 and reservations['Cancelled']|length == 0 %}
        <div class="empty-state card-panel">
            <h3>No Reservations Yet</h3>
            <p>You haven't made any facility reservations.</p>
            <a href="{{ path('app_facility_index') }}" class="btn btn-primary">Browse Facilities</a>
        </div>
    {% endif %}

        </div><!-- End Main Column -->

        <!-- Right Side Column - Summary Cards -->
        <aside class="reservations-side-column">
            <!-- Reserve Button Card -->
            <section class="reservations-side-card reserve-action-card">
                <a href="{{ path('app_facility_index') }}" class="reserve-btn-large">
                    <span class="reserve-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </svg>
                    </span>
                    <span class="reserve-text">Reserve a Facility</span>
                </a>
            </section>

            <!-- Recent Reservation Summary -->
            <section class="reservations-side-card reservations-info-card">
                <div class="reservations-side-card-head">
                    <h3>Recent Reservation</h3>
                </div>
                {% set allReservations = reservations['Approved']|merge(reservations['Pending'])|merge(reservations['Suggested']) %}
                {% set recentReservation = allReservations|sort((a, b) => b.createdAt <=> a.createdAt)|first %}
                {% if recentReservation %}
                    <p>
                        <strong>{{ recentReservation.facility.name }}</strong> —
                        {{ recentReservation.status }}
                        on {{ recentReservation.reservationDate|date('M d, Y') }}
                        at {{ recentReservation.reservationStartTime|date('h:i A') }}.
                    </p>
                {% else %}
                    <p>You have no reservations yet. Book a facility to get started!</p>
                {% endif %}
            </section>

            <!-- Quick Stats -->
            <section class="reservations-side-card reservations-info-card">
                <div class="reservations-side-card-head">
                    <h3>Quick Overview</h3>
                </div>
                <div class="quick-stats-list">
                    <div class="quick-stat-item">
                        <span class="quick-stat-label">Total</span>
                        <span class="quick-stat-value">{{ reservations['Approved']|length + reservations['Pending']|length + reservations['Suggested']|length + reservations['Rejected']|length + reservations['Cancelled']|length }}</span>
                    </div>
                    <div class="quick-stat-item">
                        <span class="quick-stat-label">Approved</span>
                        <span class="quick-stat-value stat-green">{{ reservations['Approved']|length }}</span>
                    </div>
                    <div class="quick-stat-item">
                        <span class="quick-stat-label">Pending</span>
                        <span class="quick-stat-value stat-yellow">{{ reservations['Pending']|length }}</span>
                    </div>
                </div>
            </section>
        </aside>
    </div><!-- End Layout Grid -->

<script>
    (function() {
        function initReservationTabs() {
            const filterTabs = document.querySelectorAll('.filter-tab');
            const detailCards = document.querySelectorAll('.reservation-detail-card');

            if (!filterTabs.length || !detailCards.length) return;

            // Initialize - ensure only approved is visible by default
            detailCards.forEach(card => {
                if (card.id === 'approved-card') {
                    card.classList.remove('hidden');
                    card.style.display = 'block';
                } else {
                    card.classList.add('hidden');
                    card.style.display = 'none';
                }
            });

            // Set active tab
            filterTabs.forEach(tab => {
                tab.classList.remove('active');
                if (tab.getAttribute('data-filter') === 'approved') {
                    tab.classList.add('active');
                }
            });

            // Add click handlers
            filterTabs.forEach(tab => {
                tab.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const filter = this.getAttribute('data-filter');
                    if (!filter) return;

                    // Update active tab
                    filterTabs.forEach(t => t.classList.remove('active'));
                    this.classList.add('active');

                    // Show/hide cards with display property
                    detailCards.forEach(card => {
                        if (card.id === filter + '-card') {
                            card.classList.remove('hidden');
                            card.style.display = 'block';
                        } else {
                            card.classList.add('hidden');
                            card.style.display = 'none';
                        }
                    });
                });
            });
        }

        // Run on DOM ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initReservationTabs);
        } else {
            initReservationTabs();
        }

        // Also run on pageshow event (handles back/forward navigation)
        window.addEventListener('pageshow', function(e) {
            if (e.persisted) {
                // Page was restored from bfcache, reinitialize
                initReservationTabs();
            }
        });
    })();
</script>
{% endblock %}
