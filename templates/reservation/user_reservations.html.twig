        </div><!-- End Main Column -->

        <!-- Right Side Column - Summary Cards -->
        <aside class="reservations-side-column">
            <!-- Reserve Button Card -->
            <section class="reservations-side-card reserve-action-card">
                <a href="{{ path('app_facility_index') }}" class="reserve-btn-large">
                    <span class="reserve-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </svg>
                    </span>
                    <span class="reserve-text">Reserve a Facility</span>
                </a>
            </section>


            <!-- Recent Reservation Modal -->
            {% if recentReservation %}
            <div id="recentReservationModal" class="recent-reservation-modal-overlay" style="display:none;">
                <div class="recent-reservation-modal">
                    <div class="recent-reservation-modal-header">
                        <h3>Reservation Details</h3>
                        <button type="button" class="recent-reservation-modal-close" onclick="closeRecentReservationModal()">×</button>
                    </div>
                    <div class="recent-reservation-modal-body">
                        <div class="recent-reservation-modal-status status-{{ recentReservation.status|lower }}">
                            {% if recentReservation.status == 'Approved' %}✓{% elseif recentReservation.status == 'Pending' %}⏳{% endif %}
                            {{ recentReservation.status }}
                        </div>
                        <div class="recent-reservation-modal-section">
                            <h4>Facility Information</h4>
                            <div class="recent-reservation-modal-row">
                                <span class="modal-label">Facility Name</span>
                                <span class="modal-value">{{ recentReservation.facility.name }}</span>
                            </div>
                            <div class="recent-reservation-modal-row">
                                <span class="modal-label">Capacity</span>
                                <span class="modal-value">{{ recentReservation.facility.capacity }} people</span>
                            </div>
                        </div>
                        <div class="recent-reservation-modal-section">
                            <h4>Reservation Details</h4>
                            <div class="recent-reservation-modal-row">
                                <span class="modal-label">Date</span>
                                <span class="modal-value">{{ recentReservation.reservationDate|date('F d, Y') }}</span>
                            </div>
                            <div class="recent-reservation-modal-row">
                                <span class="modal-label">Time</span>
                                <span class="modal-value">{{ recentReservation.reservationStartTime|date('h:i A') }} - {{ recentReservation.reservationEndTime|date('h:i A') }}</span>
                            </div>
                            <div class="recent-reservation-modal-row">
                                <span class="modal-label">Attendees</span>
                                <span class="modal-value">{{ recentReservation.capacity }} people</span>
                            </div>
                        </div>
                        <div class="recent-reservation-modal-section">
                            <h4>Contact Information</h4>
                            <div class="recent-reservation-modal-row">
                                <span class="modal-label">Name</span>
                                <span class="modal-value">{{ recentReservation.name }}</span>
                            </div>
                            <div class="recent-reservation-modal-row">
                                <span class="modal-label">Email</span>
                                <span class="modal-value">{{ recentReservation.email }}</span>
                            </div>
                        </div>
                        {% if recentReservation.purpose %}
                        <div class="recent-reservation-modal-section">
                            <h4>Event Objectives</h4>
                            <p class="modal-description">{{ recentReservation.purpose }}</p>
                        </div>
                        {% endif %}
                        {% if recentReservation.status == 'Approved' %}
                        <div class="recent-reservation-modal-footer">
                            <div class="check-in-badge">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Ready for check-in on {{ recentReservation.reservationDate|date('M d, Y') }}
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            <!-- Cancel Confirmation Modal -->
            <div id="cancelModal" class="cancel-modal-overlay" style="display:none;">
                <div class="cancel-modal">
                    <div class="cancel-modal-header">
                        <div class="cancel-modal-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="15" y1="9" x2="9" y2="15"/>
                                <line x1="9" y1="9" x2="15" y2="15"/>
                            </svg>
                        </div>
                        <h3>Cancel Reservation?</h3>
                        <button type="button" class="cancel-modal-close" onclick="closeCancelModal()">×</button>
                    </div>
                    <div class="cancel-modal-body">
                        <p id="cancelModalMessage">Are you sure you want to cancel this reservation? This action cannot be undone.</p>
                    </div>
                    <div class="cancel-modal-footer">
                        <button type="button" class="cancel-modal-btn cancel-modal-btn-secondary" onclick="closeCancelModal()">Keep Reservation</button>
                        <form id="cancelForm" method="POST" style="display:inline;">
                            <input type="hidden" name="_token" id="cancelToken">
                            <button type="submit" class="cancel-modal-btn cancel-modal-btn-danger">Yes, Cancel Reservation</button>
                        </form>
                    </div>
                </div>
            </div>

        </aside>
    </div><!-- End Layout Grid -->

<script>
    (function() {
        function initReservationTabs() {
            const filterTabs = document.querySelectorAll('.filter-tab');
            const detailCards = document.querySelectorAll('.reservation-detail-card');

            if (!filterTabs.length || !detailCards.length) return;

            // Initialize - ensure only approved is visible by default
            detailCards.forEach(card => {
                if (card.id === 'approved-card') {
                    card.classList.remove('hidden');
                    card.style.display = 'block';
                } else {
                    card.classList.add('hidden');
                    card.style.display = 'none';
                }
            });

            // Set active tab
            filterTabs.forEach(tab => {
                tab.classList.remove('active');
                if (tab.getAttribute('data-filter') === 'approved') {
                    tab.classList.add('active');
                }
            });

            // Add click handlers
            filterTabs.forEach(tab => {
                tab.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const filter = this.getAttribute('data-filter');
                    if (!filter) return;

                    // Update active tab
                    filterTabs.forEach(t => t.classList.remove('active'));
                    this.classList.add('active');

                    // Show/hide cards with display property
                    detailCards.forEach(card => {
                        if (card.id === filter + '-card') {
                            card.classList.remove('hidden');
                            card.style.display = 'block';
                        } else {
                            card.classList.add('hidden');
                            card.style.display = 'none';
                        }
                    });
                });
            });
        }

        // Run on DOM ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initReservationTabs);
        } else {
            initReservationTabs();
        }

        // Also run on pageshow event (handles back/forward navigation)
        window.addEventListener('pageshow', function(e) {
            if (e.persisted) {
                // Page was restored from bfcache, reinitialize
                initReservationTabs();
            }
        });

        // Recent Reservation Modal functions
        function openRecentReservationModal() {
            const modal = document.getElementById('recentReservationModal');
            if (modal) {
                modal.style.display = 'flex';
            }
        }

        function closeRecentReservationModal() {
            const modal = document.getElementById('recentReservationModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        // Make functions globally accessible
        window.openRecentReservationModal = openRecentReservationModal;
        window.closeRecentReservationModal = closeRecentReservationModal;

        // Move modal to body for proper viewport centering
        document.addEventListener('DOMContentLoaded', function() {
            const modal = document.getElementById('recentReservationModal');
            if (modal && modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }

            const cancelModal = document.getElementById('cancelModal');
            if (cancelModal && cancelModal.parentElement !== document.body) {
                document.body.appendChild(cancelModal);
            }

            // Close modal on escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    closeRecentReservationModal();
                    closeCancelModal();
                }
            });

            // Close modal on overlay click
            const modalOverlay = document.getElementById('recentReservationModal');
            if (modalOverlay) {
                modalOverlay.addEventListener('click', function(e) {
                    if (e.target === modalOverlay) {
                        closeRecentReservationModal();
                    }
                });
            }

            const cancelModalOverlay = document.getElementById('cancelModal');
            if (cancelModalOverlay) {
                cancelModalOverlay.addEventListener('click', function(e) {
                    if (e.target === cancelModalOverlay) {
                        closeCancelModal();
                    }
                });
            }
        });

        // Cancel Modal functions
        let currentCancelReservationId = null;

        function openCancelModal(reservationId, status, csrfToken) {
            currentCancelReservationId = reservationId;
            const modal = document.getElementById('cancelModal');
            const message = document.getElementById('cancelModalMessage');
            const form = document.getElementById('cancelForm');
            const token = document.getElementById('cancelToken');

            if (status === 'approved') {
                message.textContent = 'Are you sure you want to cancel this approved reservation? This action cannot be undone.';
            } else {
                message.textContent = 'Are you sure you want to cancel this pending reservation? This action cannot be undone.';
            }

            form.action = `/facility/reservations/${reservationId}/cancel`;
            token.value = csrfToken;

            if (modal) {
                modal.style.display = 'flex';
            }
        }

        function closeCancelModal() {
            const modal = document.getElementById('cancelModal');
            if (modal) {
                modal.style.display = 'none';
            }
            currentCancelReservationId = null;
        }

        // Make functions globally accessible
        window.openCancelModal = openCancelModal;
        window.closeCancelModal = closeCancelModal;
    })();
</script>
{% endblock %}
