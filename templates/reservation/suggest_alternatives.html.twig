{% extends "layouts/app.html.twig" %}

{% block title %}Suggest Alternative Facility - Reserva FTIC{% endblock %}

{% block content %}
    <div class="suggest-alternatives-page">
        <div class="suggest-alt-grid">
            <section class="reservation-column">
                <h3 class="mini-section-title">Reservation request details</h3>
                <div class="request-card">
                    <div class="request-card-grid">
                        <div class="request-field">
                            <span class="field-label">Facility:</span>
                            <span class="field-value field-emphasis">{{ reservation.facility.name }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Date:</span>
                            <span class="field-value">{{ reservation.reservationDate|date('M d, Y') }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Time:</span>
                            <span class="field-value">{{ reservation.reservationStartTime|date('h:i A') }} - {{ reservation.reservationEndTime|date('h:i A') }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Attendees:</span>
                            <span class="field-value">{{ reservation.capacity }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Facility Capacity:</span>
                            <span class="field-value">{{ reservation.facility.capacity }}</span>
                        </div>
                        {% if reservation.purpose %}
                            <div class="request-field request-field-full">
                                <span class="field-label">Event Objectives:</span>
                                <span class="field-value purpose-text">{{ reservation.purpose }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="keep-card">
                    <form method="POST" action="{{ path('user_keep_original_facility', {'id': reservation.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('keep_original_' ~ reservation.id) }}">
                        <button type="submit" class="keep-button">Keep this Facility</button>
                    </form>
                </div>
            </section>

            <section class="alternatives-column">
                <h3 class="alternatives-title">Better-Fit Facilities Available</h3>
                <p class="alternatives-subtitle">We found these facilities that are better suited for your group size ({{ reservation.capacity }} people) and available at your preferred date and time.</p>

                {% if alternatives|length > 0 %}
                    <div class="alternatives-grid">
                        {% for facility in alternatives %}
                            <article class="alt-card">
                                <h4 class="alt-name">{{ facility.name }}</h4>
                                <p class="alt-description">{% if facility.description %}{{ facility.description }}{% else %}Professional classroom or meeting space with advanced audiovisual equipment for seminars and presentations.{% endif %}</p>

                                <div class="alt-stats">
                                    <div class="alt-stat-row">
                                        <span>Facility Capacity:</span>
                                        <strong>{{ facility.capacity }} people</strong>
                                    </div>
                                    <div class="alt-stat-row">
                                        <span>Fit Score:</span>
                                        <strong class="stat-positive">Perfect fit</strong>
                                    </div>
                                    <div class="alt-stat-row">
                                        <span>Status:</span>
                                        <strong class="stat-positive">Available</strong>
                                    </div>
                                </div>

                                <form method="POST" action="{{ path('user_select_alternative', {'id': reservation.id, 'facilityId': facility.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('select_alternative_' ~ reservation.id) }}">
                                    <button type="submit" class="accept-button">Accept this Facility</button>
                                </form>
                            </article>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-alternative">
                        <p>No better-fit facilities are available for your requested date and time.</p>
                    </div>
                {% endif %}
            </section>
        </div>
    </div>

<style>
    .suggest-alternatives-page {
        padding: 10px 0 18px;
    }

    .suggest-alt-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.02fr);
        gap: 14px;
        align-items: start;
    }

    .mini-section-title,
    .alternatives-title {
        margin: 0 0 8px;
        font-size: 20px;
        line-height: 1.2;
        color: var(--feu-green);
        font-weight: 700;
        letter-spacing: 0.1px;
    }

    .alternatives-subtitle {
        margin: 0 0 12px;
        color: #8a8f98;
        font-size: 14px;
        line-height: 1.35;
        max-width: 430px;
        font-style: italic;
    }

    .request-card,
    .keep-card,
    .alt-card {
        background: #fff;
        border: 1px solid #dfe5d7;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
    }

    .request-card {
        padding: 8px 10px 10px;
        min-height: 188px;
    }

    .request-card-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px 12px;
    }

    .request-field {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .request-field-full {
        grid-column: 1 / -1;
    }

    .field-label {
        font-size: 15px;
        font-weight: 700;
        color: #1d1d1d;
    }

    .field-value {
        font-size: 15px;
        line-height: 1.35;
        color: #5f9f13;
        font-weight: 700;
        word-break: break-word;
    }

    .field-emphasis { text-transform: uppercase; }

    .purpose-text {
        color: #2d2d2d;
        font-weight: 500;
        text-transform: none;
    }

    .keep-card {
        margin-top: 14px;
        padding: 12px 16px;
        display: flex;
        justify-content: center;
    }

    .keep-card form { width: 100%; max-width: 160px; }

    .keep-button,
    .accept-button {
        width: 100%;
        border: 0;
        border-radius: 8px;
        background: #72ad14;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        padding: 7px 12px;
        cursor: pointer;
        box-shadow: 0 1px 2px rgba(0,0,0,0.12);
        transition: transform .15s ease, background .15s ease;
    }

    .keep-button:hover,
    .accept-button:hover {
        background: #689f12;
        transform: translateY(-1px);
    }

    .alternatives-column {
        padding-top: 2px;
    }

    .alternatives-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .alt-card {
        padding: 9px 9px 10px;
        min-height: 154px;
    }

    .alt-name {
        margin: 0 0 3px;
        text-align: center;
        color: var(--feu-green);
        font-size: 20px;
        line-height: 1.2;
        font-weight: 700;
    }

    .alt-description {
        margin: 0 0 8px;
        font-size: 13px;
        line-height: 1.3;
        color: #8c8c8c;
        text-align: left;
        min-height: 20px;
    }

    .alt-stats {
        display: flex;
        flex-direction: column;
        gap: 5px;
        margin-bottom: 8px;
    }

    .alt-stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #ebebeb;
        padding-bottom: 3px;
        font-size: 13px;
        color: #4c4c4c;
    }

    .alt-stat-row strong {
        color: #5f9f13;
        font-size: 13px;
        font-weight: 700;
    }

    .stat-positive { color: #2f7f0f !important; }

    .accept-button {
        margin-top: 2px;
        border-radius: 7px;
        font-size: 13px;
        padding: 6px 10px;
    }

    .empty-alternative {
        padding: 18px 12px;
        color: #6b7280;
        font-size: 16px;
    }

    @media (max-width: 1100px) {
        .suggest-alt-grid {
            grid-template-columns: 1fr;
        }

        .alternatives-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 768px) {
        .request-card-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .alternatives-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}
