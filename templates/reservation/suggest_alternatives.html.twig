{% extends "layouts/app.html.twig" %}

{% block title %}Suggested Alternative Facilities - Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="/styles/suggest_alternatives.css">
{% endblock %}

{% block content %}
    <div class="suggest-alternatives-page">
        <div class="page-header" style="margin-bottom: 1.5rem;">
            <a href="{{ path('facility_reserve', {'id': reservation.facility.id, 'restore': reservation.id}) }}" class="back-link" data-turbo="false" target="_self" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #006633; text-decoration: none; font-weight: 600;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Back to Facility Reservation
            </a>
        </div>
        <div class="suggest-alt-grid">
            <section class="reservation-column">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h3 class="mini-section-title" style="margin: 0;">Reservation Request Details</h3>
                    {% if reservation.institutionalEvent %}
                        <span style="background: #dcfce7; color: #16a34a; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; text-transform: uppercase;">Institutional</span>
                    {% endif %}
                </div>
                <div class="request-card">
                    <div class="request-card-grid">
                        <div class="request-field">
                            <span class="field-label">Event Name:</span>
                            <span class="field-value field-emphasis">{{ reservation.eventName ?: 'N/A' }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Facility:</span>
                            <span class="field-value">{{ reservation.facility.name }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Date:</span>
                            <span class="field-value">{{ reservation.reservationDate|date('M d, Y') }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Time:</span>
                            <span class="field-value">{{ reservation.reservationStartTime|date('h:i A') }} - {{ reservation.reservationEndTime|date('h:i A') }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Attendees:</span>
                            <span class="field-value">{{ reservation.capacity }}</span>
                        </div>
                        <div class="request-field">
                            <span class="field-label">Facility Capacity:</span>
                            <span class="field-value">{{ reservation.facility.capacity }}</span>
                        </div>
                        {% if reservation.eventPurpose %}
                            <div class="request-field">
                                <span class="field-label">Event Purpose:</span>
                                <span class="field-value">{{ reservation.eventPurpose }}{% if reservation.eventPurpose == 'others' and reservation.eventPurposeOther %} ({{ reservation.eventPurposeOther }}){% endif %}</span>
                            </div>
                        {% endif %}
                        {% if reservation.purpose %}
                            <div class="request-field request-field-full">
                                <span class="field-label">Event Objectives:</span>
                                <span class="field-value purpose-text">{{ reservation.purpose }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="keep-card">
                    <form method="POST" action="{{ path('user_keep_original_facility', {'id': reservation.id}) }}" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('keep_original_' ~ reservation.id) }}">
                        <button type="submit" class="keep-button">Keep This Facility</button>
                    </form>
                </div>
            </section>

            <section class="alternatives-column">
                <h3 class="alternatives-title">Better-Fit Facilities Available</h3>
                <p class="alternatives-subtitle">We found these facilities that are better suited for your group size ({{ reservation.capacity }} people) and available at your preferred date and time.</p>

                {% if alternatives|length > 0 %}
                    <div class="alternatives-grid">
                        {% for facility in alternatives %}
                            <article class="alt-card">
                                <div class="alt-image">
                                    {% if facility.image %}
                                        <img src="{{ facility.image ~ '?v=' ~ facility.updatedAt|date('U') }}" alt="{{ facility.name }}" loading="lazy">
                                    {% elseif facility.images|length > 0 %}
                                        {% set mainImage = facility.images.first %}
                                        <img src="{{ mainImage.path ~ '?v=' ~ mainImage.createdAt|date('U') }}" alt="{{ facility.name }}" loading="lazy">
                                    {% else %}
                                        <div class="alt-image-placeholder">
                                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="3" width="18" height="18" rx="2"/>
                                                <path d="M3 9h18"/>
                                                <path d="M9 21V9"/>
                                            </svg>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="alt-content">
                                    <h4 class="alt-name">{{ facility.name }}</h4>
                                    <p class="alt-description">{% if facility.description %}{{ facility.description }}{% else %}Professional classroom or meeting space with advanced audiovisual equipment for seminars and presentations.{% endif %}</p>

                                    <div class="alt-stats">
                                        <div class="alt-stat-row">
                                            <span class="stat-label">Capacity</span>
                                            <span class="stat-value">{{ facility.capacity }} people</span>
                                        </div>
                                        <div class="alt-stat-row">
                                            <span class="stat-label">Fit Score</span>
                                            <span class="stat-value stat-positive">Perfect fit</span>
                                        </div>
                                        <div class="alt-stat-row">
                                            <span class="stat-label">Status</span>
                                            <span class="stat-value stat-available">Available</span>
                                        </div>
                                    </div>

                                    <form method="POST" action="{{ path('user_select_alternative', {'id': reservation.id, 'facilityId': facility.id}) }}" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('select_alternative_' ~ reservation.id) }}">
                                        <button type="submit" class="accept-button">Accept This Facility</button>
                                    </form>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-alternative">
                        <div class="empty-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                        </div>
                        <p>No better-fit facilities are available for your requested date and time.</p>
                    </div>
                {% endif %}
            </section>
        </div>
    </div>
{% endblock %}
