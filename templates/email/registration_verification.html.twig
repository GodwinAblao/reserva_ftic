<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: #f2f5f7;
            color: #333333;
        }
        .email-wrapper {
            width: 100%;
            padding: 20px;
            box-sizing: border-box;
        }
        .email-card {
            max-width: 600px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e5e8ee;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }
        .email-header {
            background: linear-gradient(135deg, #006633, #004d26);
            color: #ffffff;
            text-align: center;
            padding: 28px 24px;
        }
        .email-header h1 {
            margin: 0;
            font-size: 24px;
            letter-spacing: 0.4px;
        }
        .email-body {
            padding: 28px 24px;
        }
        .email-body p {
            margin: 0 0 18px;
            line-height: 1.65;
            color: #4c5866;
        }
        .verification-code {
            display: inline-block;
            background: #f6fff8;
            color: #006633;
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.25em;
            padding: 18px 24px;
            border-radius: 12px;
            border: 1px solid #d9eedb;
            margin: 8px 0 22px;
        }
        .button {
            display: inline-block;
            background: #006633;
            color: #ffffff;
            text-decoration: none;
            padding: 14px 22px;
            border-radius: 10px;
            font-weight: 700;
            margin-top: 10px;
        }
        .footer {
            font-size: 13px;
            color: #8f97a3;
            text-align: center;
            padding: 24px;
            border-top: 1px solid #eef1f6;
        }
        .small {
            font-size: 12px;
            color: #a4adb9;
        }
    </style>
</head>
<body>
    <div class="email-wrapper">
        <div class="email-card">
            <div class="email-header">
                <h1>Verify Your Reserva FTIC Account</h1>
            </div>
            <div class="email-body">
                <p>Hi {{ user.getFirstName() ?: user.getEmail() }},</p>
                <p>Welcome to Reserva FTIC! Use the code below to verify your account and continue registration.</p>
                <div class="verification-code">{{ verificationCode }}</div>
                <p>Enter this code on the verification page to complete your account setup.</p>
                <a class="button" href="{{ url('app_verify_registration') }}">Verify My Account</a>
                <p class="small">If you did not request this email, you can safely ignore it.</p>
            </div>
            <div class="footer">
                <p>Reserva FTIC Team</p>
                <p class="small">This email was sent from the Reserva FTIC reservation system.</p>
            </div>
        </div>
    </div>
</body>
</html>
