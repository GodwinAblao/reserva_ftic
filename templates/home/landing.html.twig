{% extends 'base.html.twig' %}

{% block title %}Reserva | Landing Page{% endblock %}

{% block body_class %}page-landing{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/landing.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/facility_cards.css') }}">
{% endblock %}

{% block body %}
    <header class="header">
        <div class="header-inner">
            <div class="header-logo">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('images/R-Logo.png') }}" alt="R Logo">
                </a>
            </div>

            <nav class="header-nav">
                <a href="{{ path('app_home') }}" data-no-loading="true">Home</a>
                <a href="{{ path('app_home') }}#about" data-no-loading="true">About us</a>
                <a href="{{ path('app_home') }}#faq" data-no-loading="true">FAQ</a>
            </nav>

            <div class="header-auth">
                <a href="{{ path('app_login') }}" class="btn-login" data-turbo="false" target="_self">Login</a>
                <a href="{{ path('app_register') }}" class="btn-signup" data-turbo="false" target="_self">Sign in</a>
            </div>
        </div>
    </header>

    <main>
        <section id="home" class="hero-section">
            <div class="hero-image-container">
                <img src="{{ asset('innovcent_header_photo.jpg') }}" alt="FTIC Innovation Center workspace" class="hero-image">
                <div class="hero-gradient"></div>

                <div class="hero-content">
                    <img src="{{ asset('images/Reserva-Logo.png') }}" alt="Reserva Logo" class="hero-logo">
                    <h1 class="hero-title">Your All-in-One Hub for Reservations, Mentoring, and Learning at FTIC</h1>
                </div>
            </div>

            
        </section>

        <!-- Facility detail modal -->
        <div id="facilityModal" class="facility-modal" style="display:none;">
            <div class="facility-modal-overlay" data-close="true"></div>
            <div class="facility-modal-dialog" role="dialog" aria-modal="true">
                <button class="facility-modal-close" aria-label="Close">✕</button>
                <div class="facility-view-content">
                    <div class="facility-image-section" id="modalImageSection">
                        <div class="modal-main-image-wrap">
                            <img id="modalMainImage" src="" alt="" class="modal-main-image">
                        </div>
                        <div class="modal-thumbnail-strip" id="modalThumbnailStrip" aria-label="Facility images thumbnails"></div>
                    </div>
                    <div class="facility-info-section">
                        <h1 id="modalFacilityName"></h1>
                        <div class="info-box">
                            <h3>Capacity</h3>
                            <p class="capacity-value" id="modalCapacity"></p>
                        </div>
                        <div class="info-box" id="modalDescriptionBox" style="display:none;">
                            <h3>Description</h3>
                            <p id="modalDescription"></p>
                        </div>
                        <div class="user-actions">
                            <a href="{{ path('app_register') }}" class="btn btn-reserve">Reserve Now</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="offers-section">
            <div class="description-section">
                <div class="description-content">
                    <p class="description-text">
                        Reserva simplifies room reservations, mentoring sessions, and access to FTIC research and innovation articles,
                        helping students and faculty stay organized, connected, and productive within the FEU Tech Innovation Center.
                    </p>
                    <a class="btn-get-started" href="{{ path('app_register') }}" data-turbo="false" target="_self">Get Started</a>
                </div>
            </div>
            <h2 class="section-title">What we offer</h2>

            <div class="offers-grid">
                <article class="offer-card">
                    <img class="offer-icon" src="{{ asset('3.png') }}" alt="Smart Facility Reservation icon">
                    <h3 class="offer-title">Smart Facility Reservation</h3>
                    <ul class="offer-list">
                        <li>Check room availability in real time</li>
                        <li>Book rooms for classes, meetings, and events</li>
                        <li>Avoid schedule conflicts and double bookings</li>
                        <li>Manage all your reservations in one dashboard</li>
                    </ul>
                    <a href="#facilities" class="offer-link">View Facilities &rarr;</a>
                </article>

                <article class="offer-card">
                    <img class="offer-icon" src="{{ asset('4.png') }}" alt="Research and Innovation Hub icon">
                    <h3 class="offer-title">FTIC Research &amp; Innovation Hub</h3>
                    <ul class="offer-list">
                        <li>Access FTIC research publications and articles</li>
                        <li>Explore innovation-related content and updates</li>
                        <li>Discover academic achievements and projects</li>
                        <li>Support learning through shared knowledge and insights</li>
                    </ul>
                    <a href="#research" class="offer-link">View Research/Articles &rarr;</a>
                </article>

                <article class="offer-card">
                    <img class="offer-icon" src="{{ asset('5.png') }}" alt="Mentorship Leaderboard icon">
                    <h3 class="offer-title">Mentorship Leaderboard</h3>
                    <ul class="offer-list">
                        <li>Earn recognition through mentoring participation</li>
                        <li>Track mentor engagement and contributions</li>
                        <li>Encourage knowledge sharing and peer support</li>
                        <li>Promote a more active learning environment</li>
                    </ul>
                    <a href="{{ path('app_register') }}" class="offer-link" data-turbo="false" target="_self">Get Started &rarr;</a>
                </article>

                <article class="offer-card">
                    <img class="offer-icon" src="{{ asset('6.png') }}" alt="Mentoring Sessions icon">
                    <h3 class="offer-title">Mentoring Sessions Made Easy</h3>
                    <ul class="offer-list">
                        <li>Request mentoring sessions anytime</li>
                        <li>Connect with mentors based on your needs</li>
                        <li>Schedule consultations quickly and efficiently</li>
                        <li>Strengthen academic and professional growth</li>
                    </ul>
                    <a href="{{ path('app_register') }}" class="offer-link" data-turbo="false" target="_self">Get Started &rarr;</a>
                </article>
            </div>
        </section>

        <section id="facilities" class="facilities-section">
            <h2 class="section-title">Facilities Overview</h2>

            <div class="facility-list-cards facilities-grid">
                    {% if facilities is empty %}
                        <div class="facility-list-empty no-facilities">
                            <p>No facilities available at the moment.</p>
                        </div>
                    {% else %}
                        {% for facility in facilities %}
                            <article class="facility-card">
                                <div class="facility-image-holder">
                                    {% if facility.image %}
                                        <img src="{{ facility.image }}" alt="{{ facility.name }}">
                                    {% else %}
                                        <div class="placeholder-image">
                                            <span>{{ facility.name | first }}</span>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="facility-details">
                                    <h3>{{ facility.name }}</h3>
                                    <p class="capacity">Capacity: {{ facility.capacity }} pax</p>
                                    {% if facility.description %}
                                        <p class="description">{{ facility.description }}</p>
                                    {% endif %}
                                    {% set facilityImages = [] %}
                                    {% if facility.image %}
                                        {% set facilityImages = facilityImages|merge([facility.image]) %}
                                    {% endif %}
                                    {% if facility.images|length > 0 %}
                                        {% for image in facility.images %}
                                            {% set facilityImages = facilityImages|merge([image.path]) %}
                                        {% endfor %}
                                    {% endif %}
                                    <a href="javascript:void(0)" class="btn-view btn-view-modal"
                                       data-id="{{ facility.id }}"
                                       data-name="{{ facility.name|e('html_attr') }}"
                                       data-capacity="{{ facility.capacity }}"
                                       data-description="{{ facility.description|e('html_attr') }}"
                                       data-images="{{ facilityImages|json_encode|e('html_attr') }}">
                                        View Details
                                    </a>
                                </div>
                            </article>
                        {% endfor %}
                    {% endif %}
            </div>
        </section>

        <section id="research" class="research-section">
            <h2 class="section-title">Research/Articles Overview</h2>

            <div class="research-preview-grid">
                {% if researchItems is empty %}
                    <div class="research-empty-state">
                        <p>No research or articles have been posted yet.</p>
                    </div>
                {% else %}
                    {% for item in researchItems %}
                        <article class="research-preview-card">
                            <div class="research-preview-media">
                                {% if item.filePath %}
                                    <img src="{{ item.filePath }}" alt="{{ item.title }}">
                                {% else %}
                                    <div class="research-preview-placeholder">
                                        <span>{{ item.title|first }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="research-preview-content">
                                <span class="research-preview-badge">{{ item.type }}</span>
                                <h3>{{ item.title }}</h3>
                                {% if item.type == 'Research' %}
                                    {% if item.abstract %}
                                        <p>{{ item.abstract }}</p>
                                    {% elseif item.summary %}
                                        <p>{{ item.summary }}</p>
                                    {% endif %}
                                {% else %}
                                    {% if item.summary %}
                                        <p>{{ item.summary }}</p>
                                    {% elseif item.body %}
                                        <p>{{ item.body|striptags|slice(0, 140) ~ (item.body|striptags|length > 140 ? '...' : '') }}</p>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                {% endif %}
            </div>
        </section>

        <section id="about" class="about-section">
            <h2 class="section-title">About us</h2>

            <div class="about-grid">
                <div class="about-content">
                    <p class="about-text about-text-lead">
                        Reserva is a modern web-based platform created for the FEU Tech Innovation Center (FTIC) to simplify facility
                        reservations, mentoring coordination, and access to FTIC research and innovation content.
                    </p>
                    <p class="about-text">
                        By transforming manual processes into a centralized digital experience, Reserva helps create a more efficient,
                        accessible, and connected environment for students and faculty.
                    </p>
                </div>

                <div class="about-image-container">
                    <img src="{{ asset('images/R-Logo.png') }}" alt="R Logo" class="about-image">
                </div>
            </div>

            <div class="mission-container">
                <div class="mission-card">
                    <h3 class="mission-title">Our Mission</h3>
                    <div class="mission-list">
                        {% set missions = [
                            'Simplify reservation and scheduling processes',
                            'Improve access to mentoring opportunities',
                            'Centralize FTIC research and innovation resources',
                            'Encourage collaboration and engagement',
                            'Create a smarter and more organized FTIC experience'
                        ] %}

                        {% for mission in missions %}
                            <div class="mission-item">
                                <span class="mission-checkbox" aria-hidden="true">✓</span>
                                <p class="mission-text">{{ mission }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </section>

        <section id="faq" class="faq-section">
            <h2 class="section-title">Frequently Asked Questions</h2>

            <div class="faq-container">
                <div class="accordion">
                    {% set faqs = [
                        { question: 'What is Reserva?', answer: 'Reserva is a comprehensive web-based platform designed for the FEU Tech Innovation Center that simplifies facility reservations, mentoring coordination, and academic resource access in one place.' },
                        { question: 'What can I do in Reserva?', answer: 'You can reserve rooms and facilities, request mentoring sessions, access academic resources, manage schedules, and track activities in one centralized dashboard.' },
                        { question: 'How does room reservation work?', answer: 'Check room availability in real time, select your preferred room and time slot, submit your reservation request, and wait for approval.' },
                        { question: 'How do mentoring sessions work?', answer: 'You can search for mentors based on skills and expertise, request a session, and receive confirmation once approved.' },
                        { question: 'Can students apply as mentors?', answer: 'Yes. Students can apply to become mentors and share their expertise with others in the FTIC community.' },
                        { question: 'What is the Mentorship Leaderboard?', answer: 'The Mentorship Leaderboard recognizes active mentors and tracks mentor engagement and contributions.' },
                        { question: 'What resources can I access?', answer: 'You can access research papers, academic articles, innovation-focused content, and other educational materials for the FTIC community.' },
                        { question: 'Can I manage my schedule in Reserva?', answer: 'Yes. Reserva provides a centralized dashboard where you can view and manage reservations, mentoring sessions, and schedules.' }
                    ] %}

                    {% for faq in faqs %}
                        <details class="accordion-item">
                            <summary>{{ faq.question }}</summary>
                            <p>{{ faq.answer }}</p>
                        </details>
                    {% endfor %}
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="footer-content">
            <p>&copy; {{ "now"|date("Y") }} Reserva. All rights reserved.</p>
        </div>
    </footer>

    <div id="pageLoadingOverlay" class="page-loading-overlay" style="display: none;">
        <div class="page-loading-spinner" aria-hidden="true"></div>
        <span class="page-loading-text">Loading...</span>
    </div>

    <script>
        (function() {
            const overlay = document.getElementById('pageLoadingOverlay');
            if (!overlay) {
                return;
            }

            document.querySelectorAll('a[href]').forEach(function(link) {
                link.addEventListener('click', function(event) {
                    if (
                        event.defaultPrevented ||
                        event.metaKey ||
                        event.ctrlKey ||
                        event.shiftKey ||
                        event.altKey ||
                        link.target === '_blank' ||
                        link.dataset.noLoading === 'true'
                    ) {
                        return;
                    }

                    const href = link.getAttribute('href') || '';
                    if (!href || href.startsWith('#') || href === window.location.pathname + window.location.search + window.location.hash) {
                        return;
                    }

                    overlay.style.display = 'flex';
                });
            });

            window.addEventListener('beforeunload', function() {
                overlay.style.display = 'flex';
            });
        })();
    </script>

    <script>
        // Facility quick view modal wiring
        (function() {
            const modal = document.getElementById('facilityModal');
            if (!modal) return;

            const overlay = modal.querySelector('.facility-modal-overlay');
            const closeBtn = modal.querySelector('.facility-modal-close');
            const imgSection = document.getElementById('modalImageSection');
            const mainImageWrap = modal.querySelector('.modal-main-image-wrap');
            const mainImage = document.getElementById('modalMainImage');
            const thumbnailStrip = document.getElementById('modalThumbnailStrip');
            const nameEl = document.getElementById('modalFacilityName');
            const capEl = document.getElementById('modalCapacity');
            const descBox = document.getElementById('modalDescriptionBox');
            const descEl = document.getElementById('modalDescription');
            const reserveBtn = modal.querySelector('.btn-reserve');

            function setActiveThumbnail(activeBtn) {
                thumbnailStrip.querySelectorAll('.modal-thumbnail').forEach(function(btn) {
                    btn.classList.toggle('is-active', btn === activeBtn);
                });
            }

            function showImage(src, alt, activeBtn) {
                if (!src) return;
                mainImage.src = src;
                mainImage.alt = alt || '';
                setActiveThumbnail(activeBtn || null);
            }

            function openModal(data) {
                imgSection.querySelectorAll('.modal-placeholder-image').forEach(function(node) {
                    node.remove();
                });
                const images = Array.isArray(data.images) ? data.images.filter(Boolean) : [];
                imgSection.classList.toggle('has-images', images.length > 0);
                if (images.length > 0) {
                    mainImageWrap.style.display = 'block';
                    mainImage.style.display = 'block';
                    thumbnailStrip.innerHTML = '';
                    showImage(images[0], data.name, null);

                    images.forEach(function(src, index) {
                        const thumb = document.createElement('button');
                        thumb.type = 'button';
                        thumb.className = 'modal-thumbnail' + (index === 0 ? ' is-active' : '');
                        thumb.setAttribute('aria-label', (data.name || 'Facility') + ' image ' + (index + 1));

                        const thumbImg = document.createElement('img');
                        thumbImg.src = src;
                        thumbImg.alt = data.name || '';
                        thumb.appendChild(thumbImg);

                        thumb.addEventListener('click', function() {
                            showImage(src, data.name, thumb);
                        });

                        thumbnailStrip.appendChild(thumb);
                    });
                } else {
                    mainImageWrap.style.display = 'none';
                    thumbnailStrip.innerHTML = '';
                    mainImage.removeAttribute('src');
                    mainImage.alt = data.name || '';

                    const ph = document.createElement('div');
                    ph.className = 'placeholder-image modal-placeholder-image';
                    ph.textContent = data.name ? data.name.charAt(0) : '';
                    imgSection.appendChild(ph);
                }

                nameEl.textContent = data.name || '';
                capEl.textContent = data.capacity ? data.capacity + ' persons' : '';

                if (data.description) {
                    descEl.textContent = data.description;
                    descBox.style.display = 'block';
                } else {
                    descBox.style.display = 'none';
                }

                // Reserve should go to sign up page for unauthenticated quick view
                if (reserveBtn) {
                    reserveBtn.setAttribute('href', '{{ path('app_register') }}');
                    reserveBtn.setAttribute('data-turbo', 'false');
                    reserveBtn.setAttribute('target', '_self');
                }

                modal.style.display = 'grid';
                document.body.style.overflow = 'hidden';
            }

            function closeModal() {
                modal.style.display = 'none';
                document.body.style.overflow = '';
                const pageOverlay = document.getElementById('pageLoadingOverlay');
                if (pageOverlay) {
                    pageOverlay.style.display = 'none';
                }
            }

            document.querySelectorAll('.btn-view-modal').forEach(function(el) {
                el.addEventListener('click', function(e) {
                    e.preventDefault();
                    let images = [];
                    try {
                        images = JSON.parse(el.dataset.images || '[]');
                    } catch (err) {
                        images = [];
                    }
                    const data = {
                        id: el.dataset.id,
                        name: el.dataset.name,
                        capacity: el.dataset.capacity,
                        description: el.dataset.description,
                        images: images
                    };
                    openModal(data);
                });
            });

            overlay.addEventListener('click', function(e) { e.stopPropagation(); closeModal(); });
            closeBtn.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); closeModal(); });
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && modal.style.display !== 'none') {
                    closeModal();
                }
            });
        })();
    </script>

{% endblock %}
