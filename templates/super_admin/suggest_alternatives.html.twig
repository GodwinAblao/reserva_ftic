{% extends "layouts/app.html.twig" %}

{% block title %}Suggest Alternative - Reserva FTIC{% endblock %}

{% block content %}
<div class="sa-page-header">
    <div class="sa-page-header-left">
        <h2>Suggest Alternative Schedule</h2>
        <p>Propose an alternative facility and time slot for this reservation</p>
    </div>
    <div class="sa-header-actions">
        <a href="{{ path('admin_reservations') }}" class="sa-btn sa-btn-secondary">← Back to Reservations</a>
    </div>
</div>

    <!-- Original Reservation Details -->
    <div class="sa-card" style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border: 1.5px solid #bae6fd;">
        <div class="sa-card-header">
            <h3 class="sa-card-title">Original Reservation Request</h3>
            <span class="sa-badge sa-badge-info">{{ reservation.status }}</span>
        </div>
        <div class="sa-detail-grid">
            <div class="sa-detail-col">
                <label>Requester</label>
                <p>{{ reservation.name }}</p>
            </div>
            <div class="sa-detail-col">
                <label>Email</label>
                <p>{{ reservation.email }}</p>
            </div>
            <div class="sa-detail-col">
                <label>Requested Facility</label>
                <p class="highlight">{{ reservation.facility.name }}</p>
            </div>
            <div class="sa-detail-col">
                <label>Date</label>
                <p>{{ reservation.reservationDate|date('M d, Y') }}</p>
            </div>
            <div class="sa-detail-col">
                <label>Time</label>
                <p>{{ reservation.reservationStartTime|date('h:i A') }} – {{ reservation.reservationEndTime|date('h:i A') }}</p>
            </div>
            <div class="sa-detail-col">
                <label>Attendees</label>
                <p>{{ reservation.capacity }} / {{ reservation.facility.capacity }}</p>
            </div>
            {% if reservation.purpose %}
                <div class="sa-detail-col full-width">
                    <label>Event Objectives</label>
                    <p>{{ reservation.purpose }}</p>
                </div>
            {% endif %}
        </div>
    </div>

    {% if isEditingSuggestion %}
    <div class="sa-alert sa-alert-warning">
        <strong>💡 Editing Existing Suggestion</strong><br>
        You are currently editing an existing suggestion. The requester has been notified of the previous suggestion. Modifying this will update the suggestion and notify them again.
    </div>
    {% endif %}

    <div class="sa-suggest-layout">
        <!-- Alternative Facilities -->
        <div class="sa-card" style="position:sticky; top:2rem;">
            <div class="sa-card-header">
                <div>
                    <h3 class="sa-card-title">Available Facilities</h3>
                    <p class="sa-card-subtitle">Click a facility to view available time slots</p>
                </div>
            </div>
            <div class="sa-facility-list">
                {% for facility in alternatives %}
                    <div class="sa-facility-card" onclick="selectFacility({{ facility.id }}, '{{ facility.name }}', {{ facility.capacity }})" data-facility-id="{{ facility.id }}">
                        <div class="sa-facility-icon">🏢</div>
                        <div class="sa-facility-info">
                            <h4>{{ facility.name }}</h4>
                            <p>Capacity: {{ facility.capacity }} people</p>
                            {% if facility.description %}
                                <p class="sa-facility-desc">{{ facility.description }}</p>
                            {% endif %}
                        </div>
                        <div class="sa-facility-arrow">→</div>
                    </div>
                {% endfor %}
                {% if alternatives is empty %}
                    <div class="sa-empty">📋 No alternative facilities available for this request.</div>
                {% endif %}
            </div>
        </div>

        <!-- Schedule Selection -->
        <div class="sa-card" id="schedulePanel">
            <div class="sa-card-header">
                <div>
                    <h3 class="sa-card-title">Schedule Selection</h3>
                    <p class="sa-card-subtitle" id="selectedFacilityName">
                        {% if isEditingSuggestion %}{{ reservation.facility.name }}{% else %}Select a facility first{% endif %}
                    </p>
                </div>
            </div>

            <div id="facilitySelectionPlaceholder" style="{% if isEditingSuggestion %}display:none;{% endif %} text-align:center; padding:40px 20px; color:#9ca3af;">
                <div style="font-size:3rem; margin-bottom:12px;">👆</div>
                <p style="margin:0;">Select a facility from the left to view available time slots</p>
            </div>

            <div id="scheduleSelectionForm" style="{% if isEditingSuggestion %}display:block;{% else %}display:none;{% endif %}">
                <form id="suggestScheduleForm" method="POST" action="{{ path('admin_suggest_datetime', {'id': reservation.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_suggest_datetime_' ~ reservation.id) }}">
                    <input type="hidden" name="facility_id" id="selectedFacilityId" value="{% if isEditingSuggestion %}{{ reservation.facility.id }}{% endif %}">

                    <div style="margin-bottom:20px;">
                        <p style="margin:0 0 8px; font-size:13px; font-weight:700; color:#374151; text-transform:uppercase; letter-spacing:0.4px;">📅 Select Date</p>
                        <input type="date" id="suggestDate" name="date" class="sa-form-input" required min="{{ 'now'|date('Y-m-d') }}" value="{% if isEditingSuggestion %}{{ reservation.reservationDate|date('Y-m-d') }}{% endif %}" onchange="loadTimeSlots()">
                    </div>

                    <div style="margin-bottom:20px;">
                        <p style="margin:0 0 12px; font-size:13px; font-weight:700; color:#374151; text-transform:uppercase; letter-spacing:0.4px;">⏰ Available Time Slots</p>
                        <div id="timeSlotsContainer" class="sa-slots-container">
                            <p style="color:#9ca3af; font-style:italic; grid-column:1/-1; text-align:center; padding:16px 0;">Select a date to see available time slots</p>
                        </div>
                    </div>

                    <div id="selectedTimeInfo" style="display:{% if isEditingSuggestion %}block{% else %}none{% endif %}; margin-bottom:16px; padding:14px 16px; background:#f0fdf4; border:1.5px solid #86efac; border-radius:10px;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <span style="font-weight:600; color:#166534; font-size:13px;">Current Selected Time:</span>
                            <span style="font-weight:700; color:#15803d; font-size:15px;" id="selectedTimeDisplay">{{ reservation.reservationStartTime|date('H:i') }} - {{ reservation.reservationEndTime|date('H:i') }}</span>
                        </div>
                    </div>

                    <div id="availabilityIndicator" class="sa-alert" style="display:none; align-items:center; gap:10px;"></div>

                    <button type="submit" class="sa-btn sa-btn-primary" id="submitSuggestion" disabled style="width:100%; justify-content:center; padding:12px; font-size:15px;">
                        ✓ {% if isEditingSuggestion %}Update Suggestion{% else %}Suggest This Schedule{% endif %}
                    </button>
                </form>
            </div>
        </div>
    </div>

<style>
    #submitSuggestion:disabled {
        background: #9ca3af !important;
        cursor: not-allowed;
        opacity: 0.7;
        transform: none !important;
        box-shadow: none !important;
    }
    .time-slot-btn { font-family: inherit; }
    .time-slot-btn.selected {
        background: linear-gradient(130deg,#006633 0%,#008844 100%);
        border-color: #006633;
        color: #fff;
    }
    .time-slot-btn:hover:not(.unavailable):not(.selected) {
        border-color: #006633;
        color: #006633;
        background: #f0fdf4;
    }
    @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    #scheduleSelectionForm { animation: fadeIn 0.25s ease; }
    #availabilityIndicator { margin-bottom: 16px; font-weight: 600; }
</style>

<script>
    let selectedFacilityId = null;
    let selectedStartTime = null;
    let selectedEndTime = null;
    const reservationId = {{ reservation.id }};
    const originalDuration = {{ durationMinutes }};
    const isEditingSuggestion = {{ isEditingSuggestion ? 'true' : 'false' }};

    function selectFacility(facilityId, facilityName, capacity) {
        selectedFacilityId = facilityId;
        
        // Update UI
        document.querySelectorAll('.facility-select-card').forEach(card => {
            card.classList.remove('selected');
        });
        document.querySelector(`[data-facility-id="${facilityId}"]`).classList.add('selected');
        
        // Show form
        document.getElementById('facilitySelectionPlaceholder').style.display = 'none';
        document.getElementById('scheduleSelectionForm').style.display = 'block';
        document.getElementById('selectedFacilityName').textContent = facilityName;
        document.getElementById('selectedFacilityId').value = facilityId;
        
        // Reset form
        document.getElementById('suggestDate').value = '';
        document.getElementById('timeSlotsContainer').innerHTML = '<p class="loading-text">Select a date to see available time slots</p>';
        document.getElementById('selectedTimeInfo').style.display = 'none';
        document.getElementById('availabilityIndicator').style.display = 'none';
        document.getElementById('submitSuggestion').disabled = true;
    }

    function loadTimeSlots() {
        const date = document.getElementById('suggestDate').value;
        const container = document.getElementById('timeSlotsContainer');
        
        if (!date) {
            container.innerHTML = '<p class="loading-text">Select a date to see available time slots</p>';
            return;
        }

        if (!selectedFacilityId) {
            return;
        }

        container.innerHTML = '<p class="loading-text">Loading available time slots...</p>';

        fetch('/super-admin/get-available-slots', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
            },
            body: JSON.stringify({
                facility_id: selectedFacilityId,
                date: date,
                duration_minutes: originalDuration,
                exclude_reservation_id: reservationId
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.message && data.message.includes('Sunday')) {
                container.innerHTML = '<p class="loading-text" style="color: #dc2626;">🚫 All facilities are closed on Sundays</p>';
            } else if (data.slots && data.slots.length > 0) {
                container.innerHTML = data.slots.map(slot => 
                    `<button type="button" class="sa-slot-btn time-slot-btn" onclick="selectTimeSlot('${slot.start}', '${slot.end}')">
                        ${slot.start} - ${slot.end}
                    </button>`
                ).join('');
            } else {
                container.innerHTML = '<p class="loading-text">No available time slots found for this date</p>';
            }
        })
        .catch(error => {
            console.error('Error loading time slots:', error);
            container.innerHTML = '<p class="loading-text">Error loading time slots</p>';
        });
    }

    function selectTimeSlot(startTime, endTime) {
        selectedStartTime = startTime;
        selectedEndTime = endTime;

        // Update UI
        document.querySelectorAll('.time-slot-btn').forEach(btn => btn.classList.remove('selected'));
        event.target.classList.add('selected');

        // Show selected time
        document.getElementById('selectedTimeDisplay').textContent = `${startTime} - ${endTime}`;
        document.getElementById('selectedTimeInfo').style.display = 'block';

        // Check availability
        checkAvailability();
    }

    function checkAvailability() {
        const date = document.getElementById('suggestDate').value;
        const indicator = document.getElementById('availabilityIndicator');
        const submitBtn = document.getElementById('submitSuggestion');

        if (!date || !selectedStartTime || !selectedEndTime) {
            return;
        }

        indicator.style.display = 'flex';
        indicator.className = 'sa-alert sa-alert-info';
        indicator.innerHTML = '⏳ Checking availability...';
        submitBtn.disabled = true;

        fetch('/super-admin/check-availability', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
            },
            body: JSON.stringify({
                facility_id: selectedFacilityId,
                date: date,
                start_time: selectedStartTime,
                end_time: selectedEndTime,
                exclude_reservation_id: reservationId
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.available) {
                indicator.className = 'sa-alert sa-alert-info';
                indicator.style.background = '#f0fdf4';
                indicator.style.borderColor = '#86efac';
                indicator.style.color = '#166534';
                indicator.innerHTML = '✓ This time slot is available';
                submitBtn.disabled = false;
            } else {
                indicator.className = 'sa-alert sa-alert-warning';
                indicator.innerHTML = '✕ This time slot is already booked';
                submitBtn.disabled = true;
            }
        })
        .catch(error => {
            console.error('Error checking availability:', error);
            indicator.className = 'sa-alert sa-alert-warning';
            indicator.innerHTML = '⚠️ Error checking availability';
        });
    }

    document.getElementById('suggestScheduleForm').addEventListener('submit', function(e) {
        if (!selectedStartTime || !selectedEndTime) {
            e.preventDefault();
            alert('Please select a time slot');
            return;
        }

        // Add hidden inputs for start and end time
        const startTimeInput = document.createElement('input');
        startTimeInput.type = 'hidden';
        startTimeInput.name = 'start_time';
        startTimeInput.value = selectedStartTime;
        
        const endTimeInput = document.createElement('input');
        endTimeInput.type = 'hidden';
        endTimeInput.name = 'end_time';
        endTimeInput.value = selectedEndTime;

        this.appendChild(startTimeInput);
        this.appendChild(endTimeInput);
    });

    // Initialize if editing suggestion
    document.addEventListener('DOMContentLoaded', function() {
        if (isEditingSuggestion) {
            selectedFacilityId = {{ reservation.facility.id }};
            selectedStartTime = '{{ reservation.reservationStartTime|date('H:i') }}';
            selectedEndTime = '{{ reservation.reservationEndTime|date('H:i') }}';
            
            // Pre-select the current facility
            document.querySelector(`[data-facility-id="${selectedFacilityId}"]`).classList.add('selected');
            
            // Load time slots for the current date
            loadTimeSlots();
            
            // Check availability for the current time slot
            checkAvailability();
        }
    });
</script>
{% endblock %}
