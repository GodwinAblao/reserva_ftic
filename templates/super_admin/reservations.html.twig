{% extends "layouts/app.html.twig" %}

{% block title %}Reservation Management - Reserva FTIC{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.rm-toolbar { display:flex; align-items:center; justify-content:space-between; gap:14px; margin: 0 0 18px; flex-wrap:wrap; }
.rm-filter-form { display:flex; align-items:center; gap:10px; margin:0; }
.rm-filter-label { font-size:12px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; }
.rm-filter-select { min-width:170px; height:38px; border:1px solid #d1d5db; border-radius:8px; background:#fff; color:#374151; padding:0 12px; font-size:13px; font-weight:600; }
.rm-count { font-size:13px; color:#6b7280; font-weight:600; }
.rm-pagination { display:flex; align-items:center; justify-content:flex-end; gap:6px; margin-top:18px; flex-wrap:wrap; }
.rm-page-link { min-width:34px; height:34px; padding:0 11px; display:inline-flex; align-items:center; justify-content:center; border:1px solid #d1d5db; border-radius:8px; background:#fff; color:#374151; font-size:13px; font-weight:700; text-decoration:none; }
.rm-page-link:hover { border-color:#0d9b00; color:#0d9b00; }
.rm-page-link.active { background:#0d9b00; border-color:#0d9b00; color:#fff; }
.rm-page-link.disabled { opacity:.45; pointer-events:none; }
.rm-status-heading { display:flex; align-items:center; gap:8px; }
@keyframes saSpin { to { transform: rotate(360deg); } }
.sa-spinner { display:inline-block; width:13px; height:13px; border:2px solid rgba(255,255,255,.4); border-top-color:#fff; border-radius:50%; animation:saSpin .6s linear infinite; vertical-align:middle; margin-right:5px; }
.sa-btn-loading { opacity:.75 !important; pointer-events:none !important; cursor:not-allowed !important; }
</style>
{% endblock %}

{% block content %}
<!-- Superadmin approve-without-admin confirm modal -->
<div id="saApproveConfirmModal" class="sa-modal-overlay" style="display:none;">
    <div class="sa-modal">
        <div class="sa-modal-header">
            <h3>Approve Without Admin Review?</h3>
            <button type="button" class="sa-modal-close" onclick="document.getElementById('saApproveConfirmModal').style.display='none'">&times;</button>
        </div>
        <div class="sa-modal-body">
            <p style="margin:0;color:#6b7280;font-size:13px;line-height:1.55;">The admin has not yet reviewed this reservation. Are you sure you want to approve it now?</p>
        </div>
        <div class="sa-modal-footer">
            <button type="button" class="sa-btn sa-btn-secondary" onclick="document.getElementById('saApproveConfirmModal').style.display='none'">Cancel</button>
            <button type="button" class="sa-btn sa-btn-approve" id="saApproveConfirmBtn">Yes, Approve</button>
        </div>
    </div>
</div>
<div class="sa-page-header">
    <div class="sa-page-header-left">
        <h2>Reservation Management</h2>
        <p>Review, approve, reject and manage all facility reservations</p>
    </div>
    <div class="sa-header-actions">
        <a href="{{ path('admin_calendar') }}" class="sa-btn sa-btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Calendar View
        </a>
        <a href="{{ path('app_dashboard') }}" class="sa-btn sa-btn-secondary">← Dashboard</a>
    </div>
</div>

{% for message in app.flashes('reservation_success') %}
    <div class="flash-message flash-success" style="margin:0 0 16px 0;">
        <div class="flash-content">
            <span class="flash-icon">OK</span>
            <span>{{ message }}</span>
        </div>
    </div>
{% endfor %}
{% for message in app.flashes('reservation_error') %}
    <div class="flash-message flash-error" style="margin:0 0 16px 0;">
        <div class="flash-content">
            <span class="flash-icon">!</span>
            <span>{{ message }}</span>
        </div>
    </div>
{% endfor %}

<div class="sa-card">
    <div class="rm-toolbar">
        <form method="get" action="{{ path('admin_reservations') }}" class="rm-filter-form">
            <label for="reservation-status-filter" class="rm-filter-label">Status</label>
            <select id="reservation-status-filter" name="status" class="rm-filter-select" onchange="this.form.submit()">
                {% for option in statusOptions %}
                    <option value="{{ option }}" {{ selectedStatus == option ? 'selected' : '' }}>{{ option }}</option>
                {% endfor %}
            </select>
        </form>
        <div class="rm-count">
            Showing {{ reservations|length }} of {{ pagination.total }} reservation{{ pagination.total == 1 ? '' : 's' }}
        </div>
    </div>

    <div class="sa-card-header">
        <div>
            <h3 class="sa-card-title rm-status-heading">
                {% if selectedStatus == 'Approved' %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {% elseif selectedStatus == 'Pending' %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {% elseif selectedStatus == 'Rejected' %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                {% elseif selectedStatus == 'Canceled' %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                {% else %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0d9b00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h10a2 2 0 0 1 2 2v16l-7-3-7 3V5a2 2 0 0 1 2-2Z"/></svg>
                {% endif %}
                {{ selectedStatus == 'All' ? 'All Reservations' : selectedStatus ~ ' Reservations' }}
                <span class="sa-badge">{{ pagination.total }}</span>
            </h3>
            <p class="sa-card-subtitle">10 reservations per page.</p>
        </div>
    </div>

    {% if reservations|length > 0 %}
        <div class="sa-reservation-list">
            {% for reservation in reservations %}
                {% set status = reservation.status %}
                {% set statusClass = status == 'Approved' ? 'approved' : (status == 'Rejected' ? 'rejected' : (status in ['Cancelled', 'Canceled'] ? 'cancelled' : 'pending')) %}
                <div class="sa-reservation-row row-{{ statusClass }}">
                    <div class="sa-row-head">
                        <h4>{{ reservation.facility.name }}</h4>
                        <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                            <span class="sa-badge sa-badge-{{ statusClass }}">{{ status == 'Cancelled' ? 'Canceled' : status }}</span>
                            {% if status == 'Pending' %}
                                {% if reservation.adminApproved %}
                                    <span class="sa-badge" style="background:#fef9c3;color:#854d0e;border:1px solid #fde68a;" title="Admin has reviewed and approved this reservation">&#10003; Approved by Admin</span>
                                {% else %}
                                    <span class="sa-badge" style="background:#fee2e2;color:#991b1b;border:1px solid #fecaca;" title="Admin has not yet reviewed this reservation">&#9888; Pending admin approval</span>
                                {% endif %}
                            {% endif %}
                        </div>
                    </div>

                    <div class="sa-detail-grid">
                        <div class="sa-detail-col">
                            <label>Requester</label>
                            <p>{{ reservation.name }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Email</label>
                            <p>{{ reservation.email }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Contact</label>
                            <p>{{ reservation.contact ?: 'N/A' }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Date &amp; Time</label>
                            <p>{{ reservation.reservationDate|date('M d, Y') }} · {{ reservation.reservationStartTime|date('h:i A') }} - {{ reservation.reservationEndTime|date('h:i A') }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Attendees</label>
                            <p>{{ reservation.capacity }} / {{ reservation.facility.capacity }}</p>
                        </div>
                        {% if reservation.eventName %}
                            <div class="sa-detail-col">
                                <label>Event Name</label>
                                <p>{{ reservation.eventName }}</p>
                            </div>
                        {% endif %}
                        {% if reservation.eventPurpose %}
                            <div class="sa-detail-col">
                                <label>Event Purpose</label>
                                <p>{{ reservation.eventPurpose }}{% if reservation.eventPurpose == 'others' and reservation.eventPurposeOther %} ({{ reservation.eventPurposeOther }}){% endif %}</p>
                            </div>
                        {% endif %}
                        {% if reservation.purpose %}
                            <div class="sa-detail-col full-width">
                                <label>Event Objectives</label>
                                <p>{{ reservation.purpose }}</p>
                            </div>
                        {% endif %}
                        {% if reservation.rejectionReason %}
                            <div class="sa-detail-col full-width">
                                <label>Rejection Reason</label>
                                <p>{{ reservation.rejectionReason }}</p>
                            </div>
                        {% endif %}
                        {% if reservation.cancellationReason %}
                            <div class="sa-detail-col full-width">
                                <label>Cancellation Reason</label>
                                <p>{{ reservation.cancellationReason }}</p>
                            </div>
                        {% endif %}
                    </div>

                    {% if status == 'Pending' %}
                        <div class="sa-row-actions">
                            <form method="POST" action="{{ path('admin_approve_reservation', {'id': reservation.id}) }}" style="display:inline;" data-ajax="true" data-ajax-reload="1000" class="sa-approve-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('approve_reservation_' ~ reservation.id) }}">
                                <button type="button" class="sa-btn sa-btn-approve"
                                    data-admin-approved="{{ reservation.adminApproved ? '1' : '0' }}"
                                    onclick="saConfirmApprove(this)">Approve</button>
                            </form>

                            <form method="POST" action="{{ path('admin_reject_reservation', {'id': reservation.id}) }}" style="display:inline;" class="reject-form" data-ajax="true" data-ajax-reload="1000">
                                <input type="hidden" name="_token" value="{{ csrf_token('reject_reservation_' ~ reservation.id) }}">
                                <input type="hidden" name="reason" class="reject-reason">
                                <button type="button" class="sa-btn sa-btn-reject" onclick="showRejectModal(this)">Reject</button>
                            </form>
                        </div>
                    {% elseif status == 'Approved' %}
                        <div class="sa-row-actions">
                            <a href="{{ path('admin_edit_reservation', {'id': reservation.id}) }}" class="sa-btn sa-btn-secondary">Edit</a>
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="sa-empty">No reservations found for this status.</div>
    {% endif %}

    {% if pagination.pages > 1 %}
        {% set baseParams = selectedStatus == 'All' ? {} : {status: selectedStatus} %}
        {% set firstPageCandidate = pagination.page - 2 %}
        {% set lastPageCandidate = pagination.page + 2 %}
        {% set firstPage = firstPageCandidate > 1 ? firstPageCandidate : 1 %}
        {% set lastPage = lastPageCandidate < pagination.pages ? lastPageCandidate : pagination.pages %}
        <div class="rm-pagination">
            <a class="rm-page-link {{ pagination.page == 1 ? 'disabled' : '' }}" href="{{ path('admin_reservations', baseParams|merge({page: pagination.page - 1})) }}">Prev</a>
            {% for p in firstPage..lastPage %}
                <a class="rm-page-link {{ p == pagination.page ? 'active' : '' }}" href="{{ path('admin_reservations', baseParams|merge({page: p})) }}">{{ p }}</a>
            {% endfor %}
            <a class="rm-page-link {{ pagination.page == pagination.pages ? 'disabled' : '' }}" href="{{ path('admin_reservations', baseParams|merge({page: pagination.page + 1})) }}">Next</a>
        </div>
    {% endif %}
</div>

<div id="rejectModal" class="sa-modal-overlay" style="display:none;">
    <div class="sa-modal">
        <div class="sa-modal-header">
            <h3>Reject Reservation</h3>
            <button type="button" class="sa-modal-close" onclick="closeRejectModal()">×</button>
        </div>
        <div class="sa-modal-body">
            <label for="rejectionReason">Reason for rejection</label>
            <textarea id="rejectionReason" class="sa-form-input" rows="4" placeholder="Explain why this reservation is being rejected..."></textarea>
            <p id="rejectionReasonError" style="display:none;margin-top:7px;padding:8px 12px;background:#fef2f2;border:1px solid #fecaca;border-radius:7px;color:#dc2626;font-size:12.5px;font-weight:600;">Please provide a reason for rejection.</p>
        </div>
        <div class="sa-modal-footer">
            <button type="button" class="sa-btn sa-btn-secondary" onclick="closeRejectModal()">Cancel</button>
            <button type="button" class="sa-btn sa-btn-reject" id="saRejectConfirmBtn" onclick="submitReject()">Confirm Reject</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        ['rejectModal', 'saApproveConfirmModal'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el && el.parentElement !== document.body) { document.body.appendChild(el); }
        });
    });

    let currentForm = null;
    let _saRejectTriggerBtn = null;

    function showRejectModal(button) {
        _saRejectTriggerBtn = button;
        currentForm = button.closest('.reject-form');
        document.getElementById('rejectModal').style.display = 'flex';
        document.getElementById('rejectionReason').focus();
    }

    function closeRejectModal() {
        document.getElementById('rejectModal').style.display = 'none';
        document.getElementById('rejectionReason').value = '';
        document.getElementById('rejectionReasonError').style.display = 'none';
        currentForm = null;
        _saRejectTriggerBtn = null;
    }

    function _saSetBtnLoading(btn, label) {
        if (!btn) return;
        btn._saOrigHTML = btn.innerHTML;
        btn.innerHTML = '<span class="sa-spinner"></span>' + label;
        btn.classList.add('sa-btn-loading');
        btn.disabled = true;
    }
    function _saRestoreBtn(btn) {
        if (!btn) return;
        btn.innerHTML = btn._saOrigHTML || btn.innerHTML;
        btn.classList.remove('sa-btn-loading');
        btn.disabled = false;
    }

    function submitReject() {
        const reason = document.getElementById('rejectionReason').value.trim();
        if (!reason) {
            document.getElementById('rejectionReasonError').style.display = 'block';
            document.getElementById('rejectionReason').focus();
            return;
        }
        document.getElementById('rejectionReasonError').style.display = 'none';
        if (currentForm) {
            const confirmBtn = document.getElementById('saRejectConfirmBtn');
            if (confirmBtn) { _saSetBtnLoading(confirmBtn, 'Rejecting...'); }
            if (_saRejectTriggerBtn) { _saSetBtnLoading(_saRejectTriggerBtn, 'Rejecting...'); }
            currentForm.querySelector('.reject-reason').value = reason;
            currentForm.submit();
        }
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeRejectModal();
            document.getElementById('saApproveConfirmModal').style.display = 'none';
        }
    });

    var _saPendingForm = null;
    var _saApproveTriggerBtn = null;
    document.getElementById('saApproveConfirmBtn').onclick = function() {
        document.getElementById('saApproveConfirmModal').style.display = 'none';
        _saSetBtnLoading(this, 'Approving...');
        if (_saPendingForm) {
            if (_saApproveTriggerBtn) { _saSetBtnLoading(_saApproveTriggerBtn, 'Approving...'); }
            _saPendingForm.submit();
            _saPendingForm = null;
        }
    };
    document.getElementById('saApproveConfirmModal').addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
    });

    function saConfirmApprove(btn) {
        var adminApproved = btn.getAttribute('data-admin-approved');
        var form = btn.closest('.sa-approve-form');
        if (!form) { return; }
        if (adminApproved === '1') {
            _saSetBtnLoading(btn, 'Approving...');
            form.submit();
        } else {
            _saPendingForm = form;
            _saApproveTriggerBtn = btn;
            document.getElementById('saApproveConfirmModal').style.display = 'flex';
        }
    }
</script>
{% endblock %}
