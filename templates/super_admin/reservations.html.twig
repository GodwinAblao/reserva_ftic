{% extends "layouts/app.html.twig" %}

{% block title %}Reservation Management - Reserva FTIC{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.rm-table-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 22px 24px; margin-top: 20px; }
.rm-table-title { font-size: 16px; font-weight: 700; color: #111827; margin: 0 0 6px; }
.rm-table { width: 100%; border-collapse: collapse; }
.rm-table th { font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.4px; padding: 0 12px 10px; text-align: left; border-bottom: 1px solid #f3f4f6; }
.rm-table td { padding: 12px; font-size: 13.5px; color: #374151; border-bottom: 1px solid #f9fafb; }
.rm-table tr:last-child td { border-bottom: none; }
.rm-table tbody tr:hover td { background: #fafafa; }
</style>
{% endblock %}

{% block content %}
<div class="sa-page-header">
    <div class="sa-page-header-left">
        <h2>Reservation Management</h2>
        <p>Review, approve, reject and manage all facility reservations</p>
    </div>
    <div class="sa-header-actions">
        <a href="{{ path('admin_calendar') }}" class="sa-btn sa-btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Calendar View
        </a>
        <a href="{{ path('app_dashboard') }}" class="sa-btn sa-btn-secondary">← Dashboard</a>
    </div>
</div>

{# ── Pending ───────────────────────────────────────────── #}
<div class="sa-card">
    <div class="sa-card-header">
        <div>
            <h3 class="sa-card-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Pending Reservations
                <span class="sa-badge sa-badge-pending">{{ pending|length }}</span>
            </h3>
            <p class="sa-card-subtitle">Review and approve or reject new reservation requests.</p>
        </div>
    </div>

    {% if pending|length > 0 %}
        <div class="sa-reservation-list">
            {% for reservation in pending %}
                <div class="sa-reservation-row row-pending">
                    <div class="sa-row-head">
                        <h4>{{ reservation.facility.name }}</h4>
                        <span class="sa-badge sa-badge-pending">Pending</span>
                    </div>

                    <div class="sa-detail-grid">
                        <div class="sa-detail-col">
                            <label>Requester</label>
                            <p>{{ reservation.name }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Email</label>
                            <p>{{ reservation.email }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Contact</label>
                            <p>{{ reservation.contact }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Date &amp; Time</label>
                            <p>{{ reservation.reservationDate|date('M d, Y') }} · {{ reservation.reservationStartTime|date('h:i A') }} – {{ reservation.reservationEndTime|date('h:i A') }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Attendees</label>
                            <p>{{ reservation.capacity }} / {{ reservation.facility.capacity }}</p>
                        </div>
                        {% if reservation.purpose %}
                            <div class="sa-detail-col full-width">
                                <label>Event Objectives</label>
                                <p>{{ reservation.purpose }}</p>
                            </div>
                        {% endif %}
                    </div>

                    <div class="sa-row-actions">
                        <form method="POST" action="{{ path('admin_approve_reservation', {'id': reservation.id}) }}" style="display:inline;" data-ajax="true" data-ajax-reload="1000">
                            <input type="hidden" name="_token" value="{{ csrf_token('approve_reservation_' ~ reservation.id) }}">
                            <button type="submit" class="sa-btn sa-btn-approve">✓ Approve</button>
                        </form>

                        <form method="POST" action="{{ path('admin_reject_reservation', {'id': reservation.id}) }}" style="display:inline;" class="reject-form" data-ajax="true" data-ajax-reload="1000">
                            <input type="hidden" name="_token" value="{{ csrf_token('reject_reservation_' ~ reservation.id) }}">
                            <input type="hidden" name="reason" class="reject-reason">
                            <button type="button" class="sa-btn sa-btn-reject" onclick="showRejectModal(this)">✕ Reject</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="sa-empty">No pending reservations at the moment.</div>
    {% endif %}
</div>

{# ── Approved ──────────────────────────────────────────── #}
<div class="sa-card">
    <div class="sa-card-header">
        <h3 class="sa-card-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Approved Reservations
            <span class="sa-badge sa-badge-approved">{{ approved|length }}</span>
        </h3>
    </div>

    {% if approved|length > 0 %}
        <div class="sa-reservation-list">
            {% for reservation in approved %}
                <div class="sa-reservation-row row-approved">
                    <div class="sa-row-head">
                        <h4>{{ reservation.facility.name }}</h4>
                        <span class="sa-badge sa-badge-approved">Approved</span>
                    </div>
                    <div class="sa-detail-grid">
                        <div class="sa-detail-col">
                            <label>Requester</label>
                            <p>{{ reservation.name }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Email</label>
                            <p>{{ reservation.email }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Contact</label>
                            <p>{{ reservation.contact ?: '—' }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Date &amp; Time</label>
                            <p>{{ reservation.reservationDate|date('M d, Y') }} · {{ reservation.reservationStartTime|date('h:i A') }} – {{ reservation.reservationEndTime|date('h:i A') }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Attendees</label>
                            <p>{{ reservation.capacity }} / {{ reservation.facility.capacity }}</p>
                        </div>
                        {% if reservation.eventName %}
                            <div class="sa-detail-col">
                                <label>Event Name</label>
                                <p>{{ reservation.eventName }}</p>
                            </div>
                        {% endif %}
                        {% if reservation.purpose %}
                            <div class="sa-detail-col full-width">
                                <label>Event Objectives</label>
                                <p>{{ reservation.purpose }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="sa-empty">No approved reservations.</div>
    {% endif %}
</div>

{# ── Rejected ──────────────────────────────────────────── #}
<div class="sa-card">
    <div class="sa-card-header">
        <h3 class="sa-card-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Rejected Reservations
            <span class="sa-badge sa-badge-rejected">{{ rejected|length }}</span>
        </h3>
    </div>

    {% if rejected|length > 0 %}
        <div class="sa-reservation-list">
            {% for reservation in rejected %}
                <div class="sa-reservation-row row-rejected">
                    <div class="sa-row-head">
                        <h4>{{ reservation.facility.name }}</h4>
                        <span class="sa-badge sa-badge-rejected">Rejected</span>
                    </div>
                    <div class="sa-detail-grid">
                        <div class="sa-detail-col">
                            <label>Requester</label>
                            <p>{{ reservation.name }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Email</label>
                            <p>{{ reservation.email }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Contact</label>
                            <p>{{ reservation.contact ?: '—' }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Date &amp; Time</label>
                            <p>{{ reservation.reservationDate|date('M d, Y') }} · {{ reservation.reservationStartTime|date('h:i A') }} – {{ reservation.reservationEndTime|date('h:i A') }}</p>
                        </div>
                        <div class="sa-detail-col">
                            <label>Attendees</label>
                            <p>{{ reservation.capacity }} / {{ reservation.facility.capacity }}</p>
                        </div>
                        {% if reservation.eventName %}
                            <div class="sa-detail-col">
                                <label>Event Name</label>
                                <p>{{ reservation.eventName }}</p>
                            </div>
                        {% endif %}
                        {% if reservation.purpose %}
                            <div class="sa-detail-col full-width">
                                <label>Event Objectives</label>
                                <p>{{ reservation.purpose }}</p>
                            </div>
                        {% endif %}
                        {% if reservation.rejectionReason %}
                            <div class="sa-detail-col full-width">
                                <label>Rejection Reason</label>
                                <p>{{ reservation.rejectionReason }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="sa-empty">No rejected reservations.</div>
    {% endif %}
</div>


{# ── Reject Modal ──────────────────────────────────────── #}
<div id="rejectModal" class="sa-modal-overlay" style="display:none;">
    <div class="sa-modal">
        <div class="sa-modal-header">
            <h3>Reject Reservation</h3>
            <button type="button" class="sa-modal-close" onclick="closeRejectModal()">×</button>
        </div>
        <div class="sa-modal-body">
            <label for="rejectionReason">Reason for rejection</label>
            <textarea id="rejectionReason" class="sa-form-input" rows="4" placeholder="Explain why this reservation is being rejected..."></textarea>
        </div>
        <div class="sa-modal-footer">
            <button type="button" class="sa-btn sa-btn-secondary" onclick="closeRejectModal()">Cancel</button>
            <button type="button" class="sa-btn sa-btn-reject" onclick="submitReject()">Confirm Reject</button>
        </div>
    </div>
</div>

<script>
    // Move reject modal to body to ensure it's not constrained by parent containers
    document.addEventListener('DOMContentLoaded', function() {
        const rejectModal = document.getElementById('rejectModal');
        if (rejectModal && rejectModal.parentElement !== document.body) {
            document.body.appendChild(rejectModal);
        }
    });

    let currentForm = null;

    function showRejectModal(button) {
        currentForm = button.closest('.reject-form');
        document.getElementById('rejectModal').style.display = 'flex';
        document.getElementById('rejectionReason').focus();
    }

    function closeRejectModal() {
        document.getElementById('rejectModal').style.display = 'none';
        document.getElementById('rejectionReason').value = '';
        currentForm = null;
    }

    function submitReject() {
        const reason = document.getElementById('rejectionReason').value.trim();
        if (!reason) {
            alert('Please provide a reason for rejection');
            return;
        }
        if (currentForm) {
            currentForm.querySelector('.reject-reason').value = reason;
            currentForm.submit();
        }
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeRejectModal();
    });
</script>
{% endblock %}
