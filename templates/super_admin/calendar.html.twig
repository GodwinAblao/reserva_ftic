        document.getElementById('modifyBlockType').value = modal.dataset.activeStatus || 'Blocked';
        document.getElementById('modifyBlockReason').value = modal.dataset.activeTitle || '';
        document.getElementById('modifyNotes').value = modal.dataset.activePurpose || '';

        // Hide action type dropdown for blocks and set to block
        document.getElementById('actionTypeContainer').style.display = 'none';
        document.getElementById('modifyActionType').value = 'block';

        // Enable facility select for block editing (blocks can change facilities)
        const facilitySelect = document.getElementById('modifyFacilitySelect');
        facilitySelect.disabled = false;
        facilitySelect.classList.remove('disabled-field');
        // Remove readonly styling from inputs
        document.getElementById('modifyCourseCodeInput').classList.remove('readonly-field');
        document.getElementById('modifySectionInput').classList.remove('readonly-field');
        document.getElementById('modifyFacultyNameInput').classList.remove('readonly-field');

        // Show block fields for block editing
        document.getElementById('modifyFields').style.display = 'none';
        document.getElementById('blockFields').style.display = 'grid';

        document.getElementById('modifySubmit').textContent = 'Update Block';
        document.getElementById('modifyCancelEdit').style.display = 'inline-block';
        document.getElementById('modifyMessage').style.display = 'none';
        
        closeModal();
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function revertBlockFromModal() {
        const modal = document.getElementById('eventModal');
        const classId = modal.dataset.activeClassId;

        if (!classId) {
            return;
        }

        // Show the revert confirmation modal
        const revertModal = document.getElementById('revertScheduleModal');
        revertModal.classList.add('is-open');
        
        // Store the class ID for the confirm action
        revertModal.dataset.classId = classId;
    }

    function deleteBlockFromModal() {
        const modal = document.getElementById('eventModal');
        const blockId = modal.dataset.activeBlock;

        if (!blockId) {
            return;
        }

        // Show the delete confirmation modal
        const deleteModal = document.getElementById('deleteBlockModal');
        deleteModal.classList.add('is-open');
        
        // Store the block ID for the confirm action
        deleteModal.dataset.blockId = blockId;
    }

    function closeDeleteBlockModal() {
        document.getElementById('deleteBlockModal').classList.remove('is-open');
    }

    async function confirmDeleteBlock() {
        const deleteModal = document.getElementById('deleteBlockModal');
        const blockId = deleteModal.dataset.blockId;

        if (!blockId) {
            closeDeleteBlockModal();
            return;
        }

        closeDeleteBlockModal();
        setCalendarStatus('Deleting schedule block...', 'loading', false);

        try {
            const response = await fetch(`/super-admin/calendar/block/${blockId}/delete`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Delete failed.');
            }

            closeModal();
            calendarEventsCache.clear();
            setCalendarStatus('Schedule block deleted.', 'success', false);
            // Non-blocking refresh
            renderCalendar(true);
        } catch (error) {
            setCalendarStatus('Could not delete schedule block.', 'error', false);
        }
    }

    async function notifyClassScheduleFaculty(data) {
        const classId = data.classId;
        if (!classId || !calendarConfig.notifyUrlPattern) {
            return;
        }

        const url = calendarConfig.notifyUrlPattern.replace('{id}', classId);
        const formData = new FormData();
        formData.append('_token', data.notifyCsrf || '');

        setCalendarStatus('Sending faculty notification...', 'loading', false);

        try {
            const response = await fetch(url, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const result = await response.json();
            if (!response.ok || !result.success) {
                throw new Error(result.message || 'Notification failed.');
            }
            closeModal();
            setCalendarStatus(result.message, 'success', true);
            showNotificationModal('Success', result.message, 'success');
        } catch (error) {
            setCalendarStatus(error.message || 'Notification failed.', 'error', false);
            showNotificationModal('Error', error.message || 'Notification failed.', 'error');
        }
    }

    function showNotificationModal(title, message, type) {
        const modal = document.getElementById('notificationModal');
        const icon = document.getElementById('notificationIcon');
        const titleEl = document.getElementById('notificationTitle');
        const messageEl = document.getElementById('notificationMessage');

        if (type === 'success') {
            icon.textContent = '✓';
            icon.style.color = '#0d9b00';
        } else {
            icon.textContent = '✕';
            icon.style.color = '#dc2626';
        }

        titleEl.textContent = title;
        messageEl.textContent = message;
        modal.classList.add('is-open');
    }

    function closeNotificationModal() {
        const modal = document.getElementById('notificationModal');
        modal.classList.remove('is-open');
    }

    async function saveReservationStatusFromModal(data) {
        const select = document.getElementById('modalStatusSelect');
        if (!select || !calendarConfig.statusUrlPattern) {
            return;
        }

        const newStatus = select.value;
        const url = calendarConfig.statusUrlPattern.replace('{id}', data.id);
        const formData = new FormData();
        formData.append('status', newStatus);
        formData.append('_token', data.statusCsrf || '');

        setCalendarStatus('Updating reservation status...', 'loading', false);

        try {
            const response = await fetch(url, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const result = await response.json();
            if (!response.ok || !result.success) {
                throw new Error(result.message || 'Status update failed.');
            }
            closeModal();
            calendarEventsCache.clear();
            setCalendarStatus(result.message || 'Status updated.', 'success', true);
            await renderCalendar(true);
        } catch (error) {
            setCalendarStatus(error.message || 'Status update failed.', 'error', false);
        }
    }

    function closeModal() {
        const modal = document.getElementById('eventModal');
        if (modal) {
            modal.classList.remove('is-open');
        }
    }

    function formatHour(hour) {
        return `${hour > 12 ? hour - 12 : hour}:00 ${hour >= 12 ? 'PM' : 'AM'}`;
    }

    function formatEventTime(timeStr) {
        return new Date('2000-01-01 ' + timeStr).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
    }

    function escapeHtml(value) {
        return String(value).replace(/[&<>'"]/g, character => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#039;', '"': '&quot;' }[character]));
    }
</script>
{% endblock %}
