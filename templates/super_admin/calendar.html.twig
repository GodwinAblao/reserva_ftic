<script>
    // Move modals to body to ensure they're not constrained by parent containers
    document.addEventListener('DOMContentLoaded', function() {
        const modals = ['eventModal', 'deleteScheduleModal', 'revertScheduleModal', 'deleteClassScheduleModal', 'deleteBlockModal'];
        modals.forEach(modalId => {
            const modal = document.getElementById(modalId);
            if (modal && modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
        });
    });
</script>

<script>
    const calendarAppEl = document.getElementById('calendarApp');
    const calendarConfig = {
        dataUrl: calendarAppEl.dataset.dataUrl,
        editUrlPattern: calendarAppEl.dataset.editUrlPattern,
        statusUrlPattern: calendarAppEl.dataset.statusUrlPattern || '',
        blockCreateUrl: calendarAppEl.dataset.blockCreateUrl || '',
        blockUpdatePattern: calendarAppEl.dataset.blockUpdatePattern || '',
        blockDeletePattern: calendarAppEl.dataset.blockDeletePattern || '',
        notifyUrlPattern: calendarAppEl.dataset.notifyUrlPattern || '',
        classScheduleUpdatePattern: calendarAppEl.dataset.classScheduleUpdatePattern || '',
        classScheduleDeletePattern: calendarAppEl.dataset.classScheduleDeletePattern || '',
        classScheduleAvailableUrl: calendarAppEl.dataset.classScheduleAvailableUrl || '',
        fullMode: calendarAppEl.dataset.fullMode === '1',
        canImport: calendarAppEl.dataset.canImport === '1',
    };
    let facilityAllocationTimer = null;

    const today = new Date();
    const initialCalendarDate = '{{ initialDate|default('')|e('js') }}';
    let currentDate = initialCalendarDate
        ? parseDateOnly(initialCalendarDate)
        : new Date(today.getFullYear(), today.getMonth(), today.getDate());
    let viewMode = 'week';
    let selectedFacility = '';
    let selectedStatus = '';
    let calendarRequestId = 0;
    let calendarAbortController = null;
    let calendarStatusHideTimer = null;
    const calendarEventsCache = new Map();
    const calendarStartHour = 7;
    const calendarEndHour = 20;
    const calendarHourHeight = 60;

    function destroyPreviousCalendarInstance() {
        const prev = window.__calendarInstance;
        if (!prev) return;
        clearInterval(prev.timer);
        if (prev.abortCtrl) prev.abortCtrl.abort();
        prev.listeners.forEach(({ el, type, fn }) => el.removeEventListener(type, fn));
        window.__calendarInstance = null;
    }

    function on(el, type, fn, store) {
        if (!el) return;
        el.addEventListener(type, fn);
        store.push({ el, type, fn });
    }

    function initializeFormRestrictions() {
        // Set date restrictions - no past dates, no Sundays
        const dateInput = document.getElementById('manualScheduleDate');
        if (dateInput) {
            const today = new Date();
            const minDate = today.toISOString().split('T')[0];
            
            dateInput.min = minDate;
            
            // Prevent Sunday selection - silently clear value
            dateInput.addEventListener('change', function() {
                const selectedDate = new Date(this.value);
                if (selectedDate.getDay() === 0) { // Sunday
                    this.value = '';
                }
            });
        }

        // Add same restrictions to modify schedule date input
        const modifyDateInput = document.getElementById('modifyScheduleDate');
        if (modifyDateInput) {
            const today = new Date();
            const minDate = today.toISOString().split('T')[0];
            
            modifyDateInput.min = minDate;
            
            // Prevent Sunday selection - silently clear value
            modifyDateInput.addEventListener('change', function() {
                const selectedDate = new Date(this.value);
                if (selectedDate.getDay() === 0) { // Sunday
                    this.value = '';
                }
            });
        }

        // Enhance time inputs with AM/PM display and validation
        const startTimeInput = document.getElementById('modifyStartTime');
        const endTimeInput = document.getElementById('modifyEndTime');
        
        function formatTimeToAMPM(time24) {
            const [hours, minutes] = time24.split(':');
            const hour = parseInt(hours);
            const ampm = hour >= 12 ? 'PM' : 'AM';
            const displayHour = hour % 12 || 12;
            return `${displayHour}:${minutes} ${ampm}`;
        }
        
        function validateTimeRange() {
            if (startTimeInput.value && endTimeInput.value) {
                const start = startTimeInput.value;
                const end = endTimeInput.value;
                
                // Check if end time is after start time
                if (end <= start) {
                    alert('End time must be after start time.');
                    endTimeInput.value = '';
                    return false;
                }
                
                // Check if times are within 7AM-7PM
                const startHour = parseInt(start.split(':')[0]);
                const endHour = parseInt(end.split(':')[0]);
                
                if (startHour < 7 || startHour > 19 || endHour < 7 || endHour > 19) {
                    alert('Time must be between 7:00 AM and 7:00 PM.');
                    return false;
                }
            }
            return true;
        }
        
        // Implement dynamic smart blocking for dropdown time selection
        function updateEndTimeOptions() {
            const startTime = startTimeInput.value;
            const endTimeSelect = endTimeInput;
            
            if (!startTime) {
                // Reset end time options if no start time selected
                resetEndTimeOptions();
                return;
            }
            
            const [startHour, startMinute] = startTime.split(':').map(Number);
            const startTotalMinutes = startHour * 60 + startMinute;
            
            // Add smooth transition effect
            endTimeSelect.style.transition = 'opacity 0.3s ease';
            endTimeSelect.style.opacity = '0.5';
            
            setTimeout(() => {
                // Clear current end time options
                endTimeSelect.innerHTML = '<option value="">Select End Time</option>';
                
                // Generate valid end time options (must be after start time and <= 7:00 PM)
                for (let hour = 7; hour <= 19; hour++) {
                    for (let minute of [0, 50]) {
                        // Skip 7:50 PM as it's beyond 7:00 PM
                        if (hour === 19 && minute > 0) continue;
                        
                        const endTotalMinutes = hour * 60 + minute;
                        
                        // End time must be after start time
                        if (endTotalMinutes > startTotalMinutes) {
                            const timeValue = `${hour.toString().padStart(2, '0')}:${minute.toString().padStart(2, '0')}`;
                            const displayTime = hour === 12 ? `12:${minute.toString().padStart(2, '0')} PM` : 
                                              (hour > 12 ? `${hour-12}:${minute.toString().padStart(2, '0')} PM` : 
                                               `${hour}:${minute.toString().padStart(2, '0')} AM`);
                            
                            const option = document.createElement('option');
                            option.value = timeValue;
                            option.textContent = displayTime;
                            endTimeSelect.appendChild(option);
                        }
                    }
                }
                
                // If current end time is no longer valid, clear it
                if (endTimeSelect.value && startTime >= endTimeSelect.value) {
                    endTimeSelect.value = '';
                    // Add visual feedback
                    endTimeSelect.style.borderColor = '#f59e0b';
                    setTimeout(() => {
                        endTimeSelect.style.borderColor = '';
                    }, 1000);
                }
                
                // Restore opacity with smooth transition
                endTimeSelect.style.opacity = '1';
                
                // Add success indicator
                endTimeSelect.style.boxShadow = '0 0 0 3px rgba(16, 185, 129, 0.2)';
                setTimeout(() => {
                    endTimeSelect.style.boxShadow = '';
                }, 800);
            }, 150);
        }
        
        function resetEndTimeOptions() {
            const endTimeSelect = endTimeInput;
            endTimeSelect.innerHTML = '<option value="">Select End Time</option>';
            
            // Add all valid end time options (7:00, 7:50, 8:00, 8:50 pattern)
            for (let hour = 7; hour <= 19; hour++) {
                for (let minute of [0, 50]) {
                    // Skip 7:50 PM as it's beyond 7:00 PM
                    if (hour === 19 && minute > 0) continue;
                    
                    const timeValue = `${hour.toString().padStart(2, '0')}:${minute.toString().padStart(2, '0')}`;
                    const displayTime = hour === 12 ? `12:${minute.toString().padStart(2, '0')} PM` : 
                                      (hour > 12 ? `${hour-12}:${minute.toString().padStart(2, '0')} PM` : 
                                       `${hour}:${minute.toString().padStart(2, '0')} AM`);
                    
                    const option = document.createElement('option');
                    option.value = timeValue;
                    option.textContent = displayTime;
                    endTimeSelect.appendChild(option);
                }
            }
        }
        
        // Add event listeners for dynamic time blocking
        startTimeInput.addEventListener('change', function() {
            if (this.value) {
                updateEndTimeOptions();
                
                // Refresh facility allocation if in class mode
                if (document.getElementById('manualEditMode').value === 'class' && calendarConfig.classScheduleAvailableUrl) {
                    refreshFacilityAllocation();
                }
            } else {
                resetEndTimeOptions();
            }
        });
        
        // Initialize end time options
        resetEndTimeOptions();

        // Make facility allocation non-clickable when dropdown exists
        const facilityAllocationList = document.getElementById('facilityAllocationList');
        if (facilityAllocationList) {
            facilityAllocationList.addEventListener('click', function(e) {
                if (e.target.classList.contains('facility-chip')) {
                    e.preventDefault();
                    e.stopPropagation();
                    // Don't allow clicking - user must use dropdown
                }
            });
        }
    }

    function initializeModalImprovements() {
        // Create improved modal overlay
        const modalOverlay = document.createElement('div');
        modalOverlay.id = 'improvedModalOverlay';
        modalOverlay.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
            z-index: 9998;
            display: none;
            align-items: center;
            justify-content: center;
        `;
        document.body.appendChild(modalOverlay);

        // Override modal opening functions
        const originalOpenModal = window.openModal;
        window.openModal = function(event) {
            if (event) {
                renderEventModal(event);
            }
            modalOverlay.style.display = 'flex';
        };

        // Override modal closing functions
        const originalCloseModal = window.closeModal;
        window.closeModal = function() {
            modalOverlay.style.display = 'none';
            if (originalCloseModal) originalCloseModal();
        };

        // Close modal when clicking overlay
        modalOverlay.addEventListener('click', function(e) {
            if (e.target === modalOverlay) {
                window.closeModal();
            }
        });
    }

    function bootCalendar() {
        if (!document.getElementById('calendarView')) return;

        destroyPreviousCalendarInstance();

        calendarEventsCache.clear();
        calendarRequestId = 0;
        selectedFacility = document.getElementById('facilityFilter')?.value || '';
        selectedStatus   = document.getElementById('statusFilter')?.value  || '';
        viewMode         = document.getElementById('viewMode')?.value       || 'week';

        const inst = { timer: null, abortCtrl: null, listeners: [] };
        window.__calendarInstance = inst;

        const L = inst.listeners;

        on(document.getElementById('prevDate'),   'click',  () => navigateDate(-1), L);
        on(document.getElementById('nextDate'),   'click',  () => navigateDate(1),  L);
        on(document.getElementById('todayBtn'),   'click',  () => { currentDate = new Date(); calendarEventsCache.clear(); renderCalendar(true); }, L);
        on(document.getElementById('viewMode'),   'change', (e) => { viewMode = e.target.value; calendarEventsCache.clear(); renderCalendar(true); }, L);
        on(document.getElementById('facilityFilter'), 'change', (e) => { selectedFacility = e.target.value; calendarEventsCache.clear(); renderCalendar(true); }, L);
        on(document.getElementById('statusFilter'),   'change', (e) => { selectedStatus   = e.target.value; calendarEventsCache.clear(); renderCalendar(true); }, L);
        on(document.querySelector('.modal-close'), 'click', closeModal, L);
        on(document.getElementById('calendarRetryBtn'), 'click', () => renderCalendar(true), L);

        const winClickFn = (e) => {
            if (e.target.id === 'eventModal') closeModal();
            if (e.target.id === 'deleteScheduleModal') closeDeleteScheduleModal();
            if (e.target.id === 'revertScheduleModal') closeRevertScheduleModal();
            if (e.target.id === 'deleteClassScheduleModal') closeDeleteClassScheduleModal();
            if (e.target.id === 'deleteBlockModal') closeDeleteBlockModal();
        };
        on(window, 'click', winClickFn, L);

        // Removed window.focus auto-refresh (too aggressive; visibilitychange is sufficient)

        // Throttled visibility handler: refresh at most once per 30 s when tab becomes visible
        let _lastVisRefresh = 0;
        const visFn = () => {
            if (!document.hidden) {
                const now = Date.now();
                if (now - _lastVisRefresh > 30000) {
                    _lastVisRefresh = now;
                    renderCalendar(true);
                }
            }
        };
        on(document, 'visibilitychange', visFn, L);

        if (calendarConfig.canImport) {
            on(document.getElementById('scheduleImportForm'),    'submit', importScheduleInBackground,      L);
            on(document.getElementById('scheduleDeleteSubmit'),  'click',  openDeleteScheduleModal,         L);
        }
        // Delete class schedule, delete imported schedule, delete block, and revert buttons should work in both canImport and fullMode
        on(document.getElementById('cancelDeleteClassSchedule'),  'click',  closeDeleteClassScheduleModal,        L);
        on(document.getElementById('confirmDeleteClassSchedule'), 'click',  confirmDeleteClassSchedule,            L);
        on(document.getElementById('cancelDeleteBlock'),  'click',  closeDeleteBlockModal,        L);
        on(document.getElementById('confirmDeleteBlock'), 'click',  confirmDeleteBlock,            L);
        on(document.getElementById('cancelDeleteSchedule'),  'click',  closeDeleteScheduleModal,        L);
        on(document.getElementById('confirmDeleteSchedule'), 'click',  deleteImportedScheduleInBackground, L);
        on(document.getElementById('cancelRevertSchedule'),  'click',  closeRevertScheduleModal,        L);
        on(document.getElementById('confirmRevertSchedule'), 'click',  confirmRevertSchedule,            L);
        if (calendarConfig.fullMode) {
            on(document.getElementById('modifyScheduleForm'),       'submit', saveModifyScheduleInBackground, L);
            on(document.getElementById('modifyCancelEdit'), 'click',  resetModifyScheduleForm,        L);
            on(document.getElementById('modifyActionType'), 'change', handleModifyActionTypeChange, L);
            // Initialize form in block-only mode on page load
            resetModifyScheduleForm();
        }

        // Remove references to deleted manualBlockForm to prevent errors
        // The manual block form has been replaced by modifyScheduleForm

        // Initialize date restrictions and modal improvements
        initializeFormRestrictions();
        initializeModalImprovements();

        inst.timer = setInterval(() => {
            if (!document.hidden) renderCalendar(true);
        }, 300000);  // 5 min — calendar data rarely changes; user actions trigger immediate refresh

        renderCalendar();
    }

    // Boot the calendar once per page visit, regardless of Turbo or hard-load.
    // _calendarBootedAt guards against double-boot when both turbo:load and the
    // immediate call below fire within the same visit (< 300 ms apart).
    let _calendarBootedAt = 0;
    function guardedBoot() {
        const now = Date.now();
        if (now - _calendarBootedAt < 300) return;
        _calendarBootedAt = now;
        bootCalendar();
    }

    document.addEventListener('turbo:load', guardedBoot);
    document.addEventListener('turbo:before-visit', () => {
        const inst = window.__calendarInstance;
        if (inst) { clearInterval(inst.timer); if (inst.abortCtrl) inst.abortCtrl.abort(); }
    });

    // Immediate boot for hard loads (and non-Turbo environments).
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', guardedBoot);
    } else {
        guardedBoot();
    }

    function broadcastScheduleRevision(revision) {
        if (!revision) {
            return;
        }
        try {
            localStorage.setItem('classScheduleRevision', revision);
            window.dispatchEvent(new CustomEvent('classScheduleUpdated', { detail: { revision } }));
        } catch (error) {
            // ignore private browsing restrictions
        }
    }

    async function importScheduleInBackground(event) {
        event.preventDefault();

        const form = event.currentTarget;
        const submitButton = document.getElementById('scheduleImportSubmit');
        const messageBox = document.getElementById('scheduleImportMessage');
        const originalText = submitButton.textContent;

        submitButton.disabled = true;
        submitButton.textContent = 'Importing and syncing...';
        showImportMessage('Uploading schedule and rebuilding calendar blocks...', 'success');
        setCalendarStatus('Importing schedule. Calendar will refresh automatically...', 'loading', false);

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const data = await response.json();

            console.log('Import Response:', data);
            console.log('Response status:', response.status);
            console.log('Success:', data.success);
            console.log('Errors:', data.errors);
            console.log('Detailed Errors:', data.debug?.detailed_errors);
            
            // Show errors in console for debugging
            if (data.errors && data.errors.length > 0) {
                console.log('=== IMPORT ERRORS ===');
                data.errors.forEach((error, index) => {
                    console.log(`Error ${index + 1}: ${error}`);
                });
                console.log('===================');
            }

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Schedule import failed.');
            }

            if (data.date) {
                currentDate = parseDateOnly(data.date);
                window.history.replaceState(null, '', `${window.location.pathname}?date=${data.date}`);
            }

            calendarEventsCache.clear();
            broadcastScheduleRevision(data.scheduleRevision);
            showImportMessage(data.message, 'success');
            setCalendarStatus('Schedule imported. Refreshing calendar...', 'loading', false);
            
            // Force refresh with a small delay to ensure database is updated
            await new Promise(resolve => setTimeout(resolve, 500));
            await renderCalendar(true);

            if (Array.isArray(data.warnings) && data.warnings.length > 0) {
                showImportMessage(`${data.message} ${data.warnings.slice(0, 3).join(' ')}`, 'success');
            }
        } catch (error) {
            console.error('Import error:', error);
            console.error('Error status:', error.status);
            
            let errorMessage = error.message || 'Schedule import failed.';
            
            // Try to get detailed error information from the response
            if (error.response) {
                try {
                    const errorText = await error.response.text();
                    console.error('Error response text:', errorText);
                    
                    const errorData = JSON.parse(errorText);
                    console.error('Parsed error data:', errorData);
                    
                    if (errorData.errors && errorData.errors.length > 0) {
                        errorMessage = 'Import failed:\n' + errorData.errors.join('\n');
                    } else if (errorData.message) {
                        errorMessage = errorData.message;
                    }
                } catch (e) {
                    console.error('Failed to parse error response:', e);
                    // If parsing fails, try to show the raw response
                    try {
                        const errorText = await error.response.text();
                        if (errorText) {
                            errorMessage = 'Import failed: ' + errorText.substring(0, 500);
                        }
                    } catch (e2) {
                        // If all else fails, use the original error message
                    }
                }
            }
            
            showImportMessage(errorMessage, 'error');
            setCalendarStatus('Schedule import failed. Fix the CSV and try again.', 'error', false);
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = originalText;
        }

        function showImportMessage(message, type) {
            // Format multi-line messages with better styling
            if (message.includes('\n')) {
                messageBox.innerHTML = message.replace(/\n/g, '<br>');
            } else {
                messageBox.textContent = message;
            }
            messageBox.className = 'schedule-import-message ' + type;
            messageBox.style.display = 'block';
        }
    }

