    async function saveModifyScheduleInBackground(e) {
        e.preventDefault();
        const form = document.getElementById('modifyScheduleForm');
        const submitBtn = document.getElementById('modifySubmit');
        const messageBox = document.getElementById('modifyMessage');
        
        submitBtn.disabled = true;
        submitBtn.textContent = 'Processing...';
        
        try {
            const formData = new FormData(form);
            // If selects are disabled, they won't be included in FormData — add them manually
            const facilitySelect = document.getElementById('modifyFacilitySelect');
            if (facilitySelect && facilitySelect.disabled && facilitySelect.value) {
                formData.set('facility', facilitySelect.value);
            }
            const startTimeSelect = document.getElementById('modifyStartTime');
            if (startTimeSelect && startTimeSelect.disabled && startTimeSelect.value) {
                formData.set('start_time', startTimeSelect.value);
            }
            const endTimeSelect = document.getElementById('modifyEndTime');
            if (endTimeSelect && endTimeSelect.disabled && endTimeSelect.value) {
                formData.set('end_time', endTimeSelect.value);
            }
            const actionType = formData.get('action_type');
            const classScheduleId = formData.get('class_schedule_id');
            const editMode = formData.get('edit_mode');
            
            console.log('=== Form Submission Debug ===');
            console.log('Action type:', actionType);
            console.log('Edit mode:', editMode);
            console.log('Class schedule ID:', classScheduleId);
            console.log('Form data:');
            for (let [key, value] of formData.entries()) {
                console.log(`  ${key}: ${value}`);
            }
            
            // Determine the correct endpoint based on action type and edit mode
            let actionUrl;
            const blockId = document.getElementById('modifyBlockId').value;
            if (editMode === 'class' && classScheduleId) {
                // For class schedule modification, use the class schedule update endpoint
                if (actionType === 'block') {
                    actionUrl = `/super-admin/class-schedule/${classScheduleId}/block`;
                } else {
                    actionUrl = `/super-admin/class-schedule/${classScheduleId}/update`;
                }
            } else if (editMode === 'block' && blockId) {
                // For block editing, use the update endpoint with numeric block ID
                const numericBlockId = blockId.toString().replace('block_', '');
                actionUrl = `/super-admin/calendar/block/${numericBlockId}/update`;
            } else {
                // For manual blocks, use the block endpoint
                actionUrl = form.action;
            }
            
            console.log('Using action URL:', actionUrl);
            
            const response = await fetch(actionUrl, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            
            console.log('Response status:', response.status);
            
            let result;
            try {
                result = await response.json();
                console.log('Response data:', result);
            } catch (jsonError) {
                console.error('Failed to parse JSON response:', jsonError);
                const textResponse = await response.text();
                console.error('Response text:', textResponse);
                throw new Error(`Server returned non-JSON response: ${response.status} ${response.statusText}`);
            }
            
            if (result.success) {
                messageBox.textContent = result.message || 'Schedule updated successfully';
                messageBox.className = 'schedule-import-message success';
                messageBox.style.display = 'block';
                resetModifyScheduleForm(false);
                calendarEventsCache.clear();
                // Navigate to the block/schedule date so user can see it
                const savedDate = result.block?.reservationDate || result.schedule?.reservationDate;
                if (savedDate) { currentDate = parseDateOnly(savedDate); }
                await renderCalendar(true);
            } else {
                const errorMsg = result.message || 'Failed to update schedule';
                console.error('Server error:', errorMsg);
                messageBox.textContent = `Error: ${errorMsg}`;
                messageBox.className = 'schedule-import-message error';
                messageBox.style.display = 'block';
            }
        } catch (error) {
            console.error('=== Form Submission Error ===');
            console.error('Error type:', error.name);
            console.error('Error message:', error.message);
            console.error('Error stack:', error.stack);
            
            const errorMsg = error.message || 'Unknown error occurred';
            messageBox.textContent = `Error: ${errorMsg} (Check browser console for details)`;
            messageBox.className = 'schedule-import-message error';
            messageBox.style.display = 'block';
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit';
        }
    }

