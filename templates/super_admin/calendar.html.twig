    async function refreshFacilityAllocation() {
        console.log('refreshFacilityAllocation called');
        console.log('calendarConfig:', calendarConfig);
        
        if (!calendarConfig.classScheduleAvailableUrl) {
            console.log('No classScheduleAvailableUrl in config');
            return;
        }

        const date = document.getElementById('modifyScheduleDate').value;
        const start = document.getElementById('modifyStartTime').value;
        const end = document.getElementById('modifyEndTime').value;
        const excludeId = document.getElementById('modifyClassScheduleId').value;
        const listEl = document.getElementById('facilityAllocationList');
        const facilitySelect = document.getElementById('modifyFacilitySelect');

        console.log('refreshFacilityAllocation params:', { date, start, end, excludeId });

        if (!date || !start || !end || end <= start) {
            listEl.innerHTML = '<span style="color:#9ca3af;font-size:0.85rem;">Set date and time to see available facilities.</span>';
            return;
        }

        listEl.innerHTML = '<span style="color:#6b7280;font-size:0.85rem;">Checking availability...</span>';

        try {
            const params = new URLSearchParams({ date, start, end, exclude_id: excludeId || '' });
            const url = `${calendarConfig.classScheduleAvailableUrl}?${params.toString()}`;
            console.log('Fetching facilities from:', url);
            
            const response = await fetch(url, {
                headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            });
            
            console.log('Facility response status:', response.status);
            
            const data = await response.json();
            console.log('Facility data:', data);
            const availableIds = new Set((data.facilities || []).map((f) => String(f.id)));
            const selectedId = facilitySelect.value;

            Array.from(facilitySelect.options).forEach((opt) => {
                if (!opt.value) {
                    return;
                }
                const available = availableIds.has(opt.value);
                opt.disabled = !available;
                opt.className = available ? 'facility-available' : 'facility-unavailable';
            });

            if (!availableIds.size) {
                listEl.innerHTML = '<span style="color:#b91c1c;font-size:0.85rem;">No facilities are free for this slot.</span>';
                return;
            }

            listEl.innerHTML = '';
            Array.from(facilitySelect.options).forEach((opt) => {
                if (!opt.value) {
                    return;
                }
                const chip = document.createElement('button');
                chip.type = 'button';
                const available = availableIds.has(opt.value);
                chip.className = 'facility-chip ' + (available ? 'available' : 'unavailable') + (opt.value === selectedId ? ' selected' : '');
                chip.textContent = opt.textContent;
                chip.disabled = !available;
                if (available) {
                    chip.onclick = () => {
                        facilitySelect.value = opt.value;
                        refreshFacilityAllocation();
                    };
                }
                listEl.appendChild(chip);
            });
        } catch (error) {
            listEl.innerHTML = '<span style="color:#b91c1c;font-size:0.85rem;">Could not load facility availability.</span>';
        }
    }

