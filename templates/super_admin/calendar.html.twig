    async function deleteClassScheduleFromModal() {
        const modal = document.getElementById('eventModal');
        const classId = modal.dataset.activeClassId;

        if (!classId) {
            return;
        }

        if (!calendarConfig.classScheduleDeletePattern) {
            return;
        }

        // Show the delete confirmation modal
        const deleteModal = document.getElementById('deleteClassScheduleModal');
        deleteModal.classList.add('is-open');
        
        // Store the class ID for the confirm action
        deleteModal.dataset.classId = classId;
    }

    async function confirmDeleteClassSchedule() {
        const deleteModal = document.getElementById('deleteClassScheduleModal');
        const classId = deleteModal.dataset.classId;

        if (!classId) {
            closeDeleteClassScheduleModal();
            return;
        }

        closeDeleteClassScheduleModal();
        setCalendarStatus('Deleting class schedule...', 'loading', false);

        try {
            const response = await fetch(`/super-admin/class-schedule/${classId}/delete`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Delete failed.');
            }

            closeModal();
            calendarEventsCache.clear();
            if (data.scheduleRevision) {
                broadcastScheduleRevision(data.scheduleRevision);
            }
            setCalendarStatus('Class schedule deleted.', 'success', false);
            // Non-blocking refresh
            renderCalendar(true);
        } catch (error) {
            setCalendarStatus('Could not delete class schedule.', 'error', false);
        }
    }

    function closeDeleteClassScheduleModal() {
        document.getElementById('deleteClassScheduleModal').classList.remove('is-open');
    }

