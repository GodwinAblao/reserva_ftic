{% extends "layouts/app.html.twig" %}

{% block title %}Calendar View - Reserva FTIC{% endblock %}

{% block content %}
<div class="sa-page-header">
    <div class="sa-page-header-left">
        <h2>Reservation Calendar</h2>
        <p>View and manage all facility reservations on the calendar</p>
    </div>
    <div class="sa-header-actions">
        <a href="{{ path('admin_reservations') }}" class="sa-btn sa-btn-secondary">← List View</a>
    </div>
</div>

    <!-- Filters -->
    <div class="sa-filter-panel">
        <div class="sa-filter-grid">
            <div class="sa-filter-group">
                <label for="facilityFilter">Facility</label>
                <select id="facilityFilter">
                    <option value="">All Facilities</option>
                    {% for facility in facilities %}
                        <option value="{{ facility.id }}">{{ facility.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="sa-filter-group">
                <label for="statusFilter">Status</label>
                <select id="statusFilter">
                    <option value="">All Statuses</option>
                    <option value="Pending">Pending</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected">Rejected</option>
                    <option value="Class Schedule">Class Schedule</option>
                    <option value="Blocked">Blocked</option>
                    <option value="Manual">Manual</option>
                    <option value="Maintenance">Maintenance</option>
                    <option value="Imported">Imported</option>
                </select>
            </div>

            <div class="sa-filter-group">
                <label for="viewMode">View</label>
                <select id="viewMode">
                    <option value="week">Week View</option>
                    <option value="day">Day View</option>
                </select>
            </div>

            <div class="sa-filter-group">
                <label>&nbsp;</label>
                <div class="sa-filter-nav">
                    <button type="button" id="prevDate" class="sa-btn sa-btn-secondary" style="padding:9px 14px;">← Prev</button>
                    <button type="button" id="todayBtn" class="sa-btn sa-btn-primary" style="padding:9px 14px;">Today</button>
                    <button type="button" id="nextDate" class="sa-btn sa-btn-secondary" style="padding:9px 14px;">Next →</button>
                </div>
            </div>
        </div>

        <div class="sa-date-display">
            <h3 id="currentDateDisplay"></h3>
        </div>
    </div>


    <div class="sa-import-grid">
        <form id="scheduleImportForm" action="{{ path('admin_calendar_import') }}" method="POST" enctype="multipart/form-data" class="sa-import-card">
            <h3>Import Class Schedule</h3>
            <p>Format: facility,day,start,end,title,type. Day: Monday–Sunday. Time: HH:MM.</p>

            <div class="sa-import-field">
                <label>Upload CSV</label>
                <input type="file" name="schedule_file" accept=".csv,text/csv">
            </div>

            <div class="sa-import-field">
                <label>Or Paste Schedule Data</label>
                <textarea name="schedule_paste" placeholder="facility,day,start,end,title,type" style="height:80px; font-family:monospace;"></textarea>
            </div>

            <p class="sa-warning-text">Importing replaces the previous Class Schedule blocks automatically.</p>

            <button type="button" id="scheduleDeleteSubmit" data-delete-url="{{ path('admin_calendar_import_delete') }}" data-token="{{ csrf_token('delete_imported_schedule') }}" class="sa-btn sa-btn-danger-soft">Delete Imported Schedule</button>
            <button type="submit" id="scheduleImportSubmit" class="sa-btn sa-btn-primary" style="width:100%; justify-content:center;">Import &amp; Sync Schedule</button>
            <div id="scheduleImportMessage" class="schedule-import-message" style="display:none;"></div>
            <div id="scheduleDeleteMessage" class="schedule-import-message" style="display:none;"></div>
        </form>

        <form id="manualBlockForm" action="{{ path('admin_calendar_block') }}" method="POST" data-create-url="{{ path('admin_calendar_block') }}" data-delete-token="{{ csrf_token('manual_schedule_block_delete') }}" class="sa-import-card">
            <h3>Manual Schedule Block</h3>
            <input type="hidden" name="_token" value="{{ csrf_token('manual_schedule_block') }}">
            <input type="hidden" id="manualBlockId" name="block_id" value="">
            <div class="sa-import-mini-grid">
                <select name="facility" required class="sa-import-field"><option value="">Select Facility</option>{% for facility in facilities %}<option value="{{ facility.id }}">{{ facility.name }}</option>{% endfor %}</select>
                <input type="date" name="date" required class="sa-import-field">
                <input type="time" name="start_time" required class="sa-import-field">
                <input type="time" name="end_time" required class="sa-import-field">
                <input type="text" name="title" placeholder="Title" class="sa-import-field">
                <select name="type" class="sa-import-field">
                    <option value="Manual">Manual</option>
                    <option value="Blocked">Blocked</option>
                    <option value="Maintenance">Maintenance</option>
                    <option value="Class Schedule">Class Schedule</option>
                </select>
            </div>
            <div class="sa-import-field" style="margin-top:10px;">
                <textarea name="notes" placeholder="Notes" style="height:60px;"></textarea>
            </div>
            <div style="display:flex; gap:8px; align-items:center; margin-top:10px;">
                <button type="submit" id="manualBlockSubmit" class="sa-btn sa-btn-primary">Add Block</button>
                <button type="button" id="manualBlockCancelEdit" class="sa-btn sa-btn-secondary" style="display:none;">Cancel Edit</button>
            </div>
            <div id="manualBlockMessage" class="schedule-import-message" style="display:none;"></div>
        </form>
    </div>
    <!-- Calendar Grid -->
    <div class="sa-card" style="padding:0; overflow:auto;">
        <div id="calendarStatus" class="calendar-status calendar-status-loading">
            <span class="calendar-spinner"></span>
            <span id="calendarStatusText">Loading calendar schedules...</span>
            <button type="button" id="calendarRetryBtn" class="calendar-retry-btn" style="display:none;">Retry</button>
        </div>
        <div id="calendarView" style="display: block !important; min-height: 600px !important; visibility: visible !important; opacity: 1 !important;">
            <!-- Grid renders immediately via inline script below -->
        </div>
    </div>

    <script>
        // Render calendar grid immediately without waiting for full script load
        (function() {
            const today = new Date();
            const day = today.getDay();
            const startDate = new Date(today);
            startDate.setDate(today.getDate() - day + (day === 0 ? -6 : 1));
            const calendarStartHour = 7;
            const calendarEndHour = 20;
            const calendarHourHeight = 60;

            function formatTime(h, m) {
                const period = h >= 12 ? 'PM' : 'AM';
                const displayHour = h > 12 ? h - 12 : h;
                return displayHour + ':' + m + ' ' + period;
            }

            function generateTimeSlots() {
                const slots = [];
                for (let hour = calendarStartHour; hour < calendarEndHour; hour++) {
                    slots.push({ time: String(hour).padStart(2, '0') + ':00', label: formatTime(hour, '00') });
                }
                return slots;
            }

            const days = ['MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT', 'SUN'];
            const timeSlots = generateTimeSlots();

            let html = '<div class="week-view">';
            html += '<div class="time-column"><div class="day-header" style="background: transparent; color: #6b7280;">Time</div>';
            timeSlots.forEach(slot => {
                html += '<div class="time-slot" style="height:' + calendarHourHeight + 'px;">' + slot.label + '</div>';
            });
            html += '</div>';

            for (let i = 0; i < 7; i++) {
                const dayDate = new Date(startDate);
                dayDate.setDate(startDate.getDate() + i);
                html += '<div class="day-column">';
                html += '<div class="day-header"><div class="day-name">' + days[i] + '</div><div class="day-date">' + dayDate.getDate() + '</div></div>';
                html += '<div class="day-body">';
                timeSlots.forEach(() => {
                    html += '<div class="time-slot" style="height:' + calendarHourHeight + 'px;"></div>';
                });
                html += '</div></div>';
            }
            html += '</div>';

            document.getElementById('calendarView').innerHTML = html;
        })();
    </script>

    <!-- Event Details Modal -->
    <div id="eventModal" class="modal">
        <div class="modal-content" style="border-radius:16px;">
            <span class="modal-close">&times;</span>
            <h3 id="modalTitle" style="color:#0d4702; margin-bottom:1.25rem;">Reservation Details</h3>
            <div id="modalBody" class="modal-body">
                <!-- Populated by JavaScript -->
            </div>
            <div id="modalActions" class="modal-actions">
                <!-- Buttons populated by JavaScript -->
            </div>
        </div>
    </div>

    <div id="deleteScheduleModal" class="delete-schedule-modal">
        <div class="delete-schedule-dialog">
            <div class="delete-schedule-icon">!</div>
            <h3>Delete Imported Schedule?</h3>
            <p>This will permanently delete the whole imported class schedule from the calendar. Reservations and manual blocks will not be deleted.</p>
            <div class="delete-schedule-actions">
                <button type="button" id="cancelDeleteSchedule" class="delete-schedule-cancel">Cancel</button>
                <button type="button" id="confirmDeleteSchedule" class="delete-schedule-confirm">Yes, Delete Schedule</button>
            </div>
        </div>
    </div>

<style>
    /* ── Calendar-specific styles (grid, events, modal, status) ── */
    .calendar-status { display:flex; align-items:center; justify-content:center; gap:10px; padding:12px 16px; font-size:0.9rem; font-weight:700; border-bottom:1px solid #e8ede6; }
    .calendar-status-loading { color:#065f46; background:#ecfdf5; }
    .calendar-status-success { color:#166534; background:#dcfce7; }
    .calendar-status-error   { color:#991b1b; background:#fef2f2; }
    .calendar-spinner { width:16px; height:16px; border:2px solid rgba(6,95,70,.2); border-top-color:#047857; border-radius:999px; animation:calendar-spin .8s linear infinite; }
    .calendar-status-success .calendar-spinner, .calendar-status-error .calendar-spinner { display:none; }
    .calendar-retry-btn { border:1px solid #991b1b; background:white; color:#991b1b; border-radius:8px; padding:6px 12px; font-weight:700; cursor:pointer; }
    @keyframes calendar-spin { to { transform:rotate(360deg); } }

    .schedule-import-message { margin-top:12px; padding:10px 12px; border-radius:8px; font-size:.85rem; font-weight:700; }
    .schedule-import-message.success { color:#166534; background:#dcfce7; }
    .schedule-import-message.error   { color:#991b1b; background:#fee2e2; }

    /* Week/Day grid */
    .week-view { display:grid; grid-template-columns:80px repeat(7,1fr); min-width:1000px; }
    .time-column { border-right:1px solid #e8ede6; background:#f9fbf8; }
    .time-slot { height:60px; box-sizing:border-box; border-bottom:1px solid #e8ede6; padding:.5rem; font-size:.75rem; color:#6b7280; text-align:right; }
    .day-column { border-right:1px solid #e8ede6; position:relative; }
    .day-column:last-child { border-right:none; }
    .day-body { position:relative; }
    .day-header { padding:.875rem 1rem; background:linear-gradient(135deg,#006633 0%,#004d26 100%); color:white; text-align:center; font-weight:700; border-bottom:2px solid #004d26; }
    .day-header .day-name { font-size:.8rem; text-transform:uppercase; letter-spacing:.6px; }
    .day-header .day-date { font-size:1.4rem; margin-top:.2rem; }

    .event-block { position:absolute; left:2px; right:2px; border-radius:8px; padding:.4rem .5rem; cursor:pointer; transition:all .2s; overflow:hidden; box-shadow:0 2px 6px rgba(0,0,0,.1); border-left:4px solid; box-sizing:border-box; }
    .event-block:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(0,0,0,.15); z-index:10; }
    .event-block.pending   { background:#fff7ed; border-left-color:#f97316; color:#9a3412; }
    .event-block.approved  { background:#f0fdf4; border-left-color:#22c55e; color:#14532d; }
    .event-block.rejected  { background:#fef2f2; border-left-color:#ef4444; color:#7f1d1d; }
    .event-block.classschedule,.event-block.imported { background:#eff6ff; border-left-color:#3b82f6; color:#1e3a8a; }
    .event-block.blocked,.event-block.manual { background:#fef2f2; border-left-color:#dc2626; color:#7f1d1d; }
    .event-block.maintenance { background:#f5f3ff; border-left-color:#7c3aed; color:#4c1d95; }
    .event-title { font-weight:700; font-size:.8rem; margin-bottom:.2rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .event-requester,.event-time { font-size:.72rem; opacity:.9; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .event-time { margin-top:.2rem; font-weight:500; }
    .event-status { display:inline-block; padding:.1rem .45rem; border-radius:10px; font-size:.6rem; font-weight:700; margin-top:.2rem; text-transform:uppercase; }
    .event-status.pending   { background:#f97316; color:white; }
    .event-status.approved  { background:#22c55e; color:white; }
    .event-status.rejected  { background:#ef4444; color:white; }
    .event-status.manual,.event-status.blocked { background:#dc2626; color:white; }
    .event-status.classschedule,.event-status.imported { background:#3b82f6; color:white; }
    .event-status.maintenance { background:#7c3aed; color:white; }

    /* Day view */
    .day-view { display:grid; grid-template-columns:100px 1fr; max-width:1200px; margin:0 auto; border:1px solid #e8ede6; border-radius:10px; overflow:hidden; }
    .day-view .time-column { border-right:1px solid #e8ede6; background:#f9fbf8; }
    .day-view .time-slot { height:60px; box-sizing:border-box; border-bottom:1px solid #e8ede6; padding:.5rem; font-size:.875rem; color:#6b7280; text-align:right; display:flex; align-items:center; justify-content:flex-end; }
    .day-view .day-column { position:relative; background:white; }
    .day-view .day-body { position:relative; }
    .day-view .day-column .time-slot { height:60px; border-bottom:1px solid #e8ede6; background:white; }

    /* Modal */
    .modal { display:none; position:fixed; z-index:1200; inset:0; background:rgba(12,30,20,.45); animation:calFadeIn .2s; }
    @keyframes calFadeIn { from{opacity:0} to{opacity:1} }
    .modal-content { background:white; margin:5% auto; padding:2rem; border-radius:16px; max-width:600px; position:relative; animation:calSlideDown .28s; box-shadow:0 24px 60px rgba(12,30,20,.22); }
    @keyframes calSlideDown { from{transform:translateY(-40px);opacity:0} to{transform:translateY(0);opacity:1} }
    .modal-close { position:absolute; right:1.25rem; top:1.25rem; font-size:1.75rem; font-weight:300; color:#9ca3af; cursor:pointer; transition:color .2s; background:none; border:none; line-height:1; }
    .modal-close:hover { color:#374151; }
    .modal-body { margin-bottom:1.25rem; }
    .detail-row { display:flex; justify-content:space-between; padding:.7rem 0; border-bottom:1px solid #f0f4ee; }
    .detail-row:last-child { border-bottom:none; }
    .detail-label { font-weight:700; color:#6b7280; font-size:.875rem; }
    .detail-value { color:#111827; text-align:right; font-size:.875rem; }
    .modal-actions { display:flex; gap:.75rem; justify-content:flex-end; padding-top:1rem; border-top:1px solid #e8ede6; flex-wrap:wrap; }
    .btn-approve { background:#22c55e; color:white; padding:.65rem 1.25rem; border:none; border-radius:9px; font-weight:700; cursor:pointer; transition:background .2s; }
    .btn-approve:hover { background:#16a34a; }
    .btn-reject  { background:#ef4444; color:white; padding:.65rem 1.25rem; border:none; border-radius:9px; font-weight:700; cursor:pointer; transition:background .2s; }
    .btn-reject:hover  { background:#dc2626; }
    .btn-edit    { background:#0ea5e9; color:white; padding:.65rem 1.25rem; border:none; border-radius:9px; font-weight:700; cursor:pointer; transition:background .2s; text-decoration:none; display:inline-flex; align-items:center; }
    .btn-edit:hover    { background:#0284c7; color:white; }
    .btn-delete  { background:#dc2626; color:white; padding:.65rem 1.25rem; border:none; border-radius:9px; font-weight:700; cursor:pointer; }
    .btn-delete:hover  { background:#b91c1c; }
    .no-events { padding:3rem; text-align:center; color:#9ca3af; }

    /* Delete-schedule confirm modal */
    .delete-schedule-modal { display:none; position:fixed; inset:0; z-index:2000; align-items:center; justify-content:center; padding:1.5rem; background:rgba(15,23,42,.55); backdrop-filter:blur(4px); }
    .delete-schedule-modal.is-open { display:flex; }
    .delete-schedule-dialog { width:min(440px,100%); background:white; border-radius:20px; padding:2rem; text-align:center; box-shadow:0 24px 70px rgba(15,23,42,.28); animation:deleteModalIn .18s ease-out; }
    .delete-schedule-icon { width:56px; height:56px; margin:0 auto 1rem; border-radius:999px; display:flex; align-items:center; justify-content:center; color:#991b1b; background:#fee2e2; border:1px solid #fecaca; font-size:1.6rem; font-weight:800; }
    .delete-schedule-dialog h3 { margin:0 0 .75rem; color:#111827; font-size:1.25rem; }
    .delete-schedule-dialog p  { margin:0; color:#6b7280; line-height:1.55; font-size:.9rem; }
    .delete-schedule-actions { display:flex; gap:.75rem; justify-content:center; margin-top:1.5rem; }
    .delete-schedule-actions button { border:none; border-radius:10px; padding:.7rem 1.1rem; font-weight:800; cursor:pointer; font-size:.9rem; }
    .delete-schedule-cancel  { background:#f3f4f6; color:#374151; }
    .delete-schedule-confirm { background:#dc2626; color:white; }
    @keyframes deleteModalIn { from{opacity:0;transform:translateY(12px) scale(.98)} to{opacity:1;transform:translateY(0) scale(1)} }
</style>

<script>
    const today = new Date();
    const initialCalendarDate = '{{ initialDate|default('')|e('js') }}';
    let currentDate = initialCalendarDate
        ? parseDateOnly(initialCalendarDate)
        : new Date(today.getFullYear(), today.getMonth(), today.getDate());
    let viewMode = 'week';
    let selectedFacility = '';
    let selectedStatus = '';
    let calendarRequestId = 0;
    let calendarAbortController = null;
    let calendarStatusHideTimer = null;
    const calendarEventsCache = new Map();
    const calendarStartHour = 7;
    const calendarEndHour = 20;
    const calendarHourHeight = 60;

    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('prevDate').addEventListener('click', () => navigateDate(-1));
        document.getElementById('nextDate').addEventListener('click', () => navigateDate(1));
        document.getElementById('todayBtn').addEventListener('click', () => {
            currentDate = new Date();
            renderCalendar();
        });
        document.getElementById('viewMode').addEventListener('change', (e) => {
            viewMode = e.target.value;
            renderCalendar();
        });
        document.getElementById('facilityFilter').addEventListener('change', (e) => {
            selectedFacility = e.target.value;
            renderCalendar();
        });
        document.getElementById('statusFilter').addEventListener('change', (e) => {
            selectedStatus = e.target.value;
            renderCalendar();
        });
        document.querySelector('.modal-close').addEventListener('click', closeModal);
        window.addEventListener('click', (e) => {
            if (e.target.id === 'eventModal') closeModal();
            if (e.target.id === 'deleteScheduleModal') closeDeleteScheduleModal();
        });
        document.getElementById('calendarRetryBtn').addEventListener('click', () => renderCalendar(true));
        document.getElementById('scheduleImportForm').addEventListener('submit', importScheduleInBackground);
        document.getElementById('manualBlockForm').addEventListener('submit', saveManualBlockInBackground);
        document.getElementById('manualBlockCancelEdit').addEventListener('click', resetManualBlockForm);
        document.getElementById('scheduleDeleteSubmit').addEventListener('click', openDeleteScheduleModal);
        document.getElementById('cancelDeleteSchedule').addEventListener('click', closeDeleteScheduleModal);
        document.getElementById('confirmDeleteSchedule').addEventListener('click', deleteImportedScheduleInBackground);
        window.addEventListener('focus', () => renderCalendar(true));
        document.addEventListener('visibilitychange', () => {
            if (!document.hidden) renderCalendar(true);
        });
        window.setInterval(() => {
            if (!document.hidden) renderCalendar(true);
        }, 15000);
        renderCalendar();
    });

    async function importScheduleInBackground(event) {
        event.preventDefault();

        const form = event.currentTarget;
        const submitButton = document.getElementById('scheduleImportSubmit');
        const messageBox = document.getElementById('scheduleImportMessage');
        const originalText = submitButton.textContent;

        submitButton.disabled = true;
        submitButton.textContent = 'Importing and syncing...';
        showImportMessage('Uploading schedule and rebuilding calendar blocks...', 'success');
        setCalendarStatus('Importing schedule. Calendar will refresh automatically...', 'loading', false);

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Schedule import failed.');
            }

            if (data.date) {
                currentDate = parseDateOnly(data.date);
                window.history.replaceState(null, '', `${window.location.pathname}?date=${data.date}`);
            }

            calendarEventsCache.clear();
            showImportMessage(data.message, 'success');
            setCalendarStatus('Schedule imported. Loading new calendar blocks now...', 'loading', false);
            await renderCalendar(true);

            if (Array.isArray(data.warnings) && data.warnings.length > 0) {
                showImportMessage(`${data.message} ${data.warnings.slice(0, 3).join(' ')}`, 'success');
            }
        } catch (error) {
            showImportMessage(error.message || 'Schedule import failed.', 'error');
            setCalendarStatus('Schedule import failed. Fix the CSV and try again.', 'error', false);
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = originalText;
        }

        function showImportMessage(message, type) {
            messageBox.textContent = message;
            messageBox.className = 'schedule-import-message ' + type;
            messageBox.style.display = 'block';
        }
    }

    async function saveManualBlockInBackground(event) {
        event.preventDefault();

        const form = event.currentTarget;
        const submitButton = document.getElementById('manualBlockSubmit');
        const messageBox = document.getElementById('manualBlockMessage');
        const originalText = submitButton.textContent;
        let savedSuccessfully = false;
        const blockId = document.getElementById('manualBlockId').value;
        const actionUrl = blockId ? `/super-admin/calendar/block/${blockId}/update` : form.dataset.createUrl;

        submitButton.disabled = true;
        submitButton.textContent = blockId ? 'Updating...' : 'Adding...';
        showManualBlockMessage(blockId ? 'Updating schedule block...' : 'Adding schedule block...', 'success');
        setCalendarStatus(blockId ? 'Updating blocked schedule...' : 'Adding blocked schedule...', 'loading', false);

        try {
            const response = await fetch(actionUrl, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Schedule block save failed.');
            }

            if (data.block && data.block.reservationDate) {
                currentDate = parseDateOnly(data.block.reservationDate);
            }

            calendarEventsCache.clear();
            showManualBlockMessage(data.message, 'success');
            savedSuccessfully = true;
            resetManualBlockForm(false);
            setCalendarStatus('Schedule block saved. Refreshing calendar and availability...', 'loading', false);
            await renderCalendar(true);
        } catch (error) {
            showManualBlockMessage(error.message || 'Schedule block save failed.', 'error');
            setCalendarStatus('Could not save schedule block. Resolve conflicts and try again.', 'error', false);
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = savedSuccessfully ? 'Add Block' : originalText;
        }

        function showManualBlockMessage(message, type) {
            messageBox.textContent = message;
            messageBox.className = 'schedule-import-message ' + type;
            messageBox.style.display = 'block';
        }
    }

    function resetManualBlockForm(clearMessage = true) {
        const form = document.getElementById('manualBlockForm');
        form.reset();
        form.action = form.dataset.createUrl;
        document.getElementById('manualBlockId').value = '';
        document.getElementById('manualBlockSubmit').textContent = 'Add Block';
        document.getElementById('manualBlockCancelEdit').style.display = 'none';

        if (clearMessage) {
            document.getElementById('manualBlockMessage').style.display = 'none';
        }
    }

    function openDeleteScheduleModal() {
        document.getElementById('deleteScheduleModal').classList.add('is-open');
        playDeleteWarningSound();
    }

    function closeDeleteScheduleModal() {
        document.getElementById('deleteScheduleModal').classList.remove('is-open');
    }

    function playDeleteWarningSound() {
        playDeleteWarningAudioElement();

        const AudioContext = window.AudioContext || window.webkitAudioContext;
        if (!AudioContext) {
            return;
        }

        const audioContext = window.deleteScheduleAudioContext || new AudioContext();
        window.deleteScheduleAudioContext = audioContext;

        const playTone = (frequency, startTime, duration) => {
            const oscillator = audioContext.createOscillator();
            const gain = audioContext.createGain();

            oscillator.type = 'triangle';
            oscillator.frequency.setValueAtTime(frequency, startTime);
            gain.gain.setValueAtTime(0.0001, startTime);
            gain.gain.exponentialRampToValueAtTime(0.22, startTime + 0.02);
            gain.gain.exponentialRampToValueAtTime(0.0001, startTime + duration);

            oscillator.connect(gain);
            gain.connect(audioContext.destination);
            oscillator.start(startTime);
            oscillator.stop(startTime + duration);
        };

        const startSound = () => {
            const now = audioContext.currentTime;
            playTone(880, now, 0.14);
            playTone(660, now + 0.18, 0.18);
        };

        if (audioContext.state === 'suspended') {
            audioContext.resume().then(startSound).catch(() => {});
            return;
        }

        startSound();
    }

    function playDeleteWarningAudioElement() {
        try {
            const audio = new Audio('data:audio/wav;base64,UklGRqQAAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YYAAAACAgICAgICAgICAgICAgICAgICAgICAhoyKv9j/2L+MhYCAgICAgICAhpOqweDn6uDQsoqAgICAgICAhY+drMzp8vby2MWkgICAgICAhImXp7Tn38+3n5OFgYCAgICAhI6lx9De3syupYmAgICAgICAg4mVrLXf5O/o0rSLgICAgICAgICGjIq/2P/Yv4yFgICAgICAgICAgICAgICAgICAgICAgICAgICAgA==');
            audio.volume = 0.75;
            audio.currentTime = 0;
            audio.play().catch(() => {});
        } catch (error) {}
    }

    async function deleteImportedScheduleInBackground() {
        const submitButton = document.getElementById('scheduleDeleteSubmit');
        const confirmButton = document.getElementById('confirmDeleteSchedule');
        const messageBox = document.getElementById('scheduleDeleteMessage');
        const originalText = submitButton.textContent;
        const originalConfirmText = confirmButton.textContent;
        const formData = new FormData();
        formData.append('_token', submitButton.dataset.token);

        submitButton.disabled = true;
        confirmButton.disabled = true;
        submitButton.textContent = 'Deleting...';
        confirmButton.textContent = 'Deleting...';
        showDeleteMessage('Deleting imported class schedules...', 'success');
        setCalendarStatus('Deleting imported class schedules...', 'loading', false);

        try {
            const response = await fetch(submitButton.dataset.deleteUrl, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Delete failed.');
            }

            calendarEventsCache.clear();
            closeDeleteScheduleModal();
            showDeleteMessage(data.message, 'success');
            setCalendarStatus('Imported schedule deleted. Reloading calendar...', 'loading', false);
            await renderCalendar(true);
        } catch (error) {
            showDeleteMessage(error.message || 'Delete failed.', 'error');
            setCalendarStatus('Could not delete imported schedule. Try again.', 'error', false);
        } finally {
            submitButton.disabled = false;
            confirmButton.disabled = false;
            submitButton.textContent = originalText;
            confirmButton.textContent = originalConfirmText;
        }

        function showDeleteMessage(message, type) {
            messageBox.textContent = message;
            messageBox.className = 'schedule-import-message ' + type;
            messageBox.style.display = 'block';
        }
    }

    function navigateDate(direction) {
        const next = new Date(currentDate.getFullYear(), currentDate.getMonth(), currentDate.getDate());
        next.setDate(next.getDate() + (viewMode === 'week' ? direction * 7 : direction));
        currentDate = next;
        renderCalendar();
    }

    function parseDateOnly(value) {
        const parts = value.split('-').map(Number);
        if (parts.length !== 3 || parts.some(Number.isNaN)) {
            return new Date(today.getFullYear(), today.getMonth(), today.getDate());
        }

        return new Date(parts[0], parts[1] - 1, parts[2]);
    }

    async function renderCalendar(forceRefresh = false) {
        updateDateDisplay();
        const startDate = getStartDate();
        const endDate = getEndDate();
        const container = document.getElementById('calendarView');
        const renderMode = viewMode;
        const renderDate = new Date(currentDate.getFullYear(), currentDate.getMonth(), currentDate.getDate());
        const requestId = ++calendarRequestId;
        const cacheKey = getCalendarCacheKey(startDate, endDate, renderDate, renderMode);
        const cachedEvents = calendarEventsCache.get(cacheKey);

        if (cachedEvents) {
            renderCalendarEvents(cachedEvents, startDate, renderDate, renderMode);
            setCalendarStatus('Refreshing calendar data in real time...', 'loading', false);
        } else {
            container.innerHTML = renderMode === 'week'
                ? renderWeekView([], startDate)
                : renderDayView([], renderDate);
            setCalendarStatus('Loading calendar schedules and reservations...', 'loading', false);
        }

        if (calendarAbortController) {
            calendarAbortController.abort();
        }

        calendarAbortController = new AbortController();
        const activeController = calendarAbortController;
        const slowTimer = window.setTimeout(() => {
            if (requestId === calendarRequestId) {
                setCalendarStatus('Still loading live calendar data... please wait.', 'loading', false);
            }
        }, 2500);
        const timeoutTimer = window.setTimeout(() => {
            if (activeController === calendarAbortController) {
                activeController.abort();
            }
        }, 15000);

        try {
            const events = await fetchReservations(startDate, endDate, activeController.signal);
            window.clearTimeout(slowTimer);
            window.clearTimeout(timeoutTimer);

            if (requestId !== calendarRequestId) {
                return;
            }

            // Debug logging
            console.log('Calendar data loaded:', events.length, 'events');
            console.log('Events:', events);
            console.log('Current status filter:', selectedStatus);
            console.log('Date range:', formatDateForAPI(startDate), 'to', formatDateForAPI(endDate));

            calendarEventsCache.set(cacheKey, events);
            renderCalendarEvents(events, startDate, renderDate, renderMode);
            setCalendarStatus(`Loaded ${events.length} calendar item${events.length === 1 ? '' : 's'} successfully.`, 'success', false);
        } catch (error) {
            window.clearTimeout(slowTimer);
            window.clearTimeout(timeoutTimer);

            if (requestId !== calendarRequestId) {
                return;
            }

            if (cachedEvents) {
                renderCalendarEvents(cachedEvents, startDate, renderDate, renderMode);
                setCalendarStatus('Live refresh failed. Showing the last loaded calendar data.', 'error', true);
                return;
            }

            container.innerHTML = renderMode === 'week'
                ? renderWeekView([], startDate)
                : renderDayView([], renderDate);
            setCalendarStatus('Calendar data did not load. Click Retry to load it again.', 'error', true);
        }
    }

    function renderCalendarEvents(events, startDate, renderDate, renderMode) {
        const container = document.getElementById('calendarView');
        container.innerHTML = renderMode === 'week'
            ? renderWeekView(events, startDate)
            : renderDayView(events, renderDate);
        bindEventBlocks();
    }

    function bindEventBlocks() {
        document.querySelectorAll('.event-block').forEach(el => {
            el.addEventListener('click', () => openEventModal(el));
        });
    }

    function getCalendarCacheKey(startDate, endDate, renderDate, renderMode) {
        return [
            renderMode,
            formatDateForAPI(startDate),
            formatDateForAPI(endDate),
            formatDateForAPI(renderDate),
            selectedFacility || 'all',
            selectedStatus || 'all',
        ].join('|');
    }

    function setCalendarStatus(message, type, showRetry) {
        const status = document.getElementById('calendarStatus');
        const text = document.getElementById('calendarStatusText');
        const retry = document.getElementById('calendarRetryBtn');

        if (!status || !text || !retry) {
            return;
        }

        window.clearTimeout(calendarStatusHideTimer);
        status.style.display = 'flex';
        status.className = 'calendar-status calendar-status-' + type;
        text.textContent = message;
        retry.style.display = showRetry ? 'inline-block' : 'none';

        if (type === 'success') {
            calendarStatusHideTimer = window.setTimeout(() => {
                status.style.display = 'none';
            }, 2500);
        }
    }

    function getStartDate() {
        const date = new Date(currentDate.getFullYear(), currentDate.getMonth(), currentDate.getDate());
        if (viewMode === 'week') {
            const day = date.getDay();
            date.setDate(date.getDate() - day + (day === 0 ? -6 : 1));
        }
        return date;
    }

    function getEndDate() {
        const start = getStartDate();
        const end = new Date(start.getFullYear(), start.getMonth(), start.getDate());
        if (viewMode === 'week') end.setDate(end.getDate() + 6);
        return end;
    }

    function updateDateDisplay() {
        const display = document.getElementById('currentDateDisplay');
        display.textContent = viewMode === 'week'
            ? 'Weekly Schedule - Monday to Sunday'
            : `Daily Schedule - ${currentDate.toLocaleDateString('en-US', { weekday: 'long' })}`;
    }

    function formatDate(date) {
        return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    function formatDateForAPI(date) {
        return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
    }

    async function fetchReservations(startDate, endDate, signal) {
        const params = new URLSearchParams({ start: formatDateForAPI(startDate), end: formatDateForAPI(endDate), facility: selectedFacility, status: selectedStatus });
        const response = await fetch(`/super-admin/calendar/data?${params}`, { cache: 'no-store', signal });
        if (!response.ok) {
            throw new Error('Calendar data request failed.');
        }
        const data = await response.json();
        return data.reservations || [];
    }

    function formatSlotLabel(h, m) {
        const period = h >= 12 ? 'PM' : 'AM';
        const displayHour = h > 12 ? h - 12 : h;
        return displayHour + ':' + m + ' ' + period;
    }

    function generateTimeSlots() {
        const slots = [];
        for (let hour = calendarStartHour; hour < calendarEndHour; hour++) {
            slots.push({ time: `${String(hour).padStart(2, '0')}:00`, label: formatSlotLabel(hour, '00') });
        }
        return slots;
    }

    function minutesFromCalendarStart(timeStr) {
        const [hours, minutes] = timeStr.split(':').map(Number);
        return (hours * 60 + minutes) - (calendarStartHour * 60);
    }

    function calendarMinutesToPixels(minutes) {
        return minutes * (calendarHourHeight / 60);
    }

    function renderWeekView(events, startDate) {
        const days = Array.from({ length: 7 }, (_, i) => {
            const day = new Date(startDate);
            day.setDate(startDate.getDate() + i);
            return day;
        });
        let html = '<div class="week-view">';
        const timeSlots = generateTimeSlots();
        html += '<div class="time-column"><div class="day-header" style="background: transparent; color: #6b7280;">Time</div>';
        timeSlots.forEach(slot => html += `<div class="time-slot" style="height:${calendarHourHeight}px;">${slot.label}</div>`);
        html += '</div>';
        days.forEach(day => {
            const dateKey = formatDateForAPI(day);
            const dayEvents = events.filter(event => event.reservationDate === dateKey);
            html += `<div class="day-column"><div class="day-header"><div class="day-name">${day.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase()}</div><div class="day-date">${day.toLocaleDateString('en-US', { day: 'numeric' })}</div></div><div class="day-body">`;
            timeSlots.forEach(() => html += `<div class="time-slot" style="height:${calendarHourHeight}px;"></div>`);
            dayEvents.forEach((event, index) => html += renderEventBlock(event, index, dayEvents.length));
            html += '</div></div>';
        });
        return html + '</div>';
    }

    function renderDayView(events, date) {
        const dateKey = formatDateForAPI(date);
        const dayEvents = events.filter(event => event.reservationDate === dateKey);
        let html = '<div class="day-view"><div class="time-column">';
        const timeSlots = generateTimeSlots();
        timeSlots.forEach(slot => html += `<div class="time-slot" style="height:${calendarHourHeight}px;">${slot.label}</div>`);
        html += '</div><div class="day-column"><div class="day-body">';
        timeSlots.forEach(() => html += `<div class="time-slot" style="height:${calendarHourHeight}px;"></div>`);
        dayEvents.forEach((event, index) => html += renderEventBlock(event, index, dayEvents.length));
        html += '</div></div></div>';
        if (dayEvents.length === 0) html += '<div class="no-events">No schedules for this date</div>';
        return html;
    }

    function renderEventBlock(event, index, total) {
        const dayStart = 0;
        const dayEnd = (calendarEndHour - calendarStartHour) * 60;
        const startMinutes = minutesFromCalendarStart(event.reservationStartTime);
        const endMinutes = minutesFromCalendarStart(event.reservationEndTime);
        const visibleStart = Math.max(startMinutes, dayStart);
        const visibleEnd = Math.min(endMinutes, dayEnd);
        const top = calendarMinutesToPixels(visibleStart);
        const height = Math.max(calendarMinutesToPixels(visibleEnd - visibleStart), 24);
        const status = event.status.toLowerCase().replace(/[^a-z0-9]+/g, '');
        const offset = (index % Math.min(total, 4)) * 10;
        const width = `calc(100% - ${Math.min(total - 1, 3) * 10}px)`;
        const safeName = escapeHtml(event.name);
        const safeFacility = escapeHtml(event.facility.name);
        const safeStatus = escapeHtml(event.status);
        const safePurpose = escapeHtml(event.purpose || '');
        const safeEventName = escapeHtml(event.eventName || '');
        const safeEmail = escapeHtml(event.email || '');
        const safeContact = escapeHtml(event.contact || '');
        const safeCapacity = event.capacity || 0;
        const safeFacilityCapacity = event.facility.capacity || 0;
        const safeFacilityId = event.facility.id || '';
        const isBlock = event.isBlock ? '1' : '0';
        const blockId = isBlock === '1' ? String(event.id).replace('block_', '') : '';
        const timeDisplay = formatEventTime(event.reservationStartTime) + ' - ' + formatEventTime(event.reservationEndTime);

        return '<div class="event-block ' + status + '" style="top:' + top + 'px; height:' + height + 'px; left:' + offset + 'px; width:' + width + '; right:auto;"' +
            ' data-id="' + event.id + '"' +
            ' data-block-id="' + blockId + '"' +
            ' data-is-block="' + isBlock + '"' +
            ' data-title="' + safeName + '"' +
            ' data-event-name="' + safeEventName + '"' +
            ' data-facility="' + safeFacility + '"' +
            ' data-facility-id="' + safeFacilityId + '"' +
            ' data-status="' + safeStatus + '"' +
            ' data-date="' + event.reservationDate + '"' +
            ' data-start="' + event.reservationStartTime + '"' +
            ' data-end="' + event.reservationEndTime + '"' +
            ' data-purpose="' + safePurpose + '"' +
            ' data-email="' + safeEmail + '"' +
            ' data-contact="' + safeContact + '"' +
            ' data-capacity="' + safeCapacity + '"' +
            ' data-facility-capacity="' + safeFacilityCapacity + '">' +
            '<div class="event-title">' + safeFacility + '</div>' +
            '<div class="event-requester">' + safeName + '</div>' +
            '<div class="event-time">' + timeDisplay + '</div>' +
            '<span class="event-status ' + status + '">' + safeStatus + '</span>' +
            '</div>';
    }

    function openEventModal(element) {
        const data = element.dataset;
        document.getElementById('modalTitle').textContent = `${data.facility} - ${data.status}`;
        const eventName = data.eventName || data.title || data.facility || 'Unnamed Event';
        const details = data.isBlock === '1'
            ? [['Event Name', eventName], ['Date', data.date], ['Time', `${formatEventTime(data.start)} - ${formatEventTime(data.end)}`], ['Event Objective', data.purpose || 'None']]
            : [['Event Name', eventName], ['Requester', data.title], ['Email', data.email], ['Contact', data.contact], ['Date', data.date], ['Time', `${formatEventTime(data.start)} - ${formatEventTime(data.end)}`], ['Attendees', `${data.capacity} / ${data.facilityCapacity}`], ['Event Objective', data.purpose || 'None']];
        document.getElementById('modalBody').innerHTML = details.map(([label, value]) => `<div class="detail-row"><span class="detail-label">${label}:</span><span class="detail-value">${value}</span></div>`).join('');
        if (data.isBlock === '1' && data.status !== 'Class Schedule') {
            document.getElementById('modalActions').innerHTML = `<button type="button" class="btn-edit" onclick="editManualBlockFromModal()">Edit Block</button><button type="button" class="btn-delete" onclick="deleteManualBlockFromModal()">Delete Block</button>`;
        } else if (data.isBlock === '1') {
            document.getElementById('modalActions').innerHTML = `<button type="button" class="btn-edit" onclick="modifyClassScheduleFromModal()">Modify Facility Schedule</button><button type="button" class="btn-delete" onclick="deleteManualBlockFromModal()">Delete Schedule</button>`;
        } else {
            document.getElementById('modalActions').innerHTML = `<a href="/super-admin/reservations/${data.id}/edit" class="btn-edit">Edit</a>`;
        }
        document.getElementById('eventModal').dataset.activeBlock = data.blockId || '';
        document.getElementById('eventModal').dataset.activeFacilityId = data.facilityId || '';
        document.getElementById('eventModal').dataset.activeDate = data.date || '';
        document.getElementById('eventModal').dataset.activeStart = data.start || '';
        document.getElementById('eventModal').dataset.activeEnd = data.end || '';
        document.getElementById('eventModal').dataset.activeTitle = data.title || '';
        document.getElementById('eventModal').dataset.activeStatus = data.status || 'Manual';
        document.getElementById('eventModal').dataset.activePurpose = data.purpose || '';
        document.getElementById('eventModal').style.display = 'block';
    }

    function editManualBlockFromModal() {
        const modal = document.getElementById('eventModal');
        const form = document.getElementById('manualBlockForm');
        const blockId = modal.dataset.activeBlock;

        if (!blockId) {
            return;
        }

        document.getElementById('manualBlockId').value = blockId;
        form.elements.facility.value = modal.dataset.activeFacilityId;
        form.elements.date.value = modal.dataset.activeDate;
        form.elements.start_time.value = modal.dataset.activeStart;
        form.elements.end_time.value = modal.dataset.activeEnd;
        form.elements.title.value = modal.dataset.activeTitle;
        form.elements.type.value = ['Manual', 'Blocked', 'Maintenance'].includes(modal.dataset.activeStatus) ? modal.dataset.activeStatus : 'Manual';
        form.elements.notes.value = modal.dataset.activePurpose;
        document.getElementById('manualBlockSubmit').textContent = 'Update Block';
        document.getElementById('manualBlockCancelEdit').style.display = 'inline-block';
        document.getElementById('manualBlockMessage').style.display = 'none';
        closeModal();
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function modifyClassScheduleFromModal() {
        const modal = document.getElementById('eventModal');
        const form = document.getElementById('manualBlockForm');
        const blockId = modal.dataset.activeBlock;

        if (!blockId) {
            return;
        }

        document.getElementById('manualBlockId').value = blockId;
        form.elements.facility.value = modal.dataset.activeFacilityId;
        form.elements.date.value = modal.dataset.activeDate;
        form.elements.start_time.value = modal.dataset.activeStart;
        form.elements.end_time.value = modal.dataset.activeEnd;
        form.elements.title.value = modal.dataset.activeTitle;
        form.elements.type.value = 'Class Schedule';
        form.elements.notes.value = modal.dataset.activePurpose;
        document.getElementById('manualBlockSubmit').textContent = 'Modify Schedule';
        document.getElementById('manualBlockCancelEdit').style.display = 'inline-block';
        document.getElementById('manualBlockMessage').style.display = 'none';
        closeModal();
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    async function deleteManualBlockFromModal() {
        const modal = document.getElementById('eventModal');
        const blockId = modal.dataset.activeBlock;

        if (!blockId || !window.confirm('Delete this manual schedule block? This time slot will become available if no other conflict exists.')) {
            return;
        }

        const formData = new FormData();
        formData.append('_token', document.getElementById('manualBlockForm').dataset.deleteToken);
        setCalendarStatus('Deleting manual schedule block...', 'loading', false);

        try {
            const response = await fetch(`/super-admin/calendar/block/${blockId}/delete`, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Delete failed.');
            }

            closeModal();
            calendarEventsCache.clear();
            showManualBlockToast(data.message, 'success');
            setCalendarStatus('Manual block deleted. Refreshing calendar and availability...', 'loading', false);
            await renderCalendar(true);
        } catch (error) {
            showManualBlockToast(error.message || 'Delete failed.', 'error');
            setCalendarStatus('Could not delete manual block. Try again.', 'error', false);
        }
    }

    function showManualBlockToast(message, type) {
        const messageBox = document.getElementById('manualBlockMessage');
        messageBox.textContent = message;
        messageBox.className = 'schedule-import-message ' + type;
        messageBox.style.display = 'block';
    }

    function closeModal() {
        document.getElementById('eventModal').style.display = 'none';
    }

    function formatHour(hour) {
        return `${hour > 12 ? hour - 12 : hour}:00 ${hour >= 12 ? 'PM' : 'AM'}`;
    }

    function formatEventTime(timeStr) {
        return new Date('2000-01-01 ' + timeStr).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
    }

    function escapeHtml(value) {
        return String(value).replace(/[&<>'"]/g, character => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#039;', '"': '&quot;' }[character]));
    }
</script>
{% endblock %}
