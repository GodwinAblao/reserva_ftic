    function handleModifyActionTypeChange(e) {
        const actionType = e.target.value;
        const modifyFields = document.getElementById('modifyFields');
        const blockFields = document.getElementById('blockFields');
        const facilitySelect = document.getElementById('modifyFacilitySelect');
        const startTimeSelect = document.getElementById('modifyStartTime');
        const endTimeSelect = document.getElementById('modifyEndTime');
        const readonlyInputs = [
            document.getElementById('modifyCourseCodeInput'),
            document.getElementById('modifySectionInput'),
            document.getElementById('modifyFacultyNameInput')
        ];
        const classScheduleId = document.getElementById('modifyClassScheduleId').value;
        const isClassSchedule = classScheduleId && classScheduleId !== '';

        if (actionType === 'modify') {
            modifyFields.style.display = 'grid';
            blockFields.style.display = 'none';
            // Disable facility select in modify mode (class schedule facility cannot be changed)
            facilitySelect.disabled = true;
            facilitySelect.classList.add('disabled-field');
            // Add readonly styling to inputs
            readonlyInputs.forEach(input => {
                if (input) input.classList.add('readonly-field');
            });
        } else if (actionType === 'block') {
            modifyFields.style.display = 'none';
            blockFields.style.display = 'grid';
            // For class schedules being blocked, time is also not changeable
            if (isClassSchedule) {
                startTimeSelect.disabled = true;
                startTimeSelect.classList.add('disabled-field');
                endTimeSelect.disabled = true;
                endTimeSelect.classList.add('disabled-field');
            } else {
                // Enable facility and time selects in block mode for regular blocks
                facilitySelect.disabled = false;
                facilitySelect.classList.remove('disabled-field');
                startTimeSelect.disabled = false;
                startTimeSelect.classList.remove('disabled-field');
                endTimeSelect.disabled = false;
                endTimeSelect.classList.remove('disabled-field');
            }
            // Remove readonly styling from inputs
            readonlyInputs.forEach(input => {
                if (input) input.classList.remove('readonly-field');
            });
        }
    }

