{% extends "layouts/app.html.twig" %}

{% block title %}Edit Reservation - Reserva FTIC{% endblock %}

{% block content %}
<div class="sa-form-page">
    <a href="{{ path(calendar_back_route|default('admin_calendar')) }}" class="sa-back-link">← Back to Calendar</a>

    <div class="sa-page-header">
        <div class="sa-page-header-left">
            <h2>Edit Reservation</h2>
            <p>Facility: <strong>{{ reservation.facility.name }}</strong> &nbsp;·&nbsp; ID: <strong>#{{ reservation.id }}</strong></p>
        </div>
    </div>

    <div class="sa-card sa-form-section">
        <form method="POST" action="{{ path(update_route|default('admin_update_reservation'), {'id': reservation.id}) }}" class="edit-form">
            <input type="hidden" name="_token" value="{{ csrf_token('update_reservation_' ~ reservation.id) }}">
            <div class="sa-form-grid">
                <div class="sa-form-group">
                    <label for="name">Full Name *</label>
                    <input type="text" id="name" name="name" class="sa-form-input"
                           value="{{ reservation.name }}" required>
                </div>

                <div class="sa-form-group">
                    <label for="eventName">Event Name</label>
                    <input type="text" id="eventName" name="event_name" class="sa-form-input"
                           value="{{ reservation.eventName ?? '' }}">
                </div>

                <div class="sa-form-group">
                    <label for="email">Email *</label>
                    <input type="email" id="email" name="email" class="sa-form-input"
                           value="{{ reservation.email }}" required>
                </div>

                <div class="sa-form-group">
                    <label for="contact">Contact Number *</label>
                    <input type="tel" id="contact" name="contact" class="sa-form-input"
                           value="{{ reservation.contact }}" required>
                </div>

                <div class="sa-form-group">
                    <label for="facility">Facility *</label>
                    <select id="facility" name="facility" class="sa-form-input" required onchange="updateFacilityCapacity()">
                        <option value="">Select a facility</option>
                        {% for facility in facilities %}
                            <option value="{{ facility.id }}"
                                    data-capacity="{{ facility.capacity }}"
                                    {% if reservation.facility.id == facility.id %}selected{% endif %}>
                                {{ facility.name }} (Capacity: {{ facility.capacity }})
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="sa-form-group">
                    <label for="capacity">Number of Attendees *</label>
                    <input type="number" id="capacity" name="capacity" class="sa-form-input"
                           value="{{ reservation.capacity }}" min="1" required>
                    <small class="help-text">Max capacity: <span id="maxCapacity">{{ reservation.facility.capacity }}</span></small>
                </div>

                <div class="sa-form-group">
                    <label for="reservationDate">Reservation Date *</label>
                    <input type="date" id="reservationDate" name="reservationDate" class="sa-form-input"
                           value="{{ reservation.reservationDate.format('Y-m-d') }}" required>
                </div>

                <div class="sa-form-group">
                    <label for="reservationStartTime">Start Time *</label>
                    <input type="time" id="reservationStartTime" name="reservationStartTime" class="sa-form-input"
                           value="{{ reservation.reservationStartTime.format('H:i') }}" required>
                    <small class="help-text">Available: 08:00 – 17:00</small>
                </div>

                <div class="sa-form-group">
                    <label for="reservationEndTime">End Time *</label>
                    <input type="time" id="reservationEndTime" name="reservationEndTime" class="sa-form-input"
                           value="{{ reservation.reservationEndTime.format('H:i') }}" required>
                    <small class="help-text">Must be after start time</small>
                </div>

                <div class="sa-form-group full-width">
                    <label for="purpose">Event Objective</label>
                    <textarea id="purpose" name="purpose" class="sa-form-input" rows="4"
                              placeholder="Describe the objective of the reservation...">{{ reservation.purpose ?? '' }}</textarea>
                </div>

                <div class="sa-form-group">
                    <label for="status">Status *</label>
                    <select id="status" name="status" class="sa-form-input" required>
                        <option value="Pending" {% if reservation.status == 'Pending' %}selected{% endif %}>Pending</option>
                        <option value="Approved" {% if reservation.status == 'Approved' %}selected{% endif %}>Approved</option>
                        <option value="Rejected" {% if reservation.status == 'Rejected' %}selected{% endif %}>Rejected</option>
                        <option value="Cancelled" {% if reservation.status == 'Cancelled' %}selected{% endif %}>Cancelled</option>
                    </select>
                </div>
            </div>

            <div class="sa-form-actions">
                <a href="{{ path('admin_calendar') }}" class="sa-btn sa-btn-secondary">✕ Cancel</a>
                <button type="submit" class="sa-btn sa-btn-primary">✓ Update Reservation</button>
            </div>
        </form>
    </div>

    <div class="sa-card">
        <h3 class="sa-card-title" style="margin-bottom:18px;">Reservation Information</h3>
        <div class="sa-info-grid">
            <div class="sa-info-item">
                <span class="sa-info-label">Created</span>
                <span class="sa-info-value">{{ reservation.createdAt.format('M d, Y H:i') }}</span>
            </div>
            <div class="sa-info-item">
                <span class="sa-info-label">Last Updated</span>
                <span class="sa-info-value">{{ reservation.updatedAt.format('M d, Y H:i') }}</span>
            </div>
            <div class="sa-info-item">
                <span class="sa-info-label">Current Status</span>
                <span class="sa-info-value">
                    <span class="sa-badge sa-badge-{{ reservation.status|lower }}">{{ reservation.status }}</span>
                </span>
            </div>
            {% if reservation.rejectionReason %}
            <div class="sa-info-item">
                <span class="sa-info-label">Rejection Reason</span>
                <span class="sa-info-value">{{ reservation.rejectionReason }}</span>
            </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
    function updateFacilityCapacity() {
        const facilitySelect = document.getElementById('facility');
        const selectedOption = facilitySelect.options[facilitySelect.selectedIndex];
        const maxCapacity = selectedOption.dataset.capacity;
        document.getElementById('maxCapacity').textContent = maxCapacity;
        
        // Update capacity input max value
        const capacityInput = document.getElementById('capacity');
        capacityInput.max = maxCapacity;
    }

    // Validate time inputs
    document.getElementById('reservationEndTime').addEventListener('change', function() {
        const startTime = document.getElementById('reservationStartTime').value;
        const endTime = this.value;
        
        if (startTime && endTime && startTime >= endTime) {
            alert('End time must be after start time');
            this.value = '';
        }
    });

    // Validate capacity
    document.getElementById('capacity').addEventListener('change', function() {
        const maxCapacity = parseInt(document.getElementById('maxCapacity').textContent);
        const capacity = parseInt(this.value);
        
        if (capacity > maxCapacity) {
            alert(`Capacity cannot exceed ${maxCapacity}`);
            this.value = maxCapacity;
        }
    });
</script>
{% endblock %}
