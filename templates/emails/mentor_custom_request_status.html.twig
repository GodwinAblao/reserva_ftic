<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mentoring Request Update</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            background: #f8faf9;
            color: #222;
        }
        .wrap {
            max-width: 640px;
            margin: 0 auto;
            padding: 24px;
        }
        .card {
            background: #fff;
            border: 1px solid rgba(0, 102, 51, 0.1);
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
        }
        .header {
            background: linear-gradient(135deg, #006633 0%, #008844 100%);
            color: #fff;
            padding: 28px 24px;
        }
        .header h1 {
            margin: 0 0 8px;
            font-size: 28px;
            line-height: 1.2;
        }
        .header p { margin: 0; opacity: 0.95; }
        .body { padding: 24px; }
        .status-badge {
            display: inline-block;
            padding: 8px 12px;
            border-radius: 999px;
            background: #e8f2ec;
            color: #004d26;
            font-weight: 700;
            margin-bottom: 16px;
        }
        .box {
            background: #f9fafb;
            border-left: 4px solid #006633;
            border-radius: 8px;
            padding: 16px;
            white-space: pre-wrap;
            line-height: 1.65;
            margin: 14px 0;
        }
        .note {
            color: #64748b;
            line-height: 1.6;
            margin-top: 14px;
        }
        .cta {
            display: inline-block;
            margin-top: 18px;
            background: linear-gradient(135deg, #006633 0%, #008844 100%);
            color: #fff;
            text-decoration: none;
            padding: 12px 18px;
            border-radius: 10px;
            font-weight: 700;
        }
        .footer {
            padding: 18px 24px 24px;
            color: #64748b;
            font-size: 14px;
            border-top: 1px solid rgba(0, 102, 51, 0.1);
        }
        @media (max-width: 600px) {
            .wrap { padding: 12px; }
            .body, .header, .footer { padding-left: 18px; padding-right: 18px; }
            .header h1 { font-size: 22px; }
        }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="card">
            <div class="header">
                <h1>Mentoring Request {{ status }}</h1>
                <p>Update on your custom mentoring request on Reserva FTIC</p>
            </div>
            <div class="body">
                <div class="status-badge">{{ status }}</div>
                <p>Hello <strong>{{ studentName }}</strong>,</p>
                <p>{{ message }}</p>

                {% if mentorResponse %}
                    <div class="box">{{ mentorResponse }}</div>
                {% endif %}

                <a class="cta" href="{{ requestUrl }}">Open Mentoring Dashboard →</a>

                <p class="note">
                    You can view the request status inside the mentoring page. If you need to send a follow-up, use the same mentor profile page.
                </p>
            </div>
            <div class="footer">
                <p><strong>Mentor:</strong> {{ mentorName }}</p>
                <p>This is an automated notification from Reserva FTIC.</p>
            </div>
        </div>
    </div>
</body>
</html>