<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mentoring Request Update</title>
</head>
<body style="margin:0;background:#f4f7f5;font-family:Arial,sans-serif;color:#1f2937;">
    <div style="max-width:680px;margin:0 auto;padding:28px;">
        <div style="background:#006633;color:#fff;padding:22px 26px;border-radius:10px 10px 0 0;">
            <h1 style="margin:0;font-size:22px;">Mentoring Request Update</h1>
            <p style="margin:8px 0 0;">We were unable to find a suitable mentor match at this time.</p>
        </div>
        <div style="background:#fff;border:1px solid #e5e7eb;border-top:0;padding:26px;border-radius:0 0 10px 10px;">
            <p>Hello {{ request.fullName ?: student.email }},</p>
            <p>{{ message }}</p>

            <table style="width:100%;border-collapse:collapse;margin:18px 0;">
                <tr>
                    <td style="padding:10px;border-bottom:1px solid #e5e7eb;width:38%;"><strong>Request</strong></td>
                    <td style="padding:10px;border-bottom:1px solid #e5e7eb;">{{ requestTitle }}</td>
                </tr>
                <tr>
                    <td style="padding:10px;border-bottom:1px solid #e5e7eb;"><strong>Status</strong></td>
                    <td style="padding:10px;border-bottom:1px solid #e5e7eb;">Canceled</td>
                </tr>
                <tr>
                    <td style="padding:10px;border-bottom:1px solid #e5e7eb;"><strong>Cancellation Reason</strong></td>
                    <td style="padding:10px;border-bottom:1px solid #e5e7eb;">{{ reason }}</td>
                </tr>
            </table>

            <div style="background:#fef2f2;border-left:4px solid #dc2626;padding:14px 16px;margin:18px 0;color:#7f1d1d;">
                There are currently no available mentors matching your request. You may submit another request in the future when mentors become available.
            </div>

            <p>
                <a href="{{ requestUrl }}" style="background:#006633;color:#fff;text-decoration:none;padding:12px 18px;border-radius:8px;display:inline-block;">View Mentoring Dashboard</a>
            </p>
            <p style="font-size:13px;color:#6b7280;">This is an automated message from Reserva FTIC.</p>
        </div>
    </div>
</body>
</html>
