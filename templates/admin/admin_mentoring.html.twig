<script>
(function(){
    var AUDIT_URL = '{{ path("mentoring_audit_log_data") }}';
    var PER_PAGE  = 15;
    var _page    = 1;
    var _pages   = 1;
    var _total   = 0;
    var _search  = '';
    var _topId   = 0;
    var _debounce= null;
    var _loading = false;

    function auditBuildRow(log){
        var actionMeta={
            'approve'      :{label:'Approved',      cls:'audit-action-approve'},
            'reject'       :{label:'Rejected',       cls:'audit-action-reject'},
            'update_status':{label:'Status Updated', cls:'audit-action-update'},
            'create_mentor':{label:'Mentor Created', cls:'audit-action-create'},
            'assign'       :{label:'Assigned',       cls:'audit-action-assign'}
        };
        var meta=actionMeta[log.action]||{label:log.action,cls:'audit-action-default'};
        var typeLabel=log.subjectType==='application'?'Application':'Mentor Request';
        var typeCls  =log.subjectType==='application'?'type-app':'type-req';
        var note=log.note?(log.note.length>60?log.note.slice(0,60)+'â€¦':log.note):'â€”';
        var statusFlow='';
        if(log.previousStatus||log.newStatus){
            statusFlow='<span class="sa-audit-status-flow">';
            if(log.previousStatus) statusFlow+='<span class="sa-audit-prev-status">'+log.previousStatus+'</span>';
            if(log.previousStatus&&log.newStatus) statusFlow+='<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
            if(log.newStatus) statusFlow+='<span class="badge '+log.newStatus.toLowerCase().replace(/ /g,'-')+' sa-audit-new-status">'+log.newStatus+'</span>';
            statusFlow+='</span>';
        } else { statusFlow='<span style="color:#d1d5db;">â€”</span>'; }
        return '<tr class="sa-audit-row" data-log-id="'+log.id+'">'
            +'<td class="sa-audit-time"><span class="sa-audit-date">'+log.loggedAt+'</span><span class="sa-audit-clock">'+log.loggedAtTime+'</span></td>'
            +'<td><span class="sa-audit-subject">'+log.subjectLabel+'</span>'+(log.subjectId?'<span class="sa-audit-id">#'+log.subjectId+'</span>':'')+'</td>'
            +'<td><span class="sa-audit-type-badge '+typeCls+'">'+typeLabel+'</span></td>'
            +'<td><span class="sa-audit-action-badge '+meta.cls+'">'+meta.label+'</span></td>'
            +'<td>'+statusFlow+'</td>'
            +'<td><div class="sa-audit-actor"><div class="sa-audit-actor-av">'+log.performedByName.slice(0,1).toUpperCase()+'</div><div><div class="sa-audit-actor-name">'+log.performedByName+'</div>'+(log.performedByRole?'<div class="sa-audit-actor-role">'+log.performedByRole+'</div>':'')+'</div></div></td>'
            +'<td class="sa-audit-note">'+note+'</td>'
            +'</tr>';
    }

    function auditRenderPagination(){
        var pg = document.getElementById('auditPagination');
        if(!pg) return;
        if(_pages<=1){ pg.innerHTML=''; return; }
        var html='';
        html+='<button class="sa-audit-pg-btn" onclick="auditGoPage('+(_page-1)+')" '+(_page<=1?'disabled':'')+'>&lsaquo; Prev</button>';
        var start=Math.max(1,_page-2), end=Math.min(_pages,_page+2);
        if(start>1) html+='<button class="sa-audit-pg-btn" onclick="auditGoPage(1)">1</button>'+(start>2?'<span style="padding:0 4px;color:#9ca3af;">â€¦</span>':'');
        for(var i=start;i<=end;i++) html+='<button class="sa-audit-pg-btn'+(_page===i?' active':'')+' " onclick="auditGoPage('+i+')">'+i+'</button>';
        if(end<_pages) html+=(end<_pages-1?'<span style="padding:0 4px;color:#9ca3af;">â€¦</span>':'')+'<button class="sa-audit-pg-btn" onclick="auditGoPage('+_pages+')">'+_pages+'</button>';
        html+='<button class="sa-audit-pg-btn" onclick="auditGoPage('+(_page+1)+')" '+(_page>=_pages?'disabled':'')+'> Next &rsaquo;</button>';
        pg.innerHTML=html;
        var info=document.getElementById('auditPaginationInfo');
        if(info) info.textContent=_total+' total Â· page '+_page+' of '+_pages;
    }

    function auditLoadPage(page){
        if(_loading) return;
        _loading=true;
        var loading=document.getElementById('auditLoading');
        var tbody=document.getElementById('auditTbody');
        var empty=document.getElementById('auditEmpty');
        if(loading) loading.style.display='block';
        if(tbody) tbody.innerHTML='';
        if(empty) empty.style.display='none';
        var url=AUDIT_URL+'?page='+page+'&per_page='+PER_PAGE+(s_search?'&search='+encodeURIComponent(_search):'');
        fetch(url,{headers:{'X-Requested-With':'XMLHttpRequest','Cache-Control':'no-cache'}})
        .then(function(r){return r.ok?r.json():null;})
        .then(function(data){
            _loading=false;
            if(loading) loading.style.display='none';
            if(!data||!data.logs){ if(empty) empty.style.display=''; return; }
            _page=data.page; _pages=data.pages; _total=data.total;
            if(data.logs.length>0){
                if(_page===1) _topId=data.logs[0].id;
                if(tbody) tbody.innerHTML=data.logs.map(auditBuildRow).join('');
                if(empty) empty.style.display='none';
            } else {
                if(tbody) tbody.innerHTML='';
                if(empty) empty.style.display='';
            }
            auditRenderPagination();
        })
        .catch(function(){_loading=false;if(loading)loading.style.display='none';if(empty)empty.style.display='';});
    }
    var s_search=false;
    window.auditGoPage=function(p){ _page=p; auditLoadPage(p); };
    window.auditSearchDebounce=function(){
        clearTimeout(_debounce);
        _debounce=setTimeout(function(){
            _search=document.getElementById('auditSearchInput').value.trim();
            s_search=_search!=='';
            _page=1;
            auditLoadPage(1);
        },400);
    };
    document.addEventListener('DOMContentLoaded',function(){ auditLoadPage(1); });
})();
</script>

