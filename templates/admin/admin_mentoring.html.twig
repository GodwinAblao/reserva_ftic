                Assigned to: <strong>{{ req.assignedMentorName }}</strong>{% if req.assignedMentorExpertise %} Â· {{ req.assignedMentorExpertise }}{% endif %}
                {% if req.availableTime %} Â· {{ req.availableTime }}{% endif %}
                {% if req.meetingMethod %} Â· {{ req.meetingMethod }}{% endif %}
            </div>
            {% endif %}
            {% if req.adminInstructions %}
            <div class="sa-sec">Admin Instructions</div>
            <div class="sa-notes">{{ req.adminInstructions }}</div>
            {% endif %}
