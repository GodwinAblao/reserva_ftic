{# â”€â”€ Audit Log â”€â”€ #}
<div class="sa-audit-wrap" style="margin-top:24px;">
    <div class="sa-audit-header">
        <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:32px;height:32px;border-radius:8px;background:#f0fdf4;border:1px solid #bbf7d0;display:flex;align-items:center;justify-content:center;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0D9B00" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <div>
                <div style="font-size:14px;font-weight:800;color:#111827;">Activity Audit Log</div>
                <div style="font-size:11px;color:#9ca3af;">All admin &amp; super admin actions on mentor applications &amp; mentor requests</div>
            </div>
