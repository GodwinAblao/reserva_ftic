            <div class="sa-det-hero">
                <div class="sa-det-av">{{ (req.fullName ?: (req.student ? (req.student.firstName~' '~req.student.lastName) : 'Unknown'))|slice(0,1)|upper }}</div>
                <div>
                    <div class="sa-det-name">{{ req.fullName ?: (req.student ? (req.student.firstName~' '~req.student.lastName) : 'Unknown') }}</div>
