            <div style="padding:12px 0;font-size:13px;display:flex;align-items:center;gap:8px;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                <span style="color:#dc2626;font-weight:600;">This request has been cancelled by the student and can no longer be edited.</span>
            </div>
            {% else %}
            <div class="sa-sec">{{ hasChosen ? 'Update Assignment' : 'Assign Mentor' }}</div>
            {% if hasChosen %}
            <div class="sa-chosen">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                Student selected: <strong>{{ req.mentorProfile.displayName }}</strong> ({{ req.mentorProfile.specialization }})
            </div>
            <form method="post" data-ajax="true" action="{{ path('admin_role_mentorship_assign', {'id': req.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('mentorship_assign_'~req.id) }}">
                <input type="hidden" name="mentor_name" value="{{ req.mentorProfile.displayName }}">
                <input type="hidden" name="expertise" value="{{ req.mentorProfile.specialization }}">
                <input type="hidden" name="available_dates" value="{{ req.availableDates }}">
