<script>
/* â”€â”€ toast â”€â”€ */
function _saToast(msg,ok){
    var n=document.createElement('div');
    n.style.cssText='position:fixed;top:16px;right:16px;z-index:9999;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;box-shadow:0 4px 12px rgba(0,0,0,.12);transition:opacity .3s;';
    n.style.background=ok?'#d1fae5':'#fee2e2'; n.style.color=ok?'#065f46':'#991b1b';
    n.textContent=msg; document.body.appendChild(n);
    setTimeout(function(){n.style.opacity='0';setTimeout(function(){n.remove();},300);},3200);
}
/* â”€â”€ Create Mentor modal â”€â”€ */
function openCreateMentor(){document.getElementById('createMentorModal').classList.add('open');}
function closeCreateMentor(){document.getElementById('createMentorModal').classList.remove('open');}
(function(){
    var m=document.getElementById('createMentorModal');
    if(m&&m.parentNode!==document.body) document.body.appendChild(m);
    closeCreateMentor();
})();
function cmFillUser(sel){
    var o=sel.options[sel.selectedIndex];
    document.getElementById('cm_user_id').value=o.value;
    document.getElementById('cm_first').value=o.dataset.first||'';
    document.getElementById('cm_middle').value=o.dataset.middle||'';
    document.getElementById('cm_last').value=o.dataset.last||'';
    document.getElementById('cm_email').value=o.dataset.email||'';
    document.getElementById('cm_program').value=o.dataset.program||'';
    document.getElementById('cm_role').value=o.dataset.role||'';
}
/* â”€â”€ type dropdown toggle â”€â”€ */
function saOnTypeChange(){
    var v=document.getElementById('saTypeSelect').value;
    document.getElementById('sa-list-all').style.display   = v==='all'    ? '' : 'none';
    document.getElementById('sa-list-custom').style.display = v==='custom' ? '' : 'none';
    document.getElementById('sa-list-apply').style.display  = v==='apply'  ? '' : 'none';
    saClearCenter();
}
/* init on load */
document.addEventListener('DOMContentLoaded', function(){ saOnTypeChange(); });
/* â”€â”€ item selection â”€â”€ */
function saClearCenter(){
    document.getElementById('saCenterEmpty').style.display='';
    document.querySelectorAll('.sa-det').forEach(function(el){el.style.display='none';});
    document.querySelectorAll('.sa-item').forEach(function(el){el.classList.remove('active');});
}
function saSelectItem(el,type,id){
    saClearCenter();
    var pane=document.getElementById('sa-det-'+type+'-'+id);
    if(pane){pane.style.display='';document.getElementById('saCenterEmpty').style.display='none';}
    if(el) el.classList.add('active');
}
/* â”€â”€ mentor input toggle â”€â”€ */
function rqToggle(id){
    var sel=document.getElementById('rq-sel-'+id);
    var txt=document.getElementById('rq-txt-'+id);
    var lbl=document.getElementById('rq-tlbl-'+id);
    if(!sel||!txt||!lbl) return;
    var manual=txt.style.display!=='none';
    if(manual){txt.style.display='none';txt.removeAttribute('required');sel.style.display='';lbl.textContent='Type manually';}
    else{sel.style.display='none';sel.value='';txt.style.display='';lbl.textContent='Pick from system';}
}
function rqFill(id){
    var sel=document.getElementById('rq-sel-'+id);
    var spec=document.getElementById('rq-spec-'+id);
    if(!sel||!spec) return;
    var o=sel.options[sel.selectedIndex];
    if(o&&o.value&&o.dataset.spec){for(var i=0;i<spec.options.length;i++){if(spec.options[i].value===o.dataset.spec){spec.selectedIndex=i;break;}}}
}
/* â”€â”€ decline application â”€â”€ */
function saDeclineApp(id){
    var note=prompt('Reason for rejection (optional):','');
    if(note===null) return;
    document.getElementById('decline-note-'+id).value=note;
    document.getElementById('decline-form-'+id).submit();
}
/* â”€â”€ collapsible group headers â”€â”€ */
var SA_STORE = 'sa_groups_admin';
function saGroupsLoad(){ try{ return JSON.parse(localStorage.getItem(SA_STORE)||'{}'); }catch(e){ return {}; } }
function saGroupsSave(s){ try{ localStorage.setItem(SA_STORE, JSON.stringify(s)); }catch(e){} }
function saInitGroups(){
    var state = saGroupsLoad();
    document.querySelectorAll('.sa-group-hd[data-group]').forEach(function(hd){
        var key = hd.dataset.group;
        var body = document.querySelector('.sa-group-body[data-body="'+key+'"]');
        if(!body) return;
        var collapsed = Object.prototype.hasOwnProperty.call(state, key) ? state[key] : (key.endsWith('-week') || key.endsWith('-older'));
        body.style.maxHeight = collapsed ? '0px' : body.scrollHeight + 'px';
        if(collapsed){ hd.classList.add('collapsed'); body.classList.add('collapsed'); }
        else { hd.classList.remove('collapsed'); body.classList.remove('collapsed'); }
    });
}
function saToggleGroup(hd){
    var key = hd.dataset.group;
    var body = document.querySelector('.sa-group-body[data-body="'+key+'"]');
    if(!body) return;
    var isCollapsed = hd.classList.contains('collapsed');
    var state = saGroupsLoad();
    if(isCollapsed){
        hd.classList.remove('collapsed'); body.classList.remove('collapsed');
        body.style.maxHeight = body.scrollHeight + 'px';
        state[key] = false;
    } else {
        hd.classList.add('collapsed'); body.classList.add('collapsed');
        body.style.maxHeight = '0px';
        state[key] = true;
    }
    saGroupsSave(state);
}
document.addEventListener('DOMContentLoaded', saInitGroups);
/* â”€â”€ search filter â”€â”€ */
function saFilterList(){
    var q=document.getElementById('saSearch').value.toLowerCase();
    document.querySelectorAll('.sa-item').forEach(function(el){
        el.style.display=(!q||el.dataset.name.includes(q))?'':'none';
    });
}

/* â”€â”€ AJAX for assign forms (with post-success lock to prevent double audit logs) â”€â”€ */
function bindAjaxForms(){
    document.querySelectorAll('form[data-ajax="true"]').forEach(function(form){
        if(form.dataset.ajaxBound === '1') return;
        form.dataset.ajaxBound = '1';
        form.addEventListener('submit',function(e){
            e.preventDefault();
            var btn=form.querySelector('button[type="submit"]');
            var orig=btn?btn.innerHTML:'';
            if(btn){btn.disabled=true;btn.innerHTML='Savingâ€¦';}
            fetch(form.action,{method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'},body:new FormData(form)})
            .then(function(r){if(!r.ok)throw new Error();return r.json();})
            .then(function(j){
                if(j.success){
                    if(btn){btn.innerHTML='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Saved';btn.style.background='#0D9B00';}
                    form.querySelectorAll('input,select,textarea,button').forEach(function(el){el.disabled=true;});
                    _saToast(j.message||'Updated.',true);
                } else {
                    if(btn){btn.disabled=false;btn.innerHTML=orig;}
                    _saToast(j.message||'Error.',false);
                }
            })
            .catch(function(){
                if(btn){btn.disabled=false;btn.innerHTML=orig;}
                _saToast('Could not save. Please try again.',false);
            });
        });
    });
}
document.addEventListener('DOMContentLoaded',function(){
    bindAjaxForms();
    document.addEventListener('keydown',function(e){if(e.key==='Escape') closeCreateMentor();});
});
document.addEventListener('turbo:load', bindAjaxForms);

</script>
