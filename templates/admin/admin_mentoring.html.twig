                </div>
                <div class="sa-assign-field" style="margin-bottom:0;"><label>Notes / Instructions</label>
                    <textarea name="instructions" class="sa-textarea" placeholder="Add notes...">{{ req.adminInstructions ?? '' }}</textarea>
                </div>
                <div class="sa-arow"><button type="submit" class="sa-btn-send">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>Update
                </button></div>
            </form>
            {% else %}
            <form method="post" data-ajax="true" action="{{ path('admin_role_mentorship_assign', {'id': req.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('mentorship_assign_'~req.id) }}">
                <div class="sa-grid2">
                    <div class="sa-assign-field">
                        <label style="display:flex;align-items:center;justify-content:space-between;">Mentor
                            <span style="font-size:10px;font-weight:600;color:#0D9B00;cursor:pointer;" onclick="rqToggle({{ req.id }})" id="rq-tlbl-{{ req.id }}">Type manually</span>
                        </label>
                        <select name="mentor_id" class="sa-inp" id="rq-sel-{{ req.id }}" onchange="rqFill({{ req.id }})">
                            <option value="">â€” Pick from system â€”</option>
                            {% for mentor in mentors %}<option value="{{ mentor.id }}" data-name="{{ mentor.displayName }}" data-spec="{{ mentor.specialization }}" {{ req.assignedMentorName==mentor.displayName?'selected':'' }}>{{ mentor.displayName }} ({{ mentor.specialization }})</option>{% endfor %}
                        </select>
                        <input type="text" name="mentor_name" class="sa-inp" id="rq-txt-{{ req.id }}" placeholder="Enter mentor nameâ€¦" value="{{ req.assignedMentorName ?? '' }}" style="display:none;margin-top:6px;">
                    </div>
                    <div class="sa-assign-field"><label>Specialization</label>
                        <select name="expertise" class="sa-inp" id="rq-spec-{{ req.id }}">
                            <option value="">Selectâ€¦</option>
                            {% for specialization in allSpecializations %}<option value="{{ specialization.name }}" {{ req.assignedMentorExpertise==specialization.name?'selected':'' }}>{{ specialization.name }}</option>{% endfor %}
                        </select>
                    </div>
                </div>
                <div class="sa-grid2">
                    <div class="sa-assign-field"><label>Meeting Method</label>
                        <select name="meeting_method" class="sa-inp">
                            <option value="In Person" {{ req.meetingMethod=='In Person'?'selected':'' }}>In Person</option>
                            <option value="Online" {{ req.meetingMethod=='Online'?'selected':'' }}>Online</option>
                            <option value="Hybrid" {{ req.meetingMethod=='Hybrid'?'selected':'' }}>Hybrid</option>
                        </select>
                    </div>
                    <div class="sa-assign-field"><label>Day</label>
                        <select name="available_dates" class="sa-inp">
                            {% for day in ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'] %}<option value="{{ day }}" {{ req.availableDates==day?'selected':'' }}>{{ day }}</option>{% endfor %}
                        </select>
                    </div>
                </div>
                <div class="sa-grid2">
                    <div class="sa-assign-field"><label>Start Time</label>
                        <input type="time" name="available_time_start" class="sa-inp" value="{{ req.availableTime ? req.availableTime|split(' â€“ ')|first|trim : '' }}">
                    </div>
                    <div class="sa-assign-field"><label>End Time</label>
                        <input type="time" name="available_time_end" class="sa-inp" value="{{ req.availableTime and 'â€“' in req.availableTime ? req.availableTime|split('â€“')|last|trim : '' }}">
                    </div>
                </div>
                <div class="sa-grid2">
                    <div class="sa-assign-field">
                        <label>Status</label>
                        <input type="hidden" name="status" value="Assigned">
                        <input type="text" class="sa-inp" value="Assigned" readonly style="background:#f0fdf4;color:#0D9B00;font-weight:700;cursor:not-allowed;">
                    </div>
                </div>
                <div class="sa-assign-field" style="margin-bottom:0;"><label>Notes</label>
                    <textarea name="instructions" class="sa-textarea" placeholder="Write any notes...">{{ req.adminInstructions ?? '' }}</textarea>
                </div>
                <div class="sa-arow"><button type="submit" class="sa-btn-send">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>Send
                </button></div>
            </form>
            {% endif %}
            {% endif %}
        </div>
        {% endfor %}

        {# â”€â”€ Application detail panes â”€â”€ #}
        {% for app in applications %}
        <div class="sa-det" id="sa-det-apply-{{ app.id }}" style="display:none">
            <div class="sa-det-ts">{{ app.createdAt|date('h:i a') }}</div>
            <div class="sa-det-hero">
                <div class="sa-det-av">{{ (app.firstName ~ app.lastName)|slice(0,1)|upper }}</div>
                <div>
                    <div class="sa-det-name">{{ app.firstName }} {{ app.lastName }}</div>
                    <div class="sa-det-sub">{{ app.email }}</div>
                </div>
            </div>
            <div class="sa-sec">Mentoring Application</div>
            <div class="sa-hr"></div>
            <div class="sa-sec">Personal Information</div>
            <div class="sa-grid4">
                <div class="sa-field"><label>First Name</label><p>{{ app.firstName ?: 'â€”' }}</p></div>
                <div class="sa-field"><label>Middle Name</label><p>{{ app.middleName ?: 'â€”' }}</p></div>
                <div class="sa-field"><label>Last Name</label><p>{{ app.lastName ?: 'â€”' }}</p></div>
                <div class="sa-field"><label>Contact Number</label><p>{{ app.contactNumber ?: 'â€”' }}</p></div>
            </div>
            <div class="sa-grid4">
                <div class="sa-field"><label>Email</label><p style="font-size:11px;">{{ app.email }}</p></div>
                <div class="sa-field"><label>Program / Course</label><p>{{ app.programCourse ?: 'â€”' }}</p></div>
                <div class="sa-field"><label>Status</label><p><span class="badge {{ app.status|lower }}">{{ app.status }}</span></p></div>
            </div>
            <div class="sa-sec">Academic Background &amp; Mentoring</div>
            <div class="sa-grid4">
                <div class="sa-field"><label>Specialization</label><p>{{ app.specialization }}</p></div>
                <div class="sa-field"><label>Experience</label><p>{% if app.yearsOfExperience %}{{ app.yearsOfExperience }} {{ app.experienceUnit|default('Years') }}{% else %}â€”{% endif %}</p></div>
                <div class="sa-field"><label>Availability</label><p>{{ app.availabilityTime ?: 'â€”' }}</p></div>
            </div>
            <div class="sa-grid2">
                <div class="sa-field"><label>Current Profession</label><p>{{ app.currentProfession ?: 'â€”' }}</p></div>
                <div class="sa-field"><label>Highest Education</label><p>{{ app.highestEducation ?: 'â€”' }}</p></div>
            </div>
            {% if app.reason %}
            <div class="sa-sec">Reason / Message</div>
            <div class="sa-notes">{{ app.reason }}</div>
            {% endif %}
            {% if app.supportingDescription %}
            <div class="sa-sec">Supporting Description</div>
            <div class="sa-notes">{{ app.supportingDescription }}</div>
            {% endif %}
            {% if app.supportingDocuments %}
            <div class="sa-sec">Proof of Expertise</div>
            <div class="sa-proof-row">
                {% for file in app.supportingDocuments %}
                    {% if file ends with '.pdf' %}
                    <a href="{{ asset('uploads/profiles/' ~ file) }}" target="_blank" class="sa-proof-pdf">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>PDF
                    </a>
                    {% else %}
                    <img src="{{ asset('uploads/profiles/' ~ file) }}" class="sa-proof-img" alt="proof" onclick="window.open(this.src)">
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}
            {# Admin can view applications but not approve/reject - only Super Admin can #}
            {% if is_super_admin and app.status in ['Pending','Pending Review'] %}
            <form method="post" action="{{ path('mentoring_review_application', {'id': app.id, 'decision': 'approve'}) }}" id="approve-form-{{ app.id }}">
                <input type="hidden" name="_token" value="{{ csrf_token('review_mentor_application_'~app.id) }}">
                <div class="sa-arow" style="margin-top:20px;padding-top:16px;border-top:1px solid #f3f4f6;align-items:flex-end;gap:12px;flex-wrap:wrap;">
                    <div style="display:flex;flex-direction:column;gap:4px;flex:1;min-width:180px;">
                        <label style="font-size:10.5px;font-weight:600;color:#6b7280;">Valid Until <span style="color:#ef4444;">*</span></label>
                        <input type="date" name="valid_until" class="sa-inp" required min="{{ "now"|date("Y-m-d") }}" id="valid-until-{{ app.id }}">
                    </div>
                    <div style="display:flex;gap:10px;">
                        <button type="button" class="sa-btn-reject" onclick="saDeclineApp({{ app.id }})">Reject</button>
                        <button type="submit" class="sa-btn-approve">Approve</button>
                    </div>
                </div>
            </form>
            <form method="post" action="{{ path('mentoring_review_application', {'id': app.id, 'decision': 'decline'}) }}" id="decline-form-{{ app.id }}" style="display:none">
                <input type="hidden" name="_token" value="{{ csrf_token('review_mentor_application_'~app.id) }}">
                <input type="hidden" name="admin_note" id="decline-note-{{ app.id }}">
            </form>
            {% else %}
            <div style="margin-top:16px;padding-top:14px;border-top:1px solid #f3f4f6;display:flex;align-items:center;gap:10px;">
                <span class="badge {{ app.status|lower }}" style="font-size:12px;padding:4px 14px;">{{ app.status }}</span>
                {% if app.validUntil %}<span style="font-size:11.5px;color:#6b7280;">Valid until {{ app.validUntil|date('M d, Y') }}</span>{% endif %}
                {% if app.adminNote %}<span style="font-size:11.5px;color:#9ca3af;font-style:italic;">Note: {{ app.adminNote }}</span>{% endif %}
            </div>
            {% if not is_super_admin and app.status in ['Pending','Pending Review'] %}
            <div style="margin-top:12px;padding:10px 14px;background:#fef9c3;border-radius:8px;font-size:12px;color:#854d0e;">
                <strong>Note:</strong> Only Super Admin can approve or reject mentor applications.
            </div>
            {% endif %}
            {% endif %}
        </div>
        {% endfor %}

    </div>{# end center #}

