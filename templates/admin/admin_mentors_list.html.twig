{% extends 'layouts/app.html.twig' %}
{% block title %}Mentors | Admin | Reserva FTIC{% endblock %}
{% block stylesheets %}{{ parent() }}
<link rel="preload" href="{{ asset('styles/mentoring.css') }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ asset('styles/mentoring.css') }}"></noscript>
<style>
.ml-page { display:flex; flex-direction:column; gap:18px; }
.ml-toolbar { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
.ml-search { flex:1; min-width:180px; display:flex; align-items:center; gap:8px; border:1px solid #e5e7eb; border-radius:9px; padding:0 14px; background:#fff; height:40px; }
.ml-search input { flex:1; border:none; outline:none; font-size:13px; color:#374151; background:transparent; }
.ml-search svg { color:#9ca3af; flex-shrink:0; }
.ml-filter { padding:9px 14px; border:1px solid #e5e7eb; border-radius:9px; font-size:13px; color:#374151; background:#fff; cursor:pointer; }
.ml-filter:focus { outline:none; border-color:#0D9B00; }
.ml-back { display:flex; align-items:center; gap:7px; padding:10px 16px; background:#fff; color:#374151; border:1px solid #e5e7eb; border-radius:9px; font-size:13px; font-weight:600; text-decoration:none; transition:background .15s; }
.ml-back:hover { background:#f9fafb; }
.ml-count { font-size:12px; color:#6b7280; white-space:nowrap; align-self:center; }

/* grid */
.ml-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; }

/* card */
.ml-card { background:#fff; border:1px solid #e5e7eb; border-radius:14px; padding:20px; display:flex; flex-direction:column; gap:12px; transition:box-shadow .15s; }
.ml-card:hover { box-shadow:0 4px 18px rgba(0,0,0,.07); }
.ml-card-top { display:flex; align-items:center; gap:12px; }
.ml-avatar { width:46px; height:46px; border-radius:50%; background:#e5e7eb; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:700; color:#374151; flex-shrink:0; }
.ml-avatar.green { background:#dcfce7; color:#166534; }
.ml-name { font-size:14px; font-weight:700; color:#111827; margin-bottom:2px; }
.ml-email { font-size:11.5px; color:#9ca3af; }
.ml-spec-badge { display:inline-flex; align-items:center; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:700; background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; width:fit-content; }
.ml-divider { height:1px; background:#f3f4f6; }
.ml-meta { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.ml-meta-item label { font-size:10px; color:#9ca3af; font-weight:600; display:block; margin-bottom:2px; }
.ml-meta-item p { font-size:12px; font-weight:600; color:#374151; margin:0; }
.ml-pts { display:flex; align-items:center; gap:5px; font-size:12px; font-weight:700; color:#0D9B00; }

/* empty state */
.ml-empty { text-align:center; padding:60px 20px; color:#9ca3af; font-size:13px; }
.ml-empty svg { margin-bottom:12px; opacity:.4; }

/* no-result message */
#mlNoResult { display:none; text-align:center; padding:40px; color:#9ca3af; font-size:13px; }

/* read-only notice */
.admin-readonly-notice { background:#f0fdf4; border:1px solid #bbf7d0; border-radius:8px; padding:12px 16px; margin-bottom:16px; font-size:12.5px; color:#166534; display:flex; align-items:center; gap:8px; }
.admin-readonly-notice svg { flex-shrink:0; }
</style>
{% endblock %}

{% block content %}
{# Read-only notice for admin #}
<div class="admin-readonly-notice">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><circle cx="12" cy="11" r="3"/></svg>
    <span><strong>View-Only Mode:</strong> As an Admin, you can view mentors but cannot edit or delete them. Contact a Super Admin for mentor management.</span>
</div>

<div class="ml-page">

    <div class="ml-toolbar">
        <a href="{{ path('admin_role_mentorship_coordination') }}" class="ml-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            Back
        </a>
        <div class="ml-search">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="mlSearch" placeholder="Search mentors by name, specialization…" oninput="mlFilter()">
        </div>
        <select class="ml-filter" id="mlSpecFilter" onchange="mlFilter()">
            <option value="">All Specializations</option>
            {% set specs = [] %}
            {% for m in mentors %}
                {% if m.specialization not in specs %}
                    {% set specs = specs|merge([m.specialization]) %}
                    <option value="{{ m.specialization|lower }}">{{ m.specialization }}</option>
                {% endif %}
            {% endfor %}
        </select>
        <span class="ml-count" id="mlCount">{{ mentors|length }} mentor{{ mentors|length != 1 ? 's' : '' }}</span>
    </div>

    {% if mentors is empty %}
    <div class="ml-empty">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        <div>No mentors found.</div>
    </div>
    {% else %}
    <div id="mlNoResult">No mentors match your search.</div>
    <div class="ml-grid" id="mlGrid">
        {% for mentor in mentors %}
        <div class="ml-card" data-name="{{ mentor.displayName|lower }}" data-spec="{{ mentor.specialization|lower }}">
            <div class="ml-card-top">
                <div class="ml-avatar green">{{ mentor.displayName|slice(0,1)|upper }}</div>
                <div>
                    <div class="ml-name">{{ mentor.displayName }}</div>
                    <div class="ml-email">{{ mentor.user ? mentor.user.email : '—' }}</div>
                </div>
            </div>
            <div class="ml-spec-badge">{{ mentor.specialization }}</div>
            <div class="ml-divider"></div>
            <div class="ml-meta">
                <div class="ml-meta-item">
                    <label>Program</label>
                    <p>{{ mentor.user ? (mentor.user.degreeName ?: mentor.user.degree ?: '—') : '—' }}</p>
                </div>
                <div class="ml-meta-item">
                    <label>Engagement</label>
                    <p class="ml-pts">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="#0D9B00" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        {{ mentor.engagementPoints }} pts
                    </p>
                </div>
                {% if mentor.availabilityDays or (mentor.availabilityStart and mentor.availabilityEnd) %}
                <div class="ml-meta-item">
                    <label>Availability</label>
                    <p>{% if mentor.availabilityDays %}{{ mentor.availabilityDays|join(', ') }}{% endif %}{% if mentor.availabilityStart and mentor.availabilityEnd %}{% if mentor.availabilityDays %}, {% endif %}{{ ('2000-01-01 ' ~ mentor.availabilityStart)|date('g:i A') }} – {{ ('2000-01-01 ' ~ mentor.availabilityEnd)|date('g:i A') }}{% endif %}</p>
                </div>
                {% endif %}
                {% if mentor.user %}
                <div class="ml-meta-item">
                    <label>Role</label>
                    <p>{{ mentor.user.roles|join(', ')|replace({'ROLE_':'','_':' '})|lower|capitalize }}</p>
                </div>
                {% endif %}
            </div>
            {% if mentor.bio %}
            <div style="font-size:11.5px;color:#6b7280;line-height:1.5;background:#f9fafb;border-radius:8px;padding:8px 11px;">{{ mentor.bio|slice(0,120) }}{% if mentor.bio|length > 120 %}…{% endif %}</div>
            {% endif %}
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>

<script>
function mlFilter() {
    var q    = document.getElementById('mlSearch').value.toLowerCase();
    var spec = document.getElementById('mlSpecFilter').value.toLowerCase();
    var cards = document.querySelectorAll('#mlGrid .ml-card');
    var shown = 0;
    cards.forEach(function(c) {
        var nameMatch = !q || c.dataset.name.includes(q) || c.dataset.spec.includes(q);
        var specMatch = !spec || c.dataset.spec === spec;
        var ok = nameMatch && specMatch;
        c.style.display = ok ? '' : 'none';
        if (ok) shown++;
    });
    var nr = document.getElementById('mlNoResult');
    var cnt = document.getElementById('mlCount');
    if (nr) nr.style.display = shown === 0 ? '' : 'none';
    if (cnt) cnt.textContent = shown + ' mentor' + (shown !== 1 ? 's' : '');
}
</script>
{% endblock %}
