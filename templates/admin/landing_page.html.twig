{% extends 'layouts/app.html.twig' %}

{% block content %}
<div class="lp-page-wrap">
    <div class="content-header landing-page-header">
        <div>
            <h2>Landing Page</h2>
            <p>Update the public Home, Offers, About, Mission, and FAQ sections without changing the layout.</p>
        </div>
        <button type="button" id="landingPageEditToggle" class="btn-secondary landing-edit-toggle">Edit</button>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-message flash-{{ label }}">
                <div class="flash-content">
                    <div class="flash-icon">{{ label == 'success' ? 'OK' : '!' }}</div>
                    <div>{{ message }}</div>
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    <form id="landingPageForm" method="post" enctype="multipart/form-data" class="landing-page-form is-locked">
        <input type="hidden" name="_token" value="{{ csrf_token('landing_page_content') }}">

        <section class="landing-section-card">
            <div class="section-title-row">
                <div>
                    <h3>Home</h3>
                    <p>Hero content shown at the top of the landing page.</p>
                </div>
            </div>

            <div class="grid-2">
                <label>
                    <span>Hero Title</span>
                    <input type="text" name="hero_title" value="{{ landing.heroTitle }}">
                </label>
                <label>
                    <span>CTA Label</span>
                    <input type="text" name="hero_cta_label" value="{{ landing.heroCtaLabel }}">
                </label>
            </div>

            <label>
                <span>Hero Description</span>
                <textarea name="hero_description" rows="4">{{ landing.heroDescription }}</textarea>
            </label>

            <div class="grid-2">
                <label>
                    <span>CTA URL</span>
                    <input type="text" name="hero_cta_url" value="{{ landing.heroCtaUrl }}">
                </label>
            </div>

            {% set heroImageSrc = landing.heroImage starts with('http') ? landing.heroImage : asset(landing.heroImage|trim('/')) %}
            <div class="landing-image-uploader" data-image-upload>
                <input type="hidden" name="hero_image_url" value="{{ landing.heroImage }}" data-image-path>
                <input type="file" name="hero_image_file" accept="image/*" class="landing-image-input" data-image-input>
                <div class="landing-upload-preview">
                    <img src="{{ heroImageSrc }}" alt="Hero image preview" data-image-preview>
                </div>
                <div class="landing-upload-details">
                    <span class="landing-upload-label">Hero Image</span>
                    <strong data-image-filename>{{ landing.heroImage ? landing.heroImage|split('/')|last : 'No image selected' }}</strong>
                    <div class="landing-upload-actions">
                        <button type="button" class="btn-secondary landing-upload-button" data-image-button>Upload Image</button>
                        <span>JPG, PNG, WebP, or GIF</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="landing-section-card">
            <div class="section-title-row">
                <div>
                    <h3>Offers</h3>
                    <p>Update the four feature cards shown in the offers section.</p>
                </div>
            </div>

            <div class="grid-2">
                <label>
                    <span>Section Title</span>
                    <input type="text" name="offers_title" value="{{ landing.offersTitle }}">
                </label>
                <label>
                    <span>Section Subtitle</span>
                    <input type="text" name="offers_subtitle" value="{{ landing.offersSubtitle }}">
                </label>
            </div>

            <div class="cards-grid">
                {% for offer in landing.offers %}
                    <article class="editor-card">
                        <h4>{{ offer.title }}</h4>
                        <input type="hidden" name="offers[{{ loop.index0 }}][key]" value="{{ offer.key }}">
                        <label>
                            <span>Title</span>
                            <input type="text" name="offers[{{ loop.index0 }}][title]" value="{{ offer.title }}">
                        </label>
                        <label>
                            <span>Description</span>
                            <textarea name="offers[{{ loop.index0 }}][description]" rows="3">{{ offer.description }}</textarea>
                        </label>
                        <div class="grid-2">
                            <label>
                                <span>Link Label</span>
                                <input type="text" name="offers[{{ loop.index0 }}][linkLabel]" value="{{ offer.linkLabel }}">
                            </label>
                            <label>
                                <span>Link URL</span>
                                <input type="text" name="offers[{{ loop.index0 }}][linkUrl]" value="{{ offer.linkUrl }}">
                            </label>
                        </div>
                        {% set offerImageSrc = offer.image starts with('http') ? offer.image : asset(offer.image|trim('/')) %}
                        <div class="landing-image-uploader compact" data-image-upload>
                            <input type="hidden" name="offers[{{ loop.index0 }}][image]" value="{{ offer.image }}" data-image-path>
                            <input type="file" name="offer_image_files[{{ loop.index0 }}]" accept="image/*" class="landing-image-input" data-image-input>
                            <div class="landing-upload-preview">
                                <img src="{{ offerImageSrc }}" alt="{{ offer.title }} image preview" data-image-preview>
                            </div>
                            <div class="landing-upload-details">
                                <span class="landing-upload-label">Image</span>
                                <strong data-image-filename>{{ offer.image ? offer.image|split('/')|last : 'No image selected' }}</strong>
                                <div class="landing-upload-actions">
                                    <button type="button" class="btn-secondary landing-upload-button" data-image-button>Upload Image</button>
                                    <span>Replaces on save</span>
                                </div>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>

        <section class="landing-section-card">
            <div class="section-title-row">
                <div>
                    <h3>About</h3>
                    <p>Edit the public About content and logo image.</p>
                </div>
            </div>

            <div class="grid-2">
                <label>
                    <span>Section Title</span>
                    <input type="text" name="about_title" value="{{ landing.aboutTitle }}">
                </label>
                <label>
                    <span>Section Subtitle</span>
                    <input type="text" name="about_subtitle" value="{{ landing.aboutSubtitle }}">
                </label>
            </div>

            {% set aboutImageSrc = landing.aboutImage starts with('http') ? landing.aboutImage : asset(landing.aboutImage|trim('/')) %}
            <div class="landing-image-uploader" data-image-upload>
                <input type="hidden" name="about_image_url" value="{{ landing.aboutImage }}" data-image-path>
                <input type="file" name="about_image_file" accept="image/*" class="landing-image-input" data-image-input>
                <div class="landing-upload-preview">
                    <img src="{{ aboutImageSrc }}" alt="About image preview" data-image-preview>
                </div>
                <div class="landing-upload-details">
                    <span class="landing-upload-label">About Image</span>
                    <strong data-image-filename>{{ landing.aboutImage ? landing.aboutImage|split('/')|last : 'No image selected' }}</strong>
                    <div class="landing-upload-actions">
                        <button type="button" class="btn-secondary landing-upload-button" data-image-button>Upload Image</button>
                        <span>JPG, PNG, WebP, or GIF</span>
                    </div>
                </div>
            </div>

            <div class="grid-2">
                {% for paragraph in landing.aboutParagraphs %}
                    <label>
                        <span>Paragraph {{ loop.index }}</span>
                        <textarea name="about_paragraphs[]" rows="4">{{ paragraph }}</textarea>
                    </label>
                {% endfor %}
            </div>
        </section>

        <section class="landing-section-card">
            <div class="section-title-row">
                <div>
                    <h3>Mission</h3>
                    <p>Edit the Vision, Mission, and Goals cards.</p>
                </div>
            </div>

            <div class="grid-2">
                <label>
                    <span>Section Title</span>
                    <input type="text" name="mission_title" value="{{ landing.missionTitle }}">
                </label>
                <label>
                    <span>Section Subtitle</span>
                    <input type="text" name="mission_subtitle" value="{{ landing.missionSubtitle }}">
                </label>
            </div>

            <div class="cards-grid mission-grid">
                {% for item in landing.missionItems %}
                    <article class="editor-card">
                        <h4>{{ item.title }}</h4>
                        <label>
                            <span>Title</span>
                            <input type="text" name="mission_items[{{ loop.index0 }}][title]" value="{{ item.title }}">
                        </label>
                        <label>
                            <span>Text</span>
                            <textarea name="mission_items[{{ loop.index0 }}][text]" rows="4">{{ item.text }}</textarea>
                        </label>
                    </article>
                {% endfor %}
            </div>
        </section>

        <section class="landing-section-card">
            <div class="section-title-row">
                <div>
                    <h3>FAQ</h3>
                    <p>Manage the questions shown in the landing page FAQ accordion.</p>
                </div>
                <button type="button" class="btn-secondary" id="addFaqItem">+ Add FAQ</button>
            </div>

            <div class="grid-2">
                <label>
                    <span>Section Title</span>
                    <input type="text" name="faq_title" value="{{ landing.faqTitle }}">
                </label>
                <label>
                    <span>Section Subtitle</span>
                    <input type="text" name="faq_subtitle" value="{{ landing.faqSubtitle }}">
                </label>
            </div>

            <div id="faqList" class="faq-editor-list">
                {% for faq in landing.faqItems %}
                    <article class="editor-card faq-item-editor">
                        <div class="faq-editor-header">
                            <h4>FAQ Item {{ loop.index }}</h4>
                            <button type="button" class="btn-secondary remove-faq-item">Remove</button>
                        </div>
                        <label>
                            <span>Question</span>
                            <input type="text" name="faq_items[{{ loop.index0 }}][question]" value="{{ faq.question }}">
                        </label>
                        <label>
                            <span>Answer</span>
                            <textarea name="faq_items[{{ loop.index0 }}][answer]" rows="4">{{ faq.answer }}</textarea>
                        </label>
                    </article>
                {% endfor %}
            </div>

            <div class="faq-pagination" id="faqPagination" aria-label="FAQ pagination">
                <button type="button" class="btn-secondary" id="faqPrevPage">Previous</button>
                <div class="faq-pagination-info">
                    <span id="faqPageLabel">Page 1</span>
                    <span id="faqPageCount">of 1</span>
                </div>
                <button type="button" class="btn-secondary" id="faqNextPage">Next</button>
            </div>
        </section>

        <section class="landing-section-card">
            <div class="section-title-row">
                <div>
                    <h3>Social Links</h3>
                    <p>Add or remove any social platform you want to show on the public landing page.</p>
                </div>
                <button type="button" class="btn-secondary" id="addSocialLink">+ Add Social</button>
            </div>

            <div class="grid-2">
                <label>
                    <span>Section Title</span>
                    <input type="text" name="social_section_title" value="{{ landing.socialSectionTitle }}">
                </label>
                <label>
                    <span>Section Subtitle</span>
                    <input type="text" name="social_section_subtitle" value="{{ landing.socialSectionSubtitle }}">
                </label>
            </div>

            <div id="socialLinksList" class="faq-editor-list">
                {% for social in landing.socialLinks %}
                    <article class="editor-card social-item-editor">
                        <div class="faq-editor-header">
                            <h4>Social Link {{ loop.index }}</h4>
                            <button type="button" class="btn-secondary remove-social-item">Remove</button>
                        </div>
                        <label>
                            <span>Platform</span>
                            <input type="text" name="social_links[{{ loop.index0 }}][platform]" value="{{ social.platform }}">
                        </label>
                        <label>
                            <span>URL</span>
                            <input type="text" name="social_links[{{ loop.index0 }}][url]" value="{{ social.url }}">
                        </label>
                    </article>
                {% endfor %}
            </div>
        </section>

        <section class="landing-section-card">
            <div class="section-title-row">
                <div>
                    <h3>Contact Us</h3>
                    <p>Add or remove contact methods shown below the social links.</p>
                </div>
                <button type="button" class="btn-secondary" id="addContactLink">+ Add Contact</button>
            </div>

            <div class="grid-2">
                <label>
                    <span>Section Title</span>
                    <input type="text" name="contact_section_title" value="{{ landing.contactSectionTitle }}">
                </label>
                <label>
                    <span>Section Subtitle</span>
                    <input type="text" name="contact_section_subtitle" value="{{ landing.contactSectionSubtitle }}">
                </label>
            </div>

            <div id="contactLinksList" class="faq-editor-list">
                {% for contact in landing.contactLinks %}
                    <article class="editor-card contact-item-editor">
                        <div class="faq-editor-header">
                            <h4>Contact Link {{ loop.index }}</h4>
                            <button type="button" class="btn-secondary remove-contact-item">Remove</button>
                        </div>
                        <div class="grid-2">
                            <label>
                                <span>Label</span>
                                <input type="text" name="contact_links[{{ loop.index0 }}][label]" value="{{ contact.label }}">
                            </label>
                            <label>
                                <span>Display Text</span>
                                <input type="text" name="contact_links[{{ loop.index0 }}][displayText]" value="{{ contact.displayText }}">
                            </label>
                        </div>
                        <label>
                            <span>URL</span>
                            <input type="text" name="contact_links[{{ loop.index0 }}][url]" value="{{ contact.url }}">
                        </label>
                    </article>
                {% endfor %}
            </div>
        </section>

        <div class="form-footer" id="landingPageSaveFooter">
            <button type="submit" class="btn-primary" id="landingPageSaveButton" disabled>Save Changes</button>
        </div>
    </form>
</div>

    <div id="landingPageDiscardModal" class="landing-discard-modal" hidden>
        <div class="landing-discard-backdrop" data-discard-close></div>
        <div class="landing-discard-panel" role="dialog" aria-modal="true" aria-labelledby="landingDiscardTitle">
            <h3 id="landingDiscardTitle">Discard changes?</h3>
            <p>If you leave now, any unsaved landing page edits will be lost.</p>
            <div class="landing-discard-actions">
                <button type="button" class="btn-secondary" id="landingDiscardCancel">Keep Editing</button>
                <button type="button" class="btn-primary" id="landingDiscardConfirm">Discard Changes</button>
            </div>
        </div>
    </div>

    <template id="faqItemTemplate">
        <article class="editor-card faq-item-editor">
            <div class="faq-editor-header">
                <h4>FAQ Item</h4>
                <button type="button" class="btn-secondary remove-faq-item">Remove</button>
            </div>
            <label>
                <span>Question</span>
                <input type="text" name="faq_items[__INDEX__][question]" value="">
            </label>
            <label>
                <span>Answer</span>
                <textarea name="faq_items[__INDEX__][answer]" rows="4"></textarea>
            </label>
        </article>
    </template>

    <template id="socialLinkTemplate">
        <article class="editor-card social-item-editor">
            <div class="faq-editor-header">
                <h4>Social Link</h4>
                <button type="button" class="btn-secondary remove-social-item">Remove</button>
            </div>
            <label>
                <span>Platform</span>
                <input type="text" name="social_links[__INDEX__][platform]" value="">
            </label>
            <label>
                <span>URL</span>
                <input type="text" name="social_links[__INDEX__][url]" value="">
            </label>
        </article>
    </template>

    <template id="contactLinkTemplate">
        <article class="editor-card contact-item-editor">
            <div class="faq-editor-header">
                <h4>Contact Link</h4>
                <button type="button" class="btn-secondary remove-contact-item">Remove</button>
            </div>
            <div class="grid-2">
                <label>
                    <span>Label</span>
                    <input type="text" name="contact_links[__INDEX__][label]" value="">
                </label>
                <label>
                    <span>Display Text</span>
                    <input type="text" name="contact_links[__INDEX__][displayText]" value="">
                </label>
            </div>
            <label>
                <span>URL</span>
                <input type="text" name="contact_links[__INDEX__][url]" value="">
            </label>
        </article>
    </template>

    <style>
        :root {
            --lp-green: #0d7a3a;
            --lp-green-strong: #0d9b00;
            --lp-green-soft: #ecfdf3;
            --lp-amber: #b7791f;
            --lp-ink: #111827;
            --lp-muted: #6b7280;
            --lp-line: #e5e7eb;
            --lp-panel: #ffffff;
            --lp-page: #f8fafc;
        }
        .landing-page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.15rem;
            margin-bottom: 1rem;
            border: 1px solid var(--lp-line);
            border-radius: 8px;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdfc 100%);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }
        .landing-page-header h2 {
            margin: 0;
            color: var(--lp-ink);
            letter-spacing: 0;
        }
        .landing-page-header p {
            margin: .35rem 0 0;
            color: var(--lp-muted);
        }
        .landing-edit-toggle {
            width: 80px;
            min-width: unset;
        }
        .lp-page-wrap {
            width: 100%;
        }
        .landing-page-form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .landing-page-form.is-locked input:not([type="hidden"]),
        .landing-page-form.is-locked textarea,
        .landing-page-form.is-locked select {
            background: #f9fafb;
            color: #4b5563;
            cursor: not-allowed;
        }
        .landing-page-form.is-locked .btn-secondary,
        .landing-page-form.is-locked .btn-primary {
            opacity: .95;
        }
        .landing-page-form.is-locked .landing-image-uploader {
            background: #f9fafb;
            cursor: not-allowed;
        }
        .landing-section-card,
        .editor-card {
            background: var(--lp-panel);
            border: 1px solid var(--lp-line);
            border-radius: 8px;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }
        .landing-section-card {
            position: relative;
            padding: 1.25rem;
            overflow: hidden;
        }
        .landing-section-card::before {
            content: "";
            position: absolute;
            inset: 0 auto 0 0;
            width: 4px;
            background: linear-gradient(180deg, var(--lp-green) 0%, #f5b942 100%);
        }
        .section-title-row,
        .faq-editor-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: center;
            margin-bottom: 1.1rem;
            padding-bottom: .9rem;
            border-bottom: 1px solid #eef2f7;
        }
        .section-title-row h3,
        .editor-card h4 {
            margin: 0;
            color: var(--lp-ink);
            letter-spacing: 0;
        }
        .section-title-row h3 {
            font-size: 1.05rem;
        }
        .section-title-row p {
            margin: .35rem 0 0;
            color: var(--lp-muted);
            line-height: 1.45;
        }
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
            margin-bottom: 1rem;
        }
        .landing-page-form label {
            display: flex;
            flex-direction: column;
            gap: .35rem;
        }
        .landing-page-form label span {
            font-size: .82rem;
            font-weight: 800;
            color: #374151;
        }
        .landing-page-form input[type="text"],
        .landing-page-form textarea {
            width: 100%;
            border: 1px solid #d8dee8;
            border-radius: 8px;
            padding: .72rem .85rem;
            font: inherit;
            color: var(--lp-ink);
            background: #fff;
            transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
        }
        .landing-page-form textarea {
            resize: vertical;
            line-height: 1.5;
        }
        .landing-page-form input[type="text"]:focus,
        .landing-page-form textarea:focus {
            outline: none;
            border-color: var(--lp-green);
            box-shadow: 0 0 0 3px rgba(13, 122, 58, 0.12);
        }
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
        }
        .mission-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
        .editor-card {
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: .85rem;
            transition: border-color .15s ease, box-shadow .15s ease;
        }
        .editor-card:hover {
            border-color: #cfd8e3;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
        }
        .landing-image-uploader {
            display: grid;
            grid-template-columns: minmax(220px, 320px) 1fr;
            gap: 1rem;
            align-items: center;
            margin-bottom: 1rem;
            padding: .75rem;
            border: 1px dashed #a8cdb8;
            border-radius: 8px;
            background: linear-gradient(180deg, #fbfefc 0%, #f7fbf8 100%);
            transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
        }
        .landing-image-uploader.compact {
            grid-template-columns: 132px 1fr;
            margin-bottom: 0;
        }
        .landing-image-uploader.is-dragging {
            border-color: var(--lp-green);
            background: var(--lp-green-soft);
            box-shadow: 0 0 0 3px rgba(13, 122, 58, 0.12);
        }
        .landing-image-input {
            position: absolute;
            width: 1px;
            height: 1px;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
        }
        .landing-upload-preview {
            aspect-ratio: 16 / 9;
            min-height: 154px;
            overflow: hidden;
            border: 1px solid var(--lp-line);
            border-radius: 8px;
            background: #f3f4f6;
        }
        .landing-image-uploader.compact .landing-upload-preview {
            aspect-ratio: 4 / 3;
            min-height: 98px;
        }
        .landing-upload-preview img {
            display: block;
            width: 100%;
            height: 100%;
            max-height: 220px;
            object-fit: cover;
        }
        .landing-image-uploader.compact .landing-upload-preview img {
            max-height: 120px;
        }
        .landing-upload-details {
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: .4rem;
        }
        .landing-upload-label {
            font-size: .82rem;
            font-weight: 800;
            color: var(--lp-green-strong);
            text-transform: uppercase;
            letter-spacing: .04em;
        }
        .landing-upload-details strong {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            color: var(--lp-ink);
            font-size: .95rem;
        }
        .landing-upload-actions {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
        }
        .landing-upload-actions span {
            color: var(--lp-muted);
            font-size: .82rem;
            font-weight: 600;
        }
        .faq-editor-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .faq-pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            margin-top: 1rem;
        }
        .faq-pagination-info {
            display: flex;
            align-items: center;
            gap: .4rem;
            color: #6b7280;
            font-size: .9rem;
            font-weight: 600;
        }
        .faq-pagination .btn-secondary:disabled {
            opacity: .45;
            cursor: not-allowed;
        }
        .social-item-editor,
        .contact-item-editor {
            width: 100%;
        }
        .form-footer {
            position: sticky;
            bottom: .75rem;
            z-index: 20;
            display: flex;
            justify-content: flex-end;
            margin-top: .25rem;
            padding: .75rem;
            border: 1px solid var(--lp-line);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        }
        .flash-message {
            margin: 0 0 1rem;
            border-radius: 14px;
            padding: 14px 18px;
        }
        .flash-success {
            background: #dcfce7;
            color: #166534;
        }
        .flash-error {
            background: #fee2e2;
            color: #991b1b;
        }
        .btn-primary,
        .btn-secondary {
            border: none;
            border-radius: 8px;
            padding: .72rem 1rem;
            font-weight: 800;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform .12s ease, box-shadow .12s ease, background .12s ease, border-color .12s ease;
        }
        .btn-primary {
            background: var(--lp-green-strong);
            color: white;
            box-shadow: 0 6px 14px rgba(13, 155, 0, 0.22);
        }
        @keyframes lpSpin { to { transform: rotate(360deg); } }
        .lp-btn-spinner { display:inline-block; width:13px; height:13px; border:2px solid rgba(255,255,255,.4); border-top-color:#fff; border-radius:50%; animation:lpSpin .6s linear infinite; vertical-align:middle; margin-right:6px; }
        #landingPageSaveButton.is-saving { opacity:.8; pointer-events:none; cursor:not-allowed; }
        .btn-secondary {
            background: white;
            border: 1px solid #b9d5c5;
            color: var(--lp-green-strong);
        }
        .btn-primary:hover,
        .btn-secondary:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 16px rgba(15, 23, 42, 0.08);
        }
        .btn-primary:disabled,
        .btn-secondary:disabled {
            transform: none;
            box-shadow: none;
        }
        #landingPageSaveButton:disabled:not(.is-saving) {
            background: #d1d5db;
            color: #9ca3af;
            box-shadow: none;
            cursor: not-allowed;
        }
        .landing-discard-modal {
            position: fixed;
            inset: 0;
            z-index: 5000;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            overflow-y: auto;
        }
        .landing-discard-modal[hidden] {
            display: none !important;
        }
        .landing-discard-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.45);
            backdrop-filter: blur(4px);
        }
        .landing-discard-panel {
            position: relative;
            z-index: 1;
            width: min(100%, 460px);
            max-height: calc(100vh - 2rem);
            overflow: auto;
            border-radius: 8px;
            background: #fff;
            border: 1px solid rgba(13, 155, 0, 0.12);
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18);
            padding: 2rem;
        }
        .landing-discard-panel h3 {
            margin: 0 0 .5rem;
            color: #111827;
        }
        .landing-discard-panel p {
            margin: 0;
            color: #6b7280;
            line-height: 1.55;
        }
        .landing-discard-actions {
            display: flex;
            gap: .75rem;
            margin-top: 1.5rem;
        }
        .landing-discard-actions button {
            flex: 1;
            justify-content: center;
            padding: .65rem 1rem;
        }
        @media (max-width: 980px) {
            .grid-2,
            .cards-grid,
            .mission-grid {
                grid-template-columns: 1fr;
            }
            .landing-page-header,
            .section-title-row,
            .faq-editor-header {
                flex-direction: column;
                align-items: flex-start;
            }
            .landing-image-uploader,
            .landing-image-uploader.compact {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <script>
        (function() {
            const form = document.getElementById('landingPageForm');
            const editToggle = document.getElementById('landingPageEditToggle');
            const saveFooter = document.getElementById('landingPageSaveFooter');
            const saveButton = document.getElementById('landingPageSaveButton');
            const addFaqButton = document.getElementById('addFaqItem');
            const faqList = document.getElementById('faqList');
            const template = document.getElementById('faqItemTemplate');
            const prevPageButton = document.getElementById('faqPrevPage');
            const nextPageButton = document.getElementById('faqNextPage');
            const pageLabel = document.getElementById('faqPageLabel');
            const pageCount = document.getElementById('faqPageCount');
            const addSocialButton = document.getElementById('addSocialLink');
            const socialList = document.getElementById('socialLinksList');
            const socialTemplate = document.getElementById('socialLinkTemplate');
            const addContactButton = document.getElementById('addContactLink');
            const contactList = document.getElementById('contactLinksList');
            const contactTemplate = document.getElementById('contactLinkTemplate');
            const discardModal = document.getElementById('landingPageDiscardModal');
            const discardCancelButton = document.getElementById('landingDiscardCancel');
            const discardConfirmButton = document.getElementById('landingDiscardConfirm');

            if (!form || !editToggle || !saveFooter || !saveButton || !addFaqButton || !faqList || !template || !prevPageButton || !nextPageButton || !pageLabel || !pageCount || !addSocialButton || !socialList || !socialTemplate || !addContactButton || !contactList || !contactTemplate || !discardModal || !discardCancelButton || !discardConfirmButton) {
                return;
            }

            if (discardModal.parentElement !== document.body) {
                document.body.appendChild(discardModal);
            }

            const pageSize = 5;
            let currentPage = 1;
            let editMode = false;
            let initialSnapshot = null;
            let isDirty = false;

            function createItem(templateEl, index) {
                const html = templateEl.innerHTML.replaceAll('__INDEX__', String(index));
                const wrapper = document.createElement('div');
                wrapper.innerHTML = html.trim();
                return wrapper.firstElementChild;
            }

            function captureSnapshot() {
                initialSnapshot = new FormData(form);
                isDirty = false;
            }

            function updateDirtyState() {
                if (!editMode || !initialSnapshot) {
                    isDirty = false;
                    return;
                }

                const currentSnapshot = new FormData(form);
                const keys = new Set([...initialSnapshot.keys(), ...currentSnapshot.keys()]);

                isDirty = false;
                for (const key of keys) {
                    const beforeValues = initialSnapshot.getAll(key).map(function(value) { return String(value); });
                    const currentValues = currentSnapshot.getAll(key).map(function(value) { return String(value); });

                    if (beforeValues.length !== currentValues.length) {
                        isDirty = true;
                        break;
                    }

                    for (let index = 0; index < beforeValues.length; index += 1) {
                        if (beforeValues[index] !== currentValues[index]) {
                            isDirty = true;
                            break;
                        }
                    }

                    if (isDirty) {
                        break;
                    }
                }
            }

            function setEditingState(enabled) {
                editMode = enabled;
                if (enabled) {
                    captureSnapshot();
                } else {
                    initialSnapshot = null;
                    isDirty = false;
                }
                form.classList.toggle('is-locked', !enabled);
                saveButton.disabled = !enabled;
                editToggle.textContent = enabled ? 'Cancel' : 'Edit';
                editToggle.classList.toggle('btn-primary', enabled);
                editToggle.classList.toggle('btn-secondary', !enabled);

                form.querySelectorAll('input, textarea, select, button[type="button"]').forEach(function(control) {
                    if (control === editToggle) {
                        return;
                    }

                    if (control.matches('#faqPrevPage, #faqNextPage')) {
                        control.disabled = false;
                        return;
                    }

                    if (enabled) {
                        control.disabled = false;
                        return;
                    }

                    if (control.tagName === 'BUTTON' && control.type === 'button') {
                        control.disabled = true;
                        return;
                    }

                    if (control.tagName === 'INPUT' || control.tagName === 'TEXTAREA' || control.tagName === 'SELECT') {
                        control.disabled = true;
                    }
                });
            }

            function getFaqItems() {
                return Array.from(faqList.querySelectorAll('.faq-item-editor'));
            }

            function totalPages() {
                return Math.max(1, Math.ceil(getFaqItems().length / pageSize));
            }

            function syncFaqTitles() {
                const items = getFaqItems();
                items.forEach(function(item, index) {
                    const heading = item.querySelector('.faq-editor-header h4');
                    if (heading) {
                        heading.textContent = 'FAQ Item ' + (index + 1);
                    }
                });
            }

            function renderFaqPage(page) {
                const items = getFaqItems();
                const pages = totalPages();
                currentPage = Math.min(Math.max(1, page), pages);
                const start = (currentPage - 1) * pageSize;
                const end = start + pageSize;

                items.forEach(function(item, index) {
                    item.style.display = index >= start && index < end ? '' : 'none';
                });

                syncFaqTitles();
                pageLabel.textContent = 'Page ' + currentPage;
                pageCount.textContent = 'of ' + pages;
                prevPageButton.disabled = currentPage <= 1;
                nextPageButton.disabled = currentPage >= pages;
            }

            function syncCardTitles(rootSelector, headingPrefix) {
                const items = Array.from(document.querySelectorAll(rootSelector));
                items.forEach(function(item, index) {
                    const heading = item.querySelector('.faq-editor-header h4');
                    if (heading) {
                        heading.textContent = headingPrefix + ' ' + (index + 1);
                    }
                });
            }

            function refreshSocialItems() {
                syncCardTitles('.social-item-editor', 'Social Link');
            }

            function refreshContactItems() {
                syncCardTitles('.contact-item-editor', 'Contact Link');
            }

            function openDiscardModal() {
                discardModal.hidden = false;
                document.body.style.overflow = 'hidden';
            }

            function closeDiscardModal() {
                discardModal.hidden = true;
                document.body.style.overflow = '';
            }

            function initializeImageUploaders() {
                form.querySelectorAll('[data-image-upload]').forEach(function(uploader) {
                    const input = uploader.querySelector('[data-image-input]');
                    const button = uploader.querySelector('[data-image-button]');
                    const preview = uploader.querySelector('[data-image-preview]');
                    const filename = uploader.querySelector('[data-image-filename]');

                    if (!input || !button || !preview || !filename) {
                        return;
                    }

                    function applyFile(file) {
                        if (!file || !file.type || !file.type.startsWith('image/')) {
                            return;
                        }

                        const previewUrl = URL.createObjectURL(file);
                        preview.onload = function() {
                            URL.revokeObjectURL(previewUrl);
                        };
                        preview.src = previewUrl;
                        filename.textContent = file.name;
                        button.textContent = 'Replace Image';
                        updateDirtyState();
                    }

                    button.addEventListener('click', function() {
                        if (!editMode || input.disabled) {
                            return;
                        }

                        input.click();
                    });

                    input.addEventListener('change', function() {
                        applyFile(input.files && input.files[0]);
                    });

                    uploader.addEventListener('dragover', function(event) {
                        if (!editMode || input.disabled) {
                            return;
                        }

                        event.preventDefault();
                        uploader.classList.add('is-dragging');
                    });

                    uploader.addEventListener('dragleave', function(event) {
                        if (!uploader.contains(event.relatedTarget)) {
                            uploader.classList.remove('is-dragging');
                        }
                    });

                    uploader.addEventListener('drop', function(event) {
                        if (!editMode || input.disabled) {
                            return;
                        }

                        event.preventDefault();
                        uploader.classList.remove('is-dragging');

                        const file = event.dataTransfer.files && event.dataTransfer.files[0];
                        if (!file || !file.type.startsWith('image/')) {
                            return;
                        }

                        const transfer = new DataTransfer();
                        transfer.items.add(file);
                        input.files = transfer.files;
                        applyFile(file);
                    });
                });
            }

            setEditingState(false);
            initializeImageUploaders();

            editToggle.addEventListener('click', function() {
                if (editMode) {
                    updateDirtyState();
                    if (!isDirty) {
                        setEditingState(false);
                        return;
                    }

                    openDiscardModal();
                    return;
                }

                setEditingState(true);
            });

            discardCancelButton.addEventListener('click', function() {
                closeDiscardModal();
            });

            discardConfirmButton.addEventListener('click', function() {
                discardConfirmButton.innerHTML = '<span class="lp-btn-spinner"></span>Discarding...';
                discardConfirmButton.disabled = true;
                setTimeout(function() {
                    closeDiscardModal();
                    setEditingState(false);
                    window.location.reload();
                }, 600);
            });

            discardModal.addEventListener('click', function(event) {
                if (event.target === discardModal || event.target.hasAttribute('data-discard-close')) {
                    closeDiscardModal();
                }
            });

            addFaqButton.addEventListener('click', function() {
                if (!editMode) {
                    return;
                }
                const index = Date.now();
                const newItem = createItem(template, index);
                newItem.querySelectorAll('.remove-faq-item').forEach(function(button) {
                    button.addEventListener('click', function() {
                        newItem.remove();
                        renderFaqPage(Math.min(currentPage, totalPages()));
                        updateDirtyState();
                    });
                });
                faqList.appendChild(newItem);
                renderFaqPage(totalPages());
                updateDirtyState();
            });

            addSocialButton.addEventListener('click', function() {
                if (!editMode) {
                    return;
                }
                const index = Date.now();
                const newItem = createItem(socialTemplate, index);
                newItem.querySelectorAll('.remove-social-item').forEach(function(button) {
                    button.addEventListener('click', function() {
                        newItem.remove();
                        refreshSocialItems();
                        updateDirtyState();
                    });
                });
                socialList.appendChild(newItem);
                refreshSocialItems();
                updateDirtyState();
            });

            addContactButton.addEventListener('click', function() {
                if (!editMode) {
                    return;
                }
                const index = Date.now();
                const newItem = createItem(contactTemplate, index);
                newItem.querySelectorAll('.remove-contact-item').forEach(function(button) {
                    button.addEventListener('click', function() {
                        newItem.remove();
                        refreshContactItems();
                        updateDirtyState();
                    });
                });
                contactList.appendChild(newItem);
                refreshContactItems();
                updateDirtyState();
            });

            faqList.querySelectorAll('.remove-faq-item').forEach(function(button) {
                button.addEventListener('click', function() {
                    const card = button.closest('.faq-item-editor');
                    if (card) {
                        card.remove();
                        renderFaqPage(Math.min(currentPage, totalPages()));
                    }
                });
            });

            socialList.querySelectorAll('.remove-social-item').forEach(function(button) {
                button.addEventListener('click', function() {
                    const card = button.closest('.social-item-editor');
                    if (card) {
                        card.remove();
                        refreshSocialItems();
                    }
                });
            });

            contactList.querySelectorAll('.remove-contact-item').forEach(function(button) {
                button.addEventListener('click', function() {
                    const card = button.closest('.contact-item-editor');
                    if (card) {
                        card.remove();
                        refreshContactItems();
                        updateDirtyState();
                    }
                });
            });

            form.querySelectorAll('input, textarea, select').forEach(function(control) {
                control.addEventListener('input', updateDirtyState);
                control.addEventListener('change', updateDirtyState);
            });

            form.addEventListener('input', function() {
                updateDirtyState();
            });
            form.addEventListener('change', function() {
                updateDirtyState();
            });

            prevPageButton.addEventListener('click', function() {
                renderFaqPage(currentPage - 1);
            });

            nextPageButton.addEventListener('click', function() {
                renderFaqPage(currentPage + 1);
            });

            renderFaqPage(1);
            refreshSocialItems();
            refreshContactItems();

            form.addEventListener('submit', function() {
                saveButton.classList.add('is-saving');
                saveButton.innerHTML = '<span class="lp-btn-spinner"></span>Saving...';
                saveButton.disabled = true;
            });
        })();
    </script>
{% endblock %}
