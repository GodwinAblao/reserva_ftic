function generateOrganizingInsights(d) {
    // Executive Summary
    const execEl = document.getElementById('exec-organizing');
    if (execEl) {
        const load = d.facility_load_distribution || {};
        const entries = Object.entries(load).sort((a,b) => b[1]-a[1]);
        const totalBookings = entries.reduce((s,e)=> s+e[1], 0);
        const topFac = entries[0] ? entries[0][0] : 'N/A';
        const topPct = entries[0] && totalBookings > 0 ? ((entries[0][1]/totalBookings)*100).toFixed(0) : 0;
        execEl.innerHTML = `<div class="exec-box"><h5>Executive Summary — Organizing</h5><p><strong>${Object.keys(load).length} facilities</strong> tracked with <strong>${totalBookings} total reservations</strong>. The most utilized facility is <strong>${esc(topFac)}</strong> accounting for <strong>${topPct}%</strong> of all bookings. ${entries.length > 1 && entries[entries.length-1][1] < 5 ? 'Some facilities are significantly underutilized — consider promoting them or redistributing demand.' : 'Demand is relatively balanced across facilities.'}</p></div>`;
    }

    // Facility load insight
    const loadEl = document.getElementById('insight-load');
    if (loadEl) {
        const load = d.facility_load_distribution || {};
        const entries = Object.entries(load).sort((a,b) => b[1]-a[1]);
        if (entries.length >= 2) {
            const ratio = entries[0][1] > 0 ? (entries[0][1] / entries[entries.length-1][1]).toFixed(1) : 1;
            loadEl.innerHTML = '<strong>Insight:</strong> <strong>' + esc(entries[0][0]) + '</strong> has ' + ratio + 'x more bookings than <strong>' + esc(entries[entries.length-1][0]) + '</strong>. Consider load-balancing by promoting underused facilities.';
        }
    }

    // Peak usage insight
    const peakEl = document.getElementById('insight-peak');
    if (peakEl) {
        const peak = d.peak_usage_times || {};
        const entries = Object.entries(peak).sort((a,b) => b[1]-a[1]);
        if (entries.length) {
            peakEl.innerHTML = '<strong>Insight:</strong> Peak demand slot is <strong>' + esc(entries[0][0]) + '</strong> with ' + entries[0][1] + ' reservations. Schedule maintenance and setup activities outside this window.';
        }
    }

    // Utilization insight
    const utilEl = document.getElementById('insight-util');
    if (utilEl) {
        const util = d.room_utilization || {};
        const rates = Object.entries(util).map(([k,v]) => ({name:k, rate:(v.utilization_rate||0)*100}));
        const avg = rates.length ? (rates.reduce((s,r)=>s+r.rate,0)/rates.length).toFixed(1) : 0;
        const low = rates.filter(r => r.rate < 2);
        let txt = '<strong>Insight:</strong> Average utilization: <strong>' + avg + '%</strong>. ';
        if (low.length) txt += low.length + ' facilities below 2% utilization (' + low.map(r=>r.name).join(', ') + ') — these may be candidates for schedule optimization or repurposing.';
        else txt += 'All facilities show healthy usage levels.';
        utilEl.innerHTML = txt;
    }

    // School-hour heatmap insight
    const hmEl = document.getElementById('insight-heatmap');
    if (hmEl) {
        const hm = d.peak_usage_heatmap || {};
        if (hm.hours && hm.values) {
            const schoolHourIndexes = hm.hours
                .map((hour, index) => ({ hour: Number(hour), index }))
                .filter(item => item.hour >= 7 && item.hour <= 20);
            let peakHour = 0, peakVal = 0;
            schoolHourIndexes.forEach(({ hour, index }) => {
                const total = (hm.values[index] || []).reduce((s,v)=>s+Number(v),0);
                if (total > peakVal) { peakVal = total; peakHour = hour; }
            });
            const fmt = h => h === 0 ? '12:00 AM' : h < 12 ? h+':00 AM' : h === 12 ? '12:00 PM' : (h-12)+':00 PM';
            // Find busiest day overall
            const days = hm.days || [];
            const dayTotals = days.map((day,di) => ({ day, total: schoolHourIndexes.reduce((s,{ index })=>s+Number(hm.values[index]?.[di]||0),0) }));
            dayTotals.sort((a,b)=>b.total-a.total);
            const busiestDay = dayTotals[0];
            hmEl.innerHTML = '<strong>Insight:</strong> Peak school hour across all days: <strong>' + fmt(peakHour) + '</strong> (' + peakVal + ' total reservations). Busiest day: <strong>' + esc(busiestDay?.day||'N/A') + '</strong> (' + (busiestDay?.total||0) + ' reservations). Use this to schedule staff deployment and set facility availability windows.';
        }
    }

    // Recommendations — Organizing (data-driven)
    const recoEl = document.getElementById('reco-organizing');
    if (recoEl) {
        const load = d.facility_load_distribution || {};
        const loadEntries = Object.entries(load).sort((a,b)=>b[1]-a[1]);
        const totalLoad = loadEntries.reduce((s,e)=>s+e[1],0);
        const util = d.room_utilization || {};
        const utilRates = Object.entries(util).map(([k,v])=>({name:k,rate:(v.utilization_rate||0)*100}));
        const avgUtil = utilRates.length ? utilRates.reduce((s,r)=>s+r.rate,0)/utilRates.length : 0;
        const peak = d.peak_usage_times || {};
        const peakEntries = Object.entries(peak).sort((a,b)=>b[1]-a[1]);
        const suggestions = d.optimization_suggestions || [];
        const items = [];

        if (loadEntries.length && totalLoad > 0) {
            const topPct = (loadEntries[0][1]/totalLoad*100).toFixed(0);
            if (topPct >= 60) items.push('<strong>High Concentration Risk:</strong> <strong>' + esc(loadEntries[0][0]) + '</strong> handles ' + topPct + '% of all bookings. Actively promote underused facilities to redistribute demand and reduce single-facility failure risk.');
        }
        if (avgUtil < 30 && utilRates.length) items.push('<strong>Systemwide Underutilization:</strong> Average utilization is only <strong>' + avgUtil.toFixed(1) + '%</strong>. Review facility availability policies, operating hours, and promotion strategies to drive higher usage.');
        const idleFacs = utilRates.filter(r=>r.rate===0);
        if (idleFacs.length) items.push('<strong>Idle Assets:</strong> ' + idleFacs.map(r=>esc(r.name)).join(', ') + ' have zero recorded reservations. Evaluate whether these facilities are properly listed, accessible, and visible in the booking system.');
        if (peakEntries.length >= 2) {
            const ratio = peakEntries[0][1] > 0 ? (peakEntries[0][1]/peakEntries[peakEntries.length-1][1]).toFixed(1) : 1;
            if (ratio >= 3) items.push('<strong>Scheduling Concentration:</strong> Peak slot <strong>' + esc(peakEntries[0][0]) + '</strong> has ' + ratio + 'x more reservations than the quietest slot. Consider incentivising off-peak bookings to flatten demand curves.');
        }
        if (suggestions.length) suggestions.forEach(s => items.push(esc(s)));
        const orgStanding = ['Maintain a minimum 15–30 minute buffer between consecutive reservations for setup, cleanup, and turnaround.', 'Run a quarterly facility audit to align available room configurations with the most common event types.'];
        const orgDynamic = items.length ? '<ul>' + items.map(i=>'<li>'+i+'</li>').join('') + '</ul>' : '<p style="color:#6b7280;font-size:0.92em;">No critical signals detected. System is operating within normal parameters.</p>';
        recoEl.innerHTML = '<div class="reco-box"><h5>Actionable Recommendations — Organizing</h5>' + orgDynamic + '<div class="reco-standing"><strong>Standing Practices:</strong><ul>' + orgStanding.map(i=>'<li>'+i+'</li>').join('') + '</ul></div></div>';
    }
}

function generateLeadingInsights(d) {
    const execEl = document.getElementById('exec-leading');
    if (execEl) {
        const rate = d.overall_completion_rate ?? 0;
        const status = rate >= 70 ? 'healthy' : rate >= 50 ? 'moderate' : 'concerning';
        execEl.innerHTML = `<div class="exec-box"><h5>Executive Summary — Event Execution</h5><p>Overall approval rate is <strong>${rate}%</strong> (${status}). ${rate < 50 ? 'Low approval suggests process bottlenecks or unclear requirements — review rejection reasons.' : rate >= 70 ? 'High approval rate indicates a well-functioning reservation process.' : 'Moderate approval rate — investigate top rejection reasons for improvement opportunities.'}</p></div>`;
    }

    // Participant trend insight
    const partEl = document.getElementById('insight-part');
    if (partEl) {
        const data = d.participant_demand_trend || {};
        const vals = Object.values(data);
        if (vals.length >= 3) {
            const recent = vals.slice(-3);
            const avg = (recent.reduce((a,b)=>a+b,0)/recent.length).toFixed(0);
            const trend = vals[vals.length-1] > vals[vals.length-2] ? 'increasing' : 'decreasing';
            partEl.innerHTML = '<strong>Insight:</strong> Participant demand is <strong>' + trend + '</strong>. Recent 3-month average: <strong>' + avg + ' participants</strong>. ' + (trend === 'increasing' ? 'Growing engagement signals the system is being actively adopted.' : 'Declining trend may indicate scheduling friction or reduced event activity.');
        }
    }

    // Recommendations — Event Execution (data-driven)
    const recoEl = document.getElementById('reco-leading');
    if (recoEl) {
        const rate = d.overall_completion_rate ?? 0;
        const partData = d.participant_demand_trend || {};
        const partVals = Object.values(partData);
        const items = [];

        if (rate < 50) items.push('<strong>Critical — Low Approval Rate (' + rate + '%):</strong> Fewer than half of reservations are being approved. Immediately audit the rejection workflow, identify top blockers, and consider streamlining submission requirements.');
        else if (rate < 70) items.push('<strong>Moderate Approval Rate (' + rate + '%):</strong> Room for improvement. Analyse which event categories face the most rejections and provide targeted guidance to requesters.');
        else items.push('<strong>Healthy Approval Rate (' + rate + '%):</strong> System is running well. Maintain current standards and document best practices for staff onboarding.');

        if (partVals.length >= 3) {
            const last3 = partVals.slice(-3);
            const declining = last3[2] < last3[1] && last3[1] < last3[0];
            if (declining) items.push('<strong>Declining Participant Engagement:</strong> Participant volume has dropped for 3 consecutive months. Survey users for scheduling friction, awareness gaps, or competing alternatives.');
        }

        const leadStanding = ['Publish a monthly approval report to help requesters understand expectations and reduce avoidable rejections.', 'Track time-to-approval and flag any reservation pending for more than 48 hours.'];
        const leadDynamic = items.length ? '<ul>' + items.map(i=>'<li>'+i+'</li>').join('') + '</ul>' : '<p style="color:#6b7280;font-size:0.92em;">No critical signals detected. System is operating within normal parameters.</p>';
        recoEl.innerHTML = '<div class="reco-box"><h5>Actionable Recommendations — Event Execution</h5>' + leadDynamic + '<div class="reco-standing"><strong>Standing Practices:</strong><ul>' + leadStanding.map(i=>'<li>'+i+'</li>').join('') + '</ul></div></div>';
    }
}

function generateControllingInsights(d) {
    const execEl = document.getElementById('exec-controlling');
