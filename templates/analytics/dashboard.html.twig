            <li><strong>Overall Score</strong> — Combines advance booking discipline, attendance behavior, and approval success into one operational health grade.</li>
            <li><strong>Setup Compliance (40%)</strong> — Higher is better. It means more users reserve at least 3 days before the event.</li>
            <li><strong>Attendance (35%)</strong> — Higher is better. It means fewer cancelled or rejected reservations are affecting facility use.</li>
            <li><strong>Approval Efficiency (25%)</strong> — Higher is better. It means more submitted requests successfully become approved reservations.</li>
            <li><strong>Color Meaning</strong> — Green means healthy, yellow means needs monitoring, and red means priority action is needed.</li>
        </ul></div>
    </div>`;

    // Facility Risk Matrix
    const riskEntries = Object.entries(risks);
    let riskPanel = '';
    if (riskEntries.length) {
        riskPanel = `<div class="sa-chart-container an-pro-chart-card sa-chart-wide an-pro-accuracy-panel">
            <h4>Facility Risk Assessment Matrix</h4>
            <p class="chart-sub">Identifies facilities with highest operational risk — overload probability × no-show impact</p>
            <div style="overflow-x:auto"><table class="an-pro-summary-table"><thead><tr><th>Facility</th><th>Risk Score</th><th>Overload Risk</th><th>No-Show Risk</th><th>Bookings</th></tr></thead><tbody>`;
        riskEntries.forEach(([name, r]) => {
            const riskClass = r.risk_score >= 40 ? 'color:#dc2626;font-weight:700' : r.risk_score >= 20 ? 'color:#d97706;font-weight:700' : 'color:#059669';
            riskPanel += `<tr><td>${esc(name)}</td><td style="${riskClass}">${r.risk_score}/60</td><td><span class="util-badge ${r.overload_risk === 'High' ? 'low' : r.overload_risk === 'Medium' ? 'med' : 'high'}">${r.overload_risk}</span></td><td><span class="util-badge ${r.no_show_risk === 'High' ? 'low' : r.no_show_risk === 'Medium' ? 'med' : 'high'}">${r.no_show_risk}</span> ${r.no_show_rate ?? 0}%</td><td>${r.bookings}</td></tr>`;
        });
        riskPanel += `</tbody></table></div>
            <div class="an-pro-legend-box"><h5>Risk Interpretation</h5><ul>
                <li><strong>Score 0-19:</strong> Low risk — normal operations</li>
                <li><strong>Score 20-39:</strong> Moderate — monitor closely and prepare contingencies</li>
                <li><strong>Score 40-60:</strong> High — immediate intervention recommended</li>
            </ul></div></div>`;
    }

    return `
    <div class="an-pro-exec-summary sa-chart-wide" id="exec-controlling"></div>` + scorecard + `
    <div class="sa-chart-container an-pro-chart-card"><h4>Status Distribution</h4><p class="chart-sub">Proportion of reservation statuses</p><canvas id="c-status"></canvas><div class="an-pro-insight" id="insight-status"></div></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Facility Utilization Rate</h4><p class="chart-sub">Usage intensity per facility</p><canvas id="c-futil"></canvas><div class="an-pro-insight" id="insight-futil"></div></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Reservation Outcome Breakdown</h4><p class="chart-sub">Count of rejected and cancelled reservations — high values indicate process or compliance issues</p><canvas id="c-reject"></canvas><div class="an-pro-insight" id="insight-reject"></div></div>` + riskPanel + `
    <div class="an-pro-recommendations sa-chart-wide" id="reco-controlling"></div>`;
}

function drawCharts(fn, d, isFallback) {
    if (typeof Chart === 'undefined') return;
    Chart.defaults.font.family = "'Segoe UI', system-ui, sans-serif";
    Chart.defaults.color = '#4b5563';

    if (fn === 'forecasting' || fn === 'planning') {
        const view = d._xaxis_view || 'weekly';
        const w = d.forecast_series?.weekly || {};
        const m = d.forecast_series?.monthly || {};

        if (fn === 'forecasting') {
            if (w.historical || w.forecast) charts.push(makeArimaChart('c-weekly', w, 'Reservations'));
            if (m.historical || m.forecast) charts.push(makeArimaChart('c-monthly', m, 'Reservations'));

            // Actual vs ARIMA vs Naïve
            const avf = d.actual_vs_forecast || {};
            if (avf.labels && avf.labels.length > 1) charts.push(makeActualVsForecastChart('c-actual-vs', avf));

            // Rolling MAPE
            const rm = d.rolling_mape || {};
            if (rm.labels && rm.labels.length > 1) {
                const rmEl = document.getElementById('c-rolling-mape');
                if (rmEl) {
                    charts.push(new Chart(rmEl, {
                        type: 'line',
                        data: { labels: rm.labels.map(formatLabel), datasets: [{ label: 'MAPE %', data: rm.values, borderColor: '#7c3aed', backgroundColor: 'rgba(124,58,237,0.08)', fill: true, tension: 0.3, pointRadius: 3, borderWidth: 2 }, { label: '20% threshold', data: rm.labels.map(() => 20), borderColor: '#dc2626', borderDash: [4,4], pointRadius: 0, borderWidth: 1, fill: false }] },
                        options: { ...chartOpts('MAPE %'), plugins: { legend: { labels: { usePointStyle: true, padding: 16 } } } }
                    }));
                }
                const rmInsight = document.getElementById('insight-rolling-mape');
                if (rmInsight && rm.values.length >= 3) {
                    const recent = rm.values.slice(-3);
                    const avgRecent = (recent.reduce((a,b)=>a+b,0)/recent.length).toFixed(1);
                    const trend = rm.values[rm.values.length-1] < rm.values[0] ? 'improving' : 'needs attention';
                    rmInsight.innerHTML = '<strong>Insight:</strong> Recent 3-period avg MAPE: <strong>' + avgRecent + '%</strong>. Model is <strong>' + trend + '</strong>.';
                }
            }
            generatePlanningInsights(d);
        }

        if (fn === 'planning') {
            // Planning tab: DOW, events, hours, per-facility only
            const dow = d.day_of_week_demand || {};
            if (Object.keys(dow).length) charts.push(makeBar('c-dow', dow, '#2563eb', false));
            charts.push(makeDoughnut('c-events', d.event_type_distribution || {}));
            charts.push(makeBar('c-hours', d.peak_demand_hours || {}, '#006633', true));
            generatePlanningInsights(d);
        }
    } else if (fn === 'facility_demand') {
        // Facility Demand Forecasting tab
        const fdSeries = d.facility_demand_series || {};
        const fdBtnWeekly = document.getElementById('btn-facility-weekly');
        const fdBtnMonthly = document.getElementById('btn-facility-monthly');
        const fdEl = document.getElementById('c-facility-demand');
        const fdTitle = document.getElementById('facility-demand-title');
        const fdFilter = document.getElementById('facility-filter');
        const selectedFacilityName = fdFilter && fdFilter.value ? (fdFilter.options[fdFilter.selectedIndex]?.text || 'Selected facility').replace(/\s*\(\d+\)$/, '') : 'All facilities';
        if (fdTitle) fdTitle.textContent = 'Facility Demand Forecast - ' + esc(selectedFacilityName);
        let fdChart = null;
        function drawFacilityDemand(view) {
            const s = fdSeries[view] || {};
            const hist = s.historical || {};
            const forecast = s.forecast || {};
            const lower = s.lower || {};
            const upper = s.upper || {};
            const allKeys = [...new Set([...Object.keys(hist), ...Object.keys(forecast)])].sort();
            if (!allKeys.length || !fdEl) return;
            const labels = allKeys.map(formatLabel);
            const histValues = allKeys.map(k => hist[k] ?? null);
            const fcValues = allKeys.map(k => forecast[k] ?? null);
            const hasFc = fcValues.some(v => v !== null);
            const loValues = allKeys.map(k => lower[k] ?? null);
            const hiValues = allKeys.map(k => upper[k] ?? null);
            if (fdChart) { fdChart.destroy(); fdChart = null; }
            fdChart = new Chart(fdEl, {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        { label: 'Historical (approved)', data: histValues, borderColor: '#006633', backgroundColor: 'rgba(0,102,51,0.12)', fill: true, tension: 0.35, pointRadius: 3, spanGaps: false },
                        ...(hasFc ? [
                            { label: 'ARIMA forecast', data: fcValues, borderColor: '#f59e0b', borderDash: [6,4], tension: 0.35, pointRadius: 3, spanGaps: false },
                            { label: 'Lower bound', data: loValues, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: '+1', pointRadius: 0, tension: 0.35 },
                            { label: 'Upper bound', data: hiValues, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: false, pointRadius: 0, tension: 0.35 }
                        ] : [])
                    ]
                },
                options: {
                    ...chartOpts('Approved reservations'),
                    scales: {
                        x: { grid: { display: false }, ticks: { maxRotation: 0 } },
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.06)' }, title: { display: true, text: 'Approved reservations' }, ticks: { precision: 0, callback: value => Number.isInteger(Number(value)) ? value : Math.round(Number(value)) } }
                    }
                }
            });
            charts.push(fdChart);
            const fdInsight = document.getElementById('insight-facility-demand');
            const insightText = view === 'monthly'
                ? (d.facility_demand_insight_monthly || d.facility_demand_insight || 'Facility demand forecast is available.')
                : (d.facility_demand_insight_weekly || d.facility_demand_insight || 'Facility demand forecast is available.');
            if (fdInsight) fdInsight.innerHTML = '<strong>Insight:</strong> ' + esc(insightText);
        }
        if (fdBtnWeekly && fdBtnMonthly) {
            const setView = (view) => {
                fdBtnWeekly.classList.toggle('active', view === 'weekly');
                fdBtnMonthly.classList.toggle('active', view === 'monthly');
                drawFacilityDemand(view);
            };
            fdBtnWeekly.addEventListener('click', () => setView('weekly'));
            fdBtnMonthly.addEventListener('click', () => setView('monthly'));
            setView('weekly');
        } else if (fdEl) {
            const fdInsight = document.getElementById('insight-facility-demand');
            if (fdInsight) fdInsight.textContent = 'Facility demand data not available.';
        }

        if (d.facility_actual_vs_forecast?.labels?.length > 1) {
            charts.push(makeActualVsForecastChart('c-facility-actual-vs', d.facility_actual_vs_forecast));
        }

        const fdRm = d.facility_rolling_mape || {};
        if (fdRm.labels && fdRm.labels.length > 1) {
            const fdRmEl = document.getElementById('c-facility-rolling-mape');
            if (fdRmEl) {
                charts.push(new Chart(fdRmEl, {
                    type: 'line',
                    data: { labels: fdRm.labels.map(formatLabel), datasets: [{ label: 'MAPE %', data: fdRm.values, borderColor: '#7c3aed', backgroundColor: 'rgba(124,58,237,0.08)', fill: true, tension: 0.3, pointRadius: 3, borderWidth: 2 }, { label: '20% threshold', data: fdRm.labels.map(() => 20), borderColor: '#dc2626', borderDash: [4,4], pointRadius: 0, borderWidth: 1, fill: false }] },
                    options: { ...chartOpts('MAPE %'), plugins: { legend: { labels: { usePointStyle: true, padding: 16 } } } }
                }));
            }
            const fdRmInsight = document.getElementById('insight-facility-rolling-mape');
            if (fdRmInsight && fdRm.values.length >= 3) {
                const recent = fdRm.values.slice(-3);
                const avgRecent = (recent.reduce((a,b)=>a+b,0)/recent.length).toFixed(1);
                const trend = fdRm.values[fdRm.values.length-1] < fdRm.values[0] ? 'improving' : 'needs attention';
                fdRmInsight.innerHTML = '<strong>Insight:</strong> Recent 3-period avg MAPE: <strong>' + avgRecent + '%</strong>. Model is <strong>' + trend + '</strong>.';
            }
        }

        generateFacilityDemandInsights(d);
    } else if (fn === 'organizing') {
        const view = d._xaxis_view || 'weekly';
        const loadCard = document.querySelector('#c-load')?.closest('.an-pro-chart-card');
        if (view === 'dow' && loadCard) {
            loadCard.querySelector('h4').textContent = 'Facility Usage by Day of Week';
            loadCard.querySelector('.chart-sub').textContent = 'Reservation counts per facility grouped by day of week';
        } else if (view === 'monthly' && loadCard) {
            loadCard.querySelector('h4').textContent = 'Facility Usage by Month';
            loadCard.querySelector('.chart-sub').textContent = 'Reservation counts per facility grouped by month';
        }
        charts.push(makeBar('c-load', d.facility_load_distribution || {}, '#006633'));
        charts.push(makeBar('c-peak', d.peak_usage_times || {}, '#2563eb', true));
        const util = {};
        Object.entries(d.room_utilization || {}).forEach(([k,v]) => util[k] = (v.utilization_rate || 0) * 100);
        charts.push(makeBar('c-util', util, '#0f766e'));
        renderHeatmap('heatmap', d.peak_usage_heatmap || {});
        generateOrganizingInsights(d);
    } else if (fn === 'leading') {
        const view = d._xaxis_view || 'weekly';
        const partCard = document.querySelector('#c-part')?.closest('.an-pro-chart-card');
        if (view === 'dow' && partCard) {
            partCard.querySelector('h4').textContent = 'Demand Trend by Day of Week';
            partCard.querySelector('.chart-sub').textContent = 'Reservation volume distributed across Mon–Sun';
        } else if (view === 'monthly' && partCard) {
            partCard.querySelector('h4').textContent = 'Demand Trend by Month';
            partCard.querySelector('.chart-sub').textContent = 'Reservation volume distributed across Jan–Dec';
        }
        charts.push(makeLine('c-part', d.participant_demand_trend || {}, '#7c3aed', 'Participants'));
        generateLeadingInsights(d);
    } else {
        charts.push(makeDoughnut('c-status', d.target_achievement || {}));
        const fu = {};
        Object.entries(d.facility_utilization_rate || {}).forEach(([k,v]) => {
            const rate = typeof v === 'object' && v !== null ? Number(v.utilization_rate || 0) : Number(v || 0);
            fu[k] = rate * 100;
        });
        charts.push(makeBar('c-futil', fu, '#b45309'));
        charts.push(makeBar('c-reject', d.rejection_analysis || {}, '#dc2626'));
        generateControllingInsights(d);
    }
}

// Natural sort order for DOW and Month labels
const DOW_ORDER  = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
const MON_ORDER  = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

function sortedLabels(rawLabels) {
    const first = rawLabels[0] || '';
    if (DOW_ORDER.includes(first)) {
        return DOW_ORDER.filter(d => rawLabels.includes(d));
    }
    if (MON_ORDER.includes(first)) {
        return MON_ORDER.filter(m => rawLabels.includes(m));
    }
    return [...rawLabels].sort();
}

function makeArimaChart(id, series, titleOverride) {
    const rawKeys = [...new Set([...Object.keys(series.historical || {}), ...Object.keys(series.forecast || {})])];
    const labels = sortedLabels(rawKeys);
    const hist = labels.map(l => series.historical?.[l] ?? null);
    const fc = labels.map(l => series.forecast?.[l] ?? null);
    const lo = labels.map(l => series.lower?.[l] ?? null);
    const hi = labels.map(l => series.upper?.[l] ?? null);
    const el = document.getElementById(id);
    if (!el) return null;
    const hasForecasts = fc.some(v => v !== null);
    return new Chart(el, {
        type: 'line',
        data: {
            labels: labels.map(formatLabel),
            datasets: [
                { label: titleOverride || 'Historical', data: hist, borderColor: '#006633', backgroundColor: 'rgba(0,102,51,0.12)', fill: true, tension: 0.35, pointRadius: 3, spanGaps: false },
                ...(hasForecasts ? [
                    { label: 'ARIMA forecast', data: fc, borderColor: '#f59e0b', borderDash: [6,4], tension: 0.35, pointRadius: 3, spanGaps: false },
                    { label: 'Lower bound', data: lo, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: '+1', pointRadius: 0, tension: 0.35 },
                    { label: 'Upper bound', data: hi, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: false, pointRadius: 0, tension: 0.35 }
                ] : [])
            ]
        },
        options: chartOpts('Reservations')
    });
}


function makeBar(id, src, color, sortHours) {
    let entries = Object.entries(src).sort((a,b) => sortHours ? String(a[0]).localeCompare(b[0]) : b[1]-a[1]).slice(0, 12);
    const el = document.getElementById(id);
    if (!el) return null;
    const options = { ...chartOpts(''), plugins: { legend: { display: false } } };
    if (id === 'c-util') {
        options.scales.y.ticks = {
            precision: 0,
            callback: value => Math.round(Number(value))
        };
    }
    return new Chart(el, {
        type: 'bar',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ label: 'Count', data: entries.map(e => Number(e[1])), backgroundColor: color, borderRadius: 6 }] },
        options
    });
}

function makeLine(id, src, color, label) {
    const rawKeys = Object.keys(src || {});
    const orderedKeys = sortedLabels(rawKeys);
    const entries = orderedKeys.map(k => [k, src[k]]);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'line',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ label: label || 'Value', data: entries.map(e => Number(e[1])), borderColor: color, backgroundColor: hexAlpha(color, 0.15), fill: true, tension: 0.35, pointRadius: 3 }] },
        options: chartOpts(label || '')
    });
}

function makeDoughnut(id, src) {
    const entries = Object.entries(src).sort((a,b) => b[1]-a[1]).slice(0, 8);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'doughnut',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ data: entries.map(e => Number(e[1])), backgroundColor: palette(), borderWidth: 0 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right' } } },
        plugins: [doughnutValueLabels()]
    });
}

function doughnutValueLabels() {
    return {
        id: 'doughnutValueLabels',
        afterDatasetsDraw(chart) {
            const { ctx } = chart;
            const dataset = chart.data.datasets[0];
            const meta = chart.getDatasetMeta(0);
            ctx.save();
            ctx.font = '700 12px Segoe UI, system-ui, sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            meta.data.forEach((arc, index) => {
                const value = Number(dataset.data[index] || 0);
                if (value <= 0) return;
                const pos = arc.tooltipPosition();
                ctx.lineWidth = 3;
                ctx.strokeStyle = 'rgba(0,0,0,.55)';
                ctx.fillStyle = '#fff';
                ctx.strokeText(String(value), pos.x, pos.y);
                ctx.fillText(String(value), pos.x, pos.y);
            });
            ctx.restore();
        }
    };
}

function renderHeatmap(id, hm) {
    const el = document.getElementById(id);
    if (!el) return;
    if (!hm.hours?.length || !hm.days?.length || !hm.values?.length) {
        el.insertAdjacentHTML('afterend', '<p class="chart-sub" style="color:#6b7280;margin-top:8px;">No peak-hour pattern yet. Chart fills in as reservations accumulate.</p>');
        return;
    }

    const schoolHourIndexes = (hm.hours || [])
        .map((hour, index) => ({ hour: Number(hour), index }))
        .filter(item => item.hour >= 7 && item.hour <= 20);
    if (!schoolHourIndexes.length) {
        el.insertAdjacentHTML('afterend', '<p class="chart-sub" style="color:#6b7280;margin-top:8px;">No school-hour usage pattern yet. Chart fills in as reservations accumulate.</p>');
        return;
    }
    const schoolHours = schoolHourIndexes.map(item => item.hour);
    const days = hm.days; // ['Mon','Tue','Wed','Thu','Fri','Sat','Sun']

    // X-axis: hours formatted as time strings
    const timeLabels = schoolHours.map(h => {
        if (h === 0)  return '12:00 AM';
        if (h < 12)   return h + ':00 AM';
        if (h === 12) return '12:00 PM';
        return (h - 12) + ':00 PM';
    });

    // One dataset per day — values[hourIndex][dayIndex]
    const dayColors = ['#006633','#2563eb','#f59e0b','#0f766e','#7c3aed','#dc2626','#0891b2'];
    const datasets = days.map((day, di) => ({
        label: day,
        data: schoolHourIndexes.map(({ index }) => Number(hm.values[index]?.[di] || 0)),
        borderColor: dayColors[di % dayColors.length],
        backgroundColor: dayColors[di % dayColors.length] + '18',
        fill: false,
        tension: 0.4,
        pointRadius: 3,
        pointHoverRadius: 6,
        borderWidth: 2
    }));

    const chart = new Chart(el, {
        type: 'line',
        data: { labels: timeLabels, datasets },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: {
                    position: 'top',
                    labels: { usePointStyle: true, padding: 16, boxWidth: 10 }
                },
                tooltip: {
                    callbacks: {
                        title: ctx => 'Time: ' + ctx[0].label,
                        label: ctx => ' ' + ctx.dataset.label + ': ' + ctx.parsed.y + ' reservation' + (ctx.parsed.y !== 1 ? 's' : '')
                    }
                }
            },
            scales: {
                x: {
                    grid: { display: false },
                    ticks: {
                        maxTicksLimit: 12,
                        maxRotation: 45,
                        callback: (val, i) => timeLabels[i]
                    },
                    title: { display: true, text: 'School Hours (7:00 AM-8:00 PM)' }
                },
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(0,0,0,0.06)' },
                    title: { display: true, text: 'Reservations' },
                    ticks: { stepSize: 1, precision: 0 }
                }
            }
        }
    });
    charts.push(chart);
}

function makeActualVsForecastChart(id, avf) {
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'line',
        data: {
            labels: avf.labels.map(formatLabel),
            datasets: [
                { label: 'Actual', data: avf.actual, borderColor: '#006633', backgroundColor: 'rgba(0,102,51,0.08)', fill: true, tension: 0.3, pointRadius: 3, borderWidth: 2.5 },
                { label: 'ARIMA Forecast', data: avf.arima, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.05)', tension: 0.3, pointRadius: 3, borderWidth: 2.5, fill: false },
                { label: 'Naïve Baseline (t-1)', data: avf.naive, borderColor: '#dc2626', borderDash: [5,3], tension: 0.3, pointRadius: 2, borderWidth: 1.5, fill: false }
            ]
        },
        options: {
            ...chartOpts('Reservations'),
            plugins: {
                legend: { labels: { usePointStyle: true, padding: 16 } },
                tooltip: { callbacks: { afterBody: (ctx) => {
                    const i = ctx[0].dataIndex;
                    const arimaErr = Math.abs((avf.actual[i] || 0) - (avf.arima[i] || 0)).toFixed(1);
                    const naiveErr = Math.abs((avf.actual[i] || 0) - (avf.naive[i] || 0)).toFixed(1);
                    return 'ARIMA error: ' + arimaErr + ' | Naïve error: ' + naiveErr;
                } } }
            }
        }
    });
}

function generatePlanningInsights(d) {
    // Weekly insight
    const wEl = document.getElementById('insight-weekly');
    if (wEl) {
        const w = d.forecast_series?.weekly || {};
        const hist = Object.values(w.historical || {});
        const fc = Object.values(w.forecast || {});
        if (hist.length > 1) {
            const lastWeeks = hist.slice(-4);
            const avg = (lastWeeks.reduce((a,b)=>a+b,0)/lastWeeks.length).toFixed(1);
            const trend = hist[hist.length-1] > hist[hist.length-2] ? 'increasing' : hist[hist.length-1] < hist[hist.length-2] ? 'decreasing' : 'stable';
            let insight = '<strong>Insight:</strong> Weekly demand is <strong>' + trend + '</strong>. Recent 4-week average: ' + avg + ' reservations/week.';
            if (fc.length) { const fcAvg = (fc.reduce((a,b)=>a+b,0)/fc.length).toFixed(1); insight += ' Forecasted average: ' + fcAvg + '/week over the next ' + fc.length + ' weeks.'; }
            wEl.innerHTML = insight;
        }
    }

    // Monthly insight
    const mEl = document.getElementById('insight-monthly');
    if (mEl) {
        const m = d.forecast_series?.monthly || {};
        const hist = Object.values(m.historical || {});
        if (hist.length > 2) {
            const lastMonths = hist.slice(-3);
            const avg = (lastMonths.reduce((a,b)=>a+b,0)/lastMonths.length).toFixed(1);
            const peak = Math.max(...hist);
            const peakMonth = Object.keys(m.historical || {})[hist.indexOf(peak)];
            mEl.innerHTML = '<strong>Insight:</strong> Recent 3-month average: ' + avg + ' reservations/month. Peak month: <strong>' + peakMonth + '</strong> (' + peak + ' reservations).';
        }
    }

    // Actual vs Forecast insight
    const avfEl = document.getElementById('insight-actual-vs');
    if (avfEl) {
        const avf = d.actual_vs_forecast || {};
        if (avf.actual && avf.actual.length > 1) {
            // Calculate MAE for both models
            let arimaTotal = 0, naiveTotal = 0, n = avf.actual.length;
            for (let i = 0; i < n; i++) {
                arimaTotal += Math.abs(avf.actual[i] - (avf.arima?.[i] || 0));
                naiveTotal += Math.abs(avf.actual[i] - (avf.naive?.[i] || 0));
            }
            const arimaMae = (arimaTotal / n).toFixed(2);
            const naiveMae = (naiveTotal / n).toFixed(2);
            const improvement = naiveTotal > 0 ? (((naiveTotal - arimaTotal) / naiveTotal) * 100).toFixed(1) : 0;
            avfEl.innerHTML = '<strong>ARIMA vs Naïve Comparison:</strong> ARIMA MAE = <strong>' + arimaMae + '</strong> vs Naïve MAE = <strong>' + naiveMae + '</strong>. ARIMA is <strong>' + improvement + '% more accurate</strong> than the naïve baseline. The amber line (ARIMA) should track closer to the green line (Actual) than the red dashed line (Naïve).';
        }
    }

    // Recommendations — Forecasting (data-driven)
    const recoFcEl = document.getElementById('reco-forecasting');
    if (recoFcEl) {
        const acc = d.forecast_accuracy || {};
        const vol = d.demand_volatility || {};
        const mom = d.trend_momentum || {};
        const dq = d.data_quality || {};
        const seasonal = d.seasonal_pattern || {};
        const items = [];

        if ((acc.weekly_mape ?? 0) > 20) items.push('<strong>Poor Forecast Accuracy (Weekly MAPE ' + acc.weekly_mape + '%):</strong> Model error exceeds 20%. Collect more historical data and ensure reservation records are consistent. Consider retraining the ARIMA model once 52+ weeks of data are available.');
        else if ((acc.weekly_mape ?? 0) > 10) items.push('<strong>Moderate Forecast Accuracy (Weekly MAPE ' + acc.weekly_mape + '%):</strong> Forecast is serviceable but can improve. Ensure no data gaps or outlier weeks are distorting the model.');
        else if (acc.weekly_mape != null) items.push('<strong>Excellent Forecast Accuracy (Weekly MAPE ' + acc.weekly_mape + '%):</strong> Model is reliable for operational planning. Use forecasts confidently for staffing and resource allocation decisions.');

        if ((vol.cv ?? 0) > 30) items.push('<strong>High Demand Volatility (CV ' + vol.cv + '%):</strong> Reservation counts fluctuate significantly week to week. Build capacity buffers of at least 20% above forecast to absorb demand spikes.');
        if (mom.direction === 'down' && (mom.strength ?? 0) > 5) items.push('<strong>Declining Demand Trend (' + mom.strength + '% drop):</strong> Short-term momentum is negative. Investigate whether this is seasonal or structural — if structural, review accessibility, promotion, and booking policies.');
        if (mom.direction === 'up' && (mom.strength ?? 0) > 10) items.push('<strong>Strong Growth Trend (+' + mom.strength + '%):</strong> Demand is accelerating. Pre-emptively expand facility availability, staffing coverage, and system capacity to prevent bottlenecks.');
        if ((dq.score ?? 100) < 80) items.push('<strong>Data Quality Risk (Score ' + dq.score + '%):</strong> Incomplete or inconsistent records are degrading forecast reliability. Audit data entry practices and ensure all reservation outcomes are recorded promptly.');
        if (seasonal.detected && seasonal.peak_months?.length) items.push('<strong>High-Demand Months Identified:</strong> Historically high demand in <strong>' + seasonal.peak_months.slice(-2).map(formatLabel).join(', ') + '</strong>. Pre-allocate resources and increase facility availability during these months.');

        recoFcEl.innerHTML = '<div class="reco-box"><h5>Actionable Recommendations \u2014 Forecasting</h5><ul>' + items.map(i=>'<li>'+i+'</li>').join('') + '</ul></div>';
    }

    // Recommendations — Planning (data-driven)
    const recoPlanEl = document.getElementById('reco-planning');
    if (recoPlanEl) {
        const dow = d.day_of_week_demand || {};
        const dowEntries = Object.entries(dow).sort((a,b)=>b[1]-a[1]);
        const dowTotal = dowEntries.reduce((s,e)=>s+e[1],0);
        const events = d.event_type_distribution || {};
        const eventEntries = Object.entries(events).sort((a,b)=>b[1]-a[1]);
        const eventTotal = eventEntries.reduce((s,e)=>s+e[1],0);
        const hours = d.peak_demand_hours || {};
        const hourEntries = Object.entries(hours).sort((a,b)=>b[1]-a[1]);
        const items = [];

        if (dowEntries.length && dowTotal > 0) {
            const topDayPct = ((dowEntries[0][1]/dowTotal)*100).toFixed(0);
            if (topDayPct >= 40) items.push('<strong>Day Concentration Risk:</strong> <strong>' + esc(dowEntries[0][0]) + '</strong> accounts for <strong>' + topDayPct + '%</strong> of all weekly reservations. Ensure adequate staffing and consider capping bookings on this day to avoid overload.');
        }
        if (eventEntries.length && eventTotal > 0) {
            const topEventPct = ((eventEntries[0][1]/eventTotal)*100).toFixed(0);
            if (topEventPct >= 50) items.push('<strong>Event Type Concentration:</strong> <strong>' + esc(eventEntries[0][0]) + '</strong> events make up <strong>' + topEventPct + '%</strong> of demand. Diversify promotional efforts to attract other event types and reduce reliance on a single category.');
        }
        if (hourEntries.length >= 2) {
            const ratio = hourEntries[0][1] > 0 ? (hourEntries[0][1]/hourEntries[hourEntries.length-1][1]).toFixed(1) : 1;
            if (ratio >= 3) items.push('<strong>Peak Hour Bottleneck:</strong> <strong>' + esc(hourEntries[0][0]) + '</strong> is <strong>' + ratio + 'x</strong> busier than the quietest slot. Introduce staggered booking windows or time-slot incentives to spread demand more evenly across the day.');
        }
        const planStanding = ['Use DOW demand patterns to create targeted scheduling policies \u2014 e.g. requiring 48h advance notice for the busiest day.', 'Align facility configuration (room layouts, AV setup, seating) with the top 3 event types to reduce turnaround time.'];
        const planDynamic = items.length ? '<ul>' + items.map(i=>'<li>'+i+'</li>').join('') + '</ul>' : '<p style="color:#6b7280;font-size:0.92em;">No critical signals detected. System is operating within normal parameters.</p>';
        recoPlanEl.innerHTML = '<div class="reco-box"><h5>Actionable Recommendations \u2014 Planning</h5>' + planDynamic + '<div class="reco-standing"><strong>Standing Practices:</strong><ul>' + planStanding.map(i=>'<li>'+i+'</li>').join('') + '</ul></div></div>';
    }

    // Day-of-week insight
    const dowEl = document.getElementById('insight-dow');
    if (dowEl) {
        const dow = d.day_of_week_demand || {};
        const entries = Object.entries(dow).sort((a,b) => b[1]-a[1]);
        if (entries.length) {
            const busiest = entries[0];
            const quietest = entries[entries.length-1];
            dowEl.innerHTML = '<strong>Insight:</strong> Busiest day: <strong>' + busiest[0] + '</strong> (' + busiest[1] + ' reservations). Quietest: <strong>' + quietest[0] + '</strong> (' + quietest[1] + '). Consider allocating more staff/resources on ' + busiest[0] + '.';
        }
    }

    // Event type distribution insight
    const eventsEl = document.getElementById('insight-events');
    if (eventsEl) {
        const events = d.event_type_distribution || {};
        const entries = Object.entries(events).sort((a,b) => b[1]-a[1]);
        if (entries.length) {
            const total = entries.reduce((s,e) => s + e[1], 0);
            const top = entries[0];
            const topPct = total > 0 ? ((top[1]/total)*100).toFixed(0) : 0;
            const msg = entries.length >= 2
                ? '<strong>Insight:</strong> <strong>' + esc(top[0]) + '</strong> is the dominant event type at <strong>' + topPct + '%</strong> of all reservations (' + top[1] + '). ' + (entries.length >= 3 ? 'Top 3 types account for ' + ((entries.slice(0,3).reduce((s,e)=>s+e[1],0)/total)*100).toFixed(0) + '% of demand.' : '')
                : '<strong>Insight:</strong> All reservations are of type <strong>' + esc(top[0]) + '</strong>.';
            eventsEl.innerHTML = msg;
        }
    }

    // Peak demand hours insight
    const hoursEl = document.getElementById('insight-hours');
    if (hoursEl) {
        const hours = d.peak_demand_hours || {};
        const entries = Object.entries(hours).sort((a,b) => b[1]-a[1]);
        if (entries.length) {
            const peak = entries[0];
            const offPeak = entries[entries.length-1];
            hoursEl.innerHTML = '<strong>Insight:</strong> Peak demand slot: <strong>' + esc(peak[0]) + '</strong> (' + peak[1] + ' reservations). Lowest: <strong>' + esc(offPeak[0]) + '</strong> (' + offPeak[1] + '). Schedule facility maintenance and staff breaks during off-peak windows.';
        }
    }

}

