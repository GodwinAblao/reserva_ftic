{% extends 'layouts/app.html.twig' %}

{% block title %}Analytics | Reserva FTIC{% endblock %}

{% block content %}
<div class="content-header">
    <h2>Managerial Analytics Dashboard</h2>
    <p>Advanced analytics for facility reservation management using ARIMA forecasting and managerial insights</p>
</div>

<div class="analytics-nav">
    <button class="analytics-btn active" type="button" onclick="loadAnalytics('planning')">Planning</button>
    <button class="analytics-btn" type="button" onclick="loadAnalytics('organizing')">Organizing</button>
    <button class="analytics-btn" type="button" onclick="loadAnalytics('staffing')">Staffing</button>
    <button class="analytics-btn" type="button" onclick="loadAnalytics('leading')">Leading</button>
    <button class="analytics-btn" type="button" onclick="loadAnalytics('controlling')">Controlling</button>
</div>

<div id="analytics-content" class="analytics-content">
    <div class="loading">Loading analytics...</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
let currentCharts = [];
const localAnalytics = {{ localAnalytics|json_encode|raw }};

function loadAnalytics(functionName) {
    document.querySelectorAll('.analytics-btn').forEach((btn) => {
        btn.classList.toggle('active', btn.textContent.toLowerCase() === functionName);
    });

    const content = document.getElementById('analytics-content');
    content.innerHTML = `<div class="loading">Loading ${titleCase(functionName)} analytics...</div>`;

    const apiUrls = [
        `http://127.0.0.1:8002/api/analytics/${functionName}`,
        `http://localhost:8002/api/analytics/${functionName}`,
        `/api/analytics/${functionName}`
    ];

    let attemptUrl = 0;

    function tryFetch() {
        if (attemptUrl >= apiUrls.length) {
            renderAnalytics(functionName, localAnalytics[functionName] || {}, true);
            return;
        }

        fetch(apiUrls[attemptUrl])
            .then((response) => {
                if (!response.ok) {
                    throw new Error(`HTTP error ${response.status}`);
                }
                return response.json();
            })
            .then((data) => renderAnalytics(functionName, data, false))
            .catch((error) => {
                attemptUrl++;
                if (attemptUrl < apiUrls.length) {
                    tryFetch();
                    return;
                }
                console.error('Analytics fetch error:', error);
                renderAnalytics(functionName, localAnalytics[functionName] || {}, true);
            });
    }

    tryFetch();
}

function renderAnalytics(functionName, data, isFallback) {
    destroyCurrentCharts();

    const content = document.getElementById('analytics-content');
    let html = `<div class="analytics-section">
        <div class="analytics-title-row">
            <div>
                <h3>${titleCase(functionName)} Analytics</h3>
                <p>${getFunctionSummary(functionName)}</p>
            </div>
            <span class="analytics-source ${isFallback ? 'fallback' : 'live'}">${isFallback ? 'Local database' : 'FastAPI ARIMA'}</span>
        </div>`;

    switch (functionName) {
        case 'planning':
            html += renderPlanning(data);
            break;
        case 'organizing':
            html += renderOrganizing(data);
            break;
        case 'staffing':
            html += renderStaffing(data);
            break;
        case 'leading':
            html += renderLeading(data);
            break;
        case 'controlling':
            html += renderControlling(data);
            break;
    }

    html += '</div>';
    content.innerHTML = html;
    drawAnalyticsChart(functionName, data, isFallback);
}

function renderPlanning(data) {
    let html = '<div class="analytics-grid">';
    html += '<div class="chart-container chart-wide"><h4>Weekly ARIMA Reservation Demand Forecast</h4><canvas id="planningWeeklyChart"></canvas></div>';
    html += '<div class="chart-container chart-wide"><h4>Monthly ARIMA Reservation Demand Forecast</h4><canvas id="planningMonthlyChart"></canvas></div>';
    html += '<div class="chart-container chart-wide"><h4>Event Type Distribution</h4><canvas id="eventTypeChart"></canvas></div>';

    html += '<div class="data-table"><h4>Peak Demand Hours</h4><table><tr><th>Hour</th><th>Reservations</th></tr>';
    topEntries(data.peak_demand_hours || {}, 5).forEach(([hour, count]) => {
        html += `<tr><td>${escapeHtml(formatHour(hour))}</td><td>${formatNumber(count, 0)}</td></tr>`;
    });
    html += '</table></div>';

    html += '<div class="data-table"><h4>Recommended Room Capacity</h4><table><tr><th>Facility</th><th>Avg</th><th>Max</th><th>Count</th></tr>';
    Object.entries(normalizeStatsTable(data.recommended_room_capacity || {})).forEach(([facility, stats]) => {
        html += `<tr><td>${escapeHtml(facility)}</td><td>${formatNumber(stats.mean, 1)}</td><td>${formatNumber(stats.max, 0)}</td><td>${formatNumber(stats.count, 0)}</td></tr>`;
    });
    html += '</table></div>';

    html += '<div class="data-table"><h4>Monthly Participation Trends</h4><table><tr><th>Month</th><th>Total Participants</th></tr>';
    Object.entries(normalizeValueSeries(data.participation_trends || {})).slice(-8).forEach(([month, count]) => {
        html += `<tr><td>${escapeHtml(formatLabel(month))}</td><td>${formatNumber(count, 0)}</td></tr>`;
    });
    html += '</table></div>';

    html += '<div class="data-table"><h4>ARIMA Model Accuracy</h4><table><tr><th>Metric</th><th>Value</th></tr>';
    Object.entries(data.forecast_accuracy || {}).forEach(([metric, value]) => {
        html += `<tr><td>${escapeHtml(formatMetricName(metric))}</td><td>${formatNumber(value, 2)}</td></tr>`;
    });
    html += '</table></div>';

    html += '</div>';
    return html;
}

function renderOrganizing(data) {
    let html = '<div class="analytics-grid">';
    html += '<div class="chart-container chart-wide"><h4>Facility Load Distribution</h4><canvas id="organizingChart"></canvas></div>';
    html += '<div class="chart-container chart-wide"><h4>Peak Usage Times</h4><canvas id="peakUsageChart"></canvas></div>';

    html += '<div class="data-table"><h4>Room Utilization Details</h4><table><tr><th>Facility</th><th>Reservations</th><th>Utilization Rate</th></tr>';
    Object.entries(normalizeStatsTable(data.room_utilization || {})).forEach(([facility, stats]) => {
        const rate = toNumber(stats.utilization_rate) * 100;
        html += `<tr><td>${escapeHtml(facility)}</td><td>${formatNumber(stats.reservations, 0)}</td><td>${formatNumber(rate, 1)}%</td></tr>`;
    });
    html += '</table></div>';

    html += `<div class="metric-card"><h4>Overlapping Reservations</h4><div class="metric">${formatNumber(data.overlapping_reservations, 0)}</div></div>`;

    html += '<div class="data-table"><h4>Facility Load Distribution</h4><table><tr><th>Facility</th><th>Reservations</th></tr>';
    Object.entries(data.facility_load_distribution || {}).forEach(([facility, count]) => {
        html += `<tr><td>${escapeHtml(facility)}</td><td>${formatNumber(count, 0)}</td></tr>`;
    });
    html += '</table></div>';

    html += '<div class="data-table"><h4>Optimization Suggestions</h4><ul>';
    (data.optimization_suggestions || []).forEach((suggestion) => {
        html += `<li>${escapeHtml(suggestion)}</li>`;
    });
    html += '</ul></div>';

    html += '</div>';
    return html;
}

function renderStaffing(data) {
    let html = '<div class="analytics-grid">';
    html += '<div class="chart-container chart-wide"><h4>Monthly Staffing Requirements</h4><canvas id="staffingChart"></canvas></div>';
    html += '<div class="chart-container chart-wide"><h4>Participant Demand Trend</h4><canvas id="participantDemandChart"></canvas></div>';

    html += '<div class="data-table"><h4>Participation Trends</h4><table><tr><th>Month</th><th>Participants</th><th>Required Staff</th></tr>';
    Object.entries(normalizeStatsTable(data.participation_trends || {})).forEach(([month, stats]) => {
        const requiredStaff = stats.required_staff ?? Math.ceil(toNumber(stats.sum) / 20);
        html += `<tr><td>${escapeHtml(formatLabel(month))}</td><td>${formatNumber(stats.sum, 0)}</td><td>${formatNumber(requiredStaff, 0)}</td></tr>`;
    });
    html += '</table></div>';

    html += '<div class="data-table"><h4>High Demand Periods</h4><table><tr><th>Period</th><th>Participants</th></tr>';
    Object.entries(data.high_demand_periods || {}).forEach(([date, count]) => {
        html += `<tr><td>${escapeHtml(formatLabel(date))}</td><td>${formatNumber(count, 0)}</td></tr>`;
    });
    html += '</table></div>';

    html += '<div class="data-table"><h4>Staffing Recommendations</h4><ul>';
    (data.staffing_recommendations || []).forEach((recommendation) => {
        html += `<li>${escapeHtml(recommendation)}</li>`;
    });
    html += '</ul></div>';

    html += '</div>';
    return html;
}

function renderLeading(data) {
    let html = '<div class="analytics-grid">';
    html += '<div class="chart-container chart-wide"><h4>Event Success Rate by Purpose</h4><canvas id="successChart"></canvas></div>';

    html += `<div class="metrics-grid chart-wide">
        <div class="metric-card"><h4>Overall Completion Rate</h4><div class="metric">${formatNumber(data.overall_completion_rate, 1)}%</div></div>
        <div class="metric-card"><h4>RSO Completion Rate</h4><div class="metric">${formatNumber(data.rso_completion_rate, 1)}%</div></div>
        <div class="metric-card"><h4>Participation Accuracy</h4><div class="metric">${formatNumber(data.participation_accuracy, 1)}%</div></div>
    </div>`;

    html += '<div class="data-table chart-wide"><h4>Event Success by Type</h4><table><tr><th>Purpose</th><th>Success Rate</th></tr>';
    Object.entries(data.event_success_by_type || {}).forEach(([purpose, rate]) => {
        html += `<tr><td>${escapeHtml(purpose)}</td><td>${formatNumber(rate, 1)}%</td></tr>`;
    });
    html += '</table></div>';

    html += '</div>';
    return html;
}

function renderControlling(data) {
    let html = '<div class="analytics-grid">';
    html += '<div class="chart-container chart-wide"><h4>Target Achievement by Status</h4><canvas id="controlChart"></canvas></div>';
    html += '<div class="chart-container chart-wide"><h4>Facility Utilization Rate</h4><canvas id="facilityUtilizationChart"></canvas></div>';

    html += `<div class="metrics-grid chart-wide">
        <div class="metric-card"><h4>Average Setup Gap</h4><div class="metric">${formatNumber(data.average_setup_gap, 1)} days</div></div>
        <div class="metric-card"><h4>No-Show Rate</h4><div class="metric">${formatNumber(data.no_show_rate, 1)}%</div></div>
        <div class="metric-card"><h4>Setup Compliance</h4><div class="metric">${formatNumber(data.setup_compliance_rate, 1)}%</div></div>
    </div>`;

    html += '<div class="data-table"><h4>Target Achievement</h4><table><tr><th>Status</th><th>Share</th></tr>';
    Object.entries(data.target_achievement || {}).forEach(([status, percentage]) => {
        html += `<tr><td>${escapeHtml(status)}</td><td>${formatNumber(percentage, 1)}%</td></tr>`;
    });
    html += '</table></div>';

    html += '<div class="data-table"><h4>Rejection Reasons</h4><table><tr><th>Reason</th><th>Cases</th></tr>';
    Object.entries(data.rejection_analysis || {}).forEach(([reason, count]) => {
        html += `<tr><td>${escapeHtml(reason)}</td><td>${formatNumber(count, 0)}</td></tr>`;
    });
    html += '</table></div>';

    html += '</div>';
    return html;
}

function drawAnalyticsChart(functionName, data, isFallback) {
    const canvasIds = {
        planning: ['planningWeeklyChart', 'planningMonthlyChart', 'eventTypeChart'],
        organizing: ['organizingChart', 'peakUsageChart'],
        staffing: ['staffingChart', 'participantDemandChart'],
        leading: 'successChart',
        controlling: ['controlChart', 'facilityUtilizationChart']
    }[functionName];

    if (!canvasIds) {
        return;
    }

    const ids = Array.isArray(canvasIds) ? canvasIds : [canvasIds];
    ids.forEach((canvasId, index) => {
        const canvas = document.getElementById(canvasId);
        const config = buildChartConfig(functionName, data, isFallback, index);
        if (canvas && config && functionName === 'planning') {
            currentCharts.push(drawCanvasFallback(canvas, config));
        } else if (canvas && config && typeof Chart !== 'undefined') {
            currentCharts.push(new Chart(canvas.getContext('2d'), config));
        } else if (canvas && config) {
            currentCharts.push(drawCanvasFallback(canvas, config));
        }
    });
}

function buildChartConfig(functionName, data, isFallback, chartIndex = 0) {
    switch (functionName) {
        case 'planning':
            if (chartIndex === 2) {
                return buildDoughnutChart('Event Types', data.event_type_distribution || {}, chartPalette());
            }
            return buildPlanningChart(data, isFallback, chartIndex === 0 ? 'weekly' : 'monthly');
        case 'organizing':
            if (chartIndex === 1) {
                return buildBarChart('Reservations', data.peak_usage_times || data.peak_demand_hours || {}, '#2563eb', true);
            }
            return buildBarChart('Reservations', data.facility_load_distribution || {}, '#006633');
        case 'staffing':
            if (chartIndex === 1) {
                return buildParticipantDemandChart(data);
            }
            return buildStaffingChart(data);
        case 'leading':
            return buildBarChart('Success Rate (%)', data.event_success_by_type || {}, '#0f766e');
        case 'controlling':
            if (chartIndex === 1) {
                return buildUtilizationChart(data);
            }
            return buildBarChart('Share (%)', data.target_achievement || {}, '#b45309');
        default:
            return null;
    }
}

function buildPlanningChart(data, isFallback, frequency) {
    let historical = {};
    let forecast = {};

    if (isFallback && data.forecast_series) {
        historical = data.forecast_series[frequency]?.historical || {};
        forecast = data.forecast_series[frequency]?.forecast || {};
    } else if (data.forecast_chart && Array.isArray(data.forecast_chart.data)) {
        const chart = frequency === 'monthly' && data.monthly_forecast_chart ? data.monthly_forecast_chart : data.forecast_chart;
        const historicalTrace = chart.data.find((trace) => String(trace.name || '').toLowerCase().includes('historical')) || chart.data[0];
        const forecastTrace = chart.data.find((trace) => String(trace.name || '').toLowerCase().includes('forecast')) || chart.data[1];
        historical = traceToSeries(historicalTrace);
        forecast = traceToSeries(forecastTrace);
    }

    const labels = [...Object.keys(historical), ...Object.keys(forecast)].map(formatLabel);
    const historicalValues = [...Object.values(historical), ...Object.keys(forecast).map(() => null)].map(toNullableNumber);
    const forecastValues = [...Object.keys(historical).map(() => null), ...Object.values(forecast)].map(toNullableNumber);

    return {
        type: 'line',
        data: {
            labels,
            datasets: [
                {
                    label: 'Historical Reservations',
                    data: historicalValues,
                    borderColor: '#006633',
                    backgroundColor: 'rgba(0, 102, 51, 0.12)',
                    tension: 0.25,
                    fill: true,
                    spanGaps: true
                },
                {
                    label: isFallback ? `${titleCase(frequency)} Moving Average Forecast` : `${titleCase(frequency)} ARIMA Forecast`,
                    data: forecastValues,
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245, 158, 11, 0.16)',
                    borderDash: [6, 5],
                    tension: 0.25,
                    fill: false,
                    spanGaps: true
                }
            ]
        },
        options: chartOptions('Reservations')
    };
}

function buildStaffingChart(data) {
    const trends = normalizeStatsTable(data.participation_trends || {});
    const labels = Object.keys(trends).map(formatLabel);
    const values = Object.values(trends).map((stats) => toNumber(stats.required_staff ?? Math.ceil(toNumber(stats.sum) / 20)));

    return {
        type: 'line',
        data: {
            labels,
            datasets: [{
                label: 'Required Staff',
                data: values,
                borderColor: '#2563eb',
                backgroundColor: 'rgba(37, 99, 235, 0.14)',
                fill: true,
                tension: 0.25
            }]
        },
        options: chartOptions('Staff')
    };
}

function buildParticipantDemandChart(data) {
    const source = Object.keys(data.participant_demand_trend || {}).length > 0
        ? data.participant_demand_trend
        : normalizeValueSeries(data.participation_trends || {});
    const entries = Object.entries(normalizeValueSeries(source));

    return {
        type: 'line',
        data: {
            labels: entries.map(([key]) => formatLabel(key)),
            datasets: [{
                label: 'Participants',
                data: entries.map(([, value]) => toNumber(value)),
                borderColor: '#7c3aed',
                backgroundColor: 'rgba(124, 58, 237, 0.14)',
                fill: true,
                tension: 0.25
            }]
        },
        options: chartOptions('Participants')
    };
}

function buildUtilizationChart(data) {
    let source = data.facility_utilization_rate || {};
    if (Object.keys(source).length === 0 && data.room_utilization) {
        source = {};
        Object.entries(normalizeStatsTable(data.room_utilization)).forEach(([facility, stats]) => {
            source[facility] = toNumber(stats.utilization_rate) * 100;
        });
    } else {
        source = Object.fromEntries(Object.entries(source).map(([facility, rate]) => [facility, toNumber(rate) * 100]));
    }

    return buildBarChart('Utilization (%)', source, '#0f766e');
}

function buildBarChart(label, source, color, sortByLabel = false) {
    const entries = topEntries(normalizeValueSeries(source), 10);
    if (sortByLabel) {
        entries.sort((a, b) => String(a[0]).localeCompare(String(b[0])));
    }
    return {
        type: 'bar',
        data: {
            labels: entries.map(([key]) => formatLabel(key)),
            datasets: [{
                label,
                data: entries.map(([, value]) => toNumber(value)),
                backgroundColor: color,
                borderRadius: 4
            }]
        },
        options: chartOptions(label)
    };
}

function buildDoughnutChart(label, source, colors) {
    const entries = topEntries(normalizeValueSeries(source), 8);
    return {
        type: 'doughnut',
        data: {
            labels: entries.map(([key]) => formatLabel(key)),
            datasets: [{
                label,
                data: entries.map(([, value]) => toNumber(value)),
                backgroundColor: entries.map((_, index) => colors[index % colors.length])
            }]
        },
        options: chartOptions(label)
    };
}

function chartPalette() {
    return ['#006633', '#2563eb', '#f59e0b', '#0f766e', '#7c3aed', '#dc2626', '#0891b2', '#65a30d'];
}

function chartOptions(yLabel) {
    return {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
            intersect: false,
            mode: 'index'
        },
        plugins: {
            legend: {
                labels: {
                    boxWidth: 12
                }
            }
        },
        scales: {
            x: {
                grid: {
                    display: false
                },
                ticks: {
                    maxRotation: 45
                }
            },
            y: {
                beginAtZero: true,
                title: {
                    display: true,
                    text: yLabel
                }
            }
        }
    };
}

function drawCanvasFallback(canvas, config) {
    const context = canvas.getContext('2d');
    const ratio = window.devicePixelRatio || 1;
    const displayWidth = canvas.clientWidth || canvas.parentElement.clientWidth || 800;
    const displayHeight = canvas.clientHeight || 300;
    canvas.width = displayWidth * ratio;
    canvas.height = displayHeight * ratio;
    context.setTransform(ratio, 0, 0, ratio, 0, 0);

    const width = displayWidth;
    const height = displayHeight;
    const padding = { top: 24, right: 24, bottom: 54, left: 54 };
    if (config.type === 'doughnut') {
        return drawDoughnutFallback(canvas, context, config, width, height);
    }

    const chartWidth = width - padding.left - padding.right;
    const chartHeight = height - padding.top - padding.bottom;
    const labels = config.data.labels || [];
    const datasets = config.data.datasets || [];
    const values = datasets
        .flatMap((dataset) => dataset.data || [])
        .filter((value) => value !== null && Number.isFinite(Number(value)))
        .map(Number);

    if (labels.length === 0 || values.length === 0) {
        context.clearRect(0, 0, canvas.width, canvas.height);
        context.fillStyle = '#667085';
        context.font = '14px Arial, sans-serif';
        context.textAlign = 'center';
        context.fillText('No forecast data available yet.', canvas.clientWidth / 2 || 300, 150);
        return {
            destroy() {
                context.clearRect(0, 0, canvas.width, canvas.height);
            }
        };
    }

    const maxValue = Math.max(1, ...values) * 1.15;

    context.clearRect(0, 0, width, height);
    context.fillStyle = '#ffffff';
    context.fillRect(0, 0, width, height);
    context.strokeStyle = '#d0d5dd';
    context.lineWidth = 1;

    for (let i = 0; i <= 4; i++) {
        const y = padding.top + chartHeight - (chartHeight * i / 4);
        context.beginPath();
        context.moveTo(padding.left, y);
        context.lineTo(width - padding.right, y);
        context.stroke();
        context.fillStyle = '#667085';
        context.font = '11px Arial, sans-serif';
        context.textAlign = 'right';
        context.fillText(Math.round(maxValue * i / 4), padding.left - 8, y + 4);
    }

    context.strokeStyle = '#98a2b3';
    context.beginPath();
    context.moveTo(padding.left, padding.top);
    context.lineTo(padding.left, height - padding.bottom);
    context.lineTo(width - padding.right, height - padding.bottom);
    context.stroke();

    const pointX = (index) => padding.left + (labels.length <= 1 ? chartWidth / 2 : chartWidth * index / (labels.length - 1));
    const pointY = (value) => padding.top + chartHeight - (toNumber(value) / maxValue * chartHeight);

    datasets.forEach((dataset) => {
        const data = dataset.data || [];
        const color = dataset.borderColor || dataset.backgroundColor || '#006633';

        if (config.type === 'bar') {
            const barWidth = Math.max(12, chartWidth / Math.max(data.length, 1) * 0.55);
            context.fillStyle = color;
            data.forEach((value, index) => {
                const barHeight = toNumber(value) / maxValue * chartHeight;
                const x = pointX(index) - barWidth / 2;
                const y = padding.top + chartHeight - barHeight;
                context.fillRect(x, y, barWidth, barHeight);
            });
            return;
        }

        context.strokeStyle = color;
        context.lineWidth = 3;
        context.setLineDash(dataset.borderDash || []);
        context.beginPath();
        let started = false;
        data.forEach((value, index) => {
            if (value === null || value === undefined) {
                started = false;
                return;
            }
            const x = pointX(index);
            const y = pointY(value);
            if (!started) {
                context.moveTo(x, y);
                started = true;
            } else {
                context.lineTo(x, y);
            }
        });
        context.stroke();
        context.setLineDash([]);

        context.fillStyle = color;
        data.forEach((value, index) => {
            if (value === null || value === undefined) {
                return;
            }
            context.beginPath();
            context.arc(pointX(index), pointY(value), 3, 0, Math.PI * 2);
            context.fill();
        });
    });

    context.fillStyle = '#344054';
    context.font = '11px Arial, sans-serif';
    context.textAlign = 'center';
    const labelStep = Math.max(1, Math.ceil(labels.length / 8));
    labels.forEach((label, index) => {
        if (index % labelStep !== 0 && index !== labels.length - 1) {
            return;
        }
        context.save();
        context.translate(pointX(index), height - padding.bottom + 22);
        context.rotate(-Math.PI / 7);
        context.fillText(String(label), 0, 0);
        context.restore();
    });

    context.textAlign = 'left';
    datasets.forEach((dataset, index) => {
        const color = dataset.borderColor || dataset.backgroundColor || '#006633';
        const x = padding.left + (index * 190);
        const y = 14;
        context.fillStyle = color;
        context.fillRect(x, y - 8, 18, 4);
        context.fillStyle = '#344054';
        context.font = '12px Arial, sans-serif';
        context.fillText(dataset.label || 'Series', x + 24, y - 4);
    });

    return {
        destroy() {
            context.clearRect(0, 0, width, height);
        }
    };
}

function drawDoughnutFallback(canvas, context, config, width, height) {
    const labels = config.data.labels || [];
    const dataset = (config.data.datasets || [])[0] || {};
    const values = (dataset.data || []).map(toNumber);
    const colors = dataset.backgroundColor || chartPalette();
    const total = values.reduce((sum, value) => sum + value, 0);

    context.clearRect(0, 0, width, height);
    context.fillStyle = '#ffffff';
    context.fillRect(0, 0, width, height);

    if (labels.length === 0 || total === 0) {
        context.fillStyle = '#667085';
        context.font = '14px Arial, sans-serif';
        context.textAlign = 'center';
        context.fillText('No distribution data available yet.', width / 2, height / 2);
        return {
            destroy() {
                context.clearRect(0, 0, width, height);
            }
        };
    }

    const radius = Math.min(width * 0.28, height * 0.34);
    const centerX = width * 0.32;
    const centerY = height * 0.5;
    let startAngle = -Math.PI / 2;

    values.forEach((value, index) => {
        const sliceAngle = (value / total) * Math.PI * 2;
        context.beginPath();
        context.moveTo(centerX, centerY);
        context.arc(centerX, centerY, radius, startAngle, startAngle + sliceAngle);
        context.closePath();
        context.fillStyle = colors[index % colors.length];
        context.fill();
        startAngle += sliceAngle;
    });

    context.beginPath();
    context.arc(centerX, centerY, radius * 0.55, 0, Math.PI * 2);
    context.fillStyle = '#ffffff';
    context.fill();

    context.fillStyle = '#344054';
    context.font = '700 15px Arial, sans-serif';
    context.textAlign = 'center';
    context.fillText(String(Math.round(total)), centerX, centerY - 2);
    context.font = '11px Arial, sans-serif';
    context.fillText('events', centerX, centerY + 14);

    context.textAlign = 'left';
    context.font = '12px Arial, sans-serif';
    const legendX = width * 0.58;
    let legendY = Math.max(28, centerY - (labels.length * 18) / 2);
    labels.forEach((label, index) => {
        context.fillStyle = colors[index % colors.length];
        context.fillRect(legendX, legendY - 10, 12, 12);
        context.fillStyle = '#344054';
        const percentage = ((values[index] / total) * 100).toFixed(1);
        context.fillText(`${label}: ${percentage}%`, legendX + 18, legendY);
        legendY += 18;
    });

    return {
        destroy() {
            context.clearRect(0, 0, width, height);
        }
    };
}

function normalizeStatsTable(source) {
    if (!source || Array.isArray(source) || typeof source !== 'object') {
        return {};
    }

    const columnKeys = ['mean', 'max', 'count', 'sum', 'required_staff'];
    const isColumnOriented = Object.keys(source).some((key) => columnKeys.includes(key) && typeof source[key] === 'object');
    if (!isColumnOriented) {
        return source;
    }

    const rows = {};
    Object.entries(source).forEach(([column, values]) => {
        if (!values || typeof values !== 'object') {
            return;
        }
        Object.entries(values).forEach(([row, value]) => {
            rows[row] = rows[row] || {};
            rows[row][column] = value;
        });
    });

    return rows;
}

function normalizeValueSeries(source) {
    if (!source || Array.isArray(source) || typeof source !== 'object') {
        return {};
    }

    const stats = normalizeStatsTable(source);
    const values = {};
    Object.entries(stats).forEach(([key, value]) => {
        values[key] = typeof value === 'object' && value !== null
            ? (value.sum ?? value.count ?? value.mean ?? value.required_staff ?? 0)
            : value;
    });

    return values;
}

function traceToSeries(trace) {
    if (!trace) {
        return {};
    }

    const xValues = Array.isArray(trace.x) ? trace.x : Object.values(trace.x || {});
    const yValues = Array.isArray(trace.y) ? trace.y : Object.values(trace.y || {});
    if (xValues.length === 0 || yValues.length === 0) {
        return {};
    }

    const series = {};
    xValues.forEach((label, index) => {
        series[label] = yValues[index];
    });
    return series;
}

function topEntries(source, limit = 10) {
    return Object.entries(source)
        .sort((a, b) => toNumber(b[1]) - toNumber(a[1]))
        .slice(0, limit);
}

function titleCase(value) {
    return value.charAt(0).toUpperCase() + value.slice(1);
}

function destroyCurrentCharts() {
    currentCharts.forEach((chart) => chart.destroy());
    currentCharts = [];
}

function getFunctionSummary(functionName) {
    const summaries = {
        planning: 'Forecasts reservation demand and identifies resource requirements.',
        organizing: 'Compares room load so facility allocation is easier to balance.',
        staffing: 'Estimates support needs from participation volume.',
        leading: 'Shows event success patterns by purpose and completion metrics.',
        controlling: 'Tracks status outcomes and control indicators.'
    };
    return summaries[functionName] || '';
}

function formatHour(hour) {
    const normalized = String(hour).padStart(2, '0').slice(0, 2);
    return `${normalized}:00`;
}

function formatLabel(label) {
    if (label === null || label === undefined) {
        return '';
    }

    const text = String(label);
    const weekMatch = text.match(/^(\d{4})-W(\d{2})$/);
    if (weekMatch) {
        return `${weekMatch[0]}`;
    }

    const parsed = new Date(text);
    if (!Number.isNaN(parsed.getTime()) && text.match(/^\d{4}-\d{2}/)) {
        return parsed.toLocaleDateString(undefined, {
            year: 'numeric',
            month: 'short',
            day: text.length > 7 ? 'numeric' : undefined
        });
    }
    return text;
}

function formatMetricName(metric) {
    return String(metric)
        .replace(/_/g, ' ')
        .replace(/\b\w/g, (letter) => letter.toUpperCase());
}

function formatNumber(value, decimals = 0) {
    const number = toNumber(value);
    return Number.isFinite(number) ? number.toFixed(decimals) : '0';
}

function toNumber(value) {
    const number = Number(value);
    return Number.isFinite(number) ? number : 0;
}

function toNullableNumber(value) {
    if (value === null || value === undefined) {
        return null;
    }
    return toNumber(value);
}

function escapeHtml(value) {
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

document.addEventListener('DOMContentLoaded', function() {
    loadAnalytics('planning');
});
</script>

