        const compliance = d.setup_compliance_rate ?? 0;
        const noshow = d.no_show_rate ?? 0;
        const gap = d.average_setup_gap ?? 0;
        const health = compliance >= 80 && noshow <= 15 ? 'Good' : compliance >= 50 ? 'Needs attention' : 'Critical';
        execEl.innerHTML = `<div class="exec-box"><h5>Executive Summary — Controlling</h5><p>Operational health: <strong>${health}</strong>. Setup compliance (≤3 days lead time): <strong>${compliance}%</strong>. No-show rate: <strong>${noshow}%</strong>. Average setup gap: <strong>${gap} days</strong>. ${noshow > 25 ? 'High no-show rate indicates potential policy enforcement issues — consider implementing confirmation reminders or penalties.' : 'No-show rate is within acceptable range.'}</p></div>`;
    }

    // Facility utilization rate insight (controlling)
    const futilEl = document.getElementById('insight-futil');
    if (futilEl) {
        const util = d.facility_utilization_rate || {};
        const rates = Object.entries(util).map(([k,v]) => {
            const rate = typeof v === 'object' && v !== null ? Number(v.utilization_rate || 0) : Number(v || 0);
            return { name:k, rate: rate * 100 };
        });
        if (rates.length) {
            rates.sort((a,b)=>b.rate-a.rate);
            const avg = (rates.reduce((s,r)=>s+r.rate,0)/rates.length).toFixed(1);
            const overloaded = rates.filter(r=>r.rate>=5);
            const idle = rates.filter(r=>r.rate<2);
            let txt = '<strong>Insight:</strong> Average facility utilization: <strong>' + avg + '%</strong>. ';
            if (overloaded.length) txt += '<strong>' + overloaded.map(r=>esc(r.name)).join(', ') + '</strong> ' + (overloaded.length===1?'is':'are') + ' at high load — monitor capacity closely. ';
            if (idle.length) txt += idle.map(r=>esc(r.name)).join(', ') + ' ' + (idle.length===1?'is':'are') + ' underutilized — consider repurposing or promoting.';
            futilEl.innerHTML = txt;
        }
    }

    // Status insight
    const statusEl = document.getElementById('insight-status');
    if (statusEl) {
        const data = d.target_achievement || {};
        const total = Object.values(data).reduce((s,v)=>s+v,0);
        if (total > 0) {
            const approved = data['Approved'] || data['Completed'] || 0;
            const pct = ((approved/total)*100).toFixed(0);
            statusEl.innerHTML = '<strong>Insight:</strong> Of <strong>' + total + '</strong> total reservations, <strong>' + pct + '%</strong> were approved/completed. Monitor rejected and cancelled bookings for patterns.';
        }
    }

    // Rejection insight
    const rejectEl = document.getElementById('insight-reject');
    if (rejectEl) {
        const data = d.rejection_analysis || {};
        const entries = Object.entries(data).sort((a,b)=>b[1]-a[1]);
        if (entries.length) {
            const top = entries[0];
            rejectEl.innerHTML = '<strong>Insight:</strong> Top rejection reason: <strong>' + esc(top[0]) + '</strong> (' + top[1] + ' occurrences). Address this category first for maximum impact on approval rates.';
        }
    }

    // Recommendations — Controlling (data-driven)
    const recoEl = document.getElementById('reco-controlling');
    if (recoEl) {
        const noshow = d.no_show_rate ?? 0;
        const compliance = d.setup_compliance_rate ?? 0;
        const rejection = d.rejection_analysis || {};
        const rejEntries = Object.entries(rejection).sort((a,b)=>b[1]-a[1]);
        const rejTotal = rejEntries.reduce((s,e)=>s+e[1],0);
        const target = d.target_achievement || {};
        const totalRes = Object.values(target).reduce((s,v)=>s+v,0);
        const cancelled = target['Cancelled'] || 0;
        const cancelPct = totalRes > 0 ? ((cancelled/totalRes)*100).toFixed(1) : 0;
        const items = [];

        if (noshow > 25) items.push('<strong>Priority — High No-Show Rate (' + noshow + '%):</strong> More than 1 in 4 approved reservations result in no-shows. Implement 24-hour and 1-hour automated confirmation reminders. Consider a strike policy after repeated no-shows.');
        else if (noshow > 10) items.push('<strong>Moderate No-Show Rate (' + noshow + '%):</strong> Send confirmation reminders at 24h before and follow up with a post-no-show survey to understand root causes.');

        if (compliance < 50) items.push('<strong>Priority — Poor Setup Compliance (' + compliance + '%):</strong> Majority of reservations are submitted with less than 3 days lead time. Enforce minimum advance booking requirements and educate users on setup preparation timelines.');
        else if (compliance < 80) items.push('<strong>Setup Compliance Needs Improvement (' + compliance + '%):</strong> Encourage earlier submissions by offering priority access to facilities for reservations made 5+ days in advance.');

        if (rejEntries.length && rejTotal > 0) {
            const topRejPct = ((rejEntries[0][1]/rejTotal)*100).toFixed(0);
            if (topRejPct >= 50) items.push('<strong>Single Root Cause Dominates Rejections:</strong> <strong>' + esc(rejEntries[0][0]) + '</strong> accounts for <strong>' + topRejPct + '%</strong> of all rejections. This single issue is the highest-leverage fix — resolve it to significantly improve approval rates.');
            else items.push('Top rejection reason is <strong>' + esc(rejEntries[0][0]) + '</strong> (' + rejEntries[0][1] + ' cases). Address this first for maximum impact.');
        }

        if (parseFloat(cancelPct) > 15) items.push('<strong>High Cancellation Rate (' + cancelPct + '%):</strong> Review the timing of cancellations — late cancellations block other users from booking. Introduce a cancellation window policy (e.g. no cancellation within 24h of event).');

        const ctrlStanding = ['Review rejection patterns monthly and update policies to prevent recurring issues.', 'Implement a waitlist system for peak-demand facilities to recover cancelled slots immediately.'];
        const ctrlDynamic = items.length ? '<ul>' + items.map(i=>'<li>'+i+'</li>').join('') + '</ul>' : '<p style="color:#6b7280;font-size:0.92em;">No critical signals detected. System is operating within normal parameters.</p>';
        recoEl.innerHTML = '<div class="reco-box"><h5>Actionable Recommendations — Controlling</h5>' + ctrlDynamic + '<div class="reco-standing"><strong>Standing Practices:</strong><ul>' + ctrlStanding.map(i=>'<li>'+i+'</li>').join('') + '</ul></div></div>';
    }
}

function chartOpts(y) {
    return {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { usePointStyle: true, padding: 16 } } },
        scales: {
            x: { grid: { display: false }, ticks: { maxRotation: 45 } },
            y: { beginAtZero: true, title: y ? { display: true, text: y } : undefined }
        }
    };
}

function palette() {
    return ['#006633','#2563eb','#f59e0b','#0f766e','#7c3aed','#dc2626','#0891b2','#65a30d'];
}

function title(fn) {
    if (fn === 'leading') return 'Event Execution';
    if (fn === 'forecasting') return 'Reservation Demand Forecasting';
    if (fn === 'facility_demand') return 'Facility Demand Forecasting';
    return fn.charAt(0).toUpperCase() + fn.slice(1);
}
function summary(fn) {
    const m = {
        forecasting: 'A forward-looking view of total reservation demand, demand stability, data quality, and expected usage patterns.',
        facility_demand: 'Approved-only facility demand forecast, model validation, and accuracy metrics for the selected facility or all facilities.',
        planning: 'Demand patterns by day of week, event type distribution, peak hours, and per-facility forecasts.',
        organizing: 'Facility allocation, peak times, and utilization.',
        leading: 'Approval and purpose-based success metrics.',
        controlling: 'Compliance, status mix, and utilization control.'
    };
    return m[fn] || '';
}
function formatLabel(l) {
    const s = String(l);
    // Convert ISO week key "YYYY-Www" → "Jun 1–7" style
    const wm = s.match(/^(\d{4})-W(\d{2})$/);
    if (wm) {
        const year = parseInt(wm[1]);
        const week = parseInt(wm[2]);
        // Monday of that ISO week
        const jan4 = new Date(year, 0, 4);
        const mon = new Date(jan4);
        mon.setDate(jan4.getDate() - ((jan4.getDay() + 6) % 7) + (week - 1) * 7);
        const sun = new Date(mon);
        sun.setDate(mon.getDate() + 6);
        const mNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        if (mon.getMonth() === sun.getMonth()) {
            return mNames[mon.getMonth()] + ' ' + mon.getDate() + '\u2013' + sun.getDate();
        } else {
            return mNames[mon.getMonth()] + ' ' + mon.getDate() + '\u2013' + mNames[sun.getMonth()] + ' ' + sun.getDate();
        }
    }
    // Convert "YYYY-MM" → "Jan 2024" style
    const mm = s.match(/^(\d{4})-(\d{2})$/);
    if (mm) {
        const mNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        return mNames[parseInt(mm[2]) - 1] + ' ' + mm[1];
    }
    return s;
}
function hexAlpha(hex, a) {
    const h = hex.replace('#','');
    const r = parseInt(h.slice(0,2),16), g = parseInt(h.slice(2,4),16), b = parseInt(h.slice(4,6),16);
    return 'rgba(' + r + ',' + g + ',' + b + ',' + a + ')';
}
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
{% endblock %}
