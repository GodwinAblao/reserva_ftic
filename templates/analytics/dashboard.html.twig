        capPanel = `<div class="sa-chart-container an-pro-chart-card sa-chart-wide an-pro-accuracy-panel">
            <h4>Capacity Efficiency Analysis</h4>
            <p class="chart-sub">Measures how effectively each facility's capacity is being utilized relative to demand</p>
            <div class="an-pro-metrics-grid">`;
