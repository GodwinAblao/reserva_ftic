        summaryHtml = '<div class="sa-chart-container an-pro-chart-card sa-chart-wide"><h4>Facility Usage Summary</h4><div style="overflow-x:auto;"><table class="an-pro-summary-table"><thead><tr><th>Facility</th><th>Total Reservations</th><th>Total Attendees</th><th>Utilization Rate</th><th>Status</th></tr></thead><tbody>';
        Object.entries(util).forEach(([name, v]) => {
            const rate = ((v.utilization_rate || 0) * 100).toFixed(1);
            const rateNum = parseFloat(rate);
            const badge = rateNum >= 5 ? '<span class="util-badge high">High</span>' : rateNum >= 2 ? '<span class="util-badge med">Medium</span>' : '<span class="util-badge low">Low</span>';
            summaryHtml += '<tr><td>' + esc(name) + '</td><td>' + (v.total_bookings || v.reservations || 0) + '</td><td>' + (v.total_capacity || 0) + '</td><td>' + rate + '%</td><td>' + badge + '</td></tr>';
        });
        summaryHtml += '</tbody></table></div></div>';
    }

    // Capacity Efficiency Panel
    const capEff = d.capacity_efficiency || {};
    const capEntries = Object.entries(capEff).slice(0, 6);
    let capPanel = '';
