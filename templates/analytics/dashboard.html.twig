{% extends 'layouts/app.html.twig' %}

{% block title %}Managerial Analytics | Reserva FTIC{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/analytics-pro.css') }}?v={{ 'now'|date('U') }}">
<style>
.an-pro-accuracy-panel{background:#fff!important;border:2px solid #006633!important;border-radius:16px!important;padding:24px!important;min-height:auto!important}
.an-pro-accuracy-panel h4{color:#006633!important;font-size:18px!important}
.an-pro-metrics-grid{display:grid!important;grid-template-columns:repeat(3,1fr)!important;gap:14px!important;margin:20px 0!important}
.metric-card{background:#f8fafc!important;border-radius:12px!important;padding:18px 16px!important;text-align:center!important;box-shadow:0 2px 8px rgba(0,0,0,.04)!important;border:1px solid #e5e7eb!important;position:relative!important;min-height:auto!important;display:block!important}
.metric-card:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(0,0,0,.08)!important}
.metric-card .metric-icon{position:absolute!important;top:10px!important;right:12px!important;width:22px!important;height:22px!important;border-radius:50%!important;background:#006633!important;color:#fff!important;font-size:11px!important;font-weight:800!important;display:flex!important;align-items:center!important;justify-content:center!important}
.metric-card .metric-label{font-size:11px!important;font-weight:700!important;text-transform:uppercase!important;letter-spacing:.6px!important;color:#6b7280!important;margin-bottom:6px!important}
.metric-card .metric-value{font-size:26px!important;font-weight:800!important;color:#1f2937!important;line-height:1.2!important}
.metric-card .metric-desc{font-size:11px!important;color:#9ca3af!important;margin-top:6px!important}
.metric-card.mq-excellent{border-color:#059669!important;background:linear-gradient(135deg,#ecfdf5,#d1fae5)!important}
.metric-card.mq-excellent .metric-value{color:#059669!important}
.metric-card.mq-good{border-color:#2563eb!important;background:linear-gradient(135deg,#eff6ff,#dbeafe)!important}
.metric-card.mq-good .metric-value{color:#2563eb!important}
.metric-card.mq-fair{border-color:#d97706!important;background:linear-gradient(135deg,#fffbeb,#fef3c7)!important}
.metric-card.mq-fair .metric-value{color:#d97706!important}
.metric-card.mq-poor{border-color:#dc2626!important;background:linear-gradient(135deg,#fef2f2,#fee2e2)!important}
.metric-card.mq-poor .metric-value{color:#dc2626!important}
.mq-tag{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;margin-right:4px}
.mq-tag.excellent{background:#d1fae5;color:#059669}.mq-tag.good{background:#dbeafe;color:#2563eb}
.mq-tag.fair{background:#fef3c7;color:#d97706}.mq-tag.poor{background:#fee2e2;color:#dc2626}
@media(max-width:768px){.an-pro-metrics-grid{grid-template-columns:repeat(2,1fr)!important}}
.an-pro-exec-summary{margin-bottom:0}
.exec-box{background:linear-gradient(135deg,#f0fdf4,#ecfdf5);border:1px solid #006633;border-radius:12px;padding:18px 22px;margin-bottom:4px}
.exec-box h5{margin:0 0 8px;font-size:15px;font-weight:800;color:#006633}
.exec-box p{margin:0;font-size:13.5px;line-height:1.7;color:#1f2937}
.exec-box strong{color:#004d26}
.an-pro-recommendations{margin-top:0}
.reco-box{background:linear-gradient(135deg,#eff6ff,#dbeafe);border:1px solid #2563eb;border-radius:12px;padding:18px 22px}
.reco-box h5{margin:0 0 10px;font-size:15px;font-weight:800;color:#1e40af}
.reco-box ul{margin:0;padding:0 0 0 18px}
.reco-box li{font-size:13px;line-height:1.7;color:#1f2937;margin-bottom:6px}
.reco-box li strong{color:#dc2626}
.reco-standing{margin-top:12px;padding-top:10px;border-top:1px dashed #93c5fd}
.reco-standing strong{font-size:12px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.04em}
.reco-standing ul{margin:4px 0 0;padding:0 0 0 18px}
.reco-standing li{font-size:12.5px;line-height:1.6;color:#6b7280;margin-bottom:4px}
.util-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px}
.util-badge.high{background:#d1fae5;color:#059669}
.util-badge.med{background:#fef3c7;color:#d97706}
.util-badge.low{background:#fee2e2;color:#dc2626}
.an-pro-segmented{background:#f1f5f9;border-radius:8px;padding:3px;display:flex}
.an-pro-segment{border:0;background:transparent;color:#4b5563;font-size:12px;font-weight:600;padding:6px 14px;border-radius:6px;cursor:pointer;transition:all .15s ease}
.an-pro-segment:hover{background:#e2e8f0;color:#1f2937}
.an-pro-segment.active{background:#006633;color:#fff;box-shadow:0 1px 3px rgba(0,0,0,.12)}
</style>
{% endblock %}

{% block content %}
<div class="an-pro-header">
    <div>
        <h2>Managerial Function Analytics</h2>
        <p>Forecasting, facility utilization, and decision-support visualizations for effective facility scheduling, resource allocation, and data-driven decision-making.</p>
    </div>
    <div class="an-pro-toolbar">
        <span id="data-source-badge" class="an-pro-badge live"><span class="dot"></span> Live</span>
        <select id="facility-filter" class="an-pro-select" title="Filter by facility">
            <option value="">All facilities</option>
        </select>
        <a class="an-pro-btn-dl" href="{{ path('admin_role_analytics_export_this_week') }}" title="Download this week's reservation snapshot as CSV">This Week Snapshot</a>
        <a class="an-pro-btn-dl" href="{{ is_granted('ROLE_SUPER_ADMIN') ? path('admin_reports') : path('admin_role_reports') }}" title="View all operational reports and downloads">All Reports</a>
        {% if is_granted('ROLE_SUPER_ADMIN') %}<a class="an-pro-btn-dl" href="{{ path('admin_ledger') }}" title="Full system transaction audit trail">Activity Logs</a>{% endif %}
    </div>
</div>

<div class="sa-analytics-nav">
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="forecasting">Reservation Demand Forecasting</button>
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="facility_demand">Facility Demand Forecasting</button>
    <button class="sa-analytics-btn active analytics-btn" type="button" data-fn="planning">Planning</button>
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="organizing">Organizing</button>
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="leading">Event Execution</button>
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="controlling">Controlling</button>
</div>

<div id="analytics-content" class="sa-analytics-section">
    <div class="sa-loading">Loading Planning analytics…</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" crossorigin="anonymous"></script>
<script>
const API = '/analytics/proxy';
let charts = [];
let currentFn = 'planning';
let facilities = [];
let lastData = null;

document.querySelectorAll('.analytics-btn').forEach(btn => {
    btn.addEventListener('click', () => loadAnalytics(btn.dataset.fn));
});

document.getElementById('facility-filter').addEventListener('change', () => loadAnalytics(currentFn));

function queryParams() {
    const fac = document.getElementById('facility-filter').value;
    const params = [];
    if (fac) params.push('facility_id=' + encodeURIComponent(fac));
    return params.length ? '?' + params.join('&') : '';
}

function sourceParam() {
    return '';
}

function localFacilityOptions() {
    return ({{ usage|json_encode|raw }} || []).map(f => ({
        id: f.id || '',
        name: f.name || 'Facility',
        count: Number(f.total || 0)
    }));
}

function mergeFacilities(apiFacilities) {
    const merged = new Map();
    localFacilityOptions().forEach(f => {
        merged.set(String(f.id || f.name), f);
    });
    (apiFacilities || []).forEach(f => {
        const key = String(f.id || f.name);
        const existing = merged.get(key) || {};
        merged.set(key, {
            id: f.id || existing.id || '',
            name: f.name || existing.name || 'Facility',
            count: Number(f.count ?? existing.count ?? 0)
        });
    });
    return Array.from(merged.values()).sort((a, b) => a.name.localeCompare(b.name));
}

function renderFacilityOptions(nextFacilities) {
    facilities = nextFacilities;
    const sel = document.getElementById('facility-filter');
    const currentVal = sel.value;
    sel.innerHTML = '<option value="">All facilities</option>';
    facilities.forEach(f => {
        const o = document.createElement('option');
        o.value = f.id || '';
        o.textContent = f.name + ' (' + (f.count || 0) + ')';
        if (String(f.id || '') === String(currentVal)) o.selected = true;
        sel.appendChild(o);
    });
}

function loadMeta() {
    fetch(API + '/meta' + sourceParam()).then(r => r.json()).then(meta => {
        renderFacilityOptions(mergeFacilities(meta.facilities || []));
        updateBadge(meta);
    }).catch(() => {
        console.info('Using frontend facility fallback from Symfony database');
        renderFacilityOptions(localFacilityOptions());
    });
}

document.addEventListener('DOMContentLoaded', () => {
    loadMeta();
    loadAnalytics('planning');
});

function updateBadge(data) {
    const el = document.getElementById('data-source-badge');
    el.className = 'an-pro-badge live';
    el.innerHTML = '<span class="dot"></span> Live';
    const dlWeekly = document.getElementById('dl-weekly');
    if (dlWeekly) dlWeekly.href = '{{ path('admin_role_analytics_export_weekly') }}' + queryParams();
}

async function loadAnalytics(fn) {
    currentFn = fn;
    document.querySelectorAll('.analytics-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.fn === fn);
    });
    const box = document.getElementById('analytics-content');
    box.innerHTML = '<div class="sa-loading">Loading ' + fn + '\u2026</div>';
    destroyCharts();
    // Forecasting tab uses the planning endpoint; facility_demand has its own endpoint
    const apiEndpoint = fn === 'forecasting' ? 'planning' : fn;
    try {
        const res = await fetch(API + '/' + apiEndpoint + queryParams());
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        lastData = data;
        updateBadge(data);
        renderTab(fn, data);
    } catch (e) {
        console.warn('Analytics API error, using local fallback', e);
        const local = {{ localAnalytics|json_encode|raw }};
        lastData = local[apiEndpoint] || local[fn] || {};
        updateBadge({ source: 'live', dataSourceLabel: 'Live' });
        renderTab(fn, lastData, true);
    }
}

function destroyCharts() {
    charts.forEach(c => c.destroy());
    charts = [];
}

// ─── X-AXIS VIEW MODE (Weekly / Day-of-Week / Monthly) ────────────────────

function getXAxisView() {
    return 'weekly';
}

/**
 * Collapses weekly key→value series into DOW buckets (Mon..Sun).
 * e.g. { "2024-W05": 12, "2024-W06": 8 } → { "Mon":20, "Tue":0, ... }
 * Since weekly keys map to the whole week (Mon start), we sum by week-start DOW.
 * For actual per-day grouping we use the existing day_of_week_demand data.
 */
function regroupByDow(weeklyObj, dowDemand) {
    // Use the pre-aggregated day_of_week_demand from backend (already Mon-Sun counts)
    const order = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    const out = {};
    order.forEach(d => { out[d] = dowDemand[d] ?? 0; });
    return out;
}

/**
 * Collapses weekly or daily data into monthly buckets Jan..Dec.
 * Uses monthlyTrends which is already { "2024-01": N, ... }
 * Re-keys to short month names for display.
 */
function regroupByMonth(monthlyHistorical) {
    const monthNames = { '01':'Jan','02':'Feb','03':'Mar','04':'Apr','05':'May','06':'Jun',
                         '07':'Jul','08':'Aug','09':'Sep','10':'Oct','11':'Nov','12':'Dec' };
    // Sum across years — e.g. "2024-01" + "2025-01" both contribute to "Jan"
    const out = { Jan:0,Feb:0,Mar:0,Apr:0,May:0,Jun:0,Jul:0,Aug:0,Sep:0,Oct:0,Nov:0,Dec:0 };
    Object.entries(monthlyHistorical || {}).forEach(([k, v]) => {
        const mm = k.slice(5, 7); // "2024-03" → "03"
        const label = monthNames[mm];
        if (label) out[label] = (out[label] || 0) + Number(v);
    });
    return out;
}

/**
 * Returns a transformed copy of data with X-axis regrouped.
 * Only chart-driving series are changed; KPIs/scorecards untouched.
 */
function applyAggregateFilters(d) {
    const view = getXAxisView();
    if (view === 'weekly') return d; // default — no transformation

    const transformed = Object.assign({}, d);
    const dowDemand = d.day_of_week_demand || {};
    const monthlyHistorical = d.forecast_series?.monthly?.historical || {};

    if (view === 'dow') {
        // Build DOW series for trend charts
        const dowSeries = regroupByDow(d.forecast_series?.weekly?.historical || {}, dowDemand);
        transformed.forecast_series = {
            weekly: { historical: dowSeries, forecast: {}, lower: {}, upper: {} },
            monthly: d.forecast_series?.monthly,
        };
        transformed.actual_vs_forecast = null; // not meaningful in DOW view
        transformed.rolling_mape = null;        // not meaningful in DOW view
        transformed.participant_demand_trend = dowSeries;
        transformed.facility_load_distribution = d.facility_load_distribution; // keep as-is
        transformed._xaxis_label = 'Reservations by Day of Week';
        transformed._xaxis_view = 'dow';

    } else if (view === 'monthly') {
        // Build Monthly series for trend charts
        const monthlySeries = regroupByMonth(monthlyHistorical);
        transformed.forecast_series = {
            weekly: { historical: monthlySeries, forecast: {}, lower: {}, upper: {} },
            monthly: { historical: monthlySeries, forecast: {}, lower: {}, upper: {} },
        };
        transformed.actual_vs_forecast = null; // not meaningful in month view
        transformed.rolling_mape = null;
        transformed.participant_demand_trend = monthlySeries;
        transformed._xaxis_label = 'Reservations by Month';
        transformed._xaxis_view = 'monthly';
    }

    return transformed;
}

function updateFilterBadge() {
    const existing = document.getElementById('filter-active-badge');
    if (existing) existing.remove();
}

function redrawChartsWithFilter() {
    if (!lastData) return;
    updateFilterBadge();
    destroyCharts();
    drawCharts(currentFn, applyAggregateFilters(lastData));
}

// ───────────────────────────────────────────────────────────────────────────

function renderTab(fn, data, isFallback) {
    let html = '<div class="sa-analytics-title-row"><div><h3>' + title(fn) + '</h3><p>' + summary(fn) + '</p></div>';
    html += '<span class="sa-analytics-source live">Live</span></div>';
    if (!['forecasting', 'planning', 'facility_demand'].includes(fn)) html += kpiRow(fn, data);
    html += '<div class="sa-analytics-grid">';
    if (fn === 'forecasting') html += forecastingHtml(data);
    else if (fn === 'facility_demand') html += facilityDemandHtml(data);
    else if (fn === 'planning') html += planningHtml(data);
    else if (fn === 'organizing') html += organizingHtml(data);
    else if (fn === 'leading') html += leadingHtml(data);
    else html += controllingHtml(data);
    html += '</div>';
    if (data.control_recommendations || data.optimization_suggestions) {
        const tips = data.control_recommendations || data.optimization_suggestions;
        html += '<div class="an-pro-insights sa-chart-wide"><h5>Managerial insights</h5><ul>' + tips.map(t => '<li>' + esc(t) + '</li>').join('') + '</ul></div>';
    }
    document.getElementById('analytics-content').innerHTML = html;
    updateFilterBadge();
    drawCharts(fn, applyAggregateFilters(data), isFallback);
}

function kpiRow(fn, d) {
    const cards = [];
    if (fn === 'forecasting') {
        const acc = d.forecast_accuracy || {};
        const vol = d.demand_volatility || {};
        const mom = d.trend_momentum || {};
        const dq = d.data_quality || {};
        cards.push(kpi('Weekly MAPE', (acc.weekly_mape ?? '—') + '%', 'Model accuracy', trendIcon(acc.weekly_mape, 20, true)));
        cards.push(kpi('Monthly MAPE', (acc.monthly_mape ?? '—') + '%', 'Model accuracy', trendIcon(acc.monthly_mape, 20, true)));
        cards.push(kpi('Volatility', (vol.cv ?? 0) + '%', vol.label || 'N/A', trendIcon(vol.cv, 30, true)));
        cards.push(kpi('Momentum', (mom.direction === 'up' ? '+' : mom.direction === 'down' ? '-' : '') + (mom.strength ?? 0) + '%', mom.direction || 'neutral', ''));
        cards.push(kpi('Data Quality', dq.grade || 'N/A', 'Score: ' + (dq.score ?? 0) + '%', trendIcon(dq.score, 80, false)));
    } else if (fn === 'planning') {
        const acc = d.forecast_accuracy || {};
        const vol = d.demand_volatility || {};
        const mom = d.trend_momentum || {};
        const dq = d.data_quality || {};
        const totalRows = d.totalRows ?? d.reservationCount ?? 0;
        cards.push(kpi('Weekly MAPE', (acc.weekly_mape ?? '—') + '%', 'Model accuracy', trendIcon(acc.weekly_mape, 20, true)));
        cards.push(kpi('Volatility', vol.cv + '% ' + (vol.label || ''), 'Demand stability', trendIcon(vol.cv, 30, true)));
        cards.push(kpi('Momentum', (mom.direction === 'up' ? '+' : mom.direction === 'down' ? '-' : '') + (mom.strength ?? 0) + '%', mom.direction || 'neutral', ''));
        cards.push(kpi('Data Quality', dq.grade || 'N/A', 'Score: ' + (dq.score ?? 0) + '%', trendIcon(dq.score, 80, false)));
        cards.push(kpi('Reservations', totalRows, 'Total records', ''));
    } else if (fn === 'organizing') {
        const capEff = d.capacity_efficiency || {};
        const effVals = Object.values(capEff).map(v => v.efficiency);
        const avgEff = effVals.length ? (effVals.reduce((a,b)=>a+b,0)/effVals.length).toFixed(1) : 0;
        cards.push(kpi('Facilities', Object.keys(d.facility_load_distribution || {}).length, 'Active rooms', ''));
        cards.push(kpi('Peak Slot', getPeakFromObj(d.peak_usage_times || {}), 'Highest demand', ''));
        cards.push(kpi('Avg Efficiency', avgEff + '%', 'Capacity usage', trendIcon(parseFloat(avgEff), 50, false)));
        cards.push(kpi('Total Bookings', Object.values(d.facility_load_distribution || {}).reduce((a,b)=>a+b,0), 'All facilities', ''));
    } else if (fn === 'controlling') {
        const funnel = d.approval_funnel || {};
        const compliance = d.setup_compliance_rate ?? 0;
        const noshow = d.no_show_rate ?? 0;
        const compScore = Math.round(compliance * 0.4 + (100 - noshow) * 0.35 + (funnel.approval_rate ?? 0) * 0.25);
        cards.push(kpi('Compliance Score', compScore + '%', 'Weighted composite', trendIcon(compScore, 70, false)));
        cards.push(kpi('Setup compliance', compliance + '%', '≤ 3 days lead', trendIcon(compliance, 80, false)));
        cards.push(kpi('No-show rate', noshow + '%', 'Cancelled + rejected', trendIcon(noshow, 15, true)));
        cards.push(kpi('Avg setup gap', (d.average_setup_gap ?? 0) + ' d', 'Lead time', ''));
    } else if (fn === 'leading') {
        const funnel = d.approval_funnel || {};
        cards.push(kpi('Approval rate', (funnel.approval_rate ?? 0) + '%', 'Conversion', trendIcon(funnel.approval_rate ?? 0, 70, false)));
        cards.push(kpi('Rejection rate', (funnel.rejection_rate ?? 0) + '%', 'Blocked', trendIcon(funnel.rejection_rate ?? 0, 15, true)));
        cards.push(kpi('Pipeline', funnel.submitted ?? 0, 'Total submitted', ''));
    }
    return '<div class="an-pro-kpi-row sa-chart-wide">' + cards.join('') + '</div>';
}

function trendIcon(val, threshold, lowerIsBetter) {
    if (val == null || val === '—') return '';
    const v = Number(val);
    if (lowerIsBetter) {
        if (v <= threshold) return '<span class="trend-good">↓ Good</span>';
        return '<span class="trend-warn">↑ High</span>';
    } else {
        if (v >= threshold) return '<span class="trend-good">↑ Good</span>';
        return '<span class="trend-warn">↓ Low</span>';
    }
}

function getPeakFromObj(obj) {
    const entries = Object.entries(obj);
    if (!entries.length) return '—';
    entries.sort((a,b) => b[1] - a[1]);
    return entries[0][0];
}

function kpi(label, value, sub, trend) {
    return '<div class="an-pro-kpi"><div class="label">' + esc(label) + '</div><div class="value">' + esc(String(value)) + (trend || '') + '</div><div class="sub">' + esc(sub) + '</div></div>';
}

function forecastingHtml(d) {
    const acc = d.forecast_accuracy || {};
    const mapeQuality = (v) => { if (v == null) return ''; if (v < 10) return ' mq-excellent'; if (v < 20) return ' mq-good'; if (v < 30) return ' mq-fair'; return ' mq-poor'; };
    let accuracyPanel = `<div class="sa-chart-container an-pro-chart-card sa-chart-wide an-pro-accuracy-panel">
        <h4>ARIMA Model Accuracy Evaluation</h4>
        <p class="chart-sub">Forecast accuracy metrics — lower values indicate better model performance</p>
        <div class="an-pro-metrics-grid">
            <div class="metric-card">
                <div class="metric-icon">W</div>
                <div class="metric-label">Weekly MAE</div>
                <div class="metric-value">${acc.weekly_mae ?? '—'}</div>
                <div class="metric-desc">Mean Absolute Error</div>
            </div>
            <div class="metric-card">
                <div class="metric-icon">W</div>
                <div class="metric-label">Weekly RMSE</div>
                <div class="metric-value">${acc.weekly_rmse ?? '—'}</div>
                <div class="metric-desc">Root Mean Square Error</div>
            </div>
            <div class="metric-card${mapeQuality(acc.weekly_mape)}">
                <div class="metric-icon">W</div>
                <div class="metric-label">Weekly MAPE</div>
                <div class="metric-value">${(acc.weekly_mape ?? '—')}%</div>
                <div class="metric-desc">Mean Abs % Error</div>
            </div>
            <div class="metric-card">
                <div class="metric-icon">M</div>
                <div class="metric-label">Monthly MAE</div>
                <div class="metric-value">${acc.monthly_mae ?? '—'}</div>
                <div class="metric-desc">Mean Absolute Error</div>
            </div>
            <div class="metric-card">
                <div class="metric-icon">M</div>
                <div class="metric-label">Monthly RMSE</div>
                <div class="metric-value">${acc.monthly_rmse ?? '—'}</div>
                <div class="metric-desc">Root Mean Square Error</div>
            </div>
            <div class="metric-card${mapeQuality(acc.monthly_mape)}">
                <div class="metric-icon">M</div>
                <div class="metric-label">Monthly MAPE</div>
                <div class="metric-value">${(acc.monthly_mape ?? '—')}%</div>
                <div class="metric-desc">Mean Abs % Error</div>
            </div>
        </div>
        <div class="an-pro-legend-box">
            <h5>How to Interpret</h5>
            <ul>
                <li><strong>MAE</strong> — Average absolute difference between actual and predicted reservation counts</li>
                <li><strong>RMSE</strong> — Like MAE but penalizes large errors more; useful for detecting outlier weeks</li>
                <li><strong>MAPE</strong> — Percentage-based: <span class="mq-tag excellent">&lt;10% Excellent</span> <span class="mq-tag good">&lt;20% Good</span> <span class="mq-tag fair">&lt;30% Fair</span> <span class="mq-tag poor">&gt;30% Poor</span></li>
            </ul>
        </div>
    </div>`;

    const vol = d.demand_volatility || {};
    const seasonal = d.seasonal_pattern || {};
    const momentum = d.trend_momentum || {};
    const dq = d.data_quality || {};
    const ptr = d.peak_trough_ratio || 1;
