    <div class="an-pro-recommendations sa-chart-wide" id="reco-controlling"></div>`;
}

function drawCharts(fn, d, isFallback) {
    if (typeof Chart === 'undefined') return;
    Chart.defaults.font.family = "'Segoe UI', system-ui, sans-serif";
    Chart.defaults.color = '#4b5563';

    if (fn === 'planning') {
        const w = d.forecast_series?.weekly || (isFallback ? d.forecast_series?.weekly : null) || {};
        const m = d.forecast_series?.monthly || {};
        if (w.historical || w.forecast) charts.push(makeArimaChart('c-weekly', w));
        if (m.historical || m.forecast) charts.push(makeArimaChart('c-monthly', m));

        // Actual vs ARIMA vs Naïve chart
        const avf = d.actual_vs_forecast || {};
        if (avf.labels && avf.labels.length > 1) {
            charts.push(makeActualVsForecastChart('c-actual-vs', avf));
        }

        // Rolling MAPE chart
        const rm = d.rolling_mape || {};
        if (rm.labels && rm.labels.length > 1) {
            const rmEl = document.getElementById('c-rolling-mape');
            if (rmEl) {
                charts.push(new Chart(rmEl, {
                    type: 'line',
                    data: {
                        labels: rm.labels.map(formatLabel),
                        datasets: [{
                            label: 'MAPE %', data: rm.values,
                            borderColor: '#7c3aed', backgroundColor: 'rgba(124,58,237,0.08)',
                            fill: true, tension: 0.3, pointRadius: 3, borderWidth: 2
                        }, {
                            label: '20% threshold', data: rm.labels.map(() => 20),
                            borderColor: '#dc2626', borderDash: [4,4], pointRadius: 0, borderWidth: 1, fill: false
                        }]
                    },
                    options: { ...chartOpts('MAPE %'), plugins: { legend: { labels: { usePointStyle: true, padding: 16 } } } }
                }));
            }
            const rmInsight = document.getElementById('insight-rolling-mape');
            if (rmInsight && rm.values.length >= 3) {
                const recent = rm.values.slice(-3);
                const avgRecent = (recent.reduce((a,b)=>a+b,0)/recent.length).toFixed(1);
                const trend = rm.values[rm.values.length-1] < rm.values[0] ? 'improving' : 'needs attention';
                rmInsight.innerHTML = '<strong>Insight:</strong> Recent 3-period avg MAPE: <strong>' + avgRecent + '%</strong>. Model accuracy is <strong>' + trend + '</strong>. Values below 20% (red line) indicate good forecasting performance.';
            }
        }

        // Day-of-week demand
        const dow = d.day_of_week_demand || {};
        if (Object.keys(dow).length) charts.push(makeBar('c-dow', dow, '#2563eb', false));

        charts.push(makeDoughnut('c-events', d.event_type_distribution || {}));
        charts.push(makeBar('c-hours', d.peak_demand_hours || {}, '#006633', true));
        const pf = d.per_facility_weekly || [];
        if (pf.length) charts.push(makePerFacilityChart('c-per-fac', pf));

        // Generate insights
        generatePlanningInsights(d);
    } else if (fn === 'organizing') {
        charts.push(makeBar('c-load', d.facility_load_distribution || {}, '#006633'));
        charts.push(makeBar('c-peak', d.peak_usage_times || {}, '#2563eb', true));
        const util = {};
        Object.entries(d.room_utilization || {}).forEach(([k,v]) => util[k] = (v.utilization_rate || 0) * 100);
        charts.push(makeBar('c-util', util, '#0f766e'));
        renderHeatmap('heatmap', d.peak_usage_heatmap || {});
        generateOrganizingInsights(d);
    } else if (fn === 'leading') {
        charts.push(makeBar('c-success', d.event_success_by_type || {}, '#0f766e'));
        const top = d.top_events || {};
        const topChart = makeBar('c-top', top, '#006633');
        if (topChart) charts.push(topChart);
        else {
            const el = document.getElementById('c-top');
            if (el && el.parentElement) {
                el.parentElement.insertAdjacentHTML('beforeend', '<p class="chart-sub" style="color:#6b7280;">No event names recorded yet.</p>');
            }
        }
        charts.push(makeLine('c-part', d.participant_demand_trend || {}, '#7c3aed', 'Participants'));
        generateLeadingInsights(d);
    } else {
        charts.push(makeDoughnut('c-status', d.target_achievement || {}));
        const fu = {}; Object.entries(d.facility_utilization_rate || {}).forEach(([k,v]) => fu[k] = Number(v) * 100);
        charts.push(makeBar('c-futil', fu, '#b45309'));
        charts.push(makeBar('c-reject', d.rejection_analysis || {}, '#dc2626'));
        generateControllingInsights(d);
    }
}

function makeArimaChart(id, series) {
    const labels = [...new Set([...Object.keys(series.historical || {}), ...Object.keys(series.forecast || {})])].sort();
    const hist = labels.map(l => series.historical?.[l] ?? null);
    const fc = labels.map(l => series.forecast?.[l] ?? null);
    const lo = labels.map(l => series.lower?.[l] ?? null);
    const hi = labels.map(l => series.upper?.[l] ?? null);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'line',
        data: {
            labels: labels.map(formatLabel),
            datasets: [
                { label: 'Historical', data: hist, borderColor: '#006633', backgroundColor: 'rgba(0,102,51,0.12)', fill: true, tension: 0.35, pointRadius: 2, spanGaps: false },
                { label: 'ARIMA forecast', data: fc, borderColor: '#f59e0b', borderDash: [6,4], tension: 0.35, pointRadius: 3, spanGaps: false },
                { label: 'Lower bound', data: lo, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: '+1', pointRadius: 0, tension: 0.35 },
                { label: 'Upper bound', data: hi, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: false, pointRadius: 0, tension: 0.35 }
            ]
        },
        options: chartOpts('Reservations')
    });
}

function makePerFacilityChart(id, rows) {
    const labels = rows.map(r => r.facility);
    const vals = rows.map(r => {
        if (r.chart_value != null && r.chart_value > 0) return Number(r.chart_value);
        const fc = Object.values(r.forecast || {});
        if (fc.length) return fc.reduce((a, b) => a + Number(b), 0);
        const hist = Object.values(r.historical || {});
        return hist.length ? Number(hist[hist.length - 1]) : 0;
    });
    const el = document.getElementById(id);
    if (!el) return null;
    if (!labels.length || vals.every(v => v === 0)) {
        el.parentElement.innerHTML += '<p class="chart-sub" style="margin-top:8px;color:#6b7280;">Not enough weekly history per facility yet — chart appears when more reservations are recorded.</p>';
        return null;
    }
    return new Chart(el, {
        type: 'bar',
        data: { labels, datasets: [{ label: 'Next 4 weeks (ARIMA total)', data: vals, backgroundColor: labels.map((_, i) => palette()[i % 8]), borderRadius: 6 }] },
        options: { ...chartOpts('Forecasted demand'), indexAxis: 'y' }
    });
}

function makeBar(id, src, color, sortHours) {
    let entries = Object.entries(src).sort((a,b) => sortHours ? String(a[0]).localeCompare(b[0]) : b[1]-a[1]).slice(0, 12);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'bar',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ label: 'Count', data: entries.map(e => Number(e[1])), backgroundColor: color, borderRadius: 6 }] },
        options: { ...chartOpts(''), plugins: { legend: { display: false } } }
    });
}

function makeLine(id, src, color, label) {
    const entries = Object.entries(src).sort();
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'line',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ label: label || 'Value', data: entries.map(e => Number(e[1])), borderColor: color, backgroundColor: hexAlpha(color, 0.15), fill: true, tension: 0.35, pointRadius: 3 }] },
        options: chartOpts(label || '')
    });
}

function makeDoughnut(id, src) {
    const entries = Object.entries(src).sort((a,b) => b[1]-a[1]).slice(0, 8);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'doughnut',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ data: entries.map(e => Number(e[1])), backgroundColor: palette(), borderWidth: 0 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right' } } }
    });
}

function renderHeatmap(id, hm) {
    const box = document.getElementById(id);
    if (!box) return;
    if (!hm.hours?.length || !hm.days?.length || !hm.values?.length) {
        box.innerHTML = '<p class="chart-sub" style="color:#6b7280;">No peak-hour pattern yet. Heatmap fills in as approved reservations accumulate.</p>';
        return;
    }
    const max = Math.max(1, ...hm.values.flat().map(Number));
    let html = '<table><thead><tr><th>Hour</th>';
    (hm.days || []).forEach(d => html += '<th>' + esc(String(d).slice(5)) + '</th>');
    html += '</tr></thead><tbody>';
    hm.hours.forEach((h, i) => {
        html += '<tr><th>' + esc(h) + ':00</th>';
        (hm.values[i] || []).forEach(v => {
            const n = Number(v);
            const intensity = Math.round((n / max) * 180 + 40);
            html += '<td><span class="cell" style="background:rgb(0,' + intensity + ',80)">' + n + '</span></td>';
        });
        html += '</tr>';
    });
    html += '</tbody></table>';
    box.innerHTML = html;
}

function makeActualVsForecastChart(id, avf) {
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'line',
        data: {
            labels: avf.labels.map(formatLabel),
            datasets: [
                { label: 'Actual', data: avf.actual, borderColor: '#006633', backgroundColor: 'rgba(0,102,51,0.08)', fill: true, tension: 0.3, pointRadius: 3, borderWidth: 2.5 },
                { label: 'ARIMA Forecast', data: avf.arima, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.05)', tension: 0.3, pointRadius: 3, borderWidth: 2.5, fill: false },
                { label: 'Naïve Baseline (t-1)', data: avf.naive, borderColor: '#dc2626', borderDash: [5,3], tension: 0.3, pointRadius: 2, borderWidth: 1.5, fill: false }
            ]
        },
        options: {
            ...chartOpts('Reservations'),
            plugins: {
                legend: { labels: { usePointStyle: true, padding: 16 } },
                tooltip: { callbacks: { afterBody: (ctx) => {
                    const i = ctx[0].dataIndex;
                    const arimaErr = Math.abs((avf.actual[i] || 0) - (avf.arima[i] || 0)).toFixed(1);
                    const naiveErr = Math.abs((avf.actual[i] || 0) - (avf.naive[i] || 0)).toFixed(1);
                    return 'ARIMA error: ' + arimaErr + ' | Naïve error: ' + naiveErr;
                } } }
            }
        }
    });
}

function generatePlanningInsights(d) {
    // Weekly insight
    const wEl = document.getElementById('insight-weekly');
    if (wEl) {
        const w = d.forecast_series?.weekly || {};
        const hist = Object.values(w.historical || {});
        const fc = Object.values(w.forecast || {});
        if (hist.length > 1) {
            const lastWeeks = hist.slice(-4);
            const avg = (lastWeeks.reduce((a,b)=>a+b,0)/lastWeeks.length).toFixed(1);
            const trend = hist[hist.length-1] > hist[hist.length-2] ? 'increasing' : hist[hist.length-1] < hist[hist.length-2] ? 'decreasing' : 'stable';
            let insight = '<strong>Insight:</strong> Weekly demand is <strong>' + trend + '</strong>. Recent 4-week average: ' + avg + ' reservations/week.';
            if (fc.length) { const fcAvg = (fc.reduce((a,b)=>a+b,0)/fc.length).toFixed(1); insight += ' Forecasted average: ' + fcAvg + '/week over the next ' + fc.length + ' weeks.'; }
            wEl.innerHTML = insight;
        }
    }

    // Monthly insight
    const mEl = document.getElementById('insight-monthly');
    if (mEl) {
        const m = d.forecast_series?.monthly || {};
        const hist = Object.values(m.historical || {});
        if (hist.length > 2) {
            const lastMonths = hist.slice(-3);
            const avg = (lastMonths.reduce((a,b)=>a+b,0)/lastMonths.length).toFixed(1);
            const peak = Math.max(...hist);
            const peakMonth = Object.keys(m.historical || {})[hist.indexOf(peak)];
            mEl.innerHTML = '<strong>Insight:</strong> Recent 3-month average: ' + avg + ' reservations/month. Peak month: <strong>' + peakMonth + '</strong> (' + peak + ' reservations).';
        }
    }

    // Actual vs Forecast insight
    const avfEl = document.getElementById('insight-actual-vs');
    if (avfEl) {
        const avf = d.actual_vs_forecast || {};
        if (avf.actual && avf.actual.length > 1) {
            // Calculate MAE for both models
            let arimaTotal = 0, naiveTotal = 0, n = avf.actual.length;
            for (let i = 0; i < n; i++) {
                arimaTotal += Math.abs(avf.actual[i] - (avf.arima?.[i] || 0));
                naiveTotal += Math.abs(avf.actual[i] - (avf.naive?.[i] || 0));
            }
            const arimaMae = (arimaTotal / n).toFixed(2);
            const naiveMae = (naiveTotal / n).toFixed(2);
            const improvement = naiveTotal > 0 ? (((naiveTotal - arimaTotal) / naiveTotal) * 100).toFixed(1) : 0;
            avfEl.innerHTML = '<strong>ARIMA vs Naïve Comparison:</strong> ARIMA MAE = <strong>' + arimaMae + '</strong> vs Naïve MAE = <strong>' + naiveMae + '</strong>. ARIMA is <strong>' + improvement + '% more accurate</strong> than the naïve baseline. The amber line (ARIMA) should track closer to the green line (Actual) than the red dashed line (Naïve).';
        }
    }

    // Day-of-week insight
    const dowEl = document.getElementById('insight-dow');
    if (dowEl) {
        const dow = d.day_of_week_demand || {};
        const entries = Object.entries(dow).sort((a,b) => b[1]-a[1]);
        if (entries.length) {
            const busiest = entries[0];
            const quietest = entries[entries.length-1];
            dowEl.innerHTML = '<strong>Insight:</strong> Busiest day: <strong>' + busiest[0] + '</strong> (' + busiest[1] + ' reservations). Quietest: <strong>' + quietest[0] + '</strong> (' + quietest[1] + '). Consider allocating more staff/resources on ' + busiest[0] + '.';
        }
    }
}

function generateOrganizingInsights(d) {
    // Executive Summary
    const execEl = document.getElementById('exec-organizing');
    if (execEl) {
        const load = d.facility_load_distribution || {};
        const entries = Object.entries(load).sort((a,b) => b[1]-a[1]);
        const totalBookings = entries.reduce((s,e)=> s+e[1], 0);
        const topFac = entries[0] ? entries[0][0] : 'N/A';
        const topPct = entries[0] && totalBookings > 0 ? ((entries[0][1]/totalBookings)*100).toFixed(0) : 0;
        execEl.innerHTML = `<div class="exec-box"><h5>Executive Summary — Organizing</h5><p><strong>${Object.keys(load).length} facilities</strong> tracked with <strong>${totalBookings} total reservations</strong>. The most utilized facility is <strong>${esc(topFac)}</strong> accounting for <strong>${topPct}%</strong> of all bookings. ${entries.length > 1 && entries[entries.length-1][1] < 5 ? 'Some facilities are significantly underutilized — consider promoting them or redistributing demand.' : 'Demand is relatively balanced across facilities.'}</p></div>`;
    }

    // Facility load insight
    const loadEl = document.getElementById('insight-load');
    if (loadEl) {
        const load = d.facility_load_distribution || {};
        const entries = Object.entries(load).sort((a,b) => b[1]-a[1]);
        if (entries.length >= 2) {
            const ratio = entries[0][1] > 0 ? (entries[0][1] / entries[entries.length-1][1]).toFixed(1) : 1;
            loadEl.innerHTML = '<strong>Insight:</strong> <strong>' + esc(entries[0][0]) + '</strong> has ' + ratio + 'x more bookings than <strong>' + esc(entries[entries.length-1][0]) + '</strong>. Consider load-balancing by promoting underused facilities.';
        }
    }

    // Peak usage insight
    const peakEl = document.getElementById('insight-peak');
    if (peakEl) {
        const peak = d.peak_usage_times || {};
        const entries = Object.entries(peak).sort((a,b) => b[1]-a[1]);
        if (entries.length) {
            peakEl.innerHTML = '<strong>Insight:</strong> Peak demand slot is <strong>' + esc(entries[0][0]) + '</strong> with ' + entries[0][1] + ' reservations. Schedule maintenance and setup activities outside this window.';
        }
    }

    // Utilization insight
    const utilEl = document.getElementById('insight-util');
    if (utilEl) {
        const util = d.room_utilization || {};
        const rates = Object.entries(util).map(([k,v]) => ({name:k, rate:(v.utilization_rate||0)*100}));
        const avg = rates.length ? (rates.reduce((s,r)=>s+r.rate,0)/rates.length).toFixed(1) : 0;
        const low = rates.filter(r => r.rate < 2);
        let txt = '<strong>Insight:</strong> Average utilization: <strong>' + avg + '%</strong>. ';
        if (low.length) txt += low.length + ' facilities below 2% utilization (' + low.map(r=>r.name).join(', ') + ') — these may be candidates for schedule optimization or repurposing.';
        else txt += 'All facilities show healthy usage levels.';
        utilEl.innerHTML = txt;
    }

    // Recommendations
    const recoEl = document.getElementById('reco-organizing');
    if (recoEl) {
        const suggestions = d.optimization_suggestions || [];
        let html = '<div class="reco-box"><h5>Actionable Recommendations</h5><ul>';
        html += '<li>Monitor peak facilities before approving dense schedules to prevent overbooking.</li>';
        html += '<li>Redirect overflow demand to underutilized rooms to balance load across facilities.</li>';
        html += '<li>Maintain 15–30 min buffer between consecutive reservations for setup/cleanup.</li>';
        if (suggestions.length) suggestions.forEach(s => { html += '<li>' + esc(s) + '</li>'; });
        html += '</ul></div>';
        recoEl.innerHTML = html;
    }
}

function generateLeadingInsights(d) {
    const execEl = document.getElementById('exec-leading');
    if (execEl) {
        const rate = d.overall_completion_rate ?? 0;
        const rso = d.rso_completion_rate ?? 0;
        const status = rate >= 70 ? 'healthy' : rate >= 50 ? 'moderate' : 'concerning';
        execEl.innerHTML = `<div class="exec-box"><h5>Executive Summary — Event Execution</h5><p>Overall approval rate is <strong>${rate}%</strong> (${status}). RSO-related completion rate: <strong>${rso}%</strong>. ${rate < 50 ? 'Low approval suggests process bottlenecks or unclear requirements — review rejection reasons.' : rate >= 70 ? 'High approval rate indicates a well-functioning reservation process.' : 'Moderate approval rate — investigate top rejection reasons for improvement opportunities.'}</p></div>`;
    }

    // Success insight
    const successEl = document.getElementById('insight-success');
    if (successEl) {
        const data = d.event_success_by_type || {};
        const entries = Object.entries(data).sort((a,b)=>b[1]-a[1]);
        if (entries.length >= 2) {
            const best = entries[0];
            const worst = entries[entries.length-1];
            successEl.innerHTML = '<strong>Insight:</strong> Highest success rate: <strong>' + esc(best[0]) + '</strong> (' + best[1] + '%). Lowest: <strong>' + esc(worst[0]) + '</strong> (' + worst[1] + '%). Focus improvement efforts on low-approval categories.';
        }
    }

    // Participant trend insight
    const partEl = document.getElementById('insight-part');
    if (partEl) {
        const data = d.participant_demand_trend || {};
        const vals = Object.values(data);
        if (vals.length >= 3) {
            const recent = vals.slice(-3);
            const avg = (recent.reduce((a,b)=>a+b,0)/recent.length).toFixed(0);
            const trend = vals[vals.length-1] > vals[vals.length-2] ? 'increasing' : 'decreasing';
            partEl.innerHTML = '<strong>Insight:</strong> Participant demand is <strong>' + trend + '</strong>. Recent 3-month average: <strong>' + avg + ' participants</strong>. ' + (trend === 'increasing' ? 'Growing engagement signals the system is being actively adopted.' : 'Declining trend may indicate scheduling friction or reduced event activity.');
        }
    }

    // Recommendations
    const recoEl = document.getElementById('reco-leading');
    if (recoEl) {
        const rate = d.overall_completion_rate ?? 0;
        let html = '<div class="reco-box"><h5>Actionable Recommendations</h5><ul>';
        if (rate < 50) html += '<li><strong>Critical:</strong> Review and streamline the approval workflow to reduce rejection rate.</li>';
        html += '<li>Categorize rejection reasons to identify systemic issues vs. one-off problems.</li>';
        html += '<li>Track time-to-approval metrics to identify processing delays.</li>';
        html += '<li>Consider automated pre-screening for common reservation types to speed approvals.</li>';
        html += '</ul></div>';
        recoEl.innerHTML = html;
    }
}

function generateControllingInsights(d) {
    const execEl = document.getElementById('exec-controlling');
    if (execEl) {
        const compliance = d.setup_compliance_rate ?? 0;
        const noshow = d.no_show_rate ?? 0;
        const gap = d.average_setup_gap ?? 0;
        const health = compliance >= 80 && noshow <= 15 ? 'Good' : compliance >= 50 ? 'Needs attention' : 'Critical';
        execEl.innerHTML = `<div class="exec-box"><h5>Executive Summary — Controlling</h5><p>Operational health: <strong>${health}</strong>. Setup compliance (≤3 days lead time): <strong>${compliance}%</strong>. No-show rate: <strong>${noshow}%</strong>. Average setup gap: <strong>${gap} days</strong>. ${noshow > 25 ? 'High no-show rate indicates potential policy enforcement issues — consider implementing confirmation reminders or penalties.' : 'No-show rate is within acceptable range.'}</p></div>`;
    }

    // Status insight
    const statusEl = document.getElementById('insight-status');
    if (statusEl) {
        const data = d.target_achievement || {};
        const total = Object.values(data).reduce((s,v)=>s+v,0);
        if (total > 0) {
            const approved = data['Approved'] || data['Completed'] || 0;
            const pct = ((approved/total)*100).toFixed(0);
            statusEl.innerHTML = '<strong>Insight:</strong> Of <strong>' + total + '</strong> total reservations, <strong>' + pct + '%</strong> were approved/completed. Monitor rejected and cancelled bookings for patterns.';
        }
    }

    // Rejection insight
    const rejectEl = document.getElementById('insight-reject');
    if (rejectEl) {
        const data = d.rejection_analysis || {};
        const entries = Object.entries(data).sort((a,b)=>b[1]-a[1]);
        if (entries.length) {
            const top = entries[0];
            rejectEl.innerHTML = '<strong>Insight:</strong> Top rejection reason: <strong>' + esc(top[0]) + '</strong> (' + top[1] + ' occurrences). Address this category first for maximum impact on approval rates.';
        }
    }

    // Recommendations
    const recoEl = document.getElementById('reco-controlling');
    if (recoEl) {
        const noshow = d.no_show_rate ?? 0;
        const compliance = d.setup_compliance_rate ?? 0;
        let html = '<div class="reco-box"><h5>Actionable Recommendations</h5><ul>';
        if (noshow > 25) html += '<li><strong>Priority:</strong> Implement 24-hour confirmation reminders to reduce no-show rate (currently ' + noshow + '%).</li>';
        if (compliance < 50) html += '<li><strong>Priority:</strong> Enforce minimum 3-day advance booking policy to improve setup compliance (currently ' + compliance + '%).</li>';
        html += '<li>Review rejection patterns monthly and update policies to prevent recurring issues.</li>';
        html += '<li>Track cancellation timing — early cancellations may indicate scheduling conflicts that can be prevented.</li>';
        html += '<li>Consider implementing a waitlist system for high-demand facilities to reduce underutilization.</li>';
        html += '</ul></div>';
        recoEl.innerHTML = html;
    }
}

function chartOpts(y) {
    return {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { usePointStyle: true, padding: 16 } } },
        scales: {
            x: { grid: { display: false }, ticks: { maxRotation: 45 } },
            y: { beginAtZero: true, title: y ? { display: true, text: y } : undefined }
        }
    };
}

function palette() {
    return ['#006633','#2563eb','#f59e0b','#0f766e','#7c3aed','#dc2626','#0891b2','#65a30d'];
}

function title(fn) { 
    if (fn === 'leading') return 'Event Execution';
    return fn.charAt(0).toUpperCase() + fn.slice(1); 
}
function summary(fn) {
    const m = { planning: 'ARIMA weekly/monthly demand forecasts and event mix.', organizing: 'Facility allocation, peak times, and utilization.', leading: 'Approval and purpose-based success metrics.', controlling: 'Compliance, status mix, and utilization control.' };
    return m[fn] || '';
}
function formatLabel(l) { return String(l); }
function hexAlpha(hex, a) {
    const h = hex.replace('#','');
    const r = parseInt(h.slice(0,2),16), g = parseInt(h.slice(2,4),16), b = parseInt(h.slice(4,6),16);
    return 'rgba(' + r + ',' + g + ',' + b + ',' + a + ')';
}
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
{% endblock %}
