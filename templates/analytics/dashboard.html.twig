    return `
    <div class="an-pro-exec-summary sa-chart-wide" id="exec-controlling"></div>` + scorecard + `
    <div class="sa-chart-container an-pro-chart-card"><h4>Status Distribution</h4><p class="chart-sub">Proportion of reservation statuses</p><canvas id="c-status"></canvas><div class="an-pro-insight" id="insight-status"></div></div>
