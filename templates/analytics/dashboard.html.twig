{% extends 'layouts/app.html.twig' %}

{% block title %}Managerial Analytics | Reserva FTIC{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/analytics-pro.css') }}">
{% endblock %}

{% block content %}
<div class="an-pro-header">
    <div>
        <h2>Managerial Function Analytics</h2>
        <p>ARIMA demand forecasting, facility utilization, and decision-support visualizations — live data when reservations exist, demo dataset otherwise.</p>
    </div>
    <div class="an-pro-toolbar">
        <span id="data-source-badge" class="an-pro-badge demo"><span class="dot"></span> Loading…</span>
        <select id="facility-filter" class="an-pro-select" title="Filter by facility">
            <option value="">All facilities</option>
        </select>
        <a class="an-pro-btn-dl" href="{{ path('admin_role_analytics_export_this_week') }}">This week CSV</a>
        <a class="an-pro-btn-dl" id="dl-weekly" href="{{ path('admin_role_analytics_export_weekly') }}">ARIMA weekly CSV</a>
    </div>
</div>

<div class="sa-analytics-nav">
    <button class="sa-analytics-btn active analytics-btn" type="button" data-fn="planning">Planning</button>
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="organizing">Organizing</button>
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="leading">Leading</button>
    <button class="sa-analytics-btn analytics-btn" type="button" data-fn="controlling">Controlling</button>
</div>

<div id="analytics-content" class="sa-analytics-section">
    <div class="sa-loading">Loading Planning analytics…</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" crossorigin="anonymous"></script>
<script>
const API = 'http://127.0.0.1:8002';
let charts = [];
let currentFn = 'planning';
let facilities = [];

document.querySelectorAll('.analytics-btn').forEach(btn => {
    btn.addEventListener('click', () => loadAnalytics(btn.dataset.fn));
});

document.getElementById('facility-filter').addEventListener('change', () => loadAnalytics(currentFn));

document.addEventListener('DOMContentLoaded', () => {
    fetch(API + '/api/analytics/meta').then(r => r.json()).then(meta => {
        facilities = meta.facilities || [];
        const sel = document.getElementById('facility-filter');
        facilities.forEach(f => {
            const o = document.createElement('option');
            o.value = f.id || '';
            o.textContent = f.name + ' (' + f.count + ')';
            sel.appendChild(o);
        });
        updateBadge(meta);
    }).catch(() => {});
    loadAnalytics('planning');
});

function facilityParam() {
    const v = document.getElementById('facility-filter').value;
    return v ? '?facility_id=' + encodeURIComponent(v) : '';
}

function updateBadge(data) {
    const el = document.getElementById('data-source-badge');
    const live = data.source === 'live';
    el.className = 'an-pro-badge ' + (live ? 'live' : 'demo');
    el.innerHTML = '<span class="dot"></span> ' + (data.dataSourceLabel || (live ? 'Live data' : 'Demo data'));
    const dlWeekly = document.getElementById('dl-weekly');
    if (dlWeekly) dlWeekly.href = '{{ path('admin_role_analytics_export_weekly') }}' + facilityParam();
}

async function loadAnalytics(fn) {
    currentFn = fn;
    document.querySelectorAll('.analytics-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.fn === fn);
    });
    const box = document.getElementById('analytics-content');
    box.innerHTML = '<div class="sa-loading">Loading ' + fn + '…</div>';
    destroyCharts();
    try {
        const res = await fetch(API + '/api/analytics/' + fn + facilityParam());
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        updateBadge(data);
        renderTab(fn, data);
    } catch (e) {
        console.warn('FastAPI unavailable, using Symfony fallback', e);
        const local = {{ localAnalytics|json_encode|raw }};
        updateBadge({ source: 'demo', dataSourceLabel: 'Symfony fallback (start analytics server on port 8002)' });
        renderTab(fn, local[fn] || {}, true);
    }
}

function destroyCharts() {
    charts.forEach(c => c.destroy());
    charts = [];
}

function renderTab(fn, data, isFallback) {
    const src = data.source === 'live' ? 'live' : (isFallback ? 'fallback' : 'demo');
    let html = '<div class="sa-analytics-title-row"><div><h3>' + title(fn) + '</h3><p>' + summary(fn) + '</p></div>';
    html += '<span class="sa-analytics-source ' + src + '">' + (data.dataSourceLabel || src) + '</span></div>';
    html += kpiRow(fn, data);
    html += '<div class="sa-analytics-grid">';
    if (fn === 'planning') html += planningHtml(data);
    else if (fn === 'organizing') html += organizingHtml(data);
    else if (fn === 'leading') html += leadingHtml(data);
    else html += controllingHtml(data);
    html += '</div>';
    if (data.control_recommendations || data.optimization_suggestions) {
        const tips = data.control_recommendations || data.optimization_suggestions;
        html += '<div class="an-pro-insights sa-chart-wide"><h5>Managerial insights</h5><ul>' + tips.map(t => '<li>' + esc(t) + '</li>').join('') + '</ul></div>';
    }
    document.getElementById('analytics-content').innerHTML = html;
    drawCharts(fn, data, isFallback);
}

function kpiRow(fn, d) {
    const cards = [];
    if (fn === 'planning') {
        const acc = d.forecast_accuracy || {};
        cards.push(kpi('Weekly RMSE', acc.weekly_rmse ?? '—', 'ARIMA accuracy'));
        cards.push(kpi('Reservations', d.totalRows ?? d.reservationCount ?? 0, 'In dataset'));
        cards.push(kpi('Facilities', (d.facilities || []).length, 'Tracked'));
    } else if (fn === 'organizing') {
        cards.push(kpi('Overlaps', d.overlapping_reservations ?? 0, 'Same-day conflicts'));
        cards.push(kpi('Facilities', Object.keys(d.facility_load_distribution || {}).length, 'With bookings'));
    } else if (fn === 'controlling') {
        cards.push(kpi('Setup compliance', (d.setup_compliance_rate ?? 0) + '%', '≤ 3 days'));
        cards.push(kpi('No-show rate', (d.no_show_rate ?? 0) + '%', 'Cancelled + rejected'));
        cards.push(kpi('Avg setup gap', (d.average_setup_gap ?? 0) + ' d', 'Lead time'));
    } else if (fn === 'leading') {
        cards.push(kpi('Approval rate', (d.overall_completion_rate ?? 0) + '%', 'Approved share'));
        cards.push(kpi('RSO rate', (d.rso_completion_rate ?? 0) + '%', 'RSO-related'));
    }
    return '<div class="an-pro-kpi-row sa-chart-wide">' + cards.join('') + '</div>';
}

function kpi(label, value, sub) {
    return '<div class="an-pro-kpi"><div class="label">' + esc(label) + '</div><div class="value">' + esc(String(value)) + '</div><div class="sub">' + esc(sub) + '</div></div>';
}

function planningHtml(d) {
    return `
    <div class="sa-chart-container an-pro-chart-card sa-chart-wide"><h4>Weekly demand — historical vs ARIMA forecast</h4><p class="chart-sub">Solid: actual · Dashed: forecast · Shaded: 80% confidence interval</p><canvas id="c-weekly"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card sa-chart-wide"><h4>Monthly demand — historical vs ARIMA forecast</h4><canvas id="c-monthly"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Event type distribution</h4><canvas id="c-events"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Peak demand by hour</h4><canvas id="c-hours"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card sa-chart-wide"><h4>Per-facility weekly forecast (next 4 weeks)</h4><canvas id="c-per-fac"></canvas></div>`;
}

function organizingHtml(d) {
    return `
    <div class="sa-chart-container an-pro-chart-card"><h4>Facility load comparison</h4><canvas id="c-load"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Peak usage by hour</h4><canvas id="c-peak"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card sa-chart-wide"><h4>Utilization rate by facility</h4><canvas id="c-util"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card sa-chart-wide"><h4>Peak usage heatmap (hour × day)</h4><div class="an-pro-heatmap" id="heatmap"></div></div>`;
}

function leadingHtml(d) {
    return `
    <div class="sa-chart-container an-pro-chart-card sa-chart-wide"><h4>Event success by purpose (% approved)</h4><canvas id="c-success"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Top events by volume</h4><canvas id="c-top"></canvas></div>`;
}

function controllingHtml(d) {
    return `
    <div class="sa-chart-container an-pro-chart-card"><h4>Status distribution</h4><canvas id="c-status"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Facility utilization</h4><canvas id="c-futil"></canvas></div>
    <div class="sa-chart-container an-pro-chart-card"><h4>Rejection reasons</h4><canvas id="c-reject"></canvas></div>`;
}

function drawCharts(fn, d, isFallback) {
    if (typeof Chart === 'undefined') return;
    Chart.defaults.font.family = "'Segoe UI', system-ui, sans-serif";
    Chart.defaults.color = '#4b5563';

    if (fn === 'planning') {
        const w = d.forecast_series?.weekly || (isFallback ? d.forecast_series?.weekly : null) || {};
        const m = d.forecast_series?.monthly || {};
        if (w.historical || w.forecast) charts.push(makeArimaChart('c-weekly', w));
        if (m.historical || m.forecast) charts.push(makeArimaChart('c-monthly', m));
        charts.push(makeDoughnut('c-events', d.event_type_distribution || {}));
        charts.push(makeBar('c-hours', d.peak_demand_hours || {}, '#006633', true));
        const pf = d.per_facility_weekly || [];
        if (pf.length) charts.push(makePerFacilityChart('c-per-fac', pf));
    } else if (fn === 'organizing') {
        charts.push(makeBar('c-load', d.facility_load_distribution || {}, '#006633'));
        charts.push(makeBar('c-peak', d.peak_usage_times || {}, '#2563eb', true));
        const util = {};
        Object.entries(d.room_utilization || {}).forEach(([k,v]) => util[k] = (v.utilization_rate || 0) * 100);
        charts.push(makeBar('c-util', util, '#0f766e'));
        renderHeatmap('heatmap', d.peak_usage_heatmap || {});
    } else if (fn === 'leading') {
        charts.push(makeBar('c-success', d.event_success_by_type || {}, '#0f766e'));
        const top = d.top_events || {};
        const topChart = makeBar('c-top', top, '#006633');
        if (topChart) charts.push(topChart);
        else {
            const el = document.getElementById('c-top');
            if (el && el.parentElement) {
                el.parentElement.insertAdjacentHTML('beforeend', '<p class="chart-sub" style="color:#6b7280;">No event names recorded yet.</p>');
            }
        }
    } else {
        charts.push(makeDoughnut('c-status', d.target_achievement || {}));
        const fu = {}; Object.entries(d.facility_utilization_rate || {}).forEach(([k,v]) => fu[k] = Number(v) * 100);
        charts.push(makeBar('c-futil', fu, '#b45309'));
        charts.push(makeBar('c-reject', d.rejection_analysis || {}, '#dc2626'));
    }
}

function makeArimaChart(id, series) {
    const labels = [...new Set([...Object.keys(series.historical || {}), ...Object.keys(series.forecast || {})])].sort();
    const hist = labels.map(l => series.historical?.[l] ?? null);
    const fc = labels.map(l => series.forecast?.[l] ?? null);
    const lo = labels.map(l => series.lower?.[l] ?? null);
    const hi = labels.map(l => series.upper?.[l] ?? null);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'line',
        data: {
            labels: labels.map(formatLabel),
            datasets: [
                { label: 'Historical', data: hist, borderColor: '#006633', backgroundColor: 'rgba(0,102,51,0.12)', fill: true, tension: 0.35, pointRadius: 2, spanGaps: false },
                { label: 'ARIMA forecast', data: fc, borderColor: '#f59e0b', borderDash: [6,4], tension: 0.35, pointRadius: 3, spanGaps: false },
                { label: 'Lower bound', data: lo, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: '+1', pointRadius: 0, tension: 0.35 },
                { label: 'Upper bound', data: hi, borderColor: 'transparent', backgroundColor: 'rgba(245,158,11,0.08)', fill: false, pointRadius: 0, tension: 0.35 }
            ]
        },
        options: chartOpts('Reservations')
    });
}

function makePerFacilityChart(id, rows) {
    const labels = rows.map(r => r.facility);
    const vals = rows.map(r => {
        if (r.chart_value != null && r.chart_value > 0) return Number(r.chart_value);
        const fc = Object.values(r.forecast || {});
        if (fc.length) return fc.reduce((a, b) => a + Number(b), 0);
        const hist = Object.values(r.historical || {});
        return hist.length ? Number(hist[hist.length - 1]) : 0;
    });
    const el = document.getElementById(id);
    if (!el) return null;
    if (!labels.length || vals.every(v => v === 0)) {
        el.parentElement.innerHTML += '<p class="chart-sub" style="margin-top:8px;color:#6b7280;">Not enough weekly history per facility yet — chart appears when more reservations are recorded.</p>';
        return null;
    }
    return new Chart(el, {
        type: 'bar',
        data: { labels, datasets: [{ label: 'Next 4 weeks (ARIMA total)', data: vals, backgroundColor: labels.map((_, i) => palette()[i % 8]), borderRadius: 6 }] },
        options: { ...chartOpts('Forecasted demand'), indexAxis: 'y' }
    });
}

function makeBar(id, src, color, sortHours) {
    let entries = Object.entries(src).sort((a,b) => sortHours ? String(a[0]).localeCompare(b[0]) : b[1]-a[1]).slice(0, 12);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'bar',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ data: entries.map(e => Number(e[1])), backgroundColor: color, borderRadius: 6 }] },
        options: chartOpts('')
    });
}

function makeLine(id, src, color, label) {
    const entries = Object.entries(src).sort();
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'line',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ label, data: entries.map(e => Number(e[1])), borderColor: color, backgroundColor: hexAlpha(color, 0.15), fill: true, tension: 0.35 }] },
        options: chartOpts(label)
    });
}

function makeDoughnut(id, src) {
    const entries = Object.entries(src).sort((a,b) => b[1]-a[1]).slice(0, 8);
    const el = document.getElementById(id);
    if (!el) return null;
    return new Chart(el, {
        type: 'doughnut',
        data: { labels: entries.map(e => formatLabel(e[0])), datasets: [{ data: entries.map(e => Number(e[1])), backgroundColor: palette(), borderWidth: 0 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right' } } }
    });
}

function renderHeatmap(id, hm) {
    const box = document.getElementById(id);
    if (!box) return;
    if (!hm.hours?.length || !hm.days?.length || !hm.values?.length) {
        box.innerHTML = '<p class="chart-sub" style="color:#6b7280;">No peak-hour pattern yet. Heatmap fills in as approved reservations accumulate.</p>';
        return;
    }
    const max = Math.max(1, ...hm.values.flat().map(Number));
    let html = '<table><thead><tr><th>Hour</th>';
    (hm.days || []).forEach(d => html += '<th>' + esc(String(d).slice(5)) + '</th>');
    html += '</tr></thead><tbody>';
    hm.hours.forEach((h, i) => {
        html += '<tr><th>' + esc(h) + ':00</th>';
        (hm.values[i] || []).forEach(v => {
            const n = Number(v);
            const intensity = Math.round((n / max) * 180 + 40);
            html += '<td><span class="cell" style="background:rgb(0,' + intensity + ',80)">' + n + '</span></td>';
        });
        html += '</tr>';
    });
    html += '</tbody></table>';
    box.innerHTML = html;
}

function chartOpts(y) {
    return {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { usePointStyle: true, padding: 16 } } },
        scales: {
            x: { grid: { display: false }, ticks: { maxRotation: 45 } },
            y: { beginAtZero: true, title: y ? { display: true, text: y } : undefined }
        }
    };
}

function palette() {
    return ['#006633','#2563eb','#f59e0b','#0f766e','#7c3aed','#dc2626','#0891b2','#65a30d'];
}

function title(fn) { return fn.charAt(0).toUpperCase() + fn.slice(1); }
function summary(fn) {
    const m = { planning: 'ARIMA weekly/monthly demand forecasts and event mix.', organizing: 'Facility allocation, peak times, and utilization.', leading: 'Approval and purpose-based success metrics.', controlling: 'Compliance, status mix, and utilization control.' };
    return m[fn] || '';
}
function formatLabel(l) { return String(l); }
function hexAlpha(hex, a) {
    const h = hex.replace('#','');
    const r = parseInt(h.slice(0,2),16), g = parseInt(h.slice(2,4),16), b = parseInt(h.slice(4,6),16);
    return 'rgba(' + r + ',' + g + ',' + b + ',' + a + ')';
}
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
{% endblock %}
