function controllingHtml(d) {
    const funnel = d.approval_funnel || {};
    const risks = d.facility_risk_scores || {};
    const dq = d.data_quality || {};
    const compliance = d.setup_compliance_rate ?? 0;
    const noshow = d.no_show_rate ?? 0;

    // Weighted Compliance Scorecard
    const complianceScore = Math.round(compliance * 0.4 + (100 - noshow) * 0.35 + (funnel.approval_rate ?? 0) * 0.25);
    const csClass = complianceScore >= 80 ? 'mq-excellent' : complianceScore >= 60 ? 'mq-good' : complianceScore >= 40 ? 'mq-fair' : 'mq-poor';
    const csGrade = complianceScore >= 90 ? 'A+' : complianceScore >= 80 ? 'A' : complianceScore >= 70 ? 'B' : complianceScore >= 60 ? 'C' : 'D';

    let scorecard = `<div class="sa-chart-container an-pro-chart-card sa-chart-wide an-pro-accuracy-panel">
        <h4>Operational Compliance Scorecard</h4>
        <p class="chart-sub">Weighted composite score — Setup Compliance (40%) + Attendance (35%) + Approval Efficiency (25%)</p>
        <div class="an-pro-metrics-grid">
            <div class="metric-card ${csClass}">
                <div class="metric-icon">O</div>
                <div class="metric-label">Overall Score</div>
                <div class="metric-value">${csGrade} (${complianceScore}%)</div>
                <div class="metric-desc">Composite operational health</div>
            </div>
            <div class="metric-card ${compliance >= 70 ? 'mq-excellent' : compliance >= 40 ? 'mq-good' : 'mq-poor'}">
                <div class="metric-icon">S</div>
                <div class="metric-label">Setup Compliance</div>
                <div class="metric-value">${compliance}%</div>
                <div class="metric-desc">≤3 days advance booking</div>
            </div>
            <div class="metric-card ${noshow <= 15 ? 'mq-excellent' : noshow <= 30 ? 'mq-fair' : 'mq-poor'}">
                <div class="metric-icon">N</div>
                <div class="metric-label">Attendance Rate</div>
                <div class="metric-value">${(100 - noshow).toFixed(1)}%</div>
                <div class="metric-desc">No-show: ${noshow}%</div>
            </div>
            <div class="metric-card ${(funnel.approval_rate ?? 0) >= 70 ? 'mq-excellent' : (funnel.approval_rate ?? 0) >= 50 ? 'mq-good' : 'mq-fair'}">
                <div class="metric-icon">E</div>
                <div class="metric-label">Process Efficiency</div>
                <div class="metric-value">${funnel.approval_rate ?? 0}%</div>
                <div class="metric-desc">Approval conversion rate</div>
            </div>
            <div class="metric-card ${dq.score >= 80 ? 'mq-excellent' : dq.score >= 60 ? 'mq-good' : 'mq-fair'}">
                <div class="metric-icon">Q</div>
                <div class="metric-label">Data Quality</div>
                <div class="metric-value">${dq.grade || 'N/A'}</div>
                <div class="metric-desc">${dq.score ?? 0}% completeness</div>
            </div>
            <div class="metric-card">
                <div class="metric-icon">G</div>
                <div class="metric-label">Avg Setup Gap</div>
                <div class="metric-value">${d.average_setup_gap ?? 0}d</div>
                <div class="metric-desc">Lead time before event</div>
            </div>
        </div>
    </div>`;

    // Facility Risk Matrix
    const riskEntries = Object.entries(risks).slice(0, 6);
    let riskPanel = '';
    if (riskEntries.length) {
        riskPanel = `<div class="sa-chart-container an-pro-chart-card sa-chart-wide an-pro-accuracy-panel">
            <h4>Facility Risk Assessment Matrix</h4>
            <p class="chart-sub">Identifies facilities with highest operational risk — overload probability × no-show impact</p>
            <div style="overflow-x:auto"><table class="an-pro-summary-table"><thead><tr><th>Facility</th><th>Risk Score</th><th>Overload Risk</th><th>No-Show Risk</th><th>Bookings</th></tr></thead><tbody>`;
        riskEntries.forEach(([name, r]) => {
            const riskClass = r.risk_score >= 40 ? 'color:#dc2626;font-weight:700' : r.risk_score >= 20 ? 'color:#d97706;font-weight:700' : 'color:#059669';
            riskPanel += `<tr><td>${esc(name)}</td><td style="${riskClass}">${r.risk_score}/60</td><td><span class="util-badge ${r.overload_risk === 'High' ? 'low' : r.overload_risk === 'Medium' ? 'med' : 'high'}">${r.overload_risk}</span></td><td><span class="util-badge ${r.no_show_risk === 'High' ? 'low' : r.no_show_risk === 'Medium' ? 'med' : 'high'}">${r.no_show_risk}</span></td><td>${r.bookings}</td></tr>`;
        });
        riskPanel += `</tbody></table></div>
            <div class="an-pro-legend-box"><h5>Risk Interpretation</h5><ul>
                <li><strong>Score 0-19:</strong> Low risk — normal operations</li>
                <li><strong>Score 20-39:</strong> Moderate — monitor closely and prepare contingencies</li>
                <li><strong>Score 40-60:</strong> High — immediate intervention recommended</li>
