{% extends 'layouts/app.html.twig' %}

{% block title %}Research Repository | Reserva FTIC{% endblock %}

{% block content %}
<div class="content-header">
    {% if is_granted('ROLE_SUPER_ADMIN') %}
        <div class="button-group">
            <a href="{{ path('research_new', {'type': 'News'}) }}" class="btn-primary">Add Content News</a>
            <a href="{{ path('research_new', {'type': 'Article'}) }}" class="btn-primary">Add Content Articles</a>
            <a href="{{ path('research_new', {'type': 'Research'}) }}" class="btn-primary">Add Content Research</a>
        </div>
    {% endif %}
</div>

<section class="card-panel">
    <form method="get" action="{{ path('research_index') }}" class="form-grid compact">
        <input name="q" value="{{ query }}" class="form-input" placeholder="Search title, summary, or tags">
        <select name="type" class="form-input">
            <option value="">All types</option>
            {% for option in ['News', 'Article', 'Research'] %}
                <option value="{{ option }}" {% if option == type %}selected{% endif %}>{{ option }}</option>
            {% endfor %}
        </select>
        <select name="category" class="form-input">
            <option value="">All categories</option>
            {% for itemCategory in categories %}
                <option value="{{ itemCategory }}" {% if itemCategory == category %}selected{% endif %}>{{ itemCategory }}</option>
            {% endfor %}
        </select>
        <button class="btn-secondary" type="submit">Filter</button>
    </form>
</section>

<h2>News</h2>
<section class="research-grid">
    {% set newsCount = 0 %}
    {% for item in items %}
        {% if item.type == 'News' %}
            {% set newsCount = newsCount + 1 %}
            <article class="card-panel">
                <h3>{{ item.title }}</h3>
                {% if item.body %}
                    <p>{{ item.body }}</p>
                {% endif %}
                {% if item.embeddedLink %}
                    <div class="embedded-content">
                        {{ item.embeddedLink|raw }}
                    </div>
                {% endif %}
                {% if is_granted('ROLE_SUPER_ADMIN') or item.author == app.user %}
                    <a href="{{ path('research_edit', {'id': item.id}) }}" class="btn-primary">Edit</a>
                {% endif %}
            </article>
        {% endif %}
    {% endfor %}
    {% if newsCount == 0 %}
        <div class="card-panel">
            <p>No news content found.</p>
        </div>
    {% endif %}
</section>

<h2>Articles</h2>
<section class="research-grid">
    {% set articleCount = 0 %}
    {% for item in items %}
        {% if item.type == 'Article' %}
            {% set articleCount = articleCount + 1 %}
            <article class="card-panel">
                <h3>{{ item.title }}</h3>
                {% if item.filePath %}
                    <div class="article-image-wrapper">
                        <img src="{{ item.filePath }}" alt="{{ item.title }}" class="article-image">
                    </div>
                {% endif %}
                {% if item.body %}
                    <p>{{ item.body }}</p>
                {% endif %}
                {% if item.externalLink %}
                    <a href="{{ item.externalLink }}" target="_blank" rel="noopener" class="btn-secondary">Read Article</a>
                {% endif %}
                {% if is_granted('ROLE_SUPER_ADMIN') or item.author == app.user %}
                    <a href="{{ path('research_edit', {'id': item.id}) }}" class="btn-primary">Edit</a>
                {% endif %}
            </article>
        {% endif %}
    {% endfor %}
    {% if articleCount == 0 %}
        <div class="card-panel">
            <p>No articles found.</p>
        </div>
    {% endif %}
</section>

<h2>Research</h2>
<section class="research-grid">
    {% set researchCount = 0 %}
    {% for item in items %}
        {% if item.type == 'Research' %}
            {% set researchCount = researchCount + 1 %}
            <article class="card-panel">
                <h3 style="color: green;">
                    <a href="{{ path('research_show', {'id': item.id}) }}" style="color: green; text-decoration: none;">
                        {{ item.title }}
                    </a>
                </h3>
                <p><strong>Repository Type:</strong> {{ item.repositoryType }}</p>
                <p><strong>Authors:</strong> {{ item.authors }}</p>
                <p>{{ item.abstract ?: 'No abstract provided.' }}</p>
                {% if item.filePath %}
                    <a href="{{ item.filePath }}" class="btn-secondary" title="Download PDF">
                        📄 PDF
                    </a>
                {% endif %}
                {% if is_granted('ROLE_SUPER_ADMIN') or item.author == app.user %}
                    <a href="{{ path('research_edit', {'id': item.id}) }}" class="btn-primary">Edit</a>
                {% endif %}
            </article>
        {% endif %}
    {% endfor %}
    {% if researchCount == 0 %}
        <div class="card-panel">
            <p>No research content found.</p>
        </div>
    {% endif %}
</section>
{% endblock %}
