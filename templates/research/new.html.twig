{% extends 'layouts/app.html.twig' %}

{% block title %}Add {{ type }} | Reserva FTIC{% endblock %}

{% block content %}
<style>
    .research-flash {
        margin-bottom: 16px;
        padding: 12px 14px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
    }
    .research-flash-success {
        background: #e8f7ea;
        color: #0b6b1a;
        border: 1px solid #b7e5bf;
    }
    .research-flash-error {
        background: #fdecec;
        color: #9d1c1c;
        border: 1px solid #f4bbbb;
    }
</style>
<div class="content-header">
    <h2>Add {{ type }} Content</h2>
    <a href="{{ path('research_index') }}" class="btn-secondary">Back to Research</a>
</div>

<section class="card-panel">
    {% for message in app.flashes('success') %}
        <div class="research-flash research-flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="research-flash research-flash-error">{{ message }}</div>
    {% endfor %}

    <form method="post" enctype="multipart/form-data" class="form-grid">
        <input type="hidden" name="_token" value="{{ csrf_token('research_new') }}">
        <input type="hidden" name="type" value="{{ type }}">

        <input name="title" class="form-input" placeholder="Title" required>

        {% if type == 'News' %}
            <input type="hidden" name="category" value="General">
            <input type="hidden" name="visibility" value="Public">
            <textarea name="body" class="form-input" placeholder="Content body"></textarea>
            <textarea name="embeddedLink" class="form-input" placeholder="Paste embedded iframe code here (e.g., Facebook video, YouTube embed, etc.)"></textarea>
        {% elseif type == 'Article' %}
            <textarea name="body" class="form-input" placeholder="Content body"></textarea>
            <input name="externalLink" class="form-input" placeholder="External article URL (e.g. https://...)">
            <input type="file" name="file" class="form-input" accept="image/*" title="Upload article image">
        {% else %}
            <select name="repositoryType" class="form-input" required>
                <option value="">Select Academic Repository Type</option>
                <option>Journal Article</option>
                <option>Conference Paper</option>
                <option>Thesis/Dissertation</option>
                <option>Book Chapter</option>
                <option>Technical Report</option>
                <option>Preprint</option>
                <option>Dataset</option>
                <option>Working Paper</option>
            </select>
            <input name="authors" class="form-input" placeholder="Authors (comma separated)" required>
            <textarea name="abstract" class="form-input" placeholder="Abstract" required></textarea>
            <input type="file" name="file" class="form-input" accept="application/pdf" title="Upload PDF file" required>
        {% endif %}

        <button class="btn-primary" type="submit">Publish {{ type }}</button>
    </form>
</section>
{% endblock %}
