{% extends 'layouts/app.html.twig' %}

{% block title %}Add Research | Reserva FTIC{% endblock %}

{% block content %}
<div class="content-header">
    <h2>Add Research Content</h2>
</div>

<section class="card-panel">
    <form method="post" enctype="multipart/form-data" class="form-grid">
        <input type="hidden" name="_token" value="{{ csrf_token('research_new') }}">
        <input name="title" class="form-input" placeholder="Title" required>
        <select name="type" class="form-input">
            <option>Article</option>
            <option>Research</option>
            <option>News</option>
        </select>
        <input name="category" class="form-input" placeholder="Category" value="General">
        <input name="tags" class="form-input" placeholder="Tags, comma separated">
        <select name="visibility" class="form-input">
            <option>Public</option>
            <option>Private</option>
        </select>
        <textarea name="summary" class="form-input" placeholder="Summary"></textarea>
        <textarea name="body" class="form-input" placeholder="Content body"></textarea>
        <input type="file" name="file" class="form-input">
        <button class="btn-primary" type="submit">Publish</button>
    </form>
</section>
{% endblock %}
