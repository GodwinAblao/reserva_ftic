{% extends 'layouts/app.html.twig' %}

{% block title %}Edit Research | Reserva FTIC{% endblock %}

{% block content %}
<div class="content-header">
    <h2>Edit Research Content</h2>
</div>

<section class="card-panel">
    <form method="post" class="form-grid">
        <input type="hidden" name="_token" value="{{ csrf_token('research_edit_' ~ item.id) }}">
        <input name="title" class="form-input" value="{{ item.title }}" required>
        <select name="type" class="form-input">
            {% for type in ['Article', 'Research', 'News'] %}
                <option {% if item.type == type %}selected{% endif %}>{{ type }}</option>
            {% endfor %}
        </select>
        <input name="category" class="form-input" value="{{ item.category }}">
        <input name="tags" class="form-input" value="{{ item.tags }}">
        <select name="visibility" class="form-input">
            {% for visibility in ['Public', 'Private'] %}
                <option {% if item.visibility == visibility %}selected{% endif %}>{{ visibility }}</option>
            {% endfor %}
        </select>
        <textarea name="summary" class="form-input">{{ item.summary }}</textarea>
        <textarea name="body" class="form-input">{{ item.body }}</textarea>
        <button class="btn-primary" type="submit">Save</button>
    </form>
</section>
{% endblock %}
