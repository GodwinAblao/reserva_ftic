{% extends 'layouts/app.html.twig' %}

{% block title %}Edit {{ item.type }} | Reserva FTIC{% endblock %}

{% block content %}
<style>
    .research-flash {
        margin-bottom: 16px;
        padding: 12px 14px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
    }
    .research-flash-success {
        background: #e8f7ea;
        color: #0b6b1a;
        border: 1px solid #b7e5bf;
    }
    .research-flash-error {
        background: #fdecec;
        color: #9d1c1c;
        border: 1px solid #f4bbbb;
    }
</style>
<div class="content-header">
    <h2>Edit {{ item.type }} Content</h2>
    <div class="button-group">
        <a href="{{ path('research_index') }}" class="btn-secondary">Back to Research</a>
    </div>
</div>

<section class="card-panel">
    {% for message in app.flashes('success') %}
        <div class="research-flash research-flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="research-flash research-flash-error">{{ message }}</div>
    {% endfor %}

    <form method="post" class="form-grid">
        <input type="hidden" name="_token" value="{{ csrf_token('research_edit_' ~ item.id) }}">

        {% if item.type == 'News' %}
            <input type="hidden" name="type" value="{{ item.type }}">
            <input type="hidden" name="category" value="{{ item.category }}">
            <input type="hidden" name="tags" value="{{ item.tags }}">
            <input type="hidden" name="visibility" value="{{ item.visibility }}">

            <input name="title" class="form-input" value="{{ item.title }}" required>
            <textarea name="body" class="form-input">{{ item.body }}</textarea>
            <textarea name="embeddedLink" class="form-input" placeholder="Paste embedded iframe code here (e.g., Facebook video, YouTube embed, etc.)">{{ item.embeddedLink }}</textarea>
        {% elseif item.type == 'Article' %}
            <input type="hidden" name="type" value="{{ item.type }}">
            <input type="hidden" name="category" value="{{ item.category }}">
            <input type="hidden" name="tags" value="{{ item.tags }}">
            <input type="hidden" name="visibility" value="{{ item.visibility }}">

            <input name="title" class="form-input" value="{{ item.title }}" required>
            <div class="research-image-preview" style="display:flex; flex-direction:column; gap:10px;">
                <label style="font-weight:700; color:#334155;">Current Article Image</label>
                {% if researchMediaSrc %}
                    <img src="{{ researchMediaSrc }}" alt="{{ item.title }}" style="max-width:260px; width:100%; height:auto; border-radius:14px; border:1px solid #dbe2e8; object-fit:cover;">
                {% else %}
                    <div style="width:260px; max-width:100%; height:160px; border-radius:14px; border:1px dashed #cbd5e1; background:linear-gradient(135deg, #f8fafc 0%, #eef4ef 100%);"></div>
                {% endif %}
            </div>
            <textarea name="body" class="form-input">{{ item.body }}</textarea>
            <input name="externalLink" class="form-input" placeholder="External article URL (e.g. https://...)" value="{{ item.externalLink }}">
            <input type="file" name="file" class="form-input" accept="image/*" title="Replace article image">
        {% else %}
            <input type="hidden" name="type" value="{{ item.type }}">
            <input name="title" class="form-input" value="{{ item.title }}" required>
            <select name="repositoryType" class="form-input" required>
                <option value="">Select Academic Repository Type</option>
                <option {% if item.repositoryType == 'Journal Article' %}selected{% endif %}>Journal Article</option>
                <option {% if item.repositoryType == 'Conference Paper' %}selected{% endif %}>Conference Paper</option>
                <option {% if item.repositoryType == 'Thesis/Dissertation' %}selected{% endif %}>Thesis/Dissertation</option>
                <option {% if item.repositoryType == 'Book Chapter' %}selected{% endif %}>Book Chapter</option>
                <option {% if item.repositoryType == 'Technical Report' %}selected{% endif %}>Technical Report</option>
                <option {% if item.repositoryType == 'Preprint' %}selected{% endif %}>Preprint</option>
                <option {% if item.repositoryType == 'Dataset' %}selected{% endif %}>Dataset</option>
                <option {% if item.repositoryType == 'Working Paper' %}selected{% endif %}>Working Paper</option>
            </select>
            <input name="authors" class="form-input" placeholder="Authors (comma separated)" value="{{ item.authors }}" required>
            <textarea name="abstract" class="form-input" required>{{ item.abstract }}</textarea>
            <input type="file" name="file" class="form-input" accept="application/pdf" title="Upload PDF file">
        {% endif %}

        <button class="btn-primary" type="submit">Save</button>
    </form>
</section>
{% endblock %}
