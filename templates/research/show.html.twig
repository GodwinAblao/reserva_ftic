{% extends 'layouts/app.html.twig' %}

{% block title %}{{ item.title }} | Reserva FTIC{% endblock %}

{% block content %}
<div class="content-header">
    <a href="{{ path('research_index') }}" class="btn-secondary">← Back to Research</a>
    {% if is_granted('ROLE_SUPER_ADMIN') or item.author == app.user %}
        <div class="button-group">
            <a href="{{ path('research_edit', {'id': item.id}) }}" class="btn-primary">Edit</a>
        </div>
    {% endif %}
</div>

<section class="research-detail-page">
    {% if item.type == 'Research' %}
        <div class="research-header">
            <h1>{{ item.title }}</h1>
            <p><strong>Repository Type:</strong> {{ item.repositoryType }}</p>
        </div>

        <div class="research-details">
            <div class="details-section">
                <h3>Authors</h3>
                <p>{{ item.authors }}</p>
            </div>

            <div class="details-section">
                <h3>Abstract</h3>
                <p>{{ item.abstract }}</p>
            </div>

            {% if researchFileAvailable and item.filePath %}
                <div class="pdf-section">
                    <h3>Downloadable PDF</h3>
                    <div class="pdf-controls">
                        <a href="{{ item.filePath }}" download class="btn-primary">
                            <span class="pdf-icon">📄</span> Download PDF
                        </a>
                    </div>

                    <div class="pdf-viewer">
                        <iframe 
                            src="{{ item.filePath }}" 
                            type="application/pdf" 
                            width="100%" 
                            height="700px"
                            style="border: 1px solid #ddd; border-radius: 4px;">
                        </iframe>
                    </div>
                </div>
            {% else %}
                <div class="alert-warning">
                    <p>The PDF for this research content is not available right now.</p>
                </div>
            {% endif %}
        </div>

        <div class="research-metadata">
            <p><strong>Added by:</strong> {{ item.author.email }} on {{ item.createdAt|date('M d, Y') }}</p>
            {% if item.updatedAt != item.createdAt %}
                <p><strong>Last updated:</strong> {{ item.updatedAt|date('M d, Y') }}</p>
            {% endif %}
        </div>
    {% else %}
        <article class="research-detail-card">
            <div class="research-detail-media">
                {% if researchMediaSrc and item.type == 'Article' %}
                    <img src="{{ researchMediaSrc }}" alt="{{ item.title }}">
                {% elseif item.embeddedLink %}
                    {{ item.embeddedLink|raw }}
                {% else %}
                    <div class="research-detail-placeholder" aria-hidden="true"></div>
                {% endif %}
            </div>

            <div class="research-detail-content">
                <h1>{{ item.title }}</h1>
                <p class="research-detail-author">Author : {{ item.author.email }}</p>
                {% if item.body %}
                    <div class="research-detail-body">
                        {{ item.body }}
                    </div>
                {% endif %}
                {% if item.externalLink %}
                    <a href="{{ item.externalLink }}" target="_blank" rel="noopener" class="research-view-btn">View Source</a>
                {% endif %}
            </div>
        </article>
    {% endif %}
</section>
{% endblock %}
