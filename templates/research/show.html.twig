{% extends 'layouts/app.html.twig' %}

{% block title %}{{ item.title }} | Reserva FTIC{% endblock %}

{% block content %}
<div class="content-header">
    <a href="{{ path('research_index') }}" class="btn-secondary">← Back to Research</a>
    {% if is_granted('ROLE_SUPER_ADMIN') or item.author == app.user %}
        <div class="button-group">
            <a href="{{ path('research_edit', {'id': item.id}) }}" class="btn-primary">Edit</a>
        </div>
    {% endif %}
</div>

<section class="card-panel">
    {% if item.type == 'Research' %}
        <div class="research-header">
            <h1 style="color: green;">{{ item.title }}</h1>
            <p><strong>Repository Type:</strong> {{ item.repositoryType }}</p>
        </div>

        <div class="research-details">
            <div class="details-section">
                <h3>Authors</h3>
                <p>{{ item.authors }}</p>
            </div>

            <div class="details-section">
                <h3>Abstract</h3>
                <p>{{ item.abstract }}</p>
            </div>

            {% if item.filePath %}
                <div class="pdf-section">
                    <h3>Downloadable PDF</h3>
                    <div class="pdf-controls">
                        <a href="{{ item.filePath }}" download class="btn-primary">
                            <span class="pdf-icon">📄</span> Download PDF
                        </a>
                    </div>

                    <div class="pdf-viewer">
                        <iframe 
                            src="{{ item.filePath }}" 
                            type="application/pdf" 
                            width="100%" 
                            height="700px"
                            style="border: 1px solid #ddd; border-radius: 4px;">
                        </iframe>
                    </div>
                </div>
            {% else %}
                <div class="alert-warning">
                    <p>No PDF file attached to this research content.</p>
                </div>
            {% endif %}
        </div>

        <div class="research-metadata">
            <p><strong>Added by:</strong> {{ item.author.email }} on {{ item.createdAt|date('M d, Y') }}</p>
            {% if item.updatedAt != item.createdAt %}
                <p><strong>Last updated:</strong> {{ item.updatedAt|date('M d, Y') }}</p>
            {% endif %}
        </div>
    {% else %}
        <h1>{{ item.title }}</h1>
        {% if item.filePath and item.type == 'Article' %}
            <div class="article-image-wrapper">
                <img src="{{ item.filePath }}" alt="{{ item.title }}" class="article-image">
            </div>
        {% endif %}
        {% if item.body %}
            <div class="content-body">
                {{ item.body }}
            </div>
        {% endif %}
        {% if item.embeddedLink %}
            <div class="embedded-content">
                {{ item.embeddedLink|raw }}
            </div>
        {% endif %}
    {% endif %}
</section>

<style>
    .research-header {
        margin-bottom: 2rem;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 1rem;
    }

    .research-details {
        margin: 2rem 0;
    }

    .details-section {
        margin: 1.5rem 0;
        padding: 1rem;
        background-color: #f9f9f9;
        border-left: 4px solid #007bff;
        border-radius: 4px;
    }

    .details-section h3 {
        margin-top: 0;
        color: #333;
    }

    .pdf-section {
        margin: 2rem 0;
        padding: 1.5rem;
        background-color: #f5f5f5;
        border-radius: 8px;
    }

    .pdf-controls {
        margin: 1rem 0;
    }

    .pdf-icon {
        margin-right: 0.5rem;
    }

    .pdf-viewer {
        margin-top: 1.5rem;
        background-color: white;
        padding: 1rem;
        border-radius: 4px;
    }

    .research-metadata {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #ddd;
        color: #666;
        font-size: 0.9rem;
    }
</style>
{% endblock %}
