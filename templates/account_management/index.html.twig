{% extends 'layouts/app.html.twig' %}

{% block title %}Account Management | Reserva FTIC{% endblock %}

{% block content %}
    <style>
        .filter-bar {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            align-items: center;
        }
        .filter-bar .search-wrap {
            position: relative;
            flex: 1 1 260px;
            min-width: 200px;
        }
        .filter-bar .search-wrap svg {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            color: #9ca3af;
            pointer-events: none;
        }
        .filter-bar .search-wrap input {
            width: 100%;
            padding: 10px 12px 10px 38px;
            border-radius: 12px;
            border: 1px solid rgba(0, 102, 51, 0.2);
            font-size: 14px;
            outline: none;
            transition: border 0.2s ease, box-shadow 0.2s ease;
            background: #fff;
        }
        .filter-bar .search-wrap input:focus {
            border-color: var(--feu-green-light);
            box-shadow: 0 0 0 3px rgba(0, 136, 68, 0.15);
        }
        .filter-bar select {
            padding: 10px 14px;
            border-radius: 12px;
            border: 1px solid rgba(0, 102, 51, 0.2);
            font-size: 14px;
            outline: none;
            background: #fff;
            cursor: pointer;
            min-width: 160px;
        }
        .accounts-table tbody tr.row-hidden {
            display: none;
        }
        .accounts-table tbody tr.row-shown {
            display: table-row;
            animation: popInRow 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
        }
        @keyframes popInRow {
            from {
                opacity: 0;
                transform: translateY(10px) scale(0.985);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
        .no-results {
            display: none;
            text-align: center;
            padding: 48px 20px;
            color: #94a3b8;
            font-size: 15px;
        }
        .no-results.visible {
            display: block;
            animation: popInRow 0.3s ease both;
        }
        .results-counter {
            font-size: 13px;
            color: #64748b;
            margin-bottom: 12px;
            margin-top: -8px;
        }
        .search-clear {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: none;
            background: #e5e7eb;
            color: #64748b;
            cursor: pointer;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            line-height: 1;
            padding: 0;
            transition: background 0.15s ease;
        }
        .search-clear:hover {
            background: #d1d5db;
        }
        .search-clear.show {
            display: flex;
        }
        .pill-role--superadmin {
            background: rgba(220, 38, 38, 0.15);
            color: #991b1b;
        }
        .pill-role--admin {
            background: rgba(37, 99, 235, 0.15);
            color: #1e40af;
        }
        .pill-role--faculty {
            background: rgba(126, 34, 206, 0.15);
            color: #6b21a8;
        }
        .pill-role--mentor {
            background: rgba(219, 39, 119, 0.15);
            color: #9d174d;
        }
        .pill-role--student {
            background: rgba(34, 197, 94, 0.15);
            color: #166534;
        }

        /* Account View Modal */
        .account-view-modal {
            display: none;
            position: fixed;
            z-index: 9999;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            animation: fadeIn 0.2s ease;
        }
        .account-view-modal.is-open {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .account-view-modal-content {
            background: white;
            padding: 2rem;
            border-radius: 16px;
            max-width: 800px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            animation: slideUp 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
        .account-view-modal-close {
            position: absolute;
            right: 1.25rem;
            top: 1.25rem;
            font-size: 1.75rem;
            font-weight: 300;
            color: #9ca3af;
            cursor: pointer;
            transition: color 0.2s;
            background: none;
            border: none;
            line-height: 1;
        }
        .account-view-modal-close:hover {
            color: #374151;
        }
        .account-view-modal-header {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #e5e7eb;
        }
        .account-view-modal-header h3 {
            margin: 0;
            font-size: 20px;
            font-weight: 700;
            color: #111827;
        }
        .account-view-profile-section {
            display: flex;
            gap: 20px;
            margin-bottom: 24px;
            align-items: center;
        }
        .account-view-profile-picture {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid #0D9B00;
            flex-shrink: 0;
            background: #f3f4f6;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .account-view-profile-picture img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .account-view-profile-picture .placeholder {
            color: #9ca3af;
            font-size: 32px;
        }
        .account-view-profile-info h4 {
            margin: 0 0 4px 0;
            font-size: 18px;
            font-weight: 700;
            color: #111827;
        }
        .account-view-profile-info .email {
            color: #6b7280;
            font-size: 13px;
        }
        .account-view-info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }
        .account-view-info-item {
            background: #f9fafb;
            padding: 16px;
            border-radius: 10px;
        }
        .account-view-info-item.full-width {
            grid-column: 1 / -1;
        }
        .account-view-info-label {
            font-size: 11px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }
        .account-view-info-value {
            font-size: 14px;
            font-weight: 600;
            color: #111827;
        }
        .account-view-info-value.empty {
            color: #9ca3af;
            font-style: italic;
        }
        .account-view-roles-section {
            margin-bottom: 24px;
        }
        .account-view-roles-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .account-view-role-badge {
            padding: 6px 12px;
            border-radius: 16px;
            font-size: 12px;
            font-weight: 600;
        }
        .account-view-role-badge.superadmin {
            background: rgba(220, 38, 38, 0.15);
            color: #991b1b;
        }
        .account-view-role-badge.admin {
            background: rgba(37, 99, 235, 0.15);
            color: #1e40af;
        }
        .account-view-role-badge.faculty {
            background: rgba(126, 34, 206, 0.15);
            color: #6b21a8;
        }
        .account-view-role-badge.mentor {
            background: rgba(219, 39, 119, 0.15);
            color: #9d174d;
        }
        .account-view-role-badge.student {
            background: rgba(34, 197, 94, 0.15);
            color: #166534;
        }
        .account-view-modal-actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }
        .account-view-btn {
            padding: 10px 20px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.15s ease;
            border: none;
        }
        .account-view-btn-primary {
            background: linear-gradient(130deg, #0D9B00 0%, #0a7d00 100%);
            color: #fff;
        }
        .account-view-btn-primary:hover {
            background: linear-gradient(130deg, #0a7d00 0%, #086600 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(13, 155, 0, 0.25);
        }
        .account-view-btn-secondary {
            background: #fff;
            color: #374151;
            border: 1px solid #d1d5db;
        }
        .account-view-btn-secondary:hover {
            background: #f9fafb;
            border-color: #9ca3af;
        }
    </style>

    <div class="content-header">
        <h2>Account Management</h2>
        <a href="{{ path('app_account_management_new') }}" class="btn-primary" style="text-decoration: none; display: inline-block; padding: 10px 16px; border-radius: 12px; background: linear-gradient(130deg, #0d9b00 0%, #0d9b00 100%); color: white; font-weight: 700;">+ Create Account</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div class="card-panel">
        <div class="filter-bar">
            <div class="search-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="accountSearch" placeholder="Search by name or email..." autocomplete="off">
                <button type="button" class="search-clear" id="searchClear" title="Clear search">&times;</button>
            </div>
            <select id="roleFilter">
                <option value="">All Roles</option>
                <option value="superadmin">Superadmin</option>
                <option value="admin">Admin</option>
                <option value="faculty">Faculty</option>
                <option value="mentor">Mentor</option>
                <option value="student">Student</option>
            </select>
        </div>

        <table class="accounts-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="accountsTableBody">
                {% for user in users %}
                    {% set searchText = ((user.firstName ?? '') ~ ' ' ~ (user.lastName ?? '') ~ ' ' ~ user.email)|lower %}
                    {% if 'ROLE_SUPER_ADMIN' in user.roles %}
                        {% set userRole = 'superadmin' %}
                        {% set roleLabel = 'SUPER ADMIN' %}
                        {% set roleClass = 'pill-role--superadmin' %}
                    {% elseif 'ROLE_ADMIN' in user.roles %}
                        {% set userRole = 'admin' %}
                        {% set roleLabel = 'ADMIN' %}
                        {% set roleClass = 'pill-role--admin' %}
                    {% elseif 'ROLE_FACULTY' in user.roles %}
                        {% set userRole = 'faculty' %}
                        {% set roleLabel = 'FACULTY' %}
                        {% set roleClass = 'pill-role--faculty' %}
                    {% elseif 'ROLE_MENTOR' in user.roles %}
                        {% set userRole = 'mentor' %}
                        {% set roleLabel = 'MENTOR' %}
                        {% set roleClass = 'pill-role--mentor' %}
                    {% elseif 'ROLE_STUDENT' in user.roles %}
                        {% set userRole = 'student' %}
                        {% set roleLabel = 'STUDENT' %}
                        {% set roleClass = 'pill-role--student' %}
                    {% else %}
                        {% set userRole = 'user' %}
                        {% set roleLabel = 'USER' %}
                        {% set roleClass = '' %}
                    {% endif %}
                    <tr data-search-text="{{ searchText }}" data-role="{{ userRole }}" class="row-shown">
                        <td>
                            {% if user.firstName or user.lastName %}
                                {{ user.firstName ?? '' }} {{ user.lastName ?? '' }}
                            {% else %}
                                <span style="color: #999;">Not set</span>
                            {% endif %}
                        </td>
                        <td>{{ user.email }}</td>
                        <td>
                            <span class="pill-role {{ roleClass }}">{{ roleLabel }}</span>
                        </td>
                        <td>
                            <button class="btn-link" onclick="viewAccount({{ user.id }})">View</button>
                            <a href="{{ path('app_account_management_edit', {'id': user.id}) }}" class="btn-link">Edit</a>
                            {% if user != app.user %}
                                <form method="post" action="{{ path('app_account_management_delete', {'id': user.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_' ~ user.id) }}">
                                    <button type="submit" class="btn-link btn-danger">Delete</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        <div class="results-counter">
            Showing <strong id="visibleCount">0</strong> of <strong id="totalCount">0</strong> accounts
        </div>
        <div id="noResults" class="no-results">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="width: 48px; height: 48px; color: #cbd5e1; margin-bottom: 12px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <div>No accounts found matching your search.</div>
        </div>
    </div>

    <!-- Account View Modal -->
    <div id="accountViewModal" class="account-view-modal">
        <div class="account-view-modal-content">
            <button class="account-view-modal-close" onclick="closeAccountViewModal()">&times;</button>
            <div class="account-view-modal-header">
                <h3>Account Details</h3>
            </div>
            <div id="accountViewModalBody">
                <!-- Content loaded via AJAX -->
            </div>
            <div class="account-view-modal-actions">
                <button class="account-view-btn account-view-btn-secondary" onclick="closeAccountViewModal()">Close</button>
                <a id="accountViewEditBtn" href="#" class="account-view-btn account-view-btn-primary">Edit Account</a>
            </div>
        </div>
    </div>

    <script>
    (function() {
        const searchInput = document.getElementById('accountSearch');
        const roleFilter = document.getElementById('roleFilter');
        const searchClear = document.getElementById('searchClear');
        const tbody = document.getElementById('accountsTableBody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const noResults = document.getElementById('noResults');
        const visibleCountEl = document.getElementById('visibleCount');
        const totalCountEl = document.getElementById('totalCount');
        let debounceTimer;

        totalCountEl.textContent = rows.length;

        function updateClearButton() {
            if (searchInput.value.length > 0) {
                searchClear.classList.add('show');
            } else {
                searchClear.classList.remove('show');
            }
        }

        function filterRows() {
            const query = searchInput.value.trim().toLowerCase();
            const role = roleFilter.value;
            let visibleIndex = 0;

            rows.forEach(function(row) {
                const searchText = row.getAttribute('data-search-text');
                const userRole = row.getAttribute('data-role');
                const matchesSearch = !query || searchText.indexOf(query) !== -1;
                const matchesRole = !role || userRole === role;

                if (matchesSearch && matchesRole) {
                    row.style.animationDelay = (visibleIndex * 0.03) + 's';
                    row.classList.remove('row-hidden');
                    row.classList.add('row-shown');
                    visibleIndex++;
                } else {
                    row.classList.remove('row-shown');
                    row.classList.add('row-hidden');
                    row.style.animationDelay = '0s';
                }
            });

            visibleCountEl.textContent = visibleIndex;

            if (visibleIndex === 0) {
                noResults.classList.add('visible');
            } else {
                noResults.classList.remove('visible');
            }
        }

        searchInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            updateClearButton();
            debounceTimer = setTimeout(filterRows, 60);
        });

        roleFilter.addEventListener('change', filterRows);

        searchClear.addEventListener('click', function() {
            searchInput.value = '';
            updateClearButton();
            filterRows();
            searchInput.focus();
        });

        filterRows();

        // Account View Modal Functions
        window.viewAccount = function(userId) {
            const modal = document.getElementById('accountViewModal');
            const modalBody = document.getElementById('accountViewModalBody');
            const editBtn = document.getElementById('accountViewEditBtn');

            modalBody.innerHTML = '<div style="text-align:center;padding:40px;color:#6b7280;">Loading...</div>';
            modal.classList.add('is-open');
            document.body.style.overflow = 'hidden';

            fetch(`/account-management/${userId}/view-ajax`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        modalBody.innerHTML = data.html;
                        editBtn.href = `/account-management/${userId}/edit`;
                    } else {
                        modalBody.innerHTML = '<div style="text-align:center;padding:40px;color:#dc2626;">Failed to load account details.</div>';
                    }
                })
                .catch(error => {
                    modalBody.innerHTML = '<div style="text-align:center;padding:40px;color:#dc2626;">Error loading account details.</div>';
                });
        };

        window.closeAccountViewModal = function() {
            const modal = document.getElementById('accountViewModal');
            modal.classList.remove('is-open');
            document.body.style.overflow = '';
        };

        // Close modal when clicking outside
        document.getElementById('accountViewModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeAccountViewModal();
            }
        });

        // Close modal on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeAccountViewModal();
            }
        });

        // Move modal to body to ensure it's not constrained by parent containers
        const accountViewModal = document.getElementById('accountViewModal');
        if (accountViewModal && accountViewModal.parentElement !== document.body) {
            document.body.appendChild(accountViewModal);
        }
    })();
    </script>
{% endblock %}
