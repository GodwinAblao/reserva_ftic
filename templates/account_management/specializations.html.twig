{% extends 'layouts/app.html.twig' %}

{% block title %}Manage Specializations | Reserva FTIC{% endblock %}

{% block content %}
    <style>
        .spec-container {
            max-width: 1000px;
            margin: 0 auto;
        }
        .spec-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        .spec-header h2 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 700;
            color: #111827;
        }
        .spec-header .back-link {
            color: #374151;
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .spec-header .back-link:hover {
            color: #0D9B00;
        }
        .spec-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 20px;
        }
        .spec-add-form {
            display: flex;
            gap: 12px;
            align-items: flex-end;
        }
        .spec-form-group {
            flex: 1;
        }
        .spec-form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }
        .spec-form-group input {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 14px;
            color: #374151;
            transition: border-color 0.15s ease, box-shadow 0.15s ease;
        }
        .spec-form-group input:focus {
            outline: none;
            border-color: #0D9B00;
            box-shadow: 0 0 0 3px rgba(13, 155, 0, 0.1);
        }
        .spec-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.15s ease;
            height: 44px;
        }
        .spec-btn-primary {
            background: linear-gradient(130deg, #0D9B00 0%, #0a7d00 100%);
            color: #fff;
        }
        .spec-btn-primary:hover {
            background: linear-gradient(130deg, #0a7d00 0%, #086600 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(13, 155, 0, 0.25);
        }
        .spec-table {
            width: 100%;
            border-collapse: collapse;
        }
        .spec-table th {
            text-align: left;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #6b7280;
            border-bottom: 2px solid #f3f4f6;
        }
        .spec-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            font-size: 14px;
        }
        .spec-table tr:last-child td {
            border-bottom: none;
        }
        .spec-table tr:hover td {
            background: #f9fafb;
        }
        .spec-delete-btn {
            padding: 6px 12px;
            background: #fee2e2;
            color: #dc2626;
            border: 1px solid #fecaca;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s ease;
        }
        .spec-delete-btn:hover {
            background: #fecaca;
            border-color: #fca5a5;
        }
        .spec-empty {
            text-align: center;
            padding: 40px;
            color: #9ca3af;
            font-size: 14px;
        }
        .spec-count {
            font-size: 13px;
            color: #6b7280;
            margin-top: 8px;
        }
    </style>

    <div class="spec-container">
        <div class="spec-header">
            <h2>Manage Specializations</h2>
            <a href="{{ path('app_account_management') }}" class="back-link">
                ← Back to Account Management
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error">{{ message }}</div>
        {% endfor %}

        <div class="spec-card">
            <h3 style="margin: 0 0 16px 0; font-size: 16px; font-weight: 700; color: #111827;">Add New Specialization</h3>
            <form method="post" action="{{ path('app_specialization_new') }}" class="spec-add-form">
                <div class="spec-form-group">
                    <label for="name">Specialization Name</label>
                    <input type="text" name="name" id="name" placeholder="e.g. Artificial Intelligence" required>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('specialization_create') }}">
                <button type="submit" class="spec-btn spec-btn-primary">Add Specialization</button>
            </form>
        </div>

        <div class="spec-card">
            <h3 style="margin: 0 0 16px 0; font-size: 16px; font-weight: 700; color: #111827;">Existing Specializations</h3>
            <div class="spec-count">{{ specializations|length }} specialization(s)</div>
            
            {% if specializations|length > 0 %}
                <table class="spec-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for specialization in specializations %}
                            <tr>
                                <td>{{ specialization.id }}</td>
                                <td>{{ specialization.name }}</td>
                                <td>{{ specialization.createdAt|date('M d, Y g:i A') }}</td>
                                <td>
                                    <form method="post" action="{{ path('app_specialization_delete', {'id': specialization.id}) }}" onsubmit="return confirm('Are you sure you want to delete this specialization?');" style="display: inline;">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_specialization_' ~ specialization.id) }}">
                                        <button type="submit" class="spec-delete-btn">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="spec-empty">No specializations found. Add one above.</div>
            {% endif %}
        </div>
    </div>
{% endblock %}
