{% extends 'layouts/app.html.twig' %}

{% block title %}Dashboard | Reserva FTIC{% endblock %}

{% block body_class %}dashboard-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/end_user_dashboard.css') }}">
{% endblock %}


{% block content %}
{# Shared icon symbols used by dashboard widgets. #}
<svg class="dashboard-icons" aria-hidden="true" focusable="false">
    <defs>
        <symbol id="dashboard-icon-user" viewBox="0 0 24 24">
            <path d="M12 12.5c2.485 0 4.5-2.015 4.5-4.5S14.485 3.5 12 3.5 7.5 5.515 7.5 8s2.015 4.5 4.5 4.5Zm0 2c-4.418 0-8 2.239-8 5v1.25h16V19.5c0-2.761-3.582-5-8-5Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-grid" viewBox="0 0 24 24">
            <path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-facility" viewBox="0 0 24 24">
            <path d="M3 20V7.5L12 3l9 4.5V20h-4v-7H7v7H3Zm6-2h6v-5H9v5Zm2-7h2V9h-2v2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-mentoring" viewBox="0 0 24 24">
            <path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v7A2.5 2.5 0 0 1 17.5 16H11l-4.5 4v-4H6.5A2.5 2.5 0 0 1 4 13.5v-7Zm4 2.25h8V7h-8v1.75Zm0 3.25h5V11h-5v1Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-hub" viewBox="0 0 24 24">
            <path d="M12 2 2 6.5V9l10-4.5L22 9V6.5L12 2Zm-7 9.2 7 3.15 7-3.15V18l-7 3-7-3V11.2Zm3 2.25v1.85l4 1.7 4-1.7v-1.85l-4 1.8-4-1.8Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-bookmark" viewBox="0 0 24 24">
            <path d="M7 3h10a2 2 0 0 1 2 2v16l-7-3-7 3V5a2 2 0 0 1 2-2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-chart" viewBox="0 0 24 24">
            <path d="M5 19V5h2v14H5Zm6 0V9h2v10h-2Zm6 0V12h2v7h-2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-logout" viewBox="0 0 24 24">
            <path d="M10 17v-2h4V9h-4V7l-5 5 5 5Zm2-14a9 9 0 1 1 0 18h-1v-2h1a7 7 0 1 0 0-14h-1V3h1Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-bell" viewBox="0 0 24 24">
            <path d="M12 22a2.4 2.4 0 0 0 2.3-1.75h-4.6A2.4 2.4 0 0 0 12 22Zm6-6V11a6 6 0 1 0-12 0v5L4 18v1h16v-1l-2-2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-calendar" viewBox="0 0 24 24">
            <path d="M7 2h2v2h6V2h2v2h3a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h3V2Zm13 8H4v9h16v-9ZM4 6v2h16V6H4Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-arrow" viewBox="0 0 24 24">
            <path d="M13 5 11.6 6.4 16.2 11H4v2h12.2l-4.6 4.6L13 19l7-7-7-7Z" fill="currentColor"/>
        </symbol>
    </defs>
</svg>

<div class="dashboard-content">

        <div class="dashboard-grid">
            <section class="dashboard-main-column">
                {# Reservation and mentoring summary cards. #}
                <div class="dashboard-stats-grid">
                    <article class="dashboard-stat-card stat-green">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Total Reservations</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.totalReservations }}</div>
                        <div class="dashboard-stat-foot">Total Reservations</div>
                    </article>

                    <article class="dashboard-stat-card stat-success">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Approved Reservations</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.approvedReservations }}</div>
                        <div class="dashboard-stat-foot">Reservations this week</div>
                    </article>

                    <article class="dashboard-stat-card stat-warning">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Pending Reservation</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.pendingReservations }}</div>
                        <div class="dashboard-stat-foot">Pending this week</div>
                    </article>

                    <article class="dashboard-stat-card stat-muted">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-mentoring" /></svg></span>
                            <span class="dashboard-stat-title">Mentoring</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.mentoringSessions }}</div>
                        <div class="dashboard-stat-foot">Mentoring this week</div>
                    </article>
                </div>

                {# Facility overview: shows only the first three available facilities. #}
                <section class="dashboard-section">
                    <div class="dashboard-section-head">
                        <h3>Facilities</h3>
                        <a href="{{ path('app_facility_index') }}">View more</a>
                    </div>

                    {% if facilities is empty %}
                        <div class="no-facilities">
                            <p>No facilities available at the moment.</p>
                        </div>
                    {% else %}
                        <div class="facilities-grid dashboard-facilities-overview">
                            {% for facility in facilities %}
                                <div class="facility-card">
                                    <div class="facility-image-holder">
                                        {% if facility.image %}
                                            <img src="{{ facility.image }}" alt="{{ facility.name }}">
                                        {% else %}
                                            <div class="placeholder-image">
                                                <span>{{ facility.name | first }}</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="facility-details">
                                        <h3>{{ facility.name }}</h3>
                                        <p class="capacity">
                                            <strong>Capacity:</strong> {{ facility.capacity }} pax
                                        </p>
                                        {% if facility.description %}
                                            <p class="description">{{ facility.description }}</p>
                                        {% endif %}
                                        <a href="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-view">
                                            View Details
                                        </a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>

                {# Research/articles overview: reserved for super admin posts. #}
                <section class="dashboard-section">
                    <div class="dashboard-section-head">
                        <h3>Research/Articles</h3>
                        <a href="{{ path('research_index') }}">View more</a>
                    </div>

                    <div class="dashboard-cards-grid dashboard-articles-grid"></div>
                </section>

                {# Dashboard footer. #}
                <footer class="dashboard-footer">
                    &copy; 2026 Reserva. All rights reserved.
                </footer>
            </section>

            {# Secondary dashboard summaries. #}
            <aside class="dashboard-side-column">
                <section class="dashboard-side-card dashboard-info-card">
                    <div class="dashboard-side-card-head">
                        <h3>Upcoming Reservations</h3>
                    </div>
                    <p>You have no upcoming reservations yet. Book a facility to get started!</p>
                    <a href="{{ path('app_facility_index') }}">View more</a>
                </section>

                <section class="dashboard-side-card dashboard-info-card">
                    <div class="dashboard-side-card-head">
                        <h3>My Mentorships</h3>
                    </div>
                    <p>You don't have any scheduled mentor sessions at the moment. Request one now to get started!</p>
                    <a href="{{ path('mentoring_index') }}">View more</a>
                </section>

                <section class="dashboard-side-card dashboard-info-card">
                    <div class="dashboard-side-card-head">
                        <h3>Mentor Requests</h3>
                    </div>
                    <p>No mentor requests yet. Apply to become a mentor and help students!</p>
                    <a href="{{ path('mentoring_index') }}">View more</a>
                </section>
            </aside>
        </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% endblock %}
