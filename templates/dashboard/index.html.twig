{% extends 'layouts/app.html.twig' %}

{% block title %}Dashboard | Reserva FTIC{% endblock %}

{% block body_class %}dashboard-page regular-user-theme{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- Synchronous CSS loading to prevent FOUC -->
    <link rel="stylesheet" href="{{ asset('styles/facility_cards.css') }}?v=20260522-2" media="all">
    <link rel="stylesheet" href="{{ asset('styles/end_user_dashboard.css') }}?v=20260522-2" media="all">
{% endblock %}


{% block content %}
{# Shared icon symbols used by dashboard widgets. #}
<svg class="dashboard-icons" aria-hidden="true" focusable="false">
    <defs>
        <symbol id="dashboard-icon-user" viewBox="0 0 24 24">
            <path d="M12 12.5c2.485 0 4.5-2.015 4.5-4.5S14.485 3.5 12 3.5 7.5 5.515 7.5 8s2.015 4.5 4.5 4.5Zm0 2c-4.418 0-8 2.239-8 5v1.25h16V19.5c0-2.761-3.582-5-8-5Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-grid" viewBox="0 0 24 24">
            <path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-facility" viewBox="0 0 24 24">
            <path d="M3 20V7.5L12 3l9 4.5V20h-4v-7H7v7H3Zm6-2h6v-5H9v5Zm2-7h2V9h-2v2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-hub" viewBox="0 0 24 24">
            <path d="M12 2 2 6.5V9l10-4.5L22 9V6.5L12 2Zm-7 9.2 7 3.15 7-3.15V18l-7 3-7-3V11.2Zm3 2.25v1.85l4 1.7 4-1.7v-1.85l-4 1.8-4-1.8Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-bookmark" viewBox="0 0 24 24">
            <path d="M7 3h10a2 2 0 0 1 2 2v16l-7-3-7 3V5a2 2 0 0 1 2-2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-chart" viewBox="0 0 24 24">
            <path d="M5 19V5h2v14H5Zm6 0V9h2v10h-2Zm6 0V12h2v7h-2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-logout" viewBox="0 0 24 24">
            <path d="M10 17v-2h4V9h-4V7l-5 5 5 5Zm2-14a9 9 0 1 1 0 18h-1v-2h1a7 7 0 1 0 0-14h-1V3h1Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-bell" viewBox="0 0 24 24">
            <path d="M12 22a2.4 2.4 0 0 0 2.3-1.75h-4.6A2.4 2.4 0 0 0 12 22Zm6-6V11a6 6 0 1 0-12 0v5L4 18v1h16v-1l-2-2Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-calendar" viewBox="0 0 24 24">
            <path d="M7 2h2v2h6V2h2v2h3a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h3V2Zm13 8H4v9h16v-9ZM4 6v2h16V6H4Z" fill="currentColor"/>
        </symbol>
        <symbol id="dashboard-icon-arrow" viewBox="0 0 24 24">
            <path d="M13 5 11.6 6.4 16.2 11H4v2h12.2l-4.6 4.6L13 19l7-7-7-7Z" fill="currentColor"/>
        </symbol>
    </defs>
</svg>

<div class="dashboard-content">

        <div class="dashboard-grid">
            <section class="dashboard-main-column">
                {# Reservation summary cards. #}
                <div class="dashboard-stats-grid">
                    <a href="{{ path('user_reservations') }}" class="dashboard-stat-card stat-green" data-turbo="false">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Total Reservations</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.totalReservations }}</div>
                        <div class="dashboard-stat-foot">Total Reservations</div>
                    </a>

                    <a href="{{ path('user_reservations') }}" class="dashboard-stat-card stat-success" data-turbo="false">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Approved Reservations</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.approvedReservations }}</div>
                        <div class="dashboard-stat-foot">Reservations this week</div>
                    </a>

                    <a href="{{ path('user_reservations') }}" class="dashboard-stat-card stat-warning" data-turbo="false">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Pending Reservation</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.pendingReservations }}</div>
                        <div class="dashboard-stat-foot">Pending this week</div>
                    </a>

                    <a href="{{ path('user_reservations') }}" class="dashboard-stat-card stat-danger" data-turbo="false">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Rejected Reservations</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.rejectedReservations }}</div>
                        <div class="dashboard-stat-foot">Rejected this week</div>
                    </a>

                    <a href="{{ path('user_reservations') }}" class="dashboard-stat-card stat-grey" data-turbo="false">
                        <div class="dashboard-stat-top">
                            <span class="dashboard-stat-icon"><svg viewBox="0 0 24 24"><use href="#dashboard-icon-calendar" /></svg></span>
                            <span class="dashboard-stat-title">Cancelled Reservations</span>
                        </div>
                        <div class="dashboard-stat-value">{{ stats.cancelledReservations }}</div>
                        <div class="dashboard-stat-foot">Cancelled this week</div>
                    </a>

                </div>

                {# Facility overview: manual dashboard carousel. #}
                <section class="dashboard-section dashboard-facility-carousel-section">
                    <div class="dashboard-section-head">
                        <h3>Facilities</h3>
                        <a href="{{ path('app_facility_index') }}" class="dfc-view-all" data-turbo="false">View all →</a>
                    </div>

                    {% if facilities is empty %}
                        <div class="no-facilities">
                            <p>No facilities available at the moment.</p>
                        </div>
                    {% else %}
                        <div class="dfc-shell" data-dashboard-facility-carousel>
                            <button type="button" class="dfc-nav dfc-nav-prev" aria-label="Show previous facilities" data-dfc-prev disabled>
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.5 5.5 9 12l6.5 6.5-1.6 1.6L5.8 12l8.1-8.1 1.6 1.6Z" fill="currentColor"/></svg>
                            </button>

                            <div class="dfc-viewport" id="dashboardFacilityCarousel" tabindex="0" role="region" aria-label="Featured facilities carousel">
                                <div class="dfc-track" id="dfcTrack" role="list">
                                {% for facility in facilities %}
                                    <div class="dfc-slide" role="listitem">
                                        <div class="facility-feature-card">
                                            <div class="facility-image-holder">
                                                {% if facility.image %}
                                                    <img src="{{ facility.image ~ '?v=' ~ facility.updatedAt|date('U') }}" alt="{{ facility.name }}" loading="lazy">
                                                {% else %}
                                                    <div class="placeholder-image">
                                                        <span>{{ facility.name|first|upper }}</span>
                                                    </div>
                                                {% endif %}
                                            </div>
                                            <div class="facility-details">
                                                <h3>{{ facility.name }}</h3>
                                                <div class="facility-meta-row">
                                                    <span class="facility-pill">{{ facility.capacity }} pax</span>
                                                </div>
                                                {% if facility.description %}
                                                    <p class="description">{{ facility.description }}</p>
                                                {% endif %}
                                                <a href="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-view" data-turbo="false">Reserve now</a>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                                </div>
                            </div>

                            <button type="button" class="dfc-nav dfc-nav-next" aria-label="Show next facilities" data-dfc-next>
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 18.5 15 12 8.5 5.5l1.6-1.6 8.1 8.1-8.1 8.1-1.6-1.6Z" fill="currentColor"/></svg>
                            </button>
                        </div>
                    {% endif %}
                </section>

                {# Research/articles overview: Innovation Hub card design. #}
                <section class="dashboard-section">
                    <div class="dashboard-section-head">
                        <h3>Innovation Hub</h3>
                        <a href="{{ path('research_index') }}" class="dfc-view-all" data-turbo="false">View all →</a>
                    </div>

                    {% if recentResearch is empty %}
                        <div class="no-facilities">
                            <p>No research, articles, or news available yet.</p>
                        </div>
                    {% else %}
                        <div class="research-showcase-grid dashboard-research-grid">
                            {% for item in recentResearch %}
                                <article class="research-showcase-card {% if item.type == 'Research' %}document-card{% else %}media-card{% endif %}">
                                    {% if item.type != 'Research' %}
                                        <div class="research-card-media {% if item.type == 'News' %}video-media{% endif %}">
                                            {% if item.type == 'News' and item.embeddedLink %}
                                                {{ item.embeddedLink|raw }}
                                                <span class="video-play-indicator">▶</span>
                                            {% elseif item.filePath %}
                                                <img src="{{ item.filePath }}" alt="{{ item.title }}">
                                            {% else %}
                                                <div class="research-card-placeholder">{{ item.title|first|upper }}</div>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    <div class="research-card-content">
                                        <h3>{{ item.title }}</h3>
                                        <span>{{ item.category ?: item.type }}</span>
                                        {% if item.type == 'Research' %}
                                            <strong>Abstract</strong>
                                            <p>{{ item.abstract ?: 'No abstract provided.' }}</p>
                                        {% elseif item.body %}
                                            <p>{{ item.body }}</p>
                                        {% endif %}
                                        <div class="research-card-actions">
                                            <a href="{{ path('research_show', {id: item.id}) }}" class="research-view-btn" data-turbo="false">View</a>
                                        </div>
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>
            </section>

            {# Right sidebar is rendered by app.html.twig as user-right-col (AJAX-driven) #}
        </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(() => {
    function initDashboardFacilityCarousel() {
        document.querySelectorAll('[data-dashboard-facility-carousel]').forEach((carousel) => {
            if (carousel.dataset.dfcReady === 'true') return;
            carousel.dataset.dfcReady = 'true';

            const viewport = carousel.querySelector('.dfc-viewport');
            const prev = carousel.querySelector('[data-dfc-prev]');
            const next = carousel.querySelector('[data-dfc-next]');
            if (!viewport || !prev || !next) return;

            const getStep = () => {
                const slide = viewport.querySelector('.dfc-slide');
                if (!slide) return Math.max(240, Math.floor(viewport.clientWidth * 0.8));
                const styles = window.getComputedStyle(viewport.querySelector('.dfc-track'));
                const gap = parseFloat(styles.columnGap || styles.gap || 0) || 0;
                return slide.getBoundingClientRect().width + gap;
            };

            const getMaxScroll = () => Math.max(0, viewport.scrollWidth - viewport.clientWidth);

            const updateButtons = () => {
                const canScroll = getMaxScroll() > 2;
                prev.disabled = !canScroll;
                next.disabled = !canScroll;
                carousel.classList.toggle('is-at-start', !canScroll);
                carousel.classList.toggle('is-at-end', !canScroll);
                carousel.classList.toggle('is-looping', canScroll);
            };

            const scrollLoop = (direction) => {
                const maxScroll = getMaxScroll();
                if (maxScroll <= 2) return;

                const step = getStep() * direction;
                const target = viewport.scrollLeft + step;

                if (target > maxScroll - 2) {
                    viewport.scrollTo({ left: 0, behavior: 'smooth' });
                    return;
                }

                if (target < 2) {
                    viewport.scrollTo({ left: maxScroll, behavior: 'smooth' });
                    return;
                }

                viewport.scrollBy({ left: step, behavior: 'smooth' });
            };

            prev.addEventListener('click', () => {
                scrollLoop(-1);
            });

            next.addEventListener('click', () => {
                scrollLoop(1);
            });

            viewport.addEventListener('keydown', (event) => {
                if (event.key === 'ArrowLeft') {
                    event.preventDefault();
                    scrollLoop(-1);
                }
                if (event.key === 'ArrowRight') {
                    event.preventDefault();
                    scrollLoop(1);
                }
            });

            viewport.addEventListener('scroll', () => window.requestAnimationFrame(updateButtons), { passive: true });
            window.addEventListener('resize', updateButtons);
            updateButtons();
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initDashboardFacilityCarousel);
    } else {
        initDashboardFacilityCarousel();
    }
    document.addEventListener('turbo:load', initDashboardFacilityCarousel);
})();
</script>
{% endblock %}
