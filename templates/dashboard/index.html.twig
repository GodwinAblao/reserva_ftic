{% extends 'layouts/app.html.twig' %}

{% block title %}Dashboard | Reserva FTIC{% endblock %}

{% block content %}
    <div class="content-header">
        <h2>Dashboard</h2>
        <div class="pill-role">
            {% if is_granted('ROLE_SUPER_ADMIN') %}
                SUPER ADMIN
            {% elseif is_granted('ROLE_ADMIN') %}
                ADMIN
            {% elseif is_granted('ROLE_FACULTY') %}
                FACULTY
            {% elseif is_granted('ROLE_STUDENT') %}
                STUDENT
            {% else %}
                MEMBER
            {% endif %}
        </div>
    </div>

    <div class="card-panel welcome-card">
        <p>Welcome! <strong>{% if app.user.firstName or app.user.lastName %}{{ app.user.firstName }} {{ app.user.middleName }} {{ app.user.lastName }}{% else %}{{ app.user.email }}{% endif %}</strong></p>
    </div>

    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        <!-- Quick Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">{{ reservations['Approved']|length }}</div>
                <div class="stat-label">Approved</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ reservations['Pending']|length }}</div>
                <div class="stat-label">Pending</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ reservations['Suggested']|length }}</div>
                <div class="stat-label">Suggested</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ reservations['Rejected']|length }}</div>
                <div class="stat-label">Rejected</div>
            </div>
        </div>

        <!-- Approved Reservations -->
        {% if reservations['Approved']|length > 0 %}
            <div class="card-panel reservations-section">
                <h3 class="status-title approved-title">✓ Approved Reservations</h3>
                <div class="reservations-list">
                    {% for reservation in reservations['Approved'] %}
                        <div class="reservation-item">
                            <div class="res-facility">{{ reservation.facility.name }}</div>
                            <div class="res-details">
                                <span class="res-date">{{ reservation.reservationDate|date('M d, Y') }}</span>
                                <span class="res-time">{{ reservation.reservationStartTime|date('h:i A') }} - {{ reservation.reservationEndTime|date('h:i A') }}</span>
                                <span class="res-capacity">{{ reservation.capacity }}/{{ reservation.facility.capacity }} people</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <a href="{{ path('user_reservations') }}" class="view-all-link">View All Reservations →</a>
            </div>
        {% endif %}

        <!-- Pending Reservations -->
        {% if reservations['Pending']|length > 0 %}
            <div class="card-panel reservations-section">
                <h3 class="status-title pending-title">⏳ Pending Requests</h3>
                <p class="status-info">Your requests are under review by the Super Admin.</p>
                <div class="reservations-list">
                    {% for reservation in reservations['Pending'] %}
                        <div class="reservation-item">
                            <div class="res-facility">{{ reservation.facility.name }}</div>
                            <div class="res-details">
                                <span class="res-date">{{ reservation.reservationDate|date('M d, Y') }}</span>
                                <span class="res-time">{{ reservation.reservationStartTime|date('h:i A') }} - {{ reservation.reservationEndTime|date('h:i A') }}</span>
                                <span class="res-capacity">{{ reservation.capacity }}/{{ reservation.facility.capacity }} people</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <!-- Suggested Alternatives -->
        {% if reservations['Suggested']|length > 0 %}
            <div class="card-panel reservations-section">
                <h3 class="status-title suggested-title">💡 Suggested Alternatives</h3>
                <p class="status-info">Based on your capacity needs, we suggest these facilities that better fit your attendee count.</p>
                <div class="reservations-list">
                    {% for reservation in reservations['Suggested'] %}
                        <div class="reservation-item">
                            <div class="res-facility">{{ reservation.facility.name }}</div>
                            <div class="res-details">
                                <span class="res-date">{{ reservation.reservationDate|date('M d, Y') }}</span>
                                <span class="res-time">{{ reservation.reservationStartTime|date('h:i A') }} - {{ reservation.reservationEndTime|date('h:i A') }}</span>
                                <span class="res-capacity">{{ reservation.capacity }}/{{ reservation.facility.capacity }} people</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <!-- No Reservations -->
        {% if reservations['Approved']|length == 0 and reservations['Pending']|length == 0 
            and reservations['Suggested']|length == 0 %}
            <div class="card-panel empty-state">
                {% if dashboardScope|default('user') == 'admin' %}
                    <p>No reservation records yet.</p>
                {% else %}
                    <p>No reservations yet. <a href="{{ path('app_facility_index') }}" class="link-button">Browse facilities</a> to make your first reservation.</p>
                {% endif %}
            </div>
        {% endif %}
    {% endif %}

    <style>
        .welcome-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: var(--feu-shadow);
        }

        .welcome-card p {
            margin: 0;
            color: #333;
            font-size: 1rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin: 2rem 0;
        }

        .stat-card {
            background: white;
            padding: 1.5rem;
            border-radius: 10px;
            text-align: center;
            box-shadow: var(--feu-shadow);
            border-left: 4px solid var(--feu-green);
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--feu-green-dark);
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: #666;
            font-size: 0.95rem;
            font-weight: 600;
        }

        .reservations-section {
            background: white;
            border-radius: 12px;
            padding: 2rem;
            box-shadow: var(--feu-shadow);
            margin-bottom: 2rem;
        }

        .status-title {
            margin: 0 0 1rem 0;
            font-size: 1.2rem;
            padding-bottom: 0.75rem;
            border-bottom: 3px solid;
            display: inline-block;
        }

        .status-title.approved-title {
            color: #28a745;
            border-bottom-color: #28a745;
        }

        .status-title.pending-title {
            color: #ff9800;
            border-bottom-color: #ff9800;
        }

        .status-title.suggested-title {
            color: #17a2b8;
            border-bottom-color: #17a2b8;
        }

        .status-info {
            color: #666;
            margin: 0.75rem 0 1.5rem 0;
            font-size: 0.95rem;
        }

        .reservations-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .reservation-item {
            padding: 1rem;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            background: #f9f9f9;
            transition: all 0.3s ease;
        }

        .reservation-item:hover {
            background: white;
            border-color: var(--feu-green-light);
            box-shadow: 0 4px 8px rgba(0, 102, 51, 0.1);
        }

        .res-facility {
            font-weight: 600;
            color: var(--feu-green-dark);
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .res-details {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
            font-size: 0.9rem;
            color: #666;
        }

        .res-details span {
            display: flex;
            align-items: center;
        }

        .view-all-link {
            display: inline-block;
            color: var(--feu-green);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .view-all-link:hover {
            color: var(--feu-green-dark);
            text-decoration: underline;
        }

        .empty-state {
            text-align: center;
            padding: 2rem;
            background: white;
            border-radius: 12px;
            box-shadow: var(--feu-shadow);
        }

        .empty-state p {
            color: #666;
            margin: 0;
        }

        .link-button {
            color: var(--feu-green);
            text-decoration: none;
            font-weight: 600;
        }

        .link-button:hover {
            text-decoration: underline;
        }

        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .res-details {
                flex-direction: column;
                gap: 0.5rem;
            }
        }
    </style>
{% endblock %}
