{% extends 'layouts/app.html.twig' %}

{% block title %}Edit Mentor | Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/mentoring.css') }}">
{% endblock %}

{% block content %}
<div class="content-header">
    <h2>Edit Mentor Profile</h2>
    <a href="{{ path('mentoring_super-admin') }}" class="btn-secondary">Back to Admin</a>
</div>

<section class="em-container">
    <form method="post" action="{{ path('mentoring_edit_mentor', {'id': mentor.id}) }}" class="em-form" id="editMentorForm">
        <input type="hidden" name="_token" value="{{ csrf_token('edit_mentor_' ~ mentor.id) }}">

        {# ── User Information (read-only) ── #}
        <div class="em-section">
            <div class="em-section-header">
                <span class="em-section-icon">👤</span>
                <div>
                    <h4 class="em-section-title">User Information</h4>
                    <p class="em-section-desc">Linked account details — read only.</p>
                </div>
            </div>
            <div class="em-row em-cols-4">
                <div class="em-field">
                    <label class="em-label">First Name</label>
                    <input type="text" class="em-input em-readonly" value="{{ mentor.user.firstName }}" readonly>
                </div>
                <div class="em-field">
                    <label class="em-label">Middle Name</label>
                    <input type="text" class="em-input em-readonly" value="{{ mentor.user.middleName|default('—') }}" readonly>
                </div>
                <div class="em-field">
                    <label class="em-label">Last Name</label>
                    <input type="text" class="em-input em-readonly" value="{{ mentor.user.lastName }}" readonly>
                </div>
                <div class="em-field">
                    <label class="em-label">Institutional Email</label>
                    <input type="text" class="em-input em-readonly" value="{{ mentor.user.email }}" readonly style="font-size:11px;">
                </div>
            </div>
            <div class="em-row em-cols-3">
                <div class="em-field">
                    <label class="em-label">Program / Course</label>
                    <input type="text" class="em-input em-readonly" value="{{ mentor.user.degreeName ?: (mentor.user.degree ?: '—') }}" readonly>
                </div>
                <div class="em-field">
                    <label class="em-label">Role</label>
                    <input type="text" class="em-input em-readonly" value="{{ mentor.user.roles|join(', ')|replace({'ROLE_':'','_':' '})|lower|capitalize }}" readonly>
                </div>
                <div class="em-field">
                    <label class="em-label">Engagement Points</label>
                    <input type="text" class="em-input em-readonly" value="{{ mentor.engagementPoints }}" readonly>
                </div>
            </div>
        </div>

        {# ── Mentor Profile (editable) ── #}
        <div class="em-section">
            <div class="em-section-header">
                <span class="em-section-icon">🎓</span>
                <div>
                    <h4 class="em-section-title">Mentor Profile</h4>
                    <p class="em-section-desc">Edit display name, specialization, and background.</p>
                </div>
            </div>
            <div class="em-row em-cols-2">
                <div class="em-field">
                    <label class="em-label" for="display_name">Display Name <span class="em-req">*</span></label>
                    <input type="text" id="display_name" name="display_name" class="em-input" value="{{ mentor.displayName }}" required placeholder="How this mentor appears to students">
                </div>
                <div class="em-field">
                    <label class="em-label" for="specialization">Specialization <span class="em-req">*</span></label>
                    <select id="specialization" name="specialization" class="em-input em-select" required>
                        <option value="">Select specialization…</option>
                        {% for spec in ['Business Analytics','BSITBA','BSCS','Software Engineering','Data Science','Cybersecurity','Cloud Computing','Web Development','Mobile Development','UI/UX Design','Research','Other'] %}
                        <option value="{{ spec }}" {% if mentor.specialization == spec %}selected{% endif %}>{{ spec }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="em-row em-cols-1">
                <div class="em-field">
                    <label class="em-label" for="mentor_education">Education</label>
                    <input type="text" id="mentor_education" name="mentor_education" class="em-input" value="{{ mentor.education }}" placeholder="e.g. BS Computer Science – FEU Tech 2023">
                </div>
            </div>
            <div class="em-row em-cols-1">
                <div class="em-field">
                    <label class="em-label" for="bio">Mentoring Bio</label>
                    <textarea id="bio" name="bio" class="em-input em-textarea" rows="4" placeholder="Short bio about this mentor's strengths and expertise…">{{ mentor.bio }}</textarea>
                </div>
            </div>
        </div>

        {# ── Mentoring Availability ── #}
        <div class="em-section">
            <div class="em-section-header">
                <span class="em-section-icon">📅</span>
                <div>
                    <h4 class="em-section-title">Mentoring Availability</h4>
                    <p class="em-section-desc">Set the preferred mentoring schedule.</p>
                </div>
            </div>
            <div class="em-row em-cols-3">
                <div class="em-field">
                    <label class="em-label" for="availability_day">Mentoring Day</label>
                    <select id="availability_day" name="availability_day" class="em-input em-select">
                        <option value="">Select day…</option>
                        {% for day in ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Monday | M-W-TH','Tuesday | T-TH','Wednesday | M-W','Thursday | T-TH-S','Friday | M-F'] %}
                        <option value="{{ day }}" {% if mentor.availabilityDay == day %}selected{% endif %}>{{ day }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="em-field">
                    <label class="em-label" for="availability_start">Start Time</label>
                    <input type="time" id="availability_start" name="availability_start" class="em-input" min="07:00" max="21:00" value="{{ mentor.availabilityStart }}">
                </div>
                <div class="em-field">
                    <label class="em-label" for="availability_end">End Time</label>
                    <input type="time" id="availability_end" name="availability_end" class="em-input" min="07:00" max="21:00" value="{{ mentor.availabilityEnd }}">
                    <span class="em-error" id="em_err_time"></span>
                </div>
            </div>
        </div>

        {# ── Actions ── #}
        <div class="em-actions">
            <a href="{{ path('mentoring_super-admin') }}" class="em-btn-cancel">Cancel</a>
            <button type="submit" class="em-btn-save" id="emSaveBtn">
                <span class="em-btn-label">Update Mentor</span>
                <span class="em-btn-spinner" style="display:none;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4 31.4" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" values="0 12 12;360 12 12" dur=".8s" repeatCount="indefinite"/></circle></svg>
                    Saving…
                </span>
            </button>
        </div>
    </form>
</section>


<script>
(function(){
    /* End time > Start time validation */
    const startEl = document.getElementById('availability_start');
    const endEl   = document.getElementById('availability_end');
    if (startEl && endEl) {
        endEl.addEventListener('change', function() {
            const err = document.getElementById('em_err_time');
            if (startEl.value && endEl.value && endEl.value <= startEl.value) {
                endEl.style.borderColor = '#dc2626';
                if (err) err.textContent = 'End time must be after start time';
            } else {
                endEl.style.borderColor = '';
                if (err) err.textContent = '';
            }
        });
    }

    /* Prevent double submit */
    const form = document.getElementById('editMentorForm');
    if (form) {
        form.addEventListener('submit', function(e) {
            const btn = document.getElementById('emSaveBtn');
            if (!btn) return;
            if (btn.dataset.submitting === '1') { e.preventDefault(); return; }

            /* Validate end time */
            if (startEl && endEl && startEl.value && endEl.value && endEl.value <= startEl.value) {
                e.preventDefault();
                endEl.style.borderColor = '#dc2626';
                const err = document.getElementById('em_err_time');
                if (err) err.textContent = 'End time must be after start time';
                return;
            }

            btn.dataset.submitting = '1';
            btn.disabled = true;
            btn.querySelector('.em-btn-label').style.display = 'none';
            btn.querySelector('.em-btn-spinner').style.display = '';
        });
    }
})();
</script>
{% endblock %}