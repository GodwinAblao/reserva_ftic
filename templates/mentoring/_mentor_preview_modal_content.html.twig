{% set availabilityDays = mentor.availabilityDays|default([]) %}
{% set availabilityStart = mentor.availabilityStart|default('09:00') %}
{% set availabilityEnd = mentor.availabilityEnd|default('17:00') %}

<div class="mentor-preview-content">
    <div class="mentor-preview-header" style="display:flex; gap:1rem; align-items:flex-start; margin-bottom:1rem;">
        <div class="mentor-card-avatar" style="flex-shrink:0;">
            {% set user = mentor.user %}
            {% if user and user.profilePicture %}
                <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" alt="{{ mentor.displayName }}">
            {% else %}
                <span>{{ mentor.displayName|first|upper }}</span>
            {% endif %}
        </div>
        <div style="flex:1; min-width:0;">
            <h3 style="margin:0 0 .25rem 0;">{{ mentor.displayName }}</h3>
            <p style="margin:0 0 .5rem 0; color:#4b5563;">{{ mentor.specialization }} Mentor</p>
            <div class="mentor-card-tags">
                <span class="mentor-specialization-tag">{{ mentor.specialization }}</span>
                <span class="mentor-specialization-tag">{{ mentor.engagementPoints }} pts</span>
            </div>
        </div>
    </div>

    <div style="margin-bottom:1rem;">
        <h4 style="margin:0 0 .35rem 0;">About</h4>
        <p style="margin:0; color:#4b5563;">{{ mentor.bio|default('This mentor has not added a bio yet.') }}</p>
    </div>

    {# Mentor Availability Info — hidden until a date is selected #}
    <div class="mentor-availability-info" id="avail_info_{{ mentor.id }}" style="display:none; margin-bottom:1.25rem; padding:.75rem; background:#f8fafc; border-radius:8px; border-left:4px solid #3b82f6;">
        <h4 style="margin:0 0 .5rem 0; font-size:.9rem; color:#1e40af;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle; margin-right:.35rem;">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            Available Schedule
        </h4>
        <p style="margin:0; font-size:.85rem; color:#4b5563;">
            {% if availabilityDays %}
                <strong>Days:</strong> {{ availabilityDays|join(', ') }}<br>
            {% else %}
                <strong>Days:</strong> Flexible (contact for availability)<br>
            {% endif %}
            {% if availabilityStart and availabilityEnd %}
                <strong>Time:</strong> {{ availabilityStart|date('g:i A') }} - {{ availabilityEnd|date('g:i A') }}
            {% endif %}
        </p>
    </div>

    <div style="margin-bottom:1.25rem;">
        <h4 style="margin:0 0 .35rem 0;">Contact</h4>
        <p style="margin:0; color:#4b5563;">{{ mentor.user ? mentor.user.email : 'N/A' }}</p>
    </div>

    <div class="custom-request-section" style="margin:0; padding:0; background:transparent; box-shadow:none;">
        <div class="request-header" style="margin-bottom:1rem;">
            <h3 style="margin:0 0 .35rem 0; font-size:1.1rem; font-weight:700; color:#111827;">Schedule a Mentoring Session</h3>
            <p class="request-subtitle" style="margin:0; font-size:.85rem; color:#6b7280;">Select your specialization, date, and share your mentoring goals.</p>
        </div>

        {% if canSendCustomRequest %}
            <form method="post" action="{{ path('mentoring_custom_request', {'id': mentor.id}) }}" class="custom-request-form" data-mentor-preview-form="1" data-mentor-id="{{ mentor.id }}">
                <input type="hidden" name="_token" value="{{ csrf_token('custom_request_' ~ mentor.id) }}">
                
                {# Specialization Section #}
                <div class="form-section" style="margin-bottom:1rem;">
                    <label for="specialization_{{ mentor.id }}" class="form-label" style="display:block; margin-bottom:.4rem; font-size:.85rem; font-weight:600; color:#374151;">
                        Your Specialization <span class="form-required">*</span>
                    </label>
                    <select name="specialization" 
                            id="specialization_{{ mentor.id }}"
                            class="form-input"
                            required
                            onchange="toggleSpecializationOther(this, 'specialization_other_{{ mentor.id }}')"
                            style="width:100%; padding:.6rem .75rem; border:1px solid #e5e7eb; border-radius:8px; font-size:.9rem; color:#374151; background:#fff;">
                        <option value="">Select specialization…</option>
                        {% for specialization in allSpecializations %}
                        <option value="{{ specialization.name }}">{{ specialization.name }}</option>
                        {% endfor %}
                        <option value="Other">Other (specify below)</option>
                    </select>
                    <input type="text" 
                           name="specialization_other" 
                           id="specialization_other_{{ mentor.id }}"
                           class="form-input"
                           placeholder="Please specify your specialization..."
                           style="width:100%; padding:.6rem .75rem; border:1px solid #e5e7eb; border-radius:8px; font-size:.9rem; color:#374151; background:#fff; margin-top:.5rem; display:none;">
                </div>
                
                {# Calendar Scheduling Section #}
                <div class="scheduling-section" style="margin-bottom:1rem; padding:1rem; background:#f8fafc; border-radius:10px; border:1px solid #e2e8f0;">
                    <h4 style="margin:0 0 .75rem 0; font-size:.9rem; font-weight:600; color:#1e293b; display:flex; align-items:center; gap:.4rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        Select Date & Time
                    </h4>
                    
                    {# Date Picker - Custom Calendar #}
                    <div class="form-section" style="margin-bottom:.75rem;">
                        <label class="form-label" style="display:block; margin-bottom:.4rem; font-size:.85rem; font-weight:600; color:#374151;">Preferred Date <span class="form-required">*</span></label>
                        <input type="hidden"
                               name="scheduled_date"
                               id="scheduled_date_{{ mentor.id }}"
                               required>
                        <div class="mentor-mini-cal"
                             id="mcal_{{ mentor.id }}"
                             data-mentor-id="{{ mentor.id }}"
                             data-availability-days='{{ availabilityDays|json_encode|raw }}'
                             data-min="{{ 'now'|date('Y-m-d') }}"></div>
                        <div id="mcal_selected_{{ mentor.id }}" class="mcal-selected-display" style="display:none;"></div>
                        <div id="date_feedback_{{ mentor.id }}" style="display:none; font-size:.8rem; margin-top:.35rem; padding:.4rem .6rem; border-radius:6px; border:1px solid;"></div>
                    </div>
                    
                    {# Time Slot Selection #}
                    <div class="form-section" style="margin-bottom:.5rem;">
                        <label for="scheduled_time_{{ mentor.id }}" class="form-label" style="display:block; margin-bottom:.4rem; font-size:.85rem; font-weight:600; color:#374151;">Preferred Time <span class="form-required">*</span></label>
                        <select name="scheduled_time" 
                                id="scheduled_time_{{ mentor.id }}"
                                class="form-input scheduled-time-select"
                                required
                                data-start-time="{{ availabilityStart }}"
                                data-end-time="{{ availabilityEnd }}"
                                style="width:100%; padding:.6rem .75rem; border:1px solid #e5e7eb; border-radius:8px; font-size:.9rem; color:#374151; background:#fff;">
                            <option value="">-- Select a time slot --</option>
                        </select>
                        <small class="form-hint" style="color:#64748b; font-size:.75rem; display:block; margin-top:.3rem;">
                            Available slots: {{ availabilityStart|date('g:i A') }} - {{ availabilityEnd|date('g:i A') }}
                        </small>
                    </div>
                </div>

                {# Message Section #}
                <div class="form-section" style="margin-bottom:1rem;">
                    <label for="custom_message_preview_{{ mentor.id }}" class="form-label" style="display:flex; align-items:center; gap:.4rem; margin-bottom:.4rem; font-size:.85rem; font-weight:600; color:#374151;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                        </svg>
                        Your Message <span class="form-required">*</span>
                    </label>
                    <textarea
                        name="message"
                        id="custom_message_preview_{{ mentor.id }}"
                        class="custom-textarea"
                        rows="4"
                        placeholder="Describe what you'd like to discuss, your goals, or any specific topics you'd like mentoring on..."
                        required
                        minlength="10"
                        maxlength="500"
                        style="width:100%; padding:.6rem .75rem; border:1px solid #e5e7eb; border-radius:8px; font-size:.9rem; color:#374151; background:#fff; resize:vertical; font-family:inherit;"></textarea>
                    <small class="char-count" style="color:#64748b; font-size:.75rem; text-align:right; display:block; margin-top:.3rem;">0 / 500</small>
                </div>

                <div class="form-actions" style="display:flex; flex-direction:column; gap:.5rem;">
                    <button type="submit" class="btn-primary" id="submit_request_{{ mentor.id }}" {% if availabilityDays %}disabled{% endif %} style="display:flex; align-items:center; justify-content:center; gap:.5rem; width:100%; padding:.7rem 1.25rem; background:#0D9B00; color:#fff; border:none; border-radius:8px; font-size:.95rem; font-weight:600; cursor:pointer; transition:background .2s;">
                        <span class="mentor-req-btn-icon" style="display:flex;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="22" y1="2" x2="11" y2="13"></line>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                            </svg>
                        </span>
                        <span class="mentor-req-btn-text">Send Mentoring Request</span>
                    </button>
                    <p class="form-note" style="text-align:center; margin:0; font-size:.8rem; color:#6b7280;">
                        {{ mentor.displayName }} will review your request and confirm the meeting details.
                    </p>
                </div>
            </form>
        {% else %}
            <div class="custom-request-disabled">
                <p class="alert alert-info" style="margin:0; padding:.75rem; background:#eff6ff; border:1px solid #bfdbfe; border-radius:8px; color:#1e40af; font-size:.9rem;">You cannot send a mentor request to your own mentor profile.</p>
            </div>
        {% endif %}
    </div>
</div>

<style>
.mentor-mini-cal{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:.65rem;user-select:none;}
.mcal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.45rem;}
.mcal-nav{background:none;border:1px solid #e5e7eb;border-radius:6px;font-size:1rem;cursor:pointer;color:#374151;padding:2px 9px;line-height:1.4;}
.mcal-nav:hover{background:#f3f4f6;}
.mcal-title{font-size:.82rem;font-weight:700;color:#111827;}
.mcal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
.mcal-dow{text-align:center;font-size:.68rem;font-weight:600;color:#9ca3af;padding:3px 0;}
.mcal-cell{text-align:center;padding:5px 2px;font-size:.78rem;border-radius:6px;color:#374151;line-height:1.3;}
.mcal-cell.available{cursor:pointer;}
.mcal-cell.available:hover{background:#f0fdf4;color:#065f46;}
.mcal-cell.unavailable{color:#d1d5db;cursor:not-allowed;}
.mcal-cell.past{color:#e5e7eb;cursor:default;}
.mcal-cell.today.available{font-weight:700;background:#fef9c3;}
.mcal-cell.selected{background:#0D9B00 !important;color:#fff !important;font-weight:700;}
.mcal-selected-display{margin-top:.4rem;font-size:.78rem;color:#065f46;background:#d1fae5;padding:.35rem .6rem;border-radius:6px;}
.mentor-req-btn-loading{opacity:.75;pointer-events:none;cursor:not-allowed;}
.mentor-req-btn-loading .mentor-req-btn-icon{display:none;}
.mentor-req-btn-loading .mentor-req-btn-text{display:none;}
.mentor-req-btn-loading::after{content:'';display:inline-block;width:15px;height:15px;border:2px solid rgba(255,255,255,.35);border-top-color:#fff;border-radius:50%;animation:mreqspin .7s linear infinite;vertical-align:middle;}
@keyframes mreqspin{to{transform:rotate(360deg);}}
</style>
<script>
(function() {
    // Toggle "Other" specialization text box
    window.toggleSpecializationOther = function(select, otherInputId) {
        const otherInput = document.getElementById(otherInputId);
        if (otherInput) {
            otherInput.style.display = select.value === 'Other' ? 'block' : 'none';
            if (select.value !== 'Other') otherInput.value = '';
        }
    };

    /* ── Mini Calendar Widget ── */
    const CAL_MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const CAL_DOWS   = ['Su','Mo','Tu','We','Th','Fr','Sa'];
    const DAY_NUM    = {Sunday:0,Monday:1,Tuesday:2,Wednesday:3,Thursday:4,Friday:5,Saturday:6};

    function buildCalendar(calEl) {
        const mid         = calEl.dataset.mentorId;
        const rawDays     = JSON.parse(calEl.dataset.availabilityDays || '[]');
        const minStr      = calEl.dataset.min;   // 'YYYY-MM-DD'
        const hiddenInput = document.getElementById('scheduled_date_' + mid);
        const selDisplay  = document.getElementById('mcal_selected_' + mid);
        const timeSelect  = document.getElementById('scheduled_time_' + mid);

        // Handle compound day names like 'Monday | M-W-TH' → 'Monday'
        const allowedNums = new Set(
            rawDays.map(d => DAY_NUM[d.split('|')[0].trim()]).filter(n => n !== undefined)
        );

        const [my, mm, md] = minStr.split('-').map(Number);
        const minDate = new Date(my, mm - 1, md);
        const today   = new Date(); today.setHours(0,0,0,0);

        let year  = today.getFullYear();
        let month = today.getMonth();
        let selectedStr = null;

        function render() {
            const firstDow = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            let html = `<div class="mcal-header">
                <button type="button" class="mcal-nav" onclick="_mcalNav('${mid}',-1)">&#8249;</button>
                <span class="mcal-title">${CAL_MONTHS[month]} ${year}</span>
                <button type="button" class="mcal-nav" onclick="_mcalNav('${mid}',1)">&#8250;</button>
            </div><div class="mcal-grid">`;
            CAL_DOWS.forEach(d => { html += `<div class="mcal-dow">${d}</div>`; });
            for (let i = 0; i < firstDow; i++) html += '<div class="mcal-cell"></div>';
            for (let d = 1; d <= daysInMonth; d++) {
                const cell   = new Date(year, month, d);
                const dow    = cell.getDay();
                const dStr   = year + '-' + String(month+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
                const isPast = cell < minDate;
                const isBad  = allowedNums.size > 0 && !allowedNums.has(dow);
                const isToday = cell.getTime() === today.getTime();
                const isSel  = dStr === selectedStr;
                let cls = 'mcal-cell';
                if (isSel)   cls += ' selected';
                else if (isPast || isBad) cls += isPast ? ' past' : ' unavailable';
                else { cls += ' available'; if (isToday) cls += ' today'; }
                const handler = (!isPast && !isBad) ? ` onclick="_mcalPick('${mid}','${dStr}')"` : '';
                html += `<div class="${cls}"${handler}>${d}</div>`;
            }
            html += '</div>';
            calEl.innerHTML = html;
        }

        const availInfo   = document.getElementById('avail_info_' + mid);
        const feedbackDiv = document.getElementById('date_feedback_' + mid);
        const submitBtn   = document.getElementById('submit_request_' + mid);

        function pick(dStr) {
            selectedStr = dStr;
            if (hiddenInput) hiddenInput.value = dStr;

            const d   = new Date(dStr + 'T00:00:00');
            const dow = d.getDay();
            const valid = allowedNums.size === 0 || allowedNums.has(dow);
            const dayLabel = d.toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

            if (selDisplay) {
                selDisplay.textContent = dayLabel;
                selDisplay.style.display = 'block';
            }

            if (feedbackDiv) {
                if (valid) {
                    feedbackDiv.textContent = '\u2713 Mentor available on: ' + (rawDays.length ? rawDays.join(', ') : 'all days');
                    feedbackDiv.style.cssText = 'display:block;font-size:.8rem;margin-top:.35rem;padding:.4rem .6rem;border-radius:6px;border:1px solid #86efac;background:#f0fdf4;color:#166534;';
                } else {
                    feedbackDiv.textContent = '\u2717 Mentor is not available on the selected date';
                    feedbackDiv.style.cssText = 'display:block;font-size:.8rem;margin-top:.35rem;padding:.4rem .6rem;border-radius:6px;border:1px solid #fca5a5;background:#fef2f2;color:#dc2626;';
                }
            }

            if (availInfo) availInfo.style.display = 'block';
            if (submitBtn) submitBtn.disabled = !valid;

            if (timeSelect) { if (valid) refillTime(timeSelect); else { timeSelect.innerHTML = '<option value="">-- Select date first --</option>'; } }
            render();
        }

        calEl._mcalNav = function(dir) {
            month += dir;
            if (month < 0)  { month = 11; year--; }
            if (month > 11) { month = 0;  year++; }
            render();
        };
        calEl._mcalPick = pick;
        render();
    }

    window._mcalNav  = function(mid, dir) { document.getElementById('mcal_' + mid)?._mcalNav(dir); };
    window._mcalPick = function(mid, d)   { document.getElementById('mcal_' + mid)?._mcalPick(d); };

    /* ── Time slot generator ── */
    function generateTimeSlots(startTime, endTime, interval) {
        interval = interval || 30;
        const slots = [];
        const [sh, sm] = startTime.split(':').map(Number);
        const [eh, em] = endTime.split(':').map(Number);
        let h = sh, m = sm;
        while (h < eh || (h === eh && m < em)) {
            const ts = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0');
            const lbl = new Date('2000-01-01T' + ts).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',hour12:true});
            slots.push({value:ts,label:lbl});
            m += interval; if (m >= 60) { h++; m = 0; }
        }
        return slots;
    }

    function refillTime(timeSelect) {
        const start = timeSelect.dataset.startTime || '09:00';
        const end   = timeSelect.dataset.endTime   || '17:00';
        timeSelect.innerHTML = '<option value="">-- Select a time slot --</option>';
        generateTimeSlots(start, end).forEach(function(s) {
            const o = document.createElement('option');
            o.value = s.value; o.textContent = s.label;
            timeSelect.appendChild(o);
        });
    }

    /* ── Init all calendars in this modal ── */
    document.querySelectorAll('.mentor-mini-cal').forEach(buildCalendar);

    /* ── Populate time selects on load ── */
    document.querySelectorAll('.scheduled-time-select').forEach(function(sel) {
        refillTime(sel);
    });

    /* ── Form-level submit guard + loading state ── */
    document.querySelectorAll('form[data-mentor-preview-form]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            const mid    = form.dataset.mentorId;
            const hidden = document.getElementById('scheduled_date_' + mid);
            const btn    = document.getElementById('submit_request_' + mid);
            const fb     = document.getElementById('date_feedback_' + mid);

            if (!hidden || !hidden.value) {
                e.preventDefault();
                if (fb) { fb.textContent = '\u2717 Please select a date first.'; fb.style.cssText = 'display:block;font-size:.8rem;margin-top:.35rem;padding:.4rem .6rem;border-radius:6px;border:1px solid #fca5a5;background:#fef2f2;color:#dc2626;'; }
                return;
            }
            if (btn && btn.disabled) { e.preventDefault(); return; }

            // All valid — show loading
            if (btn) { btn.classList.add('mentor-req-btn-loading'); btn.disabled = true; }
        });
    });

    /* ── Character counter ── */
    document.querySelectorAll('.custom-textarea').forEach(function(textarea) {
        const counter = textarea.parentElement.querySelector('.char-count');
        if (counter) {
            textarea.addEventListener('input', function() {
                const len = this.value.length;
                counter.textContent = len + ' / 500';
                counter.style.color = len < 10 ? '#dc2626' : (len > 450 ? '#d97706' : '#64748b');
            });
        }
    });
})();
</script>
