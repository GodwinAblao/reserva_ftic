<div class="mentor-app-card" id="mentorAppFormCard">
    {# ── Section 1: Personal Information ── #}
    <div class="mentor-app-section">
        <div class="mentor-section-header">
            <div class="mentor-section-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div class="mentor-section-title-wrap">
                <h4 class="mentor-section-title">Personal Information</h4>
                <p class="mentor-section-desc">Basic details to identify your application</p>
            </div>
        </div>
        <div class="mentor-form-row mentor-cols-3">
            <div class="mentor-field-group">
                <label class="mentor-field-label">First Name <span class="mentor-req">*</span></label>
                <input type="text" name="firstName" id="mentor_firstName" class="mentor-input" value="{{ defaultUser.firstName|default('') }}" required placeholder="Juan">
                <span class="mentor-error" id="err_firstName"></span>
            </div>
            <div class="mentor-field-group">
                <label class="mentor-field-label">Middle Name</label>
                <input type="text" name="middleName" id="mentor_middleName" class="mentor-input" value="{{ defaultUser.middleName|default('') }}" placeholder="Optional">
            </div>
            <div class="mentor-field-group">
                <label class="mentor-field-label">Last Name <span class="mentor-req">*</span></label>
                <input type="text" name="lastName" id="mentor_lastName" class="mentor-input" value="{{ defaultUser.lastName|default('') }}" required placeholder="Dela Cruz">
                <span class="mentor-error" id="err_lastName"></span>
            </div>
        </div>
        <div class="mentor-form-row mentor-cols-1">
            <div class="mentor-field-group">
                <label class="mentor-field-label">Institutional Email <span class="mentor-req">*</span></label>
                <input type="email" name="email" id="mentor_email" class="mentor-input mentor-input-readonly" value="{{ defaultUser.email|default('') }}" required readonly>
                <span class="mentor-hint">Auto-filled from your account</span>
            </div>
        </div>
        <div class="mentor-form-row mentor-cols-1">
            <div class="mentor-field-group">
                <label class="mentor-field-label">Program / Course</label>
                <input type="text" name="programCourse" id="mentor_programCourse" class="mentor-input" value="{{ defaultUser.degreeName|default(defaultUser.degree|default('')) }}" placeholder="e.g. BS Information Technology">
                <span class="mentor-hint">Your current degree program</span>
            </div>
        </div>
    </div>

    {# ── Section 2: Academic & Professional Background ── #}
    <div class="mentor-app-section">
        <div class="mentor-section-header">
            <div class="mentor-section-icon-wrap mentor-icon-accent">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div class="mentor-section-title-wrap">
                <h4 class="mentor-section-title">Academic &amp; Professional Background</h4>
                <p class="mentor-section-desc">Your qualifications and area of expertise</p>
            </div>
        </div>
        <div class="mentor-form-row mentor-cols-1">
            <div class="mentor-field-group">
                <label class="mentor-field-label">Mentoring Specialization <span class="mentor-req">*</span></label>
                <select name="specialization" id="mentor_specialization" class="mentor-input mentor-select" required onchange="handleOtherOption(this, 'specializationOther')">
                    <option value="">Select specialization</option>
                    {% for specialization in allSpecializations %}
                    <option value="{{ specialization.name }}">{{ specialization.name }}</option>
                    {% endfor %}
                </select>
                <input type="text" id="specializationOther" name="specializationOther" class="mentor-input mentor-other-input" style="display: none; margin-top: 8px;" placeholder="Please specify your specialization">
                <span class="mentor-error" id="err_specialization"></span>
            </div>
        </div>
        <div class="mentor-form-row mentor-cols-2">
            <div class="mentor-field-group">
                <label class="mentor-field-label">Current Profession</label>
                <select name="currentProfession" id="mentor_currentProfession" class="mentor-input mentor-select" onchange="handleOtherOption(this, 'professionOther')">
                    <option value="">Select profession</option>
                    <option value="Student">Student</option>
                    <option value="Intern">Intern</option>
                    <option value="Freelancer">Freelancer</option>
                    <option value="Employee">Employee</option>
                    <option value="Professional">Professional</option>
                    <option value="Business Owner">Business Owner</option>
                    <option value="Academic / Faculty">Academic / Faculty</option>
                    <option value="Researcher">Researcher</option>
                    <option value="Consultant">Consultant</option>
                    <option value="Other">Other</option>
                </select>
                <input type="text" id="professionOther" name="professionOther" class="mentor-input mentor-other-input" style="display: none; margin-top: 8px;" placeholder="Please specify your profession">
            </div>
            <div class="mentor-field-group">
                <label class="mentor-field-label">Highest Educational Attainment</label>
                <select name="highestEducation" id="mentor_highestEducation" class="mentor-input mentor-select" required>
                    <option value="" disabled selected>Select degree</option>
                    <option value="High School Diploma">High School Diploma</option>
                    <option value="Some College (Undergraduate)">Some College</option>
                    <option value="Associate Degree">Associate Degree</option>
                    <option value="Bachelor's Degree">Bachelor's Degree</option>
                    <option value="Master's Degree">Master's Degree</option>
                    <option value="Doctorate / PhD">Doctorate / PhD</option>
                    <option value="Professional Certificate">Professional Certificate</option>
                </select>
            </div>
        </div>
    </div>

    {# ── Section 3: Mentoring Availability ── #}
    <div class="mentor-app-section">
        <div class="mentor-section-header">
            <div class="mentor-section-icon-wrap mentor-icon-accent">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="mentor-section-title-wrap">
                <h4 class="mentor-section-title">Mentoring Availability</h4>
                <p class="mentor-section-desc">When are you available for sessions?</p>
            </div>
        </div>
        <div class="mentor-form-row mentor-cols-3">
            <div class="mentor-field-group">
                <label class="mentor-field-label">Available Days</label>
                <div class="mentor-checkbox-group">
                    {% for day in ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'] %}
                    <label class="mentor-checkbox-label">
                        <input type="checkbox" name="availabilityDays[]" value="{{ day }}" class="mentor-checkbox"> 
                        <span>{{ day[:3] }}</span>
                    </label>
                    {% endfor %}
                </div>
                <input type="hidden" name="availabilityDay" id="mentor_availabilityDay">
            </div>
            <div class="mentor-field-group">
                <label class="mentor-field-label">Start Time</label>
                <input type="time" name="availabilityStart" id="mentor_availabilityStart" class="mentor-input" min="07:00" max="19:00" required>
            </div>
            <div class="mentor-field-group">
                <label class="mentor-field-label">End Time</label>
                <input type="time" name="availabilityEnd" id="mentor_availabilityEnd" class="mentor-input" min="07:00" max="19:00" required>
                <span class="mentor-error" id="err_availabilityEnd"></span>
            </div>
        </div>
        <span class="mentor-hint">Select your preferred mentoring schedule</span>
        <input type="hidden" name="availabilityTime" id="mentor_availabilityTime">
    </div>

    {# ── Section 4: Mentoring Public Bio ── #}
    <div class="mentor-app-section">
        <div class="mentor-section-header">
            <div class="mentor-section-icon-wrap mentor-icon-accent">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
            </div>
            <div class="mentor-section-title-wrap">
                <h4 class="mentor-section-title">Mentoring Public Bio</h4>
                <p class="mentor-section-desc">Tell us why you'd be a great mentor</p>
            </div>
        </div>
        <div class="mentor-form-row mentor-cols-1">
            <div class="mentor-field-group">
                <label class="mentor-field-label">Description <span class="mentor-req">*</span></label>
                <textarea name="mentoringPublicBio" id="mentor_mentoringPublicBio" class="mentor-input mentor-textarea" rows="4" required
                          placeholder="Share your strengths, relevant experience, certifications, and what motivates you to mentor other students." maxlength="2000"></textarea>
                <div class="mentor-textarea-footer">
                    <span class="mentor-hint">Be specific — reviewed by Super Admin. This will be shown publicly on your mentor profile once approved.</span>
                    <span class="mentor-charcount" id="mentor_descCharCount">0 / 2000</span>
                </div>
                <span class="mentor-error" id="err_mentoringPublicBio"></span>
            </div>
        </div>
    </div>

    {# ── Section 5: Supporting Documents ── #}
    <div class="mentor-app-section">
        <div class="mentor-section-header">
            <div class="mentor-section-icon-wrap mentor-icon-accent">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
            </div>
            <div class="mentor-section-title-wrap">
                <h4 class="mentor-section-title">Supporting Documents <span class="mentor-req">*</span></h4>
                <p class="mentor-section-desc">Upload certificates, IDs, transcripts, or portfolio samples</p>
            </div>
        </div>
        <div class="mentor-upload-zone" id="mafDropZone">
            <div class="mentor-upload-click-area" id="mafClickArea">
                <input type="file" id="mentor_supportingDocuments" multiple accept=".jpg,.jpeg,.png,.pdf" class="mentor-upload-input">
                <div class="mentor-upload-placeholder" id="mafUploadPlaceholder">
                    <div class="mentor-upload-icon-wrap">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    </div>
                    <span class="mentor-upload-text">Click to add files or drag & drop</span>
                    <span class="mentor-upload-meta">JPG, PNG, PDF — max 5 MB each</span>
                </div>
            </div>
            <div class="mentor-file-list" id="mafFileList"></div>
        </div>
        <span class="mentor-error" id="err_supportingDocuments"></span>
        {# Hidden container for actual file inputs to be submitted #}
        <div id="mafFileInputsContainer" style="display: none;"></div>
    </div>

    {# ── Submit ── #}
    <div class="mentor-submit-row">
        <button type="submit" class="mentor-submit-btn" id="mafSubmitBtn">
            <span class="mentor-submit-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="mentor-submit-label">Submit Application</span>
            <span class="mentor-submit-spinner" style="display:none;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4 31.4" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" values="0 12 12;360 12 12" dur=".8s" repeatCount="indefinite"/></circle></svg>
                Submitting…
            </span>
        </button>
        <p class="mentor-submit-note">Your application will be reviewed by the Super Admin. You'll be notified once approved.</p>
    </div>
</div>

<script>
(function(){
    /* ── Handle 'Other' option in dropdowns ── */
    window.handleOtherOption = function(select, otherInputId) {
        const otherInput = document.getElementById(otherInputId);
        if (!otherInput) return;
        
        if (select.value === 'Other') {
            otherInput.style.display = 'block';
            otherInput.required = true;
            otherInput.focus();
        } else {
            otherInput.style.display = 'none';
            otherInput.required = false;
            otherInput.value = '';
        }
    };


    /* ── Availability time merger ── */
    function mergeAvailability() {
        const checkboxes = document.querySelectorAll('input[name="availabilityDays[]"]:checked');
        const selectedDays = Array.from(checkboxes).map(cb => cb.value);
        const day = selectedDays.length > 0 ? selectedDays.join(', ') : '';
        const start = document.getElementById('mentor_availabilityStart')?.value || '';
        const end   = document.getElementById('mentor_availabilityEnd')?.value || '';
        const hidden = document.getElementById('mentor_availabilityTime');
        const dayHidden = document.getElementById('mentor_availabilityDay');
        if (!hidden) return;
        let parts = [];
        if (day) parts.push(day);
        if (start && end) parts.push(start + ' – ' + end);
        else if (start) parts.push('from ' + start);
        hidden.value = parts.join(', ');
        if (dayHidden) dayHidden.value = day;
    }
    ['mentor_availabilityStart','mentor_availabilityEnd'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('change', mergeAvailability);
    });
    document.querySelectorAll('input[name="availabilityDays[]"]').forEach(function(cb) {
        cb.addEventListener('change', mergeAvailability);
    });

    /* ── End time > Start time validation ── */
    const startTime = document.getElementById('mentor_availabilityStart');
    const endTime   = document.getElementById('mentor_availabilityEnd');
    if (startTime && endTime) {
        endTime.addEventListener('change', function() {
            const err = document.getElementById('err_availabilityEnd');
            if (startTime.value && endTime.value && endTime.value <= startTime.value) {
                endTime.classList.add('maf-input-error');
                if (err) err.textContent = 'End time must be after start time';
            } else {
                endTime.classList.remove('maf-input-error');
                if (err) err.textContent = '';
            }
        });
    }

    /* ── Character counter ── */
    const descTA = document.getElementById('mentor_mentoringPublicBio');
    const descCount = document.getElementById('mentor_descCharCount');
    if (descTA && descCount) {
        descTA.addEventListener('input', function() {
            descCount.textContent = descTA.value.length + ' / 2000';
        });
    }

    /* ── Drag-and-drop upload zone with incremental file selection ── */
    const dropZone    = document.getElementById('mafDropZone');
    const clickArea   = document.getElementById('mafClickArea');
    const fileInput   = document.getElementById('mentor_supportingDocuments');
    const fileList    = document.getElementById('mafFileList');
    const placeholder = document.getElementById('mafUploadPlaceholder');
    const fileInputsContainer = document.getElementById('mafFileInputsContainer');
    let selectedFiles = []; // Array to store selected files

    if (dropZone && fileInput) {
        // Prevent default drag behaviors
        ['dragenter','dragover','dragleave','drop'].forEach(function(ev) {
            dropZone.addEventListener(ev, function(e) { e.preventDefault(); e.stopPropagation(); });
        });
        ['dragenter','dragover'].forEach(function(ev) {
            dropZone.addEventListener(ev, function(e) { dropZone.classList.add('mentor-drop-active'); });
        });
        ['dragleave','drop'].forEach(function(ev) {
            dropZone.addEventListener(ev, function(e) { dropZone.classList.remove('mentor-drop-active'); });
        });

        // Handle dropped files
        dropZone.addEventListener('drop', function(e) {
            if (e.dataTransfer.files.length) {
                addFiles(e.dataTransfer.files);
            }
        });

        // Handle file input selection
        fileInput.addEventListener('change', function() {
            if (fileInput.files.length) {
                addFiles(fileInput.files);
            }
            // Reset input to allow selecting same files again
            fileInput.value = '';
        });

        // Click on file list area to add more files
        if (fileList) {
            fileList.addEventListener('click', function(e) {
                // Don't trigger if clicking on remove button
                if (e.target.closest('.mentor-file-remove')) return;
                fileInput.click();
            });
        }

        // Add files to the selection
        function addFiles(newFiles) {
            var errEl = document.getElementById('err_supportingDocuments');
            if (errEl) errEl.textContent = '';

            for (var i = 0; i < newFiles.length; i++) {
                var f = newFiles[i];
                // Check if file already exists (by name and size)
                var exists = selectedFiles.some(function(sf) {
                    return sf.name === f.name && sf.size === f.size;
                });
                if (!exists) {
                    selectedFiles.push(f);
                }
            }
            renderFileList();
        }

        // Remove a file from selection
        window.removeFile = function(index) {
            selectedFiles.splice(index, 1);
            renderFileList();
        };

        // Render the file list
        function renderFileList() {
            if (!fileList) return;
            fileList.innerHTML = '';
            var errEl = document.getElementById('err_supportingDocuments');
            if (errEl) errEl.textContent = '';

            if (selectedFiles.length === 0) {
                if (clickArea) clickArea.style.display = '';
                return;
            }
            // Hide click area but keep it for clicking to add more
            if (clickArea) {
                clickArea.style.padding = '16px';
                clickArea.querySelector('.mentor-upload-text').textContent = '+ Add more files';
            }

            var hasError = false;
            for (var i = 0; i < selectedFiles.length; i++) {
                var f = selectedFiles[i];
                var valid = ['image/jpeg','image/png','application/pdf'].indexOf(f.type) !== -1;
                var sizeOk = f.size <= 5 * 1024 * 1024;
                var row = document.createElement('div');
                row.className = 'mentor-file-row' + (!valid || !sizeOk ? ' mentor-file-invalid' : '');
                var icon = f.type === 'application/pdf' ? '📄' : '🖼️';
                var sizeStr = (f.size / 1024 / 1024).toFixed(2) + ' MB';
                var errorMsg = !valid ? ' — invalid type' : (!sizeOk ? ' — exceeds 5 MB' : '');

                row.innerHTML = '<span class="mentor-file-icon">' + icon + '</span>'
                    + '<span class="mentor-file-name">' + f.name + '</span>'
                    + '<span class="mentor-file-size">' + sizeStr + errorMsg + '</span>'
                    + '<button type="button" class="mentor-file-remove" onclick="removeFile(' + i + ')" title="Remove file">'
                    + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
                    + '</button>';
                fileList.appendChild(row);

                if (!valid || !sizeOk) {
                    hasError = true;
                }
            }

            if (hasError && errEl) {
                errEl.textContent = 'One or more files are invalid. Please fix before submitting.';
            }
        }

        // Prepare files for submission
        window.prepareFileSubmission = function() {
            if (!fileInputsContainer) return;
            fileInputsContainer.innerHTML = '';

            for (var i = 0; i < selectedFiles.length; i++) {
                var dt = new DataTransfer();
                dt.items.add(selectedFiles[i]);

                var input = document.createElement('input');
                input.type = 'file';
                input.name = 'supportingDocuments[]';
                input.files = dt.files;
                input.style.display = 'none';
                fileInputsContainer.appendChild(input);
            }
        };
    }

    /* ── Prevent double submit + loading state ── */
    var form = document.getElementById('mentorAppFormCard')?.closest('form');
    if (form) {
        form.addEventListener('submit', function(e) {
            var btn = document.getElementById('mafSubmitBtn');
            if (!btn) return;
            if (btn.dataset.submitting === '1') { e.preventDefault(); return; }

            /* Front-end validation gate */
            var hasError = false;

            // Validate files are selected
            if (selectedFiles.length === 0) {
                hasError = true;
                var errEl = document.getElementById('err_supportingDocuments');
                if (errEl) errEl.textContent = 'Please select at least one supporting document.';
            }

            var et = document.getElementById('mentor_availabilityEnd');
            var st = document.getElementById('mentor_availabilityStart');
            if (st && et && st.value && et.value && et.value <= st.value) {
                hasError = true;
                et.classList.add('mentor-input-error');
                var ee = document.getElementById('err_availabilityEnd');
                if (ee) ee.textContent = 'End time must be after start time';
            }
            if (hasError) { e.preventDefault(); return; }

            // Prepare file inputs for submission
            if (typeof prepareFileSubmission === 'function') {
                prepareFileSubmission();
            }

            mergeAvailability();
            btn.dataset.submitting = '1';
            btn.disabled = true;
            btn.querySelector('.mentor-submit-label').style.display = 'none';
            btn.querySelector('.mentor-submit-spinner').style.display = '';
        });
    }
})();
</script>

<style>
/* ── Modern Mentor Application Form Styles ── */
.mentor-app-card {
    background: #ffffff;
    border-radius: 12px;
    padding: 0;
    max-width: 100%;
}

/* Section Styling */
.mentor-app-section {
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e5e7eb;
}

.mentor-app-section:last-of-type {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
}

/* Section Header */
.mentor-section-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 20px;
}

.mentor-section-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: #f3f4f6;
    border-radius: 10px;
    color: #6b7280;
    flex-shrink: 0;
}

.mentor-section-icon-wrap.mentor-icon-accent {
    background: #0d9b00;
    color: #ffffff;
}

.mentor-section-title-wrap {
    flex: 1;
}

.mentor-section-title {
    font-size: 16px;
    font-weight: 600;
    color: #111827;
    margin: 0 0 4px 0;
    line-height: 1.4;
}

.mentor-section-desc {
    font-size: 13px;
    color: #6b7280;
    margin: 0;
    line-height: 1.5;
}

/* Form Row Layout */
.mentor-form-row {
    display: grid;
    gap: 16px;
    margin-bottom: 16px;
}

.mentor-form-row:last-child {
    margin-bottom: 0;
}

.mentor-cols-3 {
    grid-template-columns: repeat(3, 1fr);
}

.mentor-cols-2 {
    grid-template-columns: repeat(2, 1fr);
}

.mentor-cols-1 {
    grid-template-columns: 1fr;
}

@media (max-width: 768px) {
    .mentor-cols-3,
    .mentor-cols-2 {
        grid-template-columns: 1fr;
    }
}

/* Field Group */
.mentor-field-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

/* Labels */
.mentor-field-label {
    font-size: 13px;
    font-weight: 500;
    color: #374151;
    margin: 0;
}

.mentor-req {
    color: #dc2626;
    font-weight: 600;
}

/* Input Fields */
.mentor-input {
    padding: 12px 16px;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    font-size: 14px;
    color: #111827;
    background: #ffffff;
    transition: all 0.2s ease;
    width: 100%;
    box-sizing: border-box;
    cursor: text;
}

.mentor-input:hover {
    border-color: #0d9b00;
}

.mentor-input:focus {
    outline: none;
    border-color: #0d9b00;
    box-shadow: 0 0 0 4px rgba(13, 155, 0, 0.15);
}

.mentor-input::placeholder {
    color: #9ca3af;
