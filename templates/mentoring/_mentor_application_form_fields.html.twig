<div class="mentor-form-card">
    {# Personal Information Section #}
    <div class="mentor-form-section">
        <h4 class="mentor-form-title">Personal Information</h4>
        <div class="mentor-form-grid-3">
            <div class="form-group">
                <label class="mentor-form-label">First Name <span class="mentor-required">*</span></label>
                <input type="text" name="firstName" id="mentor_firstName" class="form-input mentor-form-input" value="{{ defaultUser.firstName|default('') }}" required>
            </div>
            <div class="form-group">
                <label class="mentor-form-label">Middle Name</label>
                <input type="text" name="middleName" id="mentor_middleName" class="form-input mentor-form-input" value="{{ defaultUser.middleName|default('') }}">
            </div>
            <div class="form-group">
                <label class="mentor-form-label">Last Name <span class="mentor-required">*</span></label>
                <input type="text" name="lastName" id="mentor_lastName" class="form-input mentor-form-input" value="{{ defaultUser.lastName|default('') }}" required>
            </div>
        </div>
        <div class="mentor-form-grid-2">
            <div class="form-group">
                <label class="mentor-form-label">Student Email <span class="mentor-required">*</span></label>
                <input type="email" name="email" id="mentor_email" class="form-input mentor-form-input" value="{{ defaultUser.email|default('') }}" required>
            </div>
            <div class="form-group">
                <label class="mentor-form-label">Contact Number</label>
                <input type="tel" name="contactNumber" id="mentor_contactNumber" class="form-input mentor-form-input" placeholder="e.g. 09123456789">
            </div>
        </div>
    </div>

    {# Professional Background Section #}
    <div class="mentor-form-section">
        <h4 class="mentor-form-title">Professional Background</h4>
        <div class="mentor-form-grid-2">
            <div class="form-group">
                <label class="mentor-form-label">Mentoring Specialization <span class="mentor-required">*</span></label>
                <select name="specialization" id="mentor_specialization" class="form-input mentor-form-input" required>
                    <option value="">Select specialization...</option>
                    <option value="BSITBA">BSITBA (IT Business Analysis)</option>
                    <option value="BSCS">BSCS (Computer Science)</option>
                    <option value="Software Engineering">Software Engineering</option>
                    <option value="Data Science">Data Science</option>
                    <option value="Cybersecurity">Cybersecurity</option>
                    <option value="Cloud Computing">Cloud Computing</option>
                    <option value="Web Development">Web Development</option>
                    <option value="Mobile Development">Mobile Development</option>
                    <option value="UI/UX Design">UI/UX Design</option>
                    <option value="Research">Research</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label class="mentor-form-label">Years of Experience</label>
                <input type="number" name="yearsOfExperience" id="mentor_yearsOfExperience" class="form-input mentor-form-input" min="0" max="50" placeholder="Optional">
            </div>
        </div>
        <div class="mentor-form-grid-2">
            <div class="form-group">
                <label class="mentor-form-label">Current Profession</label>
                <input type="text" name="currentProfession" id="mentor_currentProfession" class="form-input mentor-form-input" placeholder="e.g. Student, Intern, Freelancer">
            </div>
            <div class="form-group">
                <label class="mentor-form-label">Highest Educational Attainment</label>
                <input type="text" name="highestEducation" id="mentor_highestEducation" class="form-input mentor-form-input" placeholder="e.g. BS Computer Science 3rd Year">
            </div>
        </div>
    </div>

    {# Additional Details Section #}
    <div class="mentor-form-section">
        <h4 class="mentor-form-title">Additional Details</h4>
        <div class="form-group mentor-form-group">
            <label class="mentor-form-label">Supporting Description <span class="mentor-required">*</span></label>
            <textarea name="supportingDescription" id="mentor_supportingDescription" class="form-input mentor-form-input" rows="3" placeholder="Share your strengths, experience, and why you want to mentor other students." required></textarea>
        </div>
        <div class="form-group mentor-form-group">
            <label class="mentor-form-label">Availability Time</label>
            <input type="text" name="availabilityTime" id="mentor_availabilityTime" class="form-input mentor-form-input" placeholder="e.g. Weekdays 2-5 PM, Weekends anytime">
        </div>
        <div class="form-group">
            <label class="mentor-form-label">Proof of Expertise <span class="mentor-required">*</span></label>
            <input type="file" name="proofOfExpertise[]" id="mentor_proofOfExpertise" multiple accept=".jpg,.jpeg,.png,.pdf" required class="mentor-form-input" style="padding: 6px; font-size: 11px; margin-bottom: 4px;">
            <span class="mentor-form-hint"><strong>At least one file is required.</strong></span>
            <span class="mentor-form-hint-secondary">Accepted formats: JPG, PNG, PDF. Max 5MB per file. You can select multiple files.</span>
        </div>
    </div>

    <div class="mentor-form-submit">
        <button type="submit" class="mentor-submit-btn">Submit Application</button>
    </div>
</div>
