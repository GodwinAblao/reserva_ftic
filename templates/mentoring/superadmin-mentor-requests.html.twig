/* ── search filter ── */
function saFilterList(){
    var q=document.getElementById('saSearch').value.toLowerCase();
    document.querySelectorAll('.sa-item').forEach(function(el){
        el.style.display=(!q||el.dataset.name.includes(q))?'':'none';
    });
}

/* ── Real-time polling ── */
(function(){
    var POLL_URL = '{{ path("mentoring_superadmin_requests_data") }}';
    var INTERVAL = 15000;
    var _lastTs = 0;
    var _indicator = document.querySelector('.sa-refresh-indicator');

    function statusBadge(status){
        var cls = {pending:'pending',assigned:'assigned',approved:'approved',completed:'completed',cancelled:'cancelled',rejected:'rejected'}[status.toLowerCase()] || 'pending';
        return '<span class="badge '+cls+'">'+status+'</span>';
    }

    function fmtTime(iso){
        var d = new Date(iso.replace(' ','T'));
        return d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    }
    function fmtDate(iso){
        var d = new Date(iso.replace(' ','T'));
        return d.toLocaleDateString([],{month:'short',day:'numeric'});
    }

    /* Update a single detail pane field safely */
    function setField(paneId, selector, html){
        var pane = document.getElementById(paneId);
        if(!pane) return;
        var el = pane.querySelector(selector);
        if(el) el.innerHTML = html;
    }

    /* Patch an existing request detail pane with fresh data */
    function patchRequestPane(r){
        var pid = 'sa-det-custom-'+r.id;
        var pane = document.getElementById(pid);
        if(!pane) return;
        /* update status badge */
        pane.querySelectorAll('.sa-field').forEach(function(f){
            var lbl = f.querySelector('label');
            if(!lbl) return;
            var txt = lbl.textContent.trim();
            var p = f.querySelector('p');
            if(!p) return;
            if(txt === 'Status')              p.innerHTML = statusBadge(r.status);
            if(txt === 'Degree / Course')     p.textContent = r.departmentCourse || '—';
            if(txt === 'Specialization Needed') p.textContent = r.preferredExpertise || '—';
            if(txt === 'Preferred Day')       p.textContent = r.availableDates || '—';
            if(txt === 'Preferred Time')      p.textContent = r.preferredSchedule || r.availableTime || '—';
        });
    }

    /* Patch an existing application detail pane */
    function patchAppPane(a){
        var pane = document.getElementById('sa-det-apply-'+a.id);
        if(!pane) return;
        pane.querySelectorAll('.sa-field').forEach(function(f){
            var lbl = f.querySelector('label');
            if(!lbl) return;
            var p = f.querySelector('p');
            if(!p) return;
            if(lbl.textContent.trim() === 'Status') p.innerHTML = statusBadge(a.status);
        });
    }

    /* Update left-panel item badge/sub */
    function patchListItem(type, id, status, sub){
        var el = document.querySelector('.sa-item[data-type="'+type+'"][data-id="'+id+'"]');
        if(!el) return;
        var subEl = el.querySelector('.sa-item-sub');
        if(subEl && sub) subEl.textContent = sub;
    }

    function doPoll(){
        fetch(POLL_URL, {headers:{'X-Requested-With':'XMLHttpRequest','Cache-Control':'no-cache'}})
        .then(function(r){ return r.ok ? r.json() : null; })
        .then(function(data){
            if(!data) return;
            var isNew = data.ts > _lastTs && _lastTs > 0;
            _lastTs = data.ts;

            /* patch request panes & list items */
            (data.requests||[]).forEach(function(r){
                patchRequestPane(r);
                patchListItem('custom', r.id, r.status, r.preferredExpertise || 'Custom Request');
            });
            /* patch application panes & list items */
            (data.applications||[]).forEach(function(a){
                patchAppPane(a);
                patchListItem('apply', a.id, a.status, a.specialization);
            });

            if(isNew && _indicator){
                _indicator.textContent = 'Updated just now';
                setTimeout(function(){ _indicator.textContent=''; }, 4000);
            }
        })
        .catch(function(){});
    }

    document.addEventListener('DOMContentLoaded', function(){
        _lastTs = Date.now()/1000|0;
        setTimeout(doPoll, 3000);
        setInterval(doPoll, INTERVAL);
    });
})();
/* ── AJAX for assign forms (with post-success lock to prevent double audit logs) ── */
function bindAjaxForms(){
    document.querySelectorAll('form[data-ajax="true"]').forEach(function(form){
        if(form.dataset.ajaxBound === '1') return;
        form.dataset.ajaxBound = '1';
        form.addEventListener('submit',function(e){
            e.preventDefault();
            var btn=form.querySelector('button[type="submit"]');
            var orig=btn?btn.innerHTML:'';
            if(btn){btn.disabled=true;btn.innerHTML='Saving…';}
            fetch(form.action,{method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'},body:new FormData(form)})
            .then(function(r){if(!r.ok)throw new Error();return r.json();})
            .then(function(j){
                if(j.success){
                    /* Lock form permanently so the same action cannot be submitted twice */
                    if(btn){btn.innerHTML='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Saved';btn.style.background='#0D9B00';}
                    form.querySelectorAll('input,select,textarea,button').forEach(function(el){el.disabled=true;});
                    _saToast(j.message||'Updated.',true);
                    /* Immediately refresh audit log */
                    doPollAudit();
                } else {
                    if(btn){btn.disabled=false;btn.innerHTML=orig;}
                    _saToast(j.message||'Error.',false);
                }
            })
            .catch(function(){
                if(btn){btn.disabled=false;btn.innerHTML=orig;}
                _saToast('Could not save. Please try again.',false);
            });
        });
    });
}
document.addEventListener('DOMContentLoaded',function(){
    bindAjaxForms();
    document.addEventListener('keydown',function(e){if(e.key==='Escape') { closeCreateMentor(); closeFilePreviewModal(); closeRejectModal(); }});
});
document.addEventListener('turbo:load', bindAjaxForms);

/* ── Real-time Audit Log Polling ── */
var _auditLastId = 0;
function doPollAudit(){
    fetch('{{ path("mentoring_audit_log_data") }}',{headers:{'X-Requested-With':'XMLHttpRequest','Cache-Control':'no-cache'}})
    .then(function(r){return r.ok?r.json():null;})
    .then(function(data){
        if(!data||!data.logs) return;
        var tbody = document.querySelector('#auditTable tbody');
        if(!tbody) return;

        var actionMeta = {
            'approve':       {label:'Approved',       cls:'audit-action-approve'},
            'reject':        {label:'Rejected',        cls:'audit-action-reject'},
            'update_status': {label:'Status Updated',  cls:'audit-action-update'},
            'create_mentor': {label:'Mentor Created',  cls:'audit-action-create'},
            'assign':        {label:'Assigned',        cls:'audit-action-assign'}
        };
        function statusBadge(s){
            if(!s) return '';
            return '<span class="badge '+s.toLowerCase().replace(/ /g,'-')+' sa-audit-new-status">'+s+'</span>';
        }
        function buildRow(log){
            var meta = actionMeta[log.action]||{label:log.action,cls:'audit-action-default'};
            var typeLabel = log.subjectType==='application'?'Application':'Custom Request';
            var typeCls = log.subjectType==='application'?'type-app':'type-req';
            var search = (log.subjectLabel+' '+meta.label+' '+(log.performedByName||'')+' '+typeLabel).toLowerCase();
            var statusFlow = '';
            if(log.previousStatus||log.newStatus){
                statusFlow = '<span class="sa-audit-status-flow">';
                if(log.previousStatus) statusFlow += '<span class="sa-audit-prev-status">'+log.previousStatus+'</span>';
                if(log.previousStatus&&log.newStatus) statusFlow += '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
                if(log.newStatus) statusFlow += statusBadge(log.newStatus);
                statusFlow += '</span>';
            } else { statusFlow = '<span style="color:#d1d5db;">—</span>'; }
            var noteText = log.note ? (log.note.length>60?log.note.slice(0,60)+'…':log.note) : '—';
            return '<tr class="sa-audit-row" data-search="'+search+'" data-log-id="'+log.id+'">'
                +'<td class="sa-audit-time"><span class="sa-audit-date">'+log.loggedAt+'</span><span class="sa-audit-clock">'+log.loggedAtTime+'</span></td>'
                +'<td><span class="sa-audit-subject">'+log.subjectLabel+'</span>'+(log.subjectId?'<span class="sa-audit-id">#'+log.subjectId+'</span>':'')+'</td>'
                +'<td><span class="sa-audit-type-badge '+typeCls+'">'+typeLabel+'</span></td>'
                +'<td><span class="sa-audit-action-badge '+meta.cls+'">'+meta.label+'</span></td>'
                +'<td>'+statusFlow+'</td>'
                +'<td><div class="sa-audit-actor"><div class="sa-audit-actor-av">'+log.performedByName.slice(0,1).toUpperCase()+'</div><div><div class="sa-audit-actor-name">'+log.performedByName+'</div>'+(log.performedByRole?'<div class="sa-audit-actor-role">'+log.performedByRole+'</div>':'')+'</div></div></td>'
                +'<td class="sa-audit-note">'+noteText+'</td>'
                +'</tr>';
        }

        /* Check if there are new entries */
        var topId = data.logs.length > 0 ? data.logs[0].id : 0;
        var isNew = _auditLastId > 0 && topId > _auditLastId;
        _auditLastId = topId;

        /* Rebuild entire tbody */
        tbody.innerHTML = data.logs.map(buildRow).join('');

        /* Re-apply search filter */
        auditFilter();

        if(isNew){ _saToast('Audit log updated.',true); }
    })
    .catch(function(){});
}
document.addEventListener('DOMContentLoaded',function(){
    _auditLastId = (function(){
        var first = document.querySelector('#auditTable tbody tr[data-log-id]');
        return first ? parseInt(first.dataset.logId)||0 : 0;
    })();
    setTimeout(doPollAudit,5000);
    setInterval(doPollAudit,10000);
});

/* ── File Preview Modal ── */
function openFilePreviewModal(fileUrl, fileName) {
    var modal = document.getElementById('filePreviewModal');
    var img = document.getElementById('filePreviewImage');
    var title = document.getElementById('filePreviewTitle');
    if (!modal || !img) return;
    img.src = fileUrl;
    img.alt = fileName || 'Preview';
    if (title) title.textContent = fileName || 'File Preview';
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
}
function closeFilePreviewModal() {
    var modal = document.getElementById('filePreviewModal');
    var img = document.getElementById('filePreviewImage');
    if (modal) modal.classList.remove('open');
    if (img) img.src = '';
    document.body.style.overflow = '';
}
</script>

