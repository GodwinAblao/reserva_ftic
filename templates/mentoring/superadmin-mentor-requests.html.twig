<script>
/* ── toast ── */
function _saToast(msg,ok){
    var n=document.createElement('div');
    n.style.cssText='position:fixed;top:16px;right:16px;z-index:9999;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;box-shadow:0 4px 12px rgba(0,0,0,.12);transition:opacity .3s;';
    n.style.background=ok?'#d1fae5':'#fee2e2'; n.style.color=ok?'#065f46':'#991b1b';
    n.textContent=msg; document.body.appendChild(n);
    setTimeout(function(){n.style.opacity='0';setTimeout(function(){n.remove();},300);},3200);
}
/* ── Create Mentor modal ── */
function openCreateMentor(){document.getElementById('createMentorModal').classList.add('open');}
function closeCreateMentor(){document.getElementById('createMentorModal').classList.remove('open');}
(function(){
    var m=document.getElementById('createMentorModal');
    if(m&&m.parentNode!==document.body) document.body.appendChild(m);
    closeCreateMentor();
    var r=document.getElementById('rejectModal');
    if(r&&r.parentNode!==document.body) document.body.appendChild(r);
})();
function cmFillUser(sel){
    var o=sel.options[sel.selectedIndex];
    if(!o.value) return;
    document.getElementById('cm_user_id').value=o.value;
    document.getElementById('cm_first').value=o.dataset.first||'';
    document.getElementById('cm_middle').value=o.dataset.middle||'';
    document.getElementById('cm_last').value=o.dataset.last||'';
    document.getElementById('cm_email').value=o.dataset.email||'';
    document.getElementById('cm_program').value=o.dataset.program||'';
    // Pre-select role if it's Student or Faculty
    var roleSelect = document.getElementById('cm_role_select');
    var userRole = o.dataset.role || '';
    if(userRole.toLowerCase().includes('student')) {
        roleSelect.value = 'Student';
    } else if(userRole.toLowerCase().includes('faculty')) {
        roleSelect.value = 'Faculty';
    } else {
        roleSelect.value = '';
    }
}
function cmFilterUsers(query){
    var select = document.getElementById('cm_user_select');
    var options = select.querySelectorAll('option');
    var lowerQuery = query.toLowerCase();
    var hasMatch = false;
    options.forEach(function(opt){
        if(!opt.value) return; // Skip placeholder
        var text = opt.textContent.toLowerCase();
        var email = opt.dataset.email ? opt.dataset.email.toLowerCase() : '';
        var first = opt.dataset.first ? opt.dataset.first.toLowerCase() : '';
        var last = opt.dataset.last ? opt.dataset.last.toLowerCase() : '';
        if(text.includes(lowerQuery) || email.includes(lowerQuery) || first.includes(lowerQuery) || last.includes(lowerQuery)){
            opt.style.display = '';
            hasMatch = true;
        } else {
            opt.style.display = 'none';
        }
    });
    // Auto-expand dropdown if searching
    if(query.length > 0) {
        select.size = Math.min(10, options.length);
    } else {
        select.size = 5;
    }
}
/* ── type dropdown toggle ── */
function saOnTypeChange(){
    var v=document.getElementById('saTypeSelect').value;
    document.getElementById('sa-list-all').style.display   = v==='all'    ? '' : 'none';
    document.getElementById('sa-list-custom').style.display = v==='custom' ? '' : 'none';
    document.getElementById('sa-list-apply').style.display  = v==='apply'  ? '' : 'none';
    saClearCenter();
}
/* init on load */
document.addEventListener('DOMContentLoaded', function(){ saOnTypeChange(); });
/* ── item selection ── */
function saClearCenter(){
    document.getElementById('saCenterEmpty').style.display='';
    document.querySelectorAll('.sa-det').forEach(function(el){el.style.display='none';});
    document.querySelectorAll('.sa-item').forEach(function(el){el.classList.remove('active');});
}
function saSelectItem(el,type,id){
    saClearCenter();
    var pane=document.getElementById('sa-det-'+type+'-'+id);
    if(pane){pane.style.display='';document.getElementById('saCenterEmpty').style.display='none';}
    if(el) el.classList.add('active');
}
/* ── mentor input toggle ── */
function rqToggle(id){
    var sel=document.getElementById('rq-sel-'+id);
    var txt=document.getElementById('rq-txt-'+id);
    var lbl=document.getElementById('rq-tlbl-'+id);
    if(!sel||!txt||!lbl) return;
    var manual=txt.style.display!=='none';
    if(manual){txt.style.display='none';txt.removeAttribute('required');sel.style.display='';lbl.textContent='Type manually';}
    else{sel.style.display='none';sel.value='';txt.style.display='';lbl.textContent='Pick from system';}
}
function saToggleMethod(sel, linkId, locId){
    var link=document.getElementById(linkId);
    var loc=document.getElementById(locId);
    if(link){ link.style.display=sel.value==='Online'?'block':'none'; if(sel.value!=='Online') link.value=''; }
    if(loc){  loc.style.display=sel.value==='In Person'?'block':'none'; if(sel.value!=='In Person') loc.value=''; }
}
function saToggleOther(sel, otherId){
    var other=document.getElementById(otherId);
    if(!other) return;
    var isOther=sel.value==='Other';
    other.style.display=isOther?'block':'none';
    if(!isOther) other.value='';
    if(isOther) other.focus();
}
function rqFill(id){
    var sel=document.getElementById('rq-sel-'+id);
    var spec=document.getElementById('rq-spec-'+id);
    var specOther=document.getElementById('rq-spec-other-'+id);
    if(!sel||!spec) return;
    var o=sel.options[sel.selectedIndex];
    if(!o||!o.value||!o.dataset.spec) return;
    var specVal=o.dataset.spec;
    var matched=false;
    for(var i=0;i<spec.options.length;i++){
        if(spec.options[i].value===specVal){spec.selectedIndex=i;matched=true;break;}
    }
    if(!matched&&specVal){
        for(var j=0;j<spec.options.length;j++){
            if(spec.options[j].value==='Other'){spec.selectedIndex=j;break;}
        }
        if(specOther){specOther.style.display='block';specOther.value=specVal;}
    } else if(specOther){
        specOther.style.display='none';specOther.value='';
    }
}
/* Merge expertise_other into expertise on submit */
document.querySelectorAll('form[data-ajax]').forEach(function(form){
    form.addEventListener('submit',function(){
        var specSel=form.querySelector('select.sa-expertise-select');
        var specOther=form.querySelector('input[name="expertise_other"]');
        if(specSel&&specOther&&specSel.value==='Other'&&specOther.value.trim()){
            // Dynamically add the custom value as an option and select it
            var opt=document.createElement('option');
            opt.value=specOther.value.trim();
            opt.textContent=opt.value;
            specSel.appendChild(opt);
            specSel.value=opt.value;
        }
    });
});
/* ── decline application ── */
function saDeclineApp(id){
