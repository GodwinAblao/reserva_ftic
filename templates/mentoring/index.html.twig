{% extends 'layouts/app.html.twig' %}

{% block title %}Mentoring | Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/user_reservations.css') }}">
{% endblock %}

{% block content %}
<div class="mentoring-page-layout">
    <!-- Main Content Column -->
    <div class="mentoring-main-column">

        <!-- Mentors Section -->
        <div class="mentoring-section" id="mentors-section">
            <!-- Search and Filter Section -->
            <div class="mentor-search-filters">
                <form method="get" action="{{ path('mentoring_index') }}" class="search-form" id="mentorSearchForm">
                    <div class="search-input-group">
                        <input
                            type="text"
                            id="mentorSearchInput"
                            name="search"
                            class="search-input"
                            placeholder="Search Mentor Name"
                            value="{{ app.request.query.get('search', '') }}"
                            autocomplete="off"
                        >
                    </div>

                    <div class="filter-group">
                        <select id="specializationFilter" name="specialization" class="filter-dropdown">
                            <option value="">All Specialization</option>
                            {% for spec in allSpecializations %}
                                <option value="{{ spec.specialization }}" {% if app.request.query.get('specialization') == spec.specialization %}selected{% endif %}>
                                    {{ spec.specialization }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </form>
            </div>

            <!-- Mentor Cards - Always Visible Above Filter Tabs -->
            <div class="mentor-card-grid" id="mentorCardGrid">
                {% include 'mentoring/_mentor_cards.html.twig' with { mentors: mentors, mentorApplicationMeta: mentorApplicationMeta|default({}) } only %}
            </div>

            <!-- Filter Tabs -->
            <div class="filter-tabs-container">
                <button class="filter-tab active" onclick="switchMentoringTab('custom-requests', this); return false;">
                    <span class="tab-text">My Custom Request</span>
                </button>
                <button class="filter-tab pending-tab" onclick="switchMentoringTab('applications', this); return false;">
                    <span class="tab-text">My Pending Submission</span>
                </button>
                <button class="filter-tab" onclick="switchMentoringTab('mentor-application', this); return false;">
                    <span class="tab-text">My Mentor Application</span>
                </button>
                <button class="filter-tab cancelled-tab" onclick="switchMentoringTab('incoming', this); return false;">
                    <span class="tab-text">Incoming Custom Request</span>
                </button>
            </div>

            <!-- Content Section -->
            <div class="mentoring-content-section">

                <!-- Custom Requests Cards -->
                <div class="mentoring-content" id="custom-requests-content">
                    <div class="reservations-grid">
                        {% if sentCustomRequests|length > 0 %}
                            {% for request in sentCustomRequests %}
                                <div class="reservation-card-new" data-req-id="{{ request.id }}">
                                    <div class="card-title">
                                        {% if request.mentorProfile %}
                                            {{ request.mentorProfile.displayName }}
                                        {% elseif request.assignedMentorName %}
                                            {{ request.assignedMentorName }}
                                        {% else %}
                                            Mentor Assistance Request
                                        {% endif %}
                                    </div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value status-{{ request.status|lower }}">{{ request.status|capitalize }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ request.createdAt|date('M d, Y') }}</span>
                                        </div>
                                        {% if request.preferredExpertise %}
                                        <div class="info-item">
                                            <span class="info-label">Specialization Needed</span>
                                            <span class="info-value">{{ request.preferredExpertise }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.departmentCourse %}
                                        <div class="info-item">
                                            <span class="info-label">Degree / Course</span>
                                            <span class="info-value">{{ request.departmentCourse }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.availableDates %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Day</span>
                                            <span class="info-value">{{ request.availableDates }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.preferredSchedule %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Time</span>
                                            <span class="info-value">{{ request.preferredSchedule }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-info-footer">
                                        {% if request.message and request.message != 'No additional notes provided.' %}
                                        <div class="info-item wide">
                                            <span class="info-label">Message</span>
                                            <span class="info-value">{{ request.message|slice(0, 160) ~ (request.message|length > 160 ? '...' : '') }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.assignedMentorName %}
                                        <div class="info-item wide" style="margin-top:8px;padding-top:8px;border-top:1px solid #e5e7eb;">
                                            <span class="info-label">Assigned Mentor</span>
                                            <span class="info-value status-approved"><strong>{{ request.assignedMentorName }}</strong>{% if request.assignedMentorExpertise %} — {{ request.assignedMentorExpertise }}{% endif %}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.availableTime %}
                                        <div class="info-item wide">
                                            <span class="info-label">Confirmed Time</span>
                                            <span class="info-value">{{ request.availableDates ? request.availableDates ~ ' · ' : '' }}{{ request.availableTime }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod %}
                                        <div class="info-item">
                                            <span class="info-label">Meeting Method</span>
                                            <span class="info-value">{{ request.meetingMethod }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.adminInstructions %}
                                        <div class="info-item wide">
                                            <span class="info-label">Admin Instructions</span>
                                            <span class="info-value">{{ request.adminInstructions }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% if request.status not in ['Cancelled', 'Completed'] %}
                                    <div class="card-actions" style="margin-top:12px;padding-top:12px;border-top:1px solid #e5e7eb;">
                                        <form method="post" action="{{ path('mentoring_assistance_update', {'id': request.id}) }}" onsubmit="return confirm('Cancel this mentor request? This cannot be undone.');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('mentor_assistance_update_' ~ request.id) }}">
                                            <input type="hidden" name="action" value="cancel">
                                            <button type="submit" style="background:#dc2626;color:white;border:none;padding:7px 16px;border-radius:6px;cursor:pointer;font-size:12.5px;font-weight:600;">
                                                Cancel Request
                                            </button>
                                        </form>
                                    </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="empty-mini-state">
                                <p>You have not sent a custom request yet.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Applications Cards -->
                <div class="mentoring-content hidden" id="applications-content">
                    <div class="reservations-grid">
                        {% set pendingApplications = applications|filter(application => application.status in ['Pending', 'Pending Review']) %}
                        {% if pendingApplications|length > 0 %}
                            {% for application in pendingApplications %}
                                <div class="reservation-card-new">
                                    <div class="card-title">{{ application.specialization }}</div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value status-pending">{{ application.status }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ application.createdAt|date('M d, Y') }}</span>
                                        </div>
                                        {% if application.currentProfession %}
                                        <div class="info-item">
                                            <span class="info-label">Profession</span>
                                            <span class="info-value">{{ application.currentProfession }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-actions" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e7eb;">
                                        <form method="post" action="{{ path('mentoring_cancel_application', {'id': application.id}) }}" onsubmit="return confirm('Are you sure you want to cancel this application? This action cannot be undone.');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cancel_application_' ~ application.id) }}">
                                            <button type="submit" class="btn btn-danger btn-sm" style="background: #dc2626; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px;">
                                            Cancel Application
                                        </button>
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}

                        {% for application in applications %}
                            {% if application.status not in ['Pending', 'Pending Review'] %}
                                <div class="reservation-card-new">
                                    <div class="card-title">{{ application.specialization }}</div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value status-{{ application.status|lower|replace({' ': '-'}) }}">{{ application.status }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ application.createdAt|date('M d, Y') }}</span>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% else %}
                            {% if pendingApplications|length == 0 %}
                                <div class="empty-mini-state">
                                    <p>You have not submitted a mentor application yet.</p>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Mentor Application Cards -->
                <div class="mentoring-content hidden" id="mentor-application-content">
                    <div class="reservations-grid">
                        {% if is_granted('ROLE_MENTOR') %}
                            {% if mentorProfile %}
                                <div class="reservation-card-new">
                                    <div class="card-title">My Mentor Profile</div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item wide">
                                            <span class="info-label">Display Name</span>
                                            <span class="info-value">{{ mentorProfile.displayName }}</span>
                                        </div>
                                        <div class="info-item wide">
                                            <span class="info-label">Bio</span>
                                            <span class="info-value">{{ mentorProfile.bio }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Specialization</span>
                                            <span class="info-value">{{ mentorProfile.specialization }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Engagement Points</span>
                                            <span class="info-value">{{ mentorProfile.engagementPoints }}</span>
                                        </div>
                                    </div>
                                    <div class="card-actions card-actions-mt">
                                        <a href="{{ path('app_profile') }}" class="btn btn-primary">Edit Profile</a>
                                    </div>
                                </div>
                            {% else %}
                                <div class="empty-mini-state">
                                    <p>You are a mentor but your profile is not fully set up yet.</p>
                                    <a href="{{ path('app_profile') }}" class="btn btn-primary btn-mt">Complete Profile</a>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="empty-mini-state">
                                <p>You are not a mentor yet. Apply to become a mentor and share your expertise with others.</p>
                                {% if canApplyAsMentor %}
                                    <button type="button" class="btn btn-primary btn-mt mentoring-apply-btn" onclick="openMentorApplication()">Apply as Mentor</button>
                                {% elseif applications|length > 0 %}
                                    <p class="text-yellow-mt"><strong>Your application is pending review.</strong></p>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Incoming Requests Cards -->
                <div class="mentoring-content hidden" id="incoming-content">
                    <div class="reservations-grid">
                        {% if is_granted('ROLE_MENTOR') %}
                            {% if incomingCustomRequests|length > 0 %}
                                {% for request in incomingCustomRequests %}
                                    <div class="mentoring-card-new">
                                        <div class="card-title">{{ request.student.firstName ?: request.student.email }}</div>
                                        <div class="card-divider"></div>
                                        <div class="card-info-grid">
                                            <div class="info-item">
                                                <span class="info-label">Status</span>
                                                <span class="info-value status-{{ request.status|lower }}">{{ request.status|capitalize }}</span>
                                            </div>
                                            <div class="info-item">
                                                <span class="info-label">Submitted</span>
                                                <span class="info-value">{{ request.createdAt|date('M d, Y') }}</span>
                                            </div>
                                            <div class="info-item wide">
                                                <span class="info-label">Student Email</span>
                                                <span class="info-value">{{ request.student.email }}</span>
                                            </div>
                                        </div>
                                        <div class="card-info-footer">
                                            <div class="info-item wide">
                                                <span class="info-label">Message</span>
                                                <span class="info-value">{{ request.message }}</span>
                                            </div>
                                        </div>
                                        {% if request.status == 'Pending' %}
                                        <div class="card-actions">
                                            <form method="post" action="{{ path('mentoring_custom_request_review', {'id': request.id}) }}" data-no-loading="true">
                                                <input type="hidden" name="_token" value="{{ csrf_token('custom_request_review_' ~ request.id) }}">
                                                <textarea name="mentor_response" class="form-input" rows="2" placeholder="Optional response..."></textarea>
                                                <div class="button-group button-group-mt">
                                                    <button type="submit" name="decision" value="accept" class="btn btn-primary-small">Accept</button>
                                                    <button type="submit" name="decision" value="decline" class="btn btn-danger-small">Decline</button>
                                                </div>
                                            </form>
                                        </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="empty-mini-state">
                                    <p>No incoming custom requests yet.</p>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="empty-mini-state">
                                <p>Only mentors can view incoming requests. Apply to become a mentor to receive mentoring requests.</p>
                                {% if canApplyAsMentor %}
                                    <button type="button" class="btn btn-primary btn-mt mentoring-apply-btn" onclick="openMentorApplication()">Apply as Mentor</button>
                                {% elseif applications|length > 0 %}
                                    <p class="text-yellow-mt"><strong>Your application is pending review.</strong></p>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>

            </div><!-- End Content Section -->
        </div><!-- End Mentors Section -->

    </div><!-- End Main Column -->

    <!-- Right Side Column - Summary -->
    <aside class="mentoring-side-column">

        <!-- Quick Actions -->
        <section class="mentoring-side-card">
            <div class="quick-actions-flex">
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('mentoring_super-admin') }}" class="btn-primary btn-full-width">Manage</a>
                {% endif %}
            </div>
        </section>

        <!-- Recent Request Summary (now contains Request button) -->
        <section class="reservations-side-card reservations-info-card">
            <div style="margin-bottom:12px;">
                <a href="#" onclick="openMentorAssistance(); return false;" class="reserve-btn-large">
                    <span class="reserve-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                        </svg>
                    </span>
                    <span class="reserve-text">Request a Mentor</span>
                </a>
            </div>
            <div class="reservations-side-card-head">
                <h3>Recent Request</h3>
            </div>
            {% set recentRequest = sentCustomRequests|first %}
            {% if recentRequest %}
                <p>
                    <strong>
                        {% if recentRequest.preferredExpertise %}{{ recentRequest.preferredExpertise }}{% elseif recentRequest.mentorProfile %}{{ recentRequest.mentorProfile.displayName }}{% else %}Mentor Request{% endif %}
                    </strong> —
                    <span class="info-value status-{{ recentRequest.status|lower }}">{{ recentRequest.status|capitalize }}</span>
                    on {{ recentRequest.createdAt|date('M d, Y') }}.
                </p>
                {% if recentRequest.availableDates %}
                <p style="font-size:12px;color:#6b7280;margin:4px 0 0;">{{ recentRequest.availableDates }}{% if recentRequest.preferredSchedule %} · {{ recentRequest.preferredSchedule }}{% endif %}</p>
                {% endif %}
                {% if recentRequest.assignedMentorName %}
                <p style="font-size:12px;color:#0D9B00;margin:4px 0 0;font-weight:600;">Assigned: {{ recentRequest.assignedMentorName }}</p>
                {% endif %}
            {% else %}
                <p>You have no mentoring requests yet. Submit a request to get started!</p>
            {% endif %}
        </section>

        <!-- Top Mentors -->
        <section class="reservations-side-card reservations-info-card">
            <div class="reservations-side-card-head">
                <h3>Traceability Leaderboard</h3>
            </div>
            <div class="mentor-list">
                {% for mentor in leaderboard|slice(0, 3) %}
                    <div class="mentor-item">
                        <div class="mentor-rank-icon">{{ loop.index == 1 ? '♕' : '♙' }}</div>
                        <div class="mentor-avatar">
                            <span>{{ mentor.displayName|first|upper }}</span>
                        </div>
                        <div class="mentor-info">
                            <div class="mentor-name">{{ mentor.displayName }}</div>
                            <div class="mentor-program">Computer Science</div>
                        </div>
                        <div class="mentor-points">
                            <span>Pts:</span> <strong>{{ mentor.engagementPoints }}</strong>
                        </div>
                    </div>
                {% else %}
                    <p>No mentors available yet.</p>
                {% endfor %}
            </div>
        </section>

        <!-- Preferred Specializations -->
        <section class="mentoring-side-card mentoring-info-card" id="preferredSpecializationsPanel">
            {% include 'mentoring/_preferred_specializations.html.twig' with { specializations: specializations } only %}
        </section>
    </aside>
</div><!-- End Layout -->

    {% if canApplyAsMentor %}
        <div id="mentorApplicationModal" class="app-modal" aria-hidden="true">
            <div class="app-modal-backdrop" onclick="closeMentorApplication()"></div>
            <div class="app-modal-panel app-modal-large mentor-modal-panel" role="dialog" aria-modal="true" aria-labelledby="mentorApplicationTitle">
                <div class="app-modal-header mentor-modal-header">
                    <div>
                        <h3 id="mentorApplicationTitle" class="mentor-modal-title">Apply as Mentor</h3>
                        <p class="mentor-modal-subtitle">Your application will be reviewed by the Super Admin.</p>
                    </div>
                    <button type="button" class="icon-button mentor-modal-close" onclick="closeMentorApplication()" aria-label="Close">x</button>
                </div>

                <div class="mentor-application-layout mentor-application-layout-custom">
                    <aside class="mentor-application-summary mentor-application-summary-custom">
                        <div class="mentor-application-summary__eyebrow mentor-application-eyebrow">Mentor application</div>
                        <h4 class="mentor-application-heading">Share your strengths with the team</h4>
                        <p class="mentor-application-desc">Your application is reviewed by the Super Admin. Keep it clear, specific, and professional.</p>

                        <div class="mentor-application-points mentor-application-points-custom">
                            <div>
                                <strong class="mentor-point-title">Complete profile</strong>
                                <span class="mentor-point-desc">We use these details to review your background.</span>
                            </div>
                            <div>
                                <strong class="mentor-point-title">Professional proof</strong>
                                <span class="mentor-point-desc">Attach certificates, IDs, or samples if available.</span>
                            </div>
                            <div>
                                <strong class="mentor-point-title">Fast review</strong>
                                <span class="mentor-point-desc">Applications are kept organized for quick checking.</span>
                            </div>
                        </div>
                    </aside>

                    <form method="post" action="{{ path('mentoring_apply') }}" class="mentor-form" enctype="multipart/form-data">
                        <input type="hidden" name="_token" value="{{ csrf_token('mentor_application') }}">
                        {% include 'mentoring/_mentor_application_form_fields.html.twig' with { defaultUser: app.user } only %}
                        <div class="app-modal-actions mentor-modal-actions">
                            <button type="button" class="btn-secondary mentor-modal-cancel" onclick="closeMentorApplication()">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% endif %}

    <div id="mentorAssistanceModal" class="app-modal" aria-hidden="true">
        <div class="app-modal-backdrop" onclick="closeMentorAssistance()"></div>
        <div class="app-modal-panel app-modal-large" role="dialog" aria-modal="true" aria-labelledby="mentorAssistanceTitle">
            <div class="app-modal-header">
                <div>
                    <h3 id="mentorAssistanceTitle">Request a Mentor</h3>
                    <p>Tell Admin what kind of mentor support you need.</p>
                </div>
                <button type="button" class="icon-button" onclick="closeMentorAssistance()" aria-label="Close">x</button>
            </div>

            <form method="post" action="{{ path('mentoring_assistance_request') }}" class="mentor-form mentor-assistance-form" data-loading-label="Submitting...">
                <input type="hidden" name="_token" value="{{ csrf_token('mentor_assistance_request') }}">
                <div class="form-section">
                    <h4>Request Details</h4>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label for="assistance_full_name">Full Name</label>
                            <input id="assistance_full_name" class="form-input" name="full_name" value="{{ (app.user.firstName ~ ' ' ~ app.user.lastName)|trim }}" required>
                        </div>
                        <div class="form-group">
                            <label for="assistance_department">Your Degree / Course</label>
                            <input id="assistance_department" class="form-input" name="department_course" value="{{ app.user.degreeName ?: app.user.degree }}" required>
                        </div>
                        <div class="form-group">
                            <label for="assistance_expertise">Mentor Specialization Needed</label>
                            <select id="assistance_expertise" class="form-input" name="preferred_expertise" required>
                                <option value="">Select specialization...</option>
                                <option value="BSITBA">BSITBA (IT Business Analysis)</option>
                                <option value="BSCS">BSCS (Computer Science)</option>
                                <option value="Software Engineering">Software Engineering</option>
                                <option value="Data Science">Data Science</option>
                                <option value="Cybersecurity">Cybersecurity</option>
                                <option value="Cloud Computing">Cloud Computing</option>
                                <option value="Web Development">Web Development</option>
                                <option value="Mobile Development">Mobile Development</option>
                                <option value="UI/UX Design">UI/UX Design</option>
                                <option value="Research">Research</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label for="assistance_available_dates">Preferred Day(s) <span style="color:#c00">*</span></label>
                            <select id="assistance_available_dates" class="form-input" name="available_dates" required>
                                <option value="">Select day(s)...</option>
                                <option value="Monday">Monday</option>
                                <option value="Tuesday">Tuesday</option>
                                <option value="Wednesday">Wednesday</option>
                                <option value="Thursday">Thursday</option>
                                <option value="Friday">Friday</option>
                                <option value="Saturday">Saturday</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="assistance_schedule_start">Preferred Time — Start <span style="color:#c00">*</span></label>
                            <input type="time" id="assistance_schedule_start" class="form-input" name="preferred_schedule_start" min="07:00" max="19:00" required>
                            <span id="assistance_schedule_start_warn" style="display:none;font-size:11.5px;color:#dc2626;margin-top:4px;">⚠ Only 7:00 AM – 7:00 PM is allowed.</span>
                        </div>
                    </div>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label for="assistance_schedule_end">End Time <span style="color:#c00">*</span></label>
                            <input type="time" id="assistance_schedule_end" class="form-input" name="preferred_schedule_end" min="07:00" max="19:00" required>
                            <span id="assistance_schedule_end_warn" style="display:none;font-size:11.5px;color:#dc2626;margin-top:4px;">⚠ Only 7:00 AM – 7:00 PM is allowed.</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="assistance_message">Additional Notes or Message</label>
                        <textarea id="assistance_message" class="form-input" name="message" rows="4" placeholder="Share goals, constraints, or what you have already tried."></textarea>
                    </div>
                </div>
                <div class="app-modal-actions">
                    <button type="button" class="btn-secondary" onclick="closeMentorAssistance()">Cancel</button>
                    <button class="btn-primary js-loading-submit" type="submit">Submit Request</button>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // ===== ASSISTANCE SCHEDULE END-TIME GUARD =====
        (function () {
            function clampTime(el, warnId) {
                const warn = document.getElementById(warnId);
                if (!el.value) { if (warn) warn.style.display = 'none'; return; }
                if (el.value < '07:00' || el.value > '19:00') {
                    if (warn) warn.style.display = 'block';
                    if (el.value < '07:00') el.value = '07:00';
                    if (el.value > '19:00') el.value = '19:00';
                    setTimeout(function(){ if (warn) warn.style.display = 'none'; }, 3500);
                } else {
                    if (warn) warn.style.display = 'none';
                }
            }
            function init() {
                const startEl = document.getElementById('assistance_schedule_start');
                const endEl   = document.getElementById('assistance_schedule_end');
                if (!startEl || !endEl) return;
                startEl.addEventListener('change', function () {
                    clampTime(startEl, 'assistance_schedule_start_warn');
                    if (endEl.value && endEl.value <= startEl.value) {
                        endEl.value = '';
                    }
                    endEl.min = startEl.value || '07:00';
                });
                endEl.addEventListener('change', function () {
                    clampTime(endEl, 'assistance_schedule_end_warn');
                });
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
            document.addEventListener('turbo:load', init);
        })();


        // ===== TAB SWITCHING - Global function for inline onclick =====
        function switchMentoringTab(filter, clickedTab) {
            // Update active tab styling
            const tabsContainer = document.querySelector('.filter-tabs-container');
            if (tabsContainer) {
                const allTabs = tabsContainer.querySelectorAll('.filter-tab');
                allTabs.forEach(function(tab) { tab.classList.remove('active'); });
            }
            clickedTab.classList.add('active');

            // Show/hide content sections
            const contents = document.querySelectorAll('.mentoring-content');
            contents.forEach(function(content) {
                if (content.id === filter + '-content') {
                    content.classList.remove('hidden');
                    content.style.display = 'block';
                } else {
                    content.classList.add('hidden');
                    content.style.display = 'none';
                }
            });
        }

        function syncMentoringTabState() {
            const activeTab = document.querySelector('.filter-tab.active');
            if (activeTab) {
                const filter = activeTab.getAttribute('onclick').match(/'([^']+)'/)[1];
                const contents = document.querySelectorAll('.mentoring-content');
                contents.forEach(function(content) {
                    if (content.id === filter + '-content') {
                        content.classList.remove('hidden');
                        content.style.display = 'block';
                    } else {
                        content.classList.add('hidden');
                        content.style.display = 'none';
                    }
                });
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', syncMentoringTabState, { once: true });
        } else {
            syncMentoringTabState();
        }
        document.addEventListener('turbo:load', syncMentoringTabState);

        // ===== REAL-TIME SEARCH =====
        function initMentoringSearch() {
            const mentorSearchForm = document.getElementById('mentorSearchForm');
            if (!mentorSearchForm || mentorSearchForm.dataset.mentoringSearchBound === '1') {
                return;
            }

            mentorSearchForm.dataset.mentoringSearchBound = '1';

            let searchTimeout;
            const DEBOUNCE_DELAY = 300;
            const searchInput = document.getElementById('mentorSearchInput');
            const specializationFilter = document.getElementById('specializationFilter');
            const mentorCardGrid = document.getElementById('mentorCardGrid');

            function performSearch() {
                const searchTerm = searchInput?.value || '';
                const specialization = specializationFilter?.value || '';

                // Show loading state
                if (mentorCardGrid) {
                    mentorCardGrid.style.opacity = '0.6';
                }

                // Make AJAX request
                fetch('{{ path("mentoring_index") }}?search=' + encodeURIComponent(searchTerm) + '&specialization=' + encodeURIComponent(specialization), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                })
                .then(response => {
                    if (!response.ok) throw new Error('Search failed');
                    return response.json();
                })
                .then(data => {
                    if (mentorCardGrid) {
                        mentorCardGrid.innerHTML = data.html;
                        mentorCardGrid.style.opacity = '1';
                        
                        // Add animation to new cards
                        const cards = mentorCardGrid.querySelectorAll('.mentor-card-link');
                        cards.forEach((card, index) => {
                            card.style.opacity = '0';
                            card.style.animation = `fadeInUp 0.4s ease-out ${index * 0.05}s forwards`;
                        });
                    }

                    if (data.specializationsHtml) {
                        const specializationsPanel = document.getElementById('preferredSpecializationsPanel');
                        if (specializationsPanel) {
                            specializationsPanel.innerHTML = data.specializationsHtml;
                        }
                    }
                })
                .catch(error => {
                    console.error('Search error:', error);
                    if (mentorCardGrid) {
                        mentorCardGrid.style.opacity = '1';
                    }
                });
            }

            // Add event listeners
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(performSearch, DEBOUNCE_DELAY);
                });
            }

            if (specializationFilter) {
                specializationFilter.addEventListener('change', performSearch);
            }

            function bindSpecializationLinks() {
                const specializationLinks = document.querySelectorAll('.specialization-link');
                specializationLinks.forEach(link => {
                    link.addEventListener('click', function(event) {
                        event.preventDefault();
                        const specialization = this.closest('.specialization-row')?.dataset.specialization || '';
                        if (specializationFilter) {
                            specializationFilter.value = specialization;
                        }
                        performSearch();
                    });
                });
            }

            bindSpecializationLinks();

            mentorSearchForm.addEventListener('submit', function(event) {
                event.preventDefault();
                performSearch();
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initMentoringSearch, { once: true });
        } else {
            initMentoringSearch();
        }
        document.addEventListener('turbo:load', initMentoringSearch);

        function openMentorApplication() {
            const modal = document.getElementById('mentorApplicationModal');
            if (!modal) {
                return;
            }

            if (modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMentorApplication() {
            const modal = document.getElementById('mentorApplicationModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        function openMentorAssistance() {
            const modal = document.getElementById('mentorAssistanceModal');
            if (!modal) {
                return;
            }

            if (modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMentorAssistance() {
            const modal = document.getElementById('mentorAssistanceModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        if (!window.__mentoringGlobalListenersBound) {
            window.__mentoringGlobalListenersBound = true;

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeMentorApplication();
                    closeMentorAssistance();
                }
            });
        }

        // ===== USER REQUEST REAL-TIME POLLING =====
        (function(){
            var POLL_URL = '{{ path("mentoring_my_requests_data") }}';
            var INTERVAL = 20000;
            var _lastStatuses = {};

            function statusClass(s){ return s ? s.toLowerCase() : 'pending'; }

            function renderCard(r){
                var title = r.mentorProfileName || r.assignedMentorName || r.preferredExpertise || 'Mentor Assistance Request';
                var rows = '';
                rows += '<div class="info-item"><span class="info-label">Status</span><span class="info-value status-'+statusClass(r.status)+'">'+r.status+'</span></div>';
                rows += '<div class="info-item"><span class="info-label">Submitted</span><span class="info-value">'+r.createdAt+'</span></div>';
                if(r.preferredExpertise) rows += '<div class="info-item"><span class="info-label">Specialization Needed</span><span class="info-value">'+r.preferredExpertise+'</span></div>';
                if(r.departmentCourse)   rows += '<div class="info-item"><span class="info-label">Degree / Course</span><span class="info-value">'+r.departmentCourse+'</span></div>';
                if(r.availableDates)     rows += '<div class="info-item"><span class="info-label">Preferred Day</span><span class="info-value">'+r.availableDates+'</span></div>';
                if(r.preferredSchedule)  rows += '<div class="info-item"><span class="info-label">Preferred Time</span><span class="info-value">'+r.preferredSchedule+'</span></div>';

                var footer = '';
                if(r.message && r.message !== 'No additional notes provided.'){
                    footer += '<div class="info-item wide"><span class="info-label">Message</span><span class="info-value">'+r.message.slice(0,160)+(r.message.length>160?'…':'')+'</span></div>';
                }
                if(r.assignedMentorName){
                    footer += '<div class="info-item wide" style="margin-top:8px;padding-top:8px;border-top:1px solid #e5e7eb;"><span class="info-label">Assigned Mentor</span><span class="info-value status-approved"><strong>'+r.assignedMentorName+'</strong>'+(r.assignedMentorExpertise?' — '+r.assignedMentorExpertise:'')+'</span></div>';
                }
                if(r.availableTime){
                    footer += '<div class="info-item wide"><span class="info-label">Confirmed Time</span><span class="info-value">'+(r.availableDates?r.availableDates+' · ':'')+r.availableTime+'</span></div>';
                }
                if(r.meetingMethod){
                    footer += '<div class="info-item"><span class="info-label">Meeting Method</span><span class="info-value">'+r.meetingMethod+'</span></div>';
                }
                if(r.adminInstructions){
                    footer += '<div class="info-item wide"><span class="info-label">Admin Instructions</span><span class="info-value">'+r.adminInstructions+'</span></div>';
                }

                return '<div class="reservation-card-new" data-req-id="'+r.id+'">'
                    + '<div class="card-title">'+title+'</div>'
                    + '<div class="card-divider"></div>'
                    + '<div class="card-info-grid">'+rows+'</div>'
                    + (footer ? '<div class="card-info-footer">'+footer+'</div>' : '')
                    + '</div>';
            }

            function doPoll(){
                fetch(POLL_URL, {headers:{'X-Requested-With':'XMLHttpRequest','Cache-Control':'no-cache'}})
                .then(function(r){ return r.ok ? r.json() : null; })
                .then(function(data){
                    if(!data || !data.requests) return;
                    var grid = document.querySelector('#custom-requests-content .reservations-grid');
                    if(!grid) return;

                    var changed = false;
                    data.requests.forEach(function(r){
                        var prev = _lastStatuses[r.id];
                        if(prev !== undefined && prev !== r.status) changed = true;
                        _lastStatuses[r.id] = r.status;
                    });

                    /* Rebuild the grid cards */
                    if(data.requests.length === 0){
                        grid.innerHTML = '<div class="empty-mini-state"><p>You have not sent a custom request yet.</p></div>';
                    } else {
                        grid.innerHTML = data.requests.map(renderCard).join('');
                    }

                    /* Also update the sidebar Recent Request snippet */
                    var sideP = document.querySelector('.reservations-side-card p');
                    if(sideP && data.requests.length > 0){
                        var latest = data.requests[0];
                        var spec = latest.preferredExpertise || latest.mentorProfileName || 'Mentor Request';
                        sideP.innerHTML = '<strong>'+spec+'</strong> — <span class="info-value status-'+statusClass(latest.status)+'">'+latest.status+'</span> on '+latest.createdAt+'.';
                    }

                    if(changed){
                        var n=document.createElement('div');
                        n.style.cssText='position:fixed;top:16px;right:16px;z-index:9999;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;background:#d1fae5;color:#065f46;box-shadow:0 4px 12px rgba(0,0,0,.12);transition:opacity .3s;';
                        n.textContent='Your mentor request was updated!';
                        document.body.appendChild(n);
                        setTimeout(function(){n.style.opacity='0';setTimeout(function(){n.remove();},300);},4000);
                    }
                })
                .catch(function(){});
            }

            function init(){
                /* Seed initial statuses from rendered cards */
                document.querySelectorAll('#custom-requests-content .reservation-card-new[data-req-id]').forEach(function(card){
                    var s = card.querySelector('.info-value[class*="status-"]');
                    if(s) _lastStatuses[card.dataset.reqId] = s.textContent.trim();
                });
                setTimeout(doPoll, 5000);
                setInterval(doPoll, INTERVAL);
            }

            if(document.readyState === 'loading'){
                document.addEventListener('DOMContentLoaded', init, {once:true});
            } else {
                init();
            }
            document.addEventListener('turbo:load', init);
        })();

        document.querySelectorAll('form[data-loading-label]').forEach(form => {
            if (form.dataset.noLoading === 'true') {
                return; // Skip loading state for these forms
            }
            form.addEventListener('submit', () => {
                const button = form.querySelector('.js-loading-submit');
                if (button) {
                    button.disabled = true;
                    button.textContent = form.dataset.loadingLabel || 'Submitting...';
                }
            });
        });

    </script>

    <style>
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Required field styling */
        .required-text {
            display: block;
            color: #dc2626;
            font-weight: 500;
            margin-bottom: 0.25rem;
        }
    </style>
{% endblock %}
