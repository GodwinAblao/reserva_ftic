    {# â”€â”€ Cancel Request Modal â”€â”€ #}
    <div class="cancel-modal-overlay" id="cancelRequestModal">
        <div class="cancel-modal-dialog" style="width: min(520px, 100%);">
            <div class="cancel-modal-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
            </div>
            <h3>Cancel Mentor Request?</h3>
            <p>Are you sure you want to cancel this mentor request? This action cannot be undone.</p>
            
            <div class="cancel-reason-section" style="margin: 20px 0; text-align: left;">
                <label for="cancelReason" style="display: block; margin-bottom: 8px; font-weight: 600; color: #374151; font-size: 14px;">
                    Cancellation Reason <span style="color: #dc2626;">*</span>
                </label>
                <textarea 
                    id="cancelReason" 
                    name="cancellation_reason" 
                    rows="4" 
                    style="width: 100%; padding: 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; resize: vertical; font-family: inherit;"
                    placeholder="Please provide a reason for cancelling this request (minimum 10 characters)..."
                    minlength="10"
                    required
                ></textarea>
                <div id="cancelReasonError" style="color: #dc2626; font-size: 13px; margin-top: 6px; display: none;">
                    Please provide a reason with at least 10 characters.
                </div>
            </div>
            
            <div class="cancel-modal-actions">
                <button type="button" class="cancel-modal-cancel" onclick="closeCancelModal()">No, Keep Request</button>
                <button type="button" class="cancel-modal-confirm" onclick="confirmCancelRequest()">Yes, Cancel Request</button>
            </div>
        </div>
    </div>

    <script>
        // â”€â”€ Mentor Response Modal Functions â”€â”€
        let currentRequestId = null;
        
        function openAcceptModal(requestId, studentName, scheduledDate, scheduledTime, csrfToken) {
            currentRequestId = requestId;
            document.getElementById('acceptStudentName').textContent = studentName || 'the student';
            document.getElementById('acceptForm').action = '{{ path("mentoring_custom_request_review", {"id": "REQUEST_ID"}) }}'.replace('REQUEST_ID', requestId);
            document.getElementById('acceptToken').value = csrfToken;
            
            // Show scheduled date if available
            const summaryDiv = document.getElementById('scheduledSummary');
            if (scheduledDate) {
                const dateObj = new Date(scheduledDate);
                const timeStr = scheduledTime ? ' at ' + scheduledTime : '';
                document.getElementById('scheduledDateText').textContent = dateObj.toLocaleDateString('en-US', { 
                    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
                }) + timeStr;
                summaryDiv.style.display = 'block';
            } else {
                summaryDiv.style.display = 'none';
            }
            
            // Reset form
            document.getElementById('acceptForm').reset();
            document.querySelectorAll('.mentor-dynamic-fields').forEach(el => el.classList.remove('is-visible'));
            
            document.getElementById('acceptModal').classList.add('is-open');
        }
        
        function closeAcceptModal() {
            document.getElementById('acceptModal').classList.remove('is-open');
        }
        
        function openDeclineModal(requestId, csrfToken) {
            currentRequestId = requestId;
            document.getElementById('declineForm').action = '{{ path("mentoring_custom_request_review", {"id": "REQUEST_ID"}) }}'.replace('REQUEST_ID', requestId);
            document.getElementById('declineToken').value = csrfToken;
            document.getElementById('declineForm').reset();
            document.getElementById('declineModal').classList.add('is-open');
        }
        
        function closeDeclineModal() {
            document.getElementById('declineModal').classList.remove('is-open');
        }
        
        function toggleMeetingFields(type) {
            // Hide all dynamic fields first
            document.querySelectorAll('.mentor-dynamic-fields').forEach(el => el.classList.remove('is-visible'));
            
            // Show relevant fields
            if (type === 'online') {
                document.getElementById('onlineFields').classList.add('is-visible');
            } else if (type === 'f2f') {
                document.getElementById('f2fFields').classList.add('is-visible');
            }
        }
        
        function toggleF2fOption(option) {
            // Hide outside location field by default
            document.getElementById('outsideLocationField').style.display = 'none';
            
            // Show outside location field only when outside option is selected
            if (option === 'outside') {
                document.getElementById('outsideLocationField').style.display = 'block';
            }
        }
        
        function validateAcceptForm() {
            const meetingType = document.querySelector('input[name="meeting_type"]:checked');
            if (!meetingType) {
                alert('Please select a meeting type (Online or Face-to-Face).');
                return false;
            }
            
            const type = meetingType.value;
            if (type === 'Online') {
                const link = document.getElementById('meetingLink').value.trim();
                if (!link) {
                    alert('Please provide a meeting link for the online session.');
                    document.getElementById('meetingLink').focus();
                    return false;
                }
            } else if (type === 'Face-to-Face') {
                const f2fOption = document.querySelector('input[name="facility_reserved_by"]:checked');
                if (!f2fOption) {
                    alert('Please select how the meeting location will be handled.');
                    return false;
                }
                
                // If outside location is selected, require location text
                if (f2fOption.value === 'outside') {
                    const outsideLoc = document.getElementById('outsideLocation').value.trim();
                    if (!outsideLoc) {
                        alert('Please specify the outside meeting location.');
                        document.getElementById('outsideLocation').focus();
                        return false;
                    }
                }
            }
            
            return true;
        }
        
        let mentorWillReserveFacility = false;
        
        function submitAccept() {
            if (!validateAcceptForm()) return;
            
            // Check if mentor chose to reserve facility
            const f2fOption = document.querySelector('input[name="facility_reserved_by"]:checked');
            mentorWillReserveFacility = (f2fOption && f2fOption.value === 'mentor');
            
            // Store flag in session storage to trigger redirect after form submission
            if (mentorWillReserveFacility) {
                sessionStorage.setItem('mentor_reserve_facility', 'true');
            }
            
            document.getElementById('acceptForm').submit();
        }
        
        // Check for facility reservation redirect on page load
        document.addEventListener('DOMContentLoaded', function() {
            if (sessionStorage.getItem('mentor_reserve_facility') === 'true') {
                sessionStorage.removeItem('mentor_reserve_facility');
                // Show message and redirect to facility reservation
                if (confirm('Request accepted! You chose to reserve a facility. Click OK to go to the facility reservation page.')) {
                    window.location.href = '{{ path("app_facility_index") }}';
                }
            }
        });
        
        function submitDecline() {
            document.getElementById('declineForm').submit();
        }
        
        // Close modals on backdrop click
        document.getElementById('acceptModal').addEventListener('click', function(e) {
            if (e.target === this) closeAcceptModal();
        });
        document.getElementById('declineModal').addEventListener('click', function(e) {
            if (e.target === this) closeDeclineModal();
        });
        
        // â”€â”€ Session Details Modal Functions â”€â”€
        function openSessionDetailsModal(requestData) {
            const modal = document.getElementById('sessionDetailsModal');
            
            // Set title based on role
            const isStudent = requestData.isStudent;
            document.getElementById('detailsModalTitle').textContent = isStudent ? 'Mentoring Session Details' : 'Mentoring Request Details';
            document.getElementById('detailsModalSubtitle').textContent = 'Complete session information';
            
            // Mentor Info Section
            const mentorHtml = `
                <div class="details-row">
                    <span class="details-label">Name</span>
                    <span class="details-value">${requestData.mentorName}</span>
                </div>
                <div class="details-row">
                    <span class="details-label">Email</span>
                    <span class="details-value">${requestData.mentorEmail}</span>
                </div>
            `;
            document.getElementById('detailsMentorInfo').innerHTML = mentorHtml;
            
            // Schedule Section
            let scheduleHtml = `
                <div class="details-row">
                    <span class="details-label">Date</span>
                    <span class="details-value">${requestData.scheduledDate || 'Flexible'}</span>
                </div>
                <div class="details-row">
                    <span class="details-label">Time</span>
                    <span class="details-value">${requestData.scheduledTime || 'To be confirmed'}</span>
                </div>
            `;
            document.getElementById('detailsSchedule').innerHTML = scheduleHtml;
            
            // Meeting Setup Section
            let meetingHtml = `
                <div class="details-row">
                    <span class="details-label">Type</span>
                    <span class="details-value">${requestData.meetingType}</span>
                </div>
            `;
            if (requestData.meetingLink) {
                meetingHtml += `
                    <div class="details-row">
                        <span class="details-label">Link</span>
                        <span class="details-value"><a href="${requestData.meetingLink}" target="_blank" style="color: #3b82f6;">Join Meeting</a></span>
                    </div>
                `;
            }
            document.getElementById('detailsMeeting').innerHTML = meetingHtml;
            
            // Location Section
            let locationHtml = '';
            if (requestData.meetingType === 'Face-to-Face') {
                if (requestData.facilityReservedBy === 'mentor') {
                    locationHtml = `
                        <div class="details-action-box">
                            <strong>Facility Reservation</strong>
                            <p>The mentor will reserve a facility and notify you of the location.</p>
                        </div>
                    `;
                } else if (requestData.facilityReservedBy === 'student') {
                    locationHtml = `
                        <div class="details-action-box">
                            <strong>Action Required: Reserve Facility</strong>
                            <p>You need to reserve a facility for this session. Click the button below to reserve now.</p>
                        </div>
                    `;
                    document.getElementById('reserveFacilityBtn').style.display = 'inline-block';
                } else if (requestData.facilityReservedBy === 'outside') {
                    locationHtml = `
                        <div class="details-row">
                            <span class="details-label">Location</span>
                            <span class="details-value">${requestData.meetingLocation}</span>
                        </div>
                    `;
                }
            } else {
                locationHtml = `
                    <div class="details-row">
                        <span class="details-label">Mode</span>
                        <span class="details-value">Online (virtual meeting)</span>
                    </div>
                `;
            }
            document.getElementById('detailsLocation').innerHTML = locationHtml;
            
            // Status & Notes Section
            let statusHtml = `
                <div class="details-row">
                    <span class="details-label">Status</span>
                    <span class="details-value"><span class="details-status-badge status-${requestData.status.toLowerCase()}">${requestData.status}</span></span>
                </div>
            `;
            if (requestData.mentorResponse) {
                statusHtml += `
                    <div class="details-row">
                        <span class="details-label">Notes</span>
                        <span class="details-value details-message-box">${requestData.mentorResponse}</span>
                    </div>
                `;
            }
            document.getElementById('detailsStatusNotes').innerHTML = statusHtml;
            
            modal.classList.add('is-open');
        }
        
        function closeSessionDetailsModal() {
            document.getElementById('sessionDetailsModal').classList.remove('is-open');
            document.getElementById('reserveFacilityBtn').style.display = 'none';
        }
        
        // Close modals on backdrop click
        document.getElementById('sessionDetailsModal').addEventListener('click', function(e) {
            if (e.target === this) closeSessionDetailsModal();
        });
        
        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeAcceptModal();
                closeDeclineModal();
                closeSessionDetailsModal();
                closeCancelModal();
            }
        });

        // â”€â”€ Cancel Request Modal Functions â”€â”€
        let cancelFormToSubmit = null;

        function openCancelModal(form) {
            cancelFormToSubmit = form;
            document.getElementById('cancelRequestModal').classList.add('is-open');
            // Clear previous reason
            document.getElementById('cancelReason').value = '';
            document.getElementById('cancelReasonError').style.display = 'none';
            document.getElementById('cancelReason').style.borderColor = '#d1d5db';
        }

        function closeCancelModal() {
            document.getElementById('cancelRequestModal').classList.remove('is-open');
            cancelFormToSubmit = null;
        }

        function confirmCancelRequest() {
            const reasonInput = document.getElementById('cancelReason');
            const reason = reasonInput.value.trim();
            const errorDiv = document.getElementById('cancelReasonError');
            
            // Validate reason
            if (!reason || reason.length < 10) {
                errorDiv.style.display = 'block';
                reasonInput.style.borderColor = '#dc2626';
                reasonInput.focus();
                return;
            }
            
            errorDiv.style.display = 'none';
            reasonInput.style.borderColor = '#d1d5db';
            
            if (cancelFormToSubmit) {
                // Add cancellation reason to form
                let reasonField = cancelFormToSubmit.querySelector('input[name="cancellation_reason"]');
                if (!reasonField) {
                    reasonField = document.createElement('input');
                    reasonField.type = 'hidden';
                    reasonField.name = 'cancellation_reason';
                    cancelFormToSubmit.appendChild(reasonField);
                }
                reasonField.value = reason;
                cancelFormToSubmit.submit();
            }
            closeCancelModal();
        }

        // Close cancel modal on backdrop click
        document.getElementById('cancelRequestModal').addEventListener('click', function(e) {
            if (e.target === this) closeCancelModal();
        });
    </script>
{% endblock %}
