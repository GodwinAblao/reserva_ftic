{% block javascripts %}
    {{ parent() }}
    <script>
        // ===== ASSISTANCE SCHEDULE END-TIME GUARD =====
        (function () {
            function clampTime(el, warnId) {
                const warn = document.getElementById(warnId);
                if (!el.value) { if (warn) warn.style.display = 'none'; return; }
                if (el.value < '07:00' || el.value > '19:00') {
                    if (warn) warn.style.display = 'block';
                    if (el.value < '07:00') el.value = '07:00';
                    if (el.value > '19:00') el.value = '19:00';
                    setTimeout(function(){ if (warn) warn.style.display = 'none'; }, 3500);
                } else {
                    if (warn) warn.style.display = 'none';
                }
            }
            function init() {
                const startEl = document.getElementById('assistance_schedule_start');
                const endEl   = document.getElementById('assistance_schedule_end');
                if (!startEl || !endEl) return;
                startEl.addEventListener('change', function () {
                    clampTime(startEl, 'assistance_schedule_start_warn');
                    if (endEl.value && endEl.value <= startEl.value) {
                        endEl.value = '';
                    }
                    endEl.min = startEl.value || '07:00';
                });
                endEl.addEventListener('change', function () {
                    clampTime(endEl, 'assistance_schedule_end_warn');
                });
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
            document.addEventListener('turbo:load', init);
        })();


        // ===== TAB SWITCHING - Global function for inline onclick =====
        function switchMentoringTab(filter, clickedTab) {
            // Update active tab styling
            const tabsContainer = document.querySelector('.filter-tabs-container');
            if (tabsContainer) {
                const allTabs = tabsContainer.querySelectorAll('.filter-tab');
                allTabs.forEach(function(tab) { tab.classList.remove('active'); });
            }
            clickedTab.classList.add('active');

            // Show/hide content sections
            const contents = document.querySelectorAll('.mentoring-content');
            contents.forEach(function(content) {
                if (content.id === filter + '-content') {
                    content.classList.remove('hidden');
                    content.style.display = 'block';
                } else {
                    content.classList.add('hidden');
                    content.style.display = 'none';
                }
            });
        }

        function syncMentoringTabState() {
            const activeTab = document.querySelector('.filter-tab.active');
            if (activeTab) {
                const filter = activeTab.getAttribute('onclick').match(/'([^']+)'/)[1];
                const contents = document.querySelectorAll('.mentoring-content');
                contents.forEach(function(content) {
                    if (content.id === filter + '-content') {
                        content.classList.remove('hidden');
                        content.style.display = 'block';
                    } else {
                        content.classList.add('hidden');
                        content.style.display = 'none';
                    }
                });
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', syncMentoringTabState, { once: true });
        } else {
            syncMentoringTabState();
        }
        document.addEventListener('turbo:load', syncMentoringTabState);

        // ===== REAL-TIME SEARCH =====
        function initMentoringSearch() {
            const mentorSearchForm = document.getElementById('mentorSearchForm');
            if (!mentorSearchForm || mentorSearchForm.dataset.mentoringSearchBound === '1') {
                return;
            }

            mentorSearchForm.dataset.mentoringSearchBound = '1';

            let searchTimeout;
            const DEBOUNCE_DELAY = 300;
            const searchInput = document.getElementById('mentorSearchInput');
            const specializationFilter = document.getElementById('specializationFilter');
            const mentorCardGrid = document.getElementById('mentorCardGrid');

            function performSearch() {
                const searchTerm = searchInput?.value || '';
                const specialization = specializationFilter?.value || '';

                // Show loading state
                if (mentorCardGrid) {
                    mentorCardGrid.style.opacity = '0.6';
                }

                // Make AJAX request
                fetch('{{ path("mentoring_index") }}?search=' + encodeURIComponent(searchTerm) + '&specialization=' + encodeURIComponent(specialization), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                })
                .then(response => {
                    if (!response.ok) throw new Error('Search failed');
                    return response.json();
                })
                .then(data => {
                    if (mentorCardGrid) {
                        mentorCardGrid.innerHTML = data.html;
                        mentorCardGrid.style.opacity = '1';
                        
                        // Add animation to new cards
                        const cards = mentorCardGrid.querySelectorAll('.mentor-card-link');
                        cards.forEach((card, index) => {
                            card.style.opacity = '0';
                            card.style.animation = `fadeInUp 0.4s ease-out ${index * 0.05}s forwards`;
                        });
                    }

                    if (data.specializationsHtml) {
                        const specializationsPanel = document.getElementById('preferredSpecializationsPanel');
                        if (specializationsPanel) {
                            specializationsPanel.innerHTML = data.specializationsHtml;
                        }
                    }
                })
                .catch(error => {
                    console.error('Search error:', error);
                    if (mentorCardGrid) {
                        mentorCardGrid.style.opacity = '1';
                    }
                });
            }

            // Add event listeners
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(performSearch, DEBOUNCE_DELAY);
                });
            }

            if (specializationFilter) {
                specializationFilter.addEventListener('change', performSearch);
            }

            function bindSpecializationLinks() {
                const specializationLinks = document.querySelectorAll('.specialization-link');
                specializationLinks.forEach(link => {
                    link.addEventListener('click', function(event) {
                        event.preventDefault();
                        const specialization = this.closest('.specialization-row')?.dataset.specialization || '';
                        if (specializationFilter) {
                            specializationFilter.value = specialization;
                        }
                        performSearch();
                    });
                });
            }

            bindSpecializationLinks();

            mentorSearchForm.addEventListener('submit', function(event) {
                event.preventDefault();
                performSearch();
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initMentoringSearch, { once: true });
        } else {
            initMentoringSearch();
        }
        document.addEventListener('turbo:load', initMentoringSearch);

        function openMentorApplication() {
            const modal = document.getElementById('mentorApplicationModal');
            if (!modal) {
                return;
            }

            if (modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMentorApplication() {
            const modal = document.getElementById('mentorApplicationModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        function openMentorAssistance() {
            const modal = document.getElementById('mentorAssistanceModal');
            if (!modal) {
                return;
            }

            if (modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMentorAssistance() {
            const modal = document.getElementById('mentorAssistanceModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        window.toggleAssistanceSpecializationOther = function(select, otherInputId) {
            const otherInput = document.getElementById(otherInputId);
            if (otherInput) {
                otherInput.style.display = select.value === 'Other' ? 'block' : 'none';
                if (select.value !== 'Other') {
                    otherInput.value = '';
                }
            }
        };

        if (!window.__mentoringGlobalListenersBound) {
            window.__mentoringGlobalListenersBound = true;

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeMentorApplication();
                    closeMentorAssistance();
                }
            });
        }

        document.querySelectorAll('form[data-loading-label]').forEach(form => {
            if (form.dataset.noLoading === 'true') {
                return; // Skip loading state for these forms
            }
            form.addEventListener('submit', () => {
                const button = form.querySelector('.js-loading-submit');
                if (button) {
                    button.disabled = true;
                    button.textContent = form.dataset.loadingLabel || 'Submitting...';
                }
            });
        });

    </script>

