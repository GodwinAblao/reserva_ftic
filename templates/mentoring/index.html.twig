{% extends 'layouts/app.html.twig' %}

{% block title %}Mentoring | Reserva FTIC{% endblock %}

{% block content %}
<div class="mentor-page-container">
    <div class="content-header mentoring-header" style="align-items:center; justify-content:space-between;">
        <div class="button-group">
            <button type="button" class="btn-secondary" onclick="openMentorAssistance()">Need Help Finding a Mentor?</button>
            {% if canApplyAsMentor %}
                <button type="button" class="btn-primary" onclick="openMentorApplication()">Apply as Mentor</button>
            {% elseif is_granted('ROLE_MENTOR') %}
                <a href="{{ path('app_profile') }}" class="btn-secondary">View Profile</a>
            {% elseif applications|length > 0 %}
                <button type="button" class="btn-secondary" disabled>Application Pending</button>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('mentoring_super-admin') }}" class="btn-primary">Manage Mentoring</a>
            {% endif %}
        </div>
    </div>

    <section class="mentor-section">
        <div class="section-heading">
            <h2>Featured Mentors</h2>
            <span>{{ mentors|length }} available profiles</span>
        </div>

        <!-- Search and Filter Section -->
        <div class="mentor-search-filters">
            <form method="get" action="{{ path('mentoring_index') }}" class="search-form" id="mentorSearchForm">
                <div class="search-input-group">
                    <input 
                        type="text" 
                        id="mentorSearchInput"
                        name="search" 
                        class="search-input" 
                        placeholder="Search mentor by name..."
                        value="{{ app.request.query.get('search', '') }}"
                        autocomplete="off"
                    >
                </div>

                <div class="filter-group">
                    <select id="specializationFilter" name="specialization" class="filter-dropdown">
                        <option value="">All Specializations</option>
                        {% for spec in allSpecializations %}
                            <option value="{{ spec.specialization }}" {% if app.request.query.get('specialization') == spec.specialization %}selected{% endif %}>
                                {{ spec.specialization }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </form>
        </div>

        <div class="mentor-card-grid" id="mentorCardGrid">
            {% include 'mentoring/_mentor_cards.html.twig' with { mentors: mentors } only %}
        </div>
    </section>



    <div class="module-grid">
        <section class="card-panel">
            <h3>My Pending Submission</h3>
            {% set pendingApplications = applications|filter(application => application.status in ['Pending', 'Pending Review']) %}

            {% for application in pendingApplications %}
                <div class="list-row">
                    <div>
                        <strong>{{ application.specialization }}</strong>
                        <p>
                            Submitted {{ application.createdAt|date('M d, Y h:i A') }}
                            {% if application.currentProfession %} - {{ application.currentProfession }}{% endif %}
                        </p>
                    </div>
                    <span class="status-badge status-pending">{{ application.status }}</span>
                </div>
            {% else %}
                <p>No pending mentor submission right now.</p>
            {% endfor %}
        </section>

        <section class="card-panel">
            <h3>My Mentor Applications</h3>
            {% for application in applications %}
                <div class="list-row">
                    <div>
                        <strong>{{ application.specialization }}</strong>
                        <p>Submitted {{ application.createdAt|date('M d, Y h:i A') }}</p>
                    </div>
                    <span class="status-badge status-{{ application.status|lower|replace({' ': '-'}) }}">{{ application.status }}</span>
                </div>
            {% else %}
                <p>You have not submitted a mentor application yet.</p>
            {% endfor %}
        </section>
    </div>

    <div class="module-grid" id="my-custom-requests">
        <section class="card-panel">
            <h3>My Custom Requests</h3>
            {% for request in sentCustomRequests %}
                <div class="list-row">
                    <div>
                        <strong>{{ request.mentorProfile ? request.mentorProfile.displayName : 'Mentor assistance request' }}</strong>
                        <p>
                            Submitted {{ request.createdAt|date('M d, Y h:i A') }}
                            {% if request.updatedAt %} - Updated {{ request.updatedAt|date('M d, Y h:i A') }}{% endif %}
                        </p>
                        {% if request.isAssistanceRequest %}
                            <p class="muted">{{ request.departmentCourse }} - {{ request.preferredExpertise }} - {{ request.preferredSchedule }}</p>
                        {% endif %}
                        <p class="muted">{{ request.message|slice(0, 160) ~ (request.message|length > 160 ? '...' : '') }}</p>
                        {% if request.assignedMentorName %}
                            <div class="mentor-request-card__response">
                                <strong>Mentor details:</strong>
                                <p>{{ request.assignedMentorName }} - {{ request.assignedMentorExpertise }}</p>
                                <p>{{ request.availableDates }} at {{ request.availableTime }} - {{ request.meetingMethod }}</p>
                                {% if request.adminInstructions %}<p>{{ request.adminInstructions }}</p>{% endif %}
                            </div>
                        {% endif %}
                        {% if request.mentorResponse %}
                            <p class="muted"><strong>Response:</strong> {{ request.mentorResponse }}</p>
                        {% endif %}
                        {% if request.isAssistanceRequest and request.status == 'Pending' %}
                            <details class="mentor-inline-editor">
                                <summary>Update request</summary>
                                <form method="post" action="{{ path('mentoring_assistance_update', {'id': request.id}) }}" class="mentor-request-actions">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mentor_assistance_update_' ~ request.id) }}">
                                    <input class="form-input" name="full_name" value="{{ request.fullName }}" required>
                                    <input class="form-input" name="department_course" value="{{ request.departmentCourse }}" required>
                                    <input class="form-input" name="preferred_expertise" value="{{ request.preferredExpertise }}" required>
                                    <input class="form-input" name="preferred_schedule" value="{{ request.preferredSchedule }}" required>
                                    <textarea class="form-input" name="message" rows="3">{{ request.message }}</textarea>
                                    <div class="button-group">
                                        <button class="btn-primary" type="submit" name="action" value="update">Save Changes</button>
                                        <button class="btn-secondary" type="submit" name="action" value="cancel">Cancel Request</button>
                                    </div>
                                </form>
                            </details>
                        {% endif %}
                    </div>
                    <span class="status-badge status-{{ request.status|lower }}">{{ request.status|capitalize }}</span>
                </div>
            {% else %}
                <p>You have not sent a custom request yet.</p>
            {% endfor %}
        </section>

        {% if is_granted('ROLE_MENTOR') %}
            <section class="card-panel" id="custom-requests">
                <h3>Incoming Custom Requests</h3>
                {% for request in incomingCustomRequests %}
                    <div class="mentor-request-card {{ request.status == 'Pending' ? 'is-pending' : '' }}">
                        <div class="mentor-request-card__header">
                            <div>
                                <strong>{{ request.student.firstName ?: request.student.email }}</strong>
                                <p>{{ request.student.email }}</p>
                            </div>
                            <span class="status-badge status-{{ request.status|lower }}">{{ request.status|capitalize }}</span>
                        </div>

                        <p class="mentor-request-card__meta">Submitted {{ request.createdAt|date('M d, Y h:i A') }}</p>
                        <div class="mentor-request-card__message">{{ request.message }}</div>

                        {% if request.mentorResponse %}
                            <div class="mentor-request-card__response">
                                <strong>Your response:</strong>
                                <p>{{ request.mentorResponse }}</p>
                            </div>
                        {% endif %}

                        {% if request.status == 'Pending' %}
                            <form method="post" action="{{ path('mentoring_custom_request_review', {'id': request.id}) }}" class="mentor-request-actions" data-no-loading="true">
                                <input type="hidden" name="_token" value="{{ csrf_token('custom_request_review_' ~ request.id) }}">
                                <textarea name="mentor_response" class="form-input" rows="3" placeholder="Optional response to the student"></textarea>
                                <div class="button-group">
                                    <button type="submit" name="decision" value="accept" class="btn-primary">Accept</button>
                                    <button type="submit" name="decision" value="decline" class="btn-secondary">Decline</button>
                                </div>
                            </form>
                        {% endif %}
                    </div>
                {% else %}
                    <p>No incoming custom requests yet.</p>
                {% endfor %}
            </section>
        {% endif %}
    </div>

    <div class="module-grid">
        <section class="card-panel">
            <h3>Traceability Leaderboard</h3>
            {% for mentor in leaderboard %}
                <div class="list-row">
                    <strong>{{ loop.index }}. {{ mentor.displayName }}</strong>
                    <span>{{ mentor.engagementPoints }} points</span>
                </div>
            {% else %}
                <p>No leaderboard data yet.</p>
            {% endfor %}
        </section>

        <section class="card-panel" id="preferredSpecializationsPanel">
            {% include 'mentoring/_preferred_specializations.html.twig' with { specializations: specializations } only %}
        </section>
    </div>

    {% if canApplyAsMentor %}
        <div id="mentorApplicationModal" class="app-modal" aria-hidden="true">
            <div class="app-modal-backdrop" onclick="closeMentorApplication()"></div>
            <div class="app-modal-panel app-modal-large" role="dialog" aria-modal="true" aria-labelledby="mentorApplicationTitle">
                <div class="app-modal-header">
                    <div>
                        <h3 id="mentorApplicationTitle">Apply as Mentor</h3>
                        <p>Fill out the form below. Your application will be reviewed by the Super Admin.</p>
                    </div>
                    <button type="button" class="icon-button" onclick="closeMentorApplication()" aria-label="Close">x</button>
                </div>

                <div class="mentor-application-layout">
                    <aside class="mentor-application-summary">
                        <div class="mentor-application-summary__eyebrow">Mentor application</div>
                        <h4>Share your strengths with the team</h4>
                        <p>Your application is reviewed by the Super Admin. Keep it clear, specific, and professional.</p>

                        <div class="mentor-application-points">
                            <div>
                                <strong>Complete profile</strong>
                                <span>We use these details to review your background.</span>
                            </div>
                            <div>
                                <strong>Professional proof</strong>
                                <span>Attach certificates, IDs, or samples if available.</span>
                            </div>
                            <div>
                                <strong>Fast review</strong>
                                <span>Applications are kept organized for quick checking.</span>
                            </div>
                        </div>
                    </aside>

                    <form method="post" action="{{ path('mentoring_apply') }}" class="mentor-form" enctype="multipart/form-data">
                        <input type="hidden" name="_token" value="{{ csrf_token('mentor_application') }}">
                        {% include 'mentoring/_mentor_application_form_fields.html.twig' with { defaultUser: app.user } only %}
                        <div class="app-modal-actions">
                            <button type="button" class="btn-secondary" onclick="closeMentorApplication()">Cancel</button>
                            <button class="btn-primary" type="submit">Submit Application</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% endif %}

    <div id="mentorAssistanceModal" class="app-modal" aria-hidden="true">
        <div class="app-modal-backdrop" onclick="closeMentorAssistance()"></div>
        <div class="app-modal-panel app-modal-large" role="dialog" aria-modal="true" aria-labelledby="mentorAssistanceTitle">
            <div class="app-modal-header">
                <div>
                    <h3 id="mentorAssistanceTitle">Request a Mentor</h3>
                    <p>Tell Admin what kind of mentor support you need.</p>
                </div>
                <button type="button" class="icon-button" onclick="closeMentorAssistance()" aria-label="Close">x</button>
            </div>

            <form method="post" action="{{ path('mentoring_assistance_request') }}" class="mentor-form mentor-assistance-form" data-loading-label="Submitting...">
                <input type="hidden" name="_token" value="{{ csrf_token('mentor_assistance_request') }}">
                <div class="form-section">
                    <h4>Request Details</h4>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label for="assistance_full_name">Full Name</label>
                            <input id="assistance_full_name" class="form-input" name="full_name" value="{{ (app.user.firstName ~ ' ' ~ app.user.lastName)|trim }}" required>
                        </div>
                        <div class="form-group">
                            <label for="assistance_department">Department / Course</label>
                            <input id="assistance_department" class="form-input" name="department_course" value="{{ app.user.degreeName ?: app.user.degree }}" required>
                        </div>
                        <div class="form-group">
                            <label for="assistance_expertise">Preferred Expertise or Skill</label>
                            <input id="assistance_expertise" class="form-input" name="preferred_expertise" placeholder="Example: Software Engineering, Research, UI/UX" required>
                        </div>
                        <div class="form-group">
                            <label for="assistance_schedule">Preferred Schedule</label>
                            <input id="assistance_schedule" class="form-input" name="preferred_schedule" placeholder="Example: Mondays 2:00 PM onward" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="assistance_message">Additional Notes or Message</label>
                        <textarea id="assistance_message" class="form-input" name="message" rows="4" placeholder="Share goals, constraints, or what you have already tried."></textarea>
                    </div>
                </div>
                <div class="app-modal-actions">
                    <button type="button" class="btn-secondary" onclick="closeMentorAssistance()">Cancel</button>
                    <button class="btn-primary js-loading-submit" type="submit">Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        let searchTimeout;
        const DEBOUNCE_DELAY = 300; // 300ms delay before searching

        // Real-time search and filter
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('mentorSearchInput');
            const specializationFilter = document.getElementById('specializationFilter');
            const mentorCardGrid = document.getElementById('mentorCardGrid');

            function performSearch() {
                const searchTerm = searchInput?.value || '';
                const specialization = specializationFilter?.value || '';

                // Show loading state
                if (mentorCardGrid) {
                    mentorCardGrid.style.opacity = '0.6';
                }

                // Make AJAX request
                fetch('{{ path("mentoring_index") }}?search=' + encodeURIComponent(searchTerm) + '&specialization=' + encodeURIComponent(specialization), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                })
                .then(response => {
                    if (!response.ok) throw new Error('Search failed');
                    return response.json();
                })
                .then(data => {
                    if (mentorCardGrid) {
                        mentorCardGrid.innerHTML = data.html;
                        mentorCardGrid.style.opacity = '1';
                        
                        // Add animation to new cards
                        const cards = mentorCardGrid.querySelectorAll('.mentor-card-link');
                        cards.forEach((card, index) => {
                            card.style.opacity = '0';
                            card.style.animation = `fadeInUp 0.4s ease-out ${index * 0.05}s forwards`;
                        });
                    }

                    if (data.specializationsHtml) {
                        const specializationsPanel = document.getElementById('preferredSpecializationsPanel');
                        if (specializationsPanel) {
                            specializationsPanel.innerHTML = data.specializationsHtml;
                        }
                    }
                })
                .catch(error => {
                    console.error('Search error:', error);
                    if (mentorCardGrid) {
                        mentorCardGrid.style.opacity = '1';
                    }
                });
            }

            // Add event listeners
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(performSearch, DEBOUNCE_DELAY);
                });
            }

            if (specializationFilter) {
                specializationFilter.addEventListener('change', performSearch);
            }

            function bindSpecializationLinks() {
                const specializationLinks = document.querySelectorAll('.specialization-link');
                specializationLinks.forEach(link => {
                    link.removeEventListener('click', handleSpecializationLinkClick);
                    link.addEventListener('click', handleSpecializationLinkClick);
                });
            }

            function handleSpecializationLinkClick(event) {
                event.preventDefault();
                const specialization = this.closest('.specialization-row')?.dataset.specialization || '';
                if (specializationFilter) {
                    specializationFilter.value = specialization;
                }
                performSearch();
            }

            bindSpecializationLinks();

            const mentorSearchForm = document.getElementById('mentorSearchForm');
            if (mentorSearchForm) {
                mentorSearchForm.addEventListener('submit', function(event) {
                    event.preventDefault();
                    performSearch();
                });
            }
        });

        function openMentorApplication() {
            const modal = document.getElementById('mentorApplicationModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMentorApplication() {
            const modal = document.getElementById('mentorApplicationModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        function openMentorAssistance() {
            const modal = document.getElementById('mentorAssistanceModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeMentorAssistance() {
            const modal = document.getElementById('mentorAssistanceModal');
            if (!modal) {
                return;
            }

            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeMentorApplication();
                closeMentorAssistance();
            }
        });

        document.querySelectorAll('form[data-loading-label]').forEach(form => {
            if (form.dataset.noLoading === 'true') {
                return; // Skip loading state for these forms
            }
            form.addEventListener('submit', () => {
                const button = form.querySelector('.js-loading-submit');
                if (button) {
                    button.disabled = true;
                    button.textContent = form.dataset.loadingLabel || 'Submitting...';
                }
            });
        });

        // Auto-refresh button group state to detect real-time updates from super admin
        const refreshButtonState = () => {
            fetch(window.location.href, { cache: 'no-store' })
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const newDoc = parser.parseFromString(html, 'text/html');
                    const newButtonGroup = newDoc.querySelector('div.button-group');
                    const oldButtonGroup = document.querySelector('div.button-group');
                    
                    if (newButtonGroup && oldButtonGroup && newButtonGroup.innerHTML !== oldButtonGroup.innerHTML) {
                        oldButtonGroup.innerHTML = newButtonGroup.innerHTML;
                        console.log('Button state updated due to admin actions');
                    }
                })
                .catch(err => console.debug('Auto-refresh check completed'));
        };
        
        // Check button state every 5 seconds
        setInterval(refreshButtonState, 5000);
    </script>

    <style>
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Required field styling */
        .required-text {
            display: block;
            color: #dc2626;
            font-weight: 500;
            margin-bottom: 0.25rem;
        }
    </style>
{% endblock %}
