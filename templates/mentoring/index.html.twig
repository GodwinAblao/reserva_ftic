{% extends 'layouts/app.html.twig' %}

{% block title %}Mentoring | Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/user_reservations.css') }}">
    <style>
        /* Prevent flash of content - hide all sections by default, JS will show the active one */
        .mentoring-content {
            display: none;
        }
        .mentoring-content:not(.hidden) {
            display: block;
        }

        /* â”€â”€ Cancel Request Modal â”€â”€ */
        .cancel-modal-overlay{display:none;position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:9999;align-items:center;justify-content:center;padding:1.5rem;background:rgba(15,23,42,.55);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);}
        .cancel-modal-overlay.is-open{display:flex;}
        .cancel-modal-dialog{width:min(480px,100%);background:#fff;border-radius:20px;padding:2rem 2rem 1.75rem;text-align:center;box-shadow:0 24px 70px rgba(15,23,42,.28);animation:cancelModalIn .18s ease-out;}
        .cancel-modal-icon{width:58px;height:58px;margin:0 auto 1rem;border-radius:999px;display:flex;align-items:center;justify-content:center;background:#fee2e2;border:1px solid #fecaca;}
        .cancel-modal-icon svg{color:#dc2626;}
        .cancel-modal-dialog h3{margin:0 0 .5rem;color:#111827;font-size:1.2rem;font-weight:800;}
        .cancel-modal-dialog p{margin:0 0 1.25rem;color:#6b7280;line-height:1.55;font-size:.9rem;}
        .cancel-modal-actions{display:flex;gap:.75rem;justify-content:center;margin-top:1.25rem;}
        .cancel-modal-actions button{border:none;border-radius:10px;padding:.7rem 1.4rem;font-weight:800;cursor:pointer;font-size:.9rem;transition:background .15s,transform .1s;}
        .cancel-modal-actions button:active{transform:scale(.97);}
        .cancel-modal-cancel{background:#f3f4f6;color:#374151;}
        .cancel-modal-cancel:hover{background:#e5e7eb;}
        .cancel-modal-confirm{background:#dc2626;color:#fff;}
        .cancel-modal-confirm:hover{background:#b91c1c;}
        @keyframes cancelModalIn{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
    </style>
{% endblock %}

{% block content %}
<div class="mentoring-page-layout">
    <!-- Main Content Column -->
    <div class="mentoring-main-column">
        <!-- Flash Messages -->
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash-message flash-{{ type }}" style="
                    padding: 12px 16px;
                    margin-bottom: 20px;
                    border-radius: 8px;
                    font-size: 14px;
                    font-weight: 500;
                    {{ type == 'error' ? 'background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;' : '' }}
                    {{ type == 'success' ? 'background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0;' : '' }}
                ">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <!-- Mentors Section -->
        <div class="mentoring-section" id="mentors-section">
            <!-- Search and Filter Section -->
            <div class="mentor-search-filters">
                <form method="get" action="{{ path('mentoring_index') }}" class="search-form" id="mentorSearchForm">
                    <div class="search-input-group">
                        <input
                            type="text"
                            id="mentorSearchInput"
                            name="search"
                            class="search-input"
                            placeholder="Search Mentor Name"
                            value="{{ app.request.query.get('search', '') }}"
                            autocomplete="off"
                        >
                    </div>

                    <div class="filter-group">
                        <select id="specializationFilter" name="specialization" class="filter-dropdown">
                            <option value="">All Specialization</option>
                            {% for spec in allSpecializations %}
                                <option value="{{ spec.name }}" {% if app.request.query.get('specialization') == spec.name %}selected{% endif %}>
                                    {{ spec.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </form>
            </div>

            <!-- Mentor Cards - Always Visible Above Filter Tabs -->
            <div class="mentor-card-grid" id="mentorCardGrid">
                {% include 'mentoring/_mentor_cards.html.twig' with { mentors: mentors, mentorApplicationMeta: mentorApplicationMeta|default({}) } only %}
            </div>

            <!-- Filter Tabs -->
            <div class="filter-tabs-container">
                <button class="filter-tab active" onclick="switchMentoringTab('custom-requests', this); return false;">
                    <span class="tab-text">My Mentor Requests</span>
                </button>
                {% set pendingApplicationsCount = applications|filter(application => application.status in ['Pending', 'Pending Review'])|length %}
                {% set pendingMentorRequestsCount = sentCustomRequests|filter(request => request.status in ['Pending'])|length %}
                {% set totalPendingAll = pendingApplicationsCount + pendingMentorRequestsCount %}
                <button class="filter-tab pending-tab" onclick="switchMentoringTab('applications', this); return false;" data-pending-count="{{ totalPendingAll }}">
                    <span class="tab-text">My Pending Submission</span>
                    {% if totalPendingAll > 0 %}
                        <span class="pending-badge" style="margin-left: 8px; background: #dc2626; color: white; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 10px; min-width: 20px; text-align: center;">{{ totalPendingAll }}</span>
                    {% endif %}
                </button>
                <button class="filter-tab" onclick="switchMentoringTab('mentor-application', this); return false;">
                    <span class="tab-text">My Mentor Application</span>
                </button>
                <button class="filter-tab cancelled-tab" onclick="switchMentoringTab('incoming', this); return false;">
                    <span class="tab-text">Incoming Mentoring Requests</span>
                </button>
                {% set cancelledRequestsCount = sentCustomRequests|filter(request => request.status == 'Cancelled')|length %}
                <button class="filter-tab" onclick="switchMentoringTab('cancelled', this); return false;" style="{% if cancelledRequestsCount > 0 %}border-bottom-color: #dc2626;{% endif %}">
                    <span class="tab-text">Cancelled Requests</span>
                    {% if cancelledRequestsCount > 0 %}
                        <span class="pending-badge" style="margin-left: 8px; background: #dc2626; color: white; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 10px; min-width: 20px; text-align: center;">{{ cancelledRequestsCount }}</span>
                    {% endif %}
                </button>
            </div>

            <!-- Content Section -->
            <div class="mentoring-content-section">

                <!-- Custom Requests Cards - Only show accepted, completed, rejected requests (cancelled has its own tab) -->
                <div class="mentoring-content" id="custom-requests-content">
                    <div class="reservations-grid">
                        {% set nonPendingRequests = sentCustomRequests|filter(request => request.status not in ['Pending', 'Pending Review', 'Cancelled']) %}
                        {% if nonPendingRequests|length > 0 %}
                            {% for request in nonPendingRequests %}
                                <div class="reservation-card-new {{ request.status == 'accepted' ? 'session-item-clickable' : '' }}" data-req-id="{{ request.id }}"
                                    {% if request.status == 'accepted' %}
                                    onclick="openSessionDetailsModal({
                                        isStudent: true,
                                        mentorName: '{{ request.mentorProfile ? request.mentorProfile.displayName|e('js') : (request.assignedMentorName|e('js')) }}',
                                        mentorEmail: '{{ request.mentorProfile ? request.mentorProfile.user.email|e('js') : '' }}',
                                        scheduledDate: '{{ request.scheduledDate ? request.scheduledDate|date('F d, Y') : 'Flexible' }}',
                                        scheduledTime: '{{ request.scheduledTime|default('To be confirmed') }}',
                                        meetingType: '{{ request.meetingType|default('Not specified') }}',
                                        meetingLink: '{{ request.meetingLink|e('js') }}',
                                        facilityReservedBy: '{{ request.facilityReservedBy|e('js') }}',
                                        meetingLocation: '{{ request.meetingLocation|e('js') }}',
                                        status: '{{ request.status|capitalize }}',
                                        mentorResponse: '{{ request.mentorResponse|e('js') }}'
                                    })"
                                    {% endif %}>
                                    <div class="card-title">
                                        {% if request.mentorProfile %}
                                            {{ request.mentorProfile.displayName }}
                                        {% elseif request.assignedMentorName %}
                                            {{ request.assignedMentorName }}
                                        {% else %}
                                            Mentor Assistance Request
                                        {% endif %}
                                    </div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value status-{{ request.status|lower }}">{{ request.status|capitalize }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ request.createdAt|date('M d, Y') }}</span>
                                        </div>
                                        {% if request.fullName %}
                                        <div class="info-item wide">
                                            <span class="info-label">Your Name</span>
                                            <span class="info-value">{{ request.fullName }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.status == 'accepted' %}
                                        <div class="info-item wide">
                                            <span class="view-details-btn">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                    <circle cx="12" cy="12" r="3"></circle>
                                                </svg>
                                                Click to view full details
                                            </span>
                                        </div>
                                        {% endif %}
                                        {% if request.preferredExpertise %}
                                        <div class="info-item">
                                            <span class="info-label">Specialization Needed</span>
                                            <span class="info-value">{{ request.preferredExpertise }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.departmentCourse %}
                                        <div class="info-item">
                                            <span class="info-label">Degree / Course</span>
                                            <span class="info-value">{{ request.departmentCourse }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.availableDates %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Day</span>
                                            <span class="info-value">{{ request.availableDates }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.preferredSchedule %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Time</span>
                                            <span class="info-value">{{ request.preferredSchedule }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-info-footer">
                                        {% if request.message and request.message != 'No additional notes provided.' %}
                                        <div class="info-item wide">
                                            <span class="info-label">Message</span>
                                            <span class="info-value">{{ request.message|slice(0, 160) ~ (request.message|length > 160 ? '...' : '') }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.assignedMentorName %}
                                        <div class="info-item wide" style="margin-top:8px;padding-top:8px;border-top:1px solid #e5e7eb;">
                                            <span class="info-label">Assigned Mentor</span>
                                            <span class="info-value status-approved"><strong>{{ request.assignedMentorName }}</strong>{% if request.assignedMentorExpertise %} - {{ request.assignedMentorExpertise }}{% endif %}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.availableTime %}
                                        <div class="info-item wide">
                                            <span class="info-label">Confirmed Time</span>
                                            <span class="info-value">{{ request.availableDates ? request.availableDates ~ ' &middot; ' : '' }}{{ request.availableTime }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod %}
                                        <div class="info-item">
                                            <span class="info-label">Meeting Method</span>
                                            <span class="info-value">{{ request.meetingMethod }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod == 'Online' and request.meetingLink %}
                                        <div class="info-item wide">
                                            <span class="info-label">Meeting Link</span>
                                            <span class="info-value"><a href="{{ request.meetingLink }}" target="_blank" rel="noopener noreferrer" style="color:#0D9B00;font-weight:600;">Join Meeting</a></span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod == 'In Person' and request.meetingLocation %}
                                        <div class="info-item wide">
                                            <span class="info-label">Location</span>
                                            <span class="info-value">{{ request.meetingLocation }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.adminInstructions %}
                                        <div class="info-item wide">
                                            <span class="info-label">Admin Instructions</span>
                                            <span class="info-value">{{ request.adminInstructions }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.status == 'Cancelled' and request.cancellationReason %}
                                        <div class="info-item wide" style="margin-top:8px;padding-top:8px;border-top:1px solid #fecaca;background:#fef2f2;padding:12px;border-radius:6px;">
                                            <span class="info-label" style="color:#dc2626;">Cancellation Reason</span>
                                            <span class="info-value" style="color:#991b1b;">{{ request.cancellationReason }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% if request.status not in ['Cancelled', 'Completed'] %}
                                    <div class="card-actions" style="margin-top:12px;padding-top:12px;border-top:1px solid #e5e7eb;">
                                        <form method="post" action="{{ path('mentoring_assistance_update', {'id': request.id}) }}" onsubmit="event.preventDefault(); event.stopPropagation(); openCancelModal(this);">
                                            <input type="hidden" name="_token" value="{{ csrf_token('mentor_assistance_update_' ~ request.id) }}">
                                            <input type="hidden" name="action" value="cancel">
                                            <button type="submit" style="background:#dc2626;color:white;border:none;padding:7px 16px;border-radius:6px;cursor:pointer;font-size:12.5px;font-weight:600;" onclick="event.stopPropagation();">
                                                Cancel Request
                                            </button>
                                        </form>
                                    </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="empty-mini-state">
                                <p>No processed mentor requests yet.</p>
                                <p style="font-size: 13px; color: #6b7280; margin-top: 8px;">Pending requests appear in "My Pending Submission" tab.<br>Cancelled requests appear in "Cancelled Requests" tab.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Applications Cards -->
                <div class="mentoring-content hidden" id="applications-content">
                    <div class="reservations-grid">
                        {# Get all pending items - only truly pending statuses #}
                        {% set pendingApplications = applications|filter(application => application.status in ['Pending', 'Pending Review']) %}
                        {% set pendingMentorRequests = sentCustomRequests|filter(request => request.status in ['Pending']) %}
                        {% set totalPendingCount = pendingApplications|length + pendingMentorRequests|length %}
                        
                        {# Display Pending Mentor Requests #}
                        {% if pendingMentorRequests|length > 0 %}
                            <div class="pending-section-header" style="width: 100%; margin-bottom: 16px; padding: 12px 16px; background: #f0fdf4; border-radius: 8px; border-left: 4px solid #16a34a;">
                                <h4 style="margin: 0; color: #166534; font-size: 14px; font-weight: 600;">
                                    ðŸ“ Pending Mentor Requests ({{ pendingMentorRequests|length }})
                                </h4>
                            </div>
                            {% for request in pendingMentorRequests %}
                                <div class="reservation-card-new">
                                    <div class="card-title">
                                        {% if request.mentorProfile %}
                                            {{ request.mentorProfile.displayName }}
                                        {% elseif request.assignedMentorName %}
                                            {{ request.assignedMentorName }}
                                        {% elseif request.preferredExpertise %}
                                            {{ request.preferredExpertise }}
                                        {% else %}
                                            Mentor Assistance Request
                                        {% endif %}
                                    </div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Type</span>
                                            <span class="info-value">Mentor Request</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value status-{{ request.status|lower|replace({' ': '-'}) }}">{{ request.status }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ request.createdAt|date('M d, Y') }}</span>
                                        </div>
                                        {% if request.fullName %}
                                        <div class="info-item wide">
                                            <span class="info-label">Your Name</span>
                                            <span class="info-value">{{ request.fullName }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.preferredExpertise %}
                                        <div class="info-item">
                                            <span class="info-label">Specialization Needed</span>
                                            <span class="info-value">{{ request.preferredExpertise }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.departmentCourse %}
                                        <div class="info-item">
                                            <span class="info-label">Degree / Course</span>
                                            <span class="info-value">{{ request.departmentCourse }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.availableDates %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Day</span>
                                            <span class="info-value">{{ request.availableDates }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.preferredSchedule %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Time</span>
                                            <span class="info-value">{{ request.preferredSchedule }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod %}
                                        <div class="info-item">
                                            <span class="info-label">Meeting Method</span>
                                            <span class="info-value">{{ request.meetingMethod }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-info-footer">
                                        {% if request.message and request.message != 'No additional notes provided.' %}
                                        <div class="info-item wide">
                                            <span class="info-label">Message</span>
                                            <span class="info-value">{{ request.message|slice(0, 160) ~ (request.message|length > 160 ? '...' : '') }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.assignedMentorName %}
                                        <div class="info-item wide" style="margin-top:8px;padding-top:8px;border-top:1px solid #e5e7eb;">
                                            <span class="info-label">Assigned Mentor</span>
                                            <span class="info-value status-approved"><strong>{{ request.assignedMentorName }}</strong>{% if request.assignedMentorExpertise %} - {{ request.assignedMentorExpertise }}{% endif %}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.availableTime %}
                                        <div class="info-item wide">
                                            <span class="info-label">Confirmed Time</span>
                                            <span class="info-value">{{ request.availableDates ? request.availableDates ~ ' &middot; ' : '' }}{{ request.availableTime }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod == 'Online' and request.meetingLink %}
                                        <div class="info-item wide">
                                            <span class="info-label">Meeting Link</span>
                                            <span class="info-value"><a href="{{ request.meetingLink }}" target="_blank" rel="noopener noreferrer" style="color:#0D9B00;font-weight:600;">Join Meeting</a></span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod == 'In Person' and request.meetingLocation %}
                                        <div class="info-item wide">
                                            <span class="info-label">Location</span>
                                            <span class="info-value">{{ request.meetingLocation }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.adminInstructions %}
                                        <div class="info-item wide">
                                            <span class="info-label">Admin Instructions</span>
                                            <span class="info-value">{{ request.adminInstructions }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% if request.status not in ['Cancelled', 'Completed'] %}
                                    <div class="card-actions" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e7eb;">
                                        <form method="post" action="{{ path('mentoring_assistance_update', {'id': request.id}) }}" onsubmit="event.preventDefault(); event.stopPropagation(); openCancelModal(this);" style="display: inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('mentor_assistance_update_' ~ request.id) }}">
                                            <input type="hidden" name="action" value="cancel">
                                            <button type="submit" class="btn btn-danger btn-sm" style="background: #dc2626; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px;" onclick="event.stopPropagation();">
                                                Cancel Request
                                            </button>
                                        </form>
                                    </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% endif %}

                        {# Display Pending Applications #}
                        {% if pendingApplications|length > 0 %}
                            <div class="pending-section-header" style="width: 100%; margin: 24px 0 16px 0; padding: 12px 16px; background: #eff6ff; border-radius: 8px; border-left: 4px solid #2563eb;">
                                <h4 style="margin: 0; color: #1e40af; font-size: 14px; font-weight: 600;">
                                    ðŸŽ“ Pending Mentor Applications ({{ pendingApplications|length }})
                                </h4>
                            </div>
                            {% for application in pendingApplications %}
                                <div class="reservation-card-new">
                                    <div class="card-title">{{ application.specialization }}</div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Type</span>
                                            <span class="info-value">Mentor Application</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value status-pending">{{ application.status }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ application.createdAt|date('M d, Y') }}</span>
                                        </div>
                                        {% set applicantName = (application.firstName ~ ' ' ~ (application.lastName|default('')))|trim %}
                                        {% if applicantName %}
                                        <div class="info-item wide">
                                            <span class="info-label">Your Name</span>
                                            <span class="info-value">{{ applicantName }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.email %}
                                        <div class="info-item wide">
                                            <span class="info-label">Email</span>
                                            <span class="info-value">{{ application.email }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.programCourse %}
                                        <div class="info-item">
                                            <span class="info-label">Program/Course</span>
                                            <span class="info-value">{{ application.programCourse }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.currentProfession %}
                                        <div class="info-item">
                                            <span class="info-label">Profession</span>
                                            <span class="info-value">{{ application.currentProfession }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.highestEducation %}
                                        <div class="info-item">
                                            <span class="info-label">Education</span>
                                            <span class="info-value">{{ application.highestEducation }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.availabilityTime %}
                                        <div class="info-item">
                                            <span class="info-label">Availability</span>
                                            <span class="info-value">{{ application.availabilityTime }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-info-footer">
                                        {% if application.mentoringPublicBio %}
                                        <div class="info-item wide">
                                            <span class="info-label">Public Bio</span>
                                            <span class="info-value">{{ application.mentoringPublicBio|slice(0, 160) ~ (application.mentoringPublicBio|length > 160 ? '...' : '') }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.reason %}
                                        <div class="info-item wide">
                                            <span class="info-label">Reason for Applying</span>
                                            <span class="info-value">{{ application.reason|slice(0, 160) ~ (application.reason|length > 160 ? '...' : '') }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.adminNote %}
                                        <div class="info-item wide" style="margin-top:8px;padding-top:8px;border-top:1px solid #e5e7eb;">
                                            <span class="info-label">Admin Note</span>
                                            <span class="info-value" style="color:#666;font-style:italic;">{{ application.adminNote }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-actions" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e7eb;">
                                        <form method="post" action="{{ path('mentoring_cancel_application', {'id': application.id}) }}" onsubmit="return confirm('Are you sure you want to cancel this application? This action cannot be undone.');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cancel_application_' ~ application.id) }}">
                                            <button type="submit" class="btn btn-danger btn-sm" style="background: #dc2626; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px;">
                                            Cancel Application
                                        </button>
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}

                        {# Display Non-Pending Applications (historical) #}
                        {% for application in applications %}
                            {% if application.status not in ['Pending', 'Pending Review'] %}
                                <div class="reservation-card-new" style="opacity: 0.8;">
                                    <div class="card-title">{{ application.specialization }}</div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Type</span>
                                            <span class="info-value">Mentor Application</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value status-{{ application.status|lower|replace({' ': '-'}) }}">{{ application.status }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ application.createdAt|date('M d, Y') }}</span>
                                        </div>
                                        {% set applicantNameHistory = (application.firstName ~ ' ' ~ (application.lastName|default('')))|trim %}
                                        {% if applicantNameHistory %}
                                        <div class="info-item wide">
                                            <span class="info-label">Your Name</span>
                                            <span class="info-value">{{ applicantNameHistory }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.email %}
                                        <div class="info-item wide">
                                            <span class="info-label">Email</span>
                                            <span class="info-value">{{ application.email }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.programCourse %}
                                        <div class="info-item">
                                            <span class="info-label">Program/Course</span>
                                            <span class="info-value">{{ application.programCourse }}</span>
                                        </div>
                                        {% endif %}
                                        {% if application.currentProfession %}
                                        <div class="info-item">
                                            <span class="info-label">Profession</span>
                                            <span class="info-value">{{ application.currentProfession }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% if application.mentoringPublicBio or application.reason %}
                                    <div class="card-info-footer" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e7eb;">
                                        {% if application.mentoringPublicBio %}
                                        <div class="info-item wide">
                                            <span class="info-label">Public Bio</span>
                                            <span class="info-value">{{ application.mentoringPublicBio|slice(0, 100) ~ (application.mentoringPublicBio|length > 100 ? '...' : '') }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% else %}
                            {% if totalPendingCount == 0 %}
                                <div class="empty-mini-state">
                                    <p>You have no pending submissions. All your applications and requests have been processed.</p>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Mentor Application Cards -->
                <div class="mentoring-content hidden" id="mentor-application-content">
                    <div class="reservations-grid">
                        {% if is_granted('ROLE_MENTOR') %}
                            {% if mentorProfile %}
                                <div class="reservation-card-new">
                                    <div class="card-title">My Mentor Profile</div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item wide">
                                            <span class="info-label">Display Name</span>
                                            <span class="info-value">{{ mentorProfile.displayName }}</span>
                                        </div>
                                        <div class="info-item wide">
                                            <span class="info-label">Bio</span>
                                            <span class="info-value">{{ mentorProfile.bio }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Specialization</span>
                                            <span class="info-value">{{ mentorProfile.specialization }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Engagement Points</span>
                                            <span class="info-value">{{ mentorProfile.engagementPoints }}</span>
                                        </div>
                                    </div>
                                    <div class="card-actions card-actions-mt">
                                        <a href="{{ path('app_profile') }}" class="btn btn-primary">Edit Profile</a>
                                    </div>
                                </div>
                            {% else %}
                                <div class="empty-mini-state">
                                    <p>You are a mentor but your profile is not fully set up yet.</p>
                                    <a href="{{ path('app_profile') }}" class="btn btn-primary btn-mt">Complete Profile</a>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="empty-mini-state">
                                <p>You are not a mentor yet. Apply to become a mentor and share your expertise with others.</p>
                                {% if canApplyAsMentor %}
                                    <button type="button" class="btn btn-primary btn-mt mentoring-apply-btn" onclick="openMentorApplication()">Apply as Mentor</button>
                                {% elseif applications|length > 0 %}
                                    <p class="text-yellow-mt"><strong>Your application is pending review.</strong></p>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Incoming Requests Cards -->
                <div class="mentoring-content hidden" id="incoming-content">
                    <div class="reservations-grid">
                        {% if is_granted('ROLE_MENTOR') %}
                            {% if incomingCustomRequests|length > 0 %}
                                {% for request in incomingCustomRequests %}
                                    <div class="mentoring-card-new {{ request.status == 'accepted' ? 'session-item-clickable' : '' }}"
                                        {% if request.status == 'accepted' %}
                                        onclick="openSessionDetailsModal({
                                            isStudent: false,
                                            mentorName: '{{ request.mentorProfile ? request.mentorProfile.displayName|e('js') : 'You' }}',
                                            mentorEmail: '{{ request.mentorProfile ? request.mentorProfile.user.email|e('js') : '' }}',
                                            studentName: '{{ request.student ? request.student.firstName|e('js') : 'Student' }}',
                                            studentEmail: '{{ request.student ? request.student.email|e('js') : '' }}',
                                            scheduledDate: '{{ request.scheduledDate ? request.scheduledDate|date('F d, Y') : 'Flexible' }}',
                                            scheduledTime: '{{ request.scheduledTime|default('To be confirmed') }}',
                                            meetingType: '{{ request.meetingType|default('Not specified') }}',
                                            meetingLink: '{{ request.meetingLink|e('js') }}',
                                            facilityReservedBy: '{{ request.facilityReservedBy|e('js') }}',
                                            meetingLocation: '{{ request.meetingLocation|e('js') }}',
                                            status: '{{ request.status|capitalize }}',
                                            mentorResponse: '{{ request.mentorResponse|e('js') }}'
                                        })"
                                        {% endif %}>
                                        <div class="card-title">{{ request.student.firstName ?: request.student.email }}</div>
                                        <div class="card-divider"></div>
                                        <div class="card-info-grid">
                                            <div class="info-item">
                                                <span class="info-label">Status</span>
                                                <span class="info-value status-{{ request.status|lower }}">{{ request.status|capitalize }}</span>
                                            </div>
                                            <div class="info-item">
                                                <span class="info-label">Submitted</span>
                                                <span class="info-value">{{ request.createdAt|date('M d, Y') }}</span>
                                            </div>
                                            {% if request.status == 'accepted' %}
                                            <div class="info-item wide">
                                                <span class="view-details-btn">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                        <circle cx="12" cy="12" r="3"></circle>
                                                    </svg>
                                                    Click to view full details
                                                </span>
                                            </div>
                                            {% endif %}
                                            <div class="info-item wide">
                                                <span class="info-label">Student Email</span>
                                                <span class="info-value">{{ request.student.email }}</span>
                                            </div>
                                        </div>
                                        <div class="card-info-footer">
                                            <div class="info-item wide">
                                                <span class="info-label">Message</span>
                                                <span class="info-value">{{ request.message }}</span>
                                            </div>
                                        </div>
                                        {% if request.status == 'Pending' %}
                                        <div class="card-actions">
                                            {# Display scheduled date/time if available #}
                                            {% if request.scheduledDate %}
                                            <div class="scheduled-info" style="background:#f0fdf4; border:1px solid #bbf7d0; border-radius:8px; padding:10px 14px; margin-bottom:12px; font-size:13px;">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#166534" stroke-width="2" style="vertical-align:middle; margin-right:6px;">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                                </svg>
                                                <strong>Requested:</strong> {{ request.scheduledDate|date('F d, Y') }} at {{ request.scheduledTime ? request.scheduledTime|date('g:i A') : '-' }}
                                            </div>
                                            {% endif %}
                                            
                                            <div class="button-group button-group-mt">
                                                <button type="button" class="btn btn-primary-small" onclick="openAcceptModal({{ request.id }}, '{{ request.student.firstName|default('Student')|e('js') }}', '{{ request.scheduledDate ? request.scheduledDate|date('Y-m-d') : '' }}', '{{ request.scheduledTime|default('') }}', '{{ csrf_token('custom_request_review_' ~ request.id) }}')">Accept</button>
                                                <button type="button" class="btn btn-danger-small" onclick="openDeclineModal({{ request.id }}, '{{ csrf_token('custom_request_review_' ~ request.id) }}')">Decline</button>
                                            </div>
                                        </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="empty-mini-state">
                                    <p>No incoming mentoring requests yet.</p>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="empty-mini-state">
                                <p>Only mentors can view incoming requests. Apply to become a mentor to receive mentoring requests.</p>
                                {% if canApplyAsMentor %}
                                    <button type="button" class="btn btn-primary btn-mt mentoring-apply-btn" onclick="openMentorApplication()">Apply as Mentor</button>
                                {% elseif applications|length > 0 %}
                                    <p class="text-yellow-mt"><strong>Your application is pending review.</strong></p>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Cancelled Requests Cards -->
                <div class="mentoring-content hidden" id="cancelled-content">
                    <div class="reservations-grid">
                        {% set cancelledRequests = sentCustomRequests|filter(request => request.status == 'Cancelled') %}
                        {% if cancelledRequests|length > 0 %}
                            <div class="pending-section-header" style="width: 100%; margin-bottom: 16px; padding: 12px 16px; background: #fef2f2; border-radius: 8px; border-left: 4px solid #dc2626;">
                                <h4 style="margin: 0; color: #991b1b; font-size: 14px; font-weight: 600;">
                                    ðŸš« Cancelled Requests ({{ cancelledRequests|length }})
                                </h4>
                            </div>
                            {% for request in cancelledRequests %}
                                <div class="reservation-card-new" style="border-left: 4px solid #dc2626;">
                                    <div class="card-title" style="color: #dc2626;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" style="vertical-align: middle; margin-right: 6px;">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <line x1="15" y1="9" x2="9" y2="15"></line>
                                            <line x1="9" y1="9" x2="15" y2="15"></line>
                                        </svg>
                                        {% if request.mentorProfile %}
                                            {{ request.mentorProfile.displayName }}
                                        {% elseif request.assignedMentorName %}
                                            {{ request.assignedMentorName }}
                                        {% elseif request.preferredExpertise %}
                                            {{ request.preferredExpertise }}
                                        {% else %}
                                            Mentor Request
                                        {% endif %}
                                    </div>
                                    <div class="card-divider"></div>
                                    <div class="card-info-grid">
                                        <div class="info-item">
                                            <span class="info-label">Type</span>
                                            <span class="info-value">Mentor Request</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Status</span>
                                            <span class="info-value" style="color: #dc2626; font-weight: 600;">{{ request.status }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Submitted</span>
                                            <span class="info-value">{{ request.createdAt|date('M d, Y') }}</span>
                                        </div>
                                        <div class="info-item">
                                            <span class="info-label">Cancelled On</span>
                                            <span class="info-value">{{ request.updatedAt|date('M d, Y') }}</span>
                                        </div>
                                        {% if request.fullName %}
                                        <div class="info-item wide">
                                            <span class="info-label">Your Name</span>
                                            <span class="info-value">{{ request.fullName }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.preferredExpertise %}
                                        <div class="info-item">
                                            <span class="info-label">Specialization Needed</span>
                                            <span class="info-value">{{ request.preferredExpertise }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.departmentCourse %}
                                        <div class="info-item">
                                            <span class="info-label">Degree / Course</span>
                                            <span class="info-value">{{ request.departmentCourse }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.availableDates %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Day</span>
                                            <span class="info-value">{{ request.availableDates }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.preferredSchedule %}
                                        <div class="info-item">
                                            <span class="info-label">Preferred Time</span>
                                            <span class="info-value">{{ request.preferredSchedule }}</span>
                                        </div>
                                        {% endif %}
                                        {% if request.meetingMethod %}
                                        <div class="info-item">
                                            <span class="info-label">Meeting Method</span>
                                            <span class="info-value">{{ request.meetingMethod }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-info-footer" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #fecaca; background: #fef2f2; border-radius: 6px; padding: 12px;">
                                        {% if request.cancellationReason %}
                                        <div class="info-item wide">
                                            <span class="info-label" style="color: #dc2626;">ðŸ“ Cancellation Reason</span>
                                            <span class="info-value" style="color: #7f1d1d; font-style: italic;">{{ request.cancellationReason }}</span>
                                        </div>
                                        {% else %}
                                        <div class="info-item wide">
                                            <span class="info-label" style="color: #dc2626;">ðŸ“ Cancellation Reason</span>
                                            <span class="info-value" style="color: #9ca3af; font-style: italic;">No reason provided</span>
                                        </div>
                                        {% endif %}
                                        {% if request.message and request.message != 'No additional notes provided.' %}
                                        <div class="info-item wide" style="margin-top: 8px; padding-top: 8px; border-top: 1px dashed #fecaca;">
                                            <span class="info-label">Original Message</span>
                                            <span class="info-value" style="color: #6b7280;">{{ request.message|slice(0, 100) ~ (request.message|length > 100 ? '...' : '') }}</span>
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="empty-mini-state">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" style="margin-bottom: 16px;">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="15" y1="9" x2="9" y2="15"></line>
                                    <line x1="9" y1="9" x2="15" y2="15"></line>
                                </svg>
                                <p>No cancelled requests.</p>
                                <p style="font-size: 13px; color: #9ca3af; margin-top: 8px;">Cancelled requests will appear here for your records.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

            </div><!-- End Content Section -->
        </div><!-- End Mentors Section -->

    </div><!-- End Main Column -->

    <!-- Right Side Column - Summary -->
    <aside class="mentoring-side-column">

        <!-- Quick Actions -->
        <section class="mentoring-side-card">
            <div class="quick-actions-flex">
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('mentoring_super-admin') }}" class="btn-primary btn-full-width">Manage</a>
                {% endif %}
            </div>
        </section>

        <!-- Recent Request Summary (now contains Request button) -->
        <section class="reservations-side-card reservations-info-card">
            <div class="reservations-side-card-head">
                <h3>Recent Request</h3>
            </div>
            {% set recentRequest = sentCustomRequests|first %}
            {% if recentRequest %}
                <p>
                    <strong>
                        {% if recentRequest.preferredExpertise %}{{ recentRequest.preferredExpertise }}{% elseif recentRequest.mentorProfile %}{{ recentRequest.mentorProfile.displayName }}{% else %}Mentor Request{% endif %}
                    </strong> -
                    <span class="info-value status-{{ recentRequest.status|lower }}">{{ recentRequest.status|capitalize }}</span>
                    on {{ recentRequest.createdAt|date('M d, Y') }}.
                </p>
                {% if recentRequest.availableDates %}
                <p style="font-size:12px;color:#6b7280;margin:4px 0 0;">{{ recentRequest.availableDates }}{% if recentRequest.preferredSchedule %} &middot; {{ recentRequest.preferredSchedule }}{% endif %}</p>
                {% endif %}
                {% if recentRequest.assignedMentorName %}
                <p style="font-size:12px;color:#0D9B00;margin:4px 0 0;font-weight:600;">Assigned: {{ recentRequest.assignedMentorName }}</p>
                {% endif %}
            {% else %}
                <p>You have no mentoring requests yet. Submit a request to get started!</p>
            {% endif %}
            
            <div style="margin-top:12px; padding-top:12px; border-top:1px solid #e5e7eb;">
                <p style="margin:0 0 10px 0; font-size:13px; color:#6b7280; line-height:1.4;">Can't find a mentor that matches your needs? Click below to request assistance from the admin.</p>
                <a href="#" onclick="openMentorAssistance(); return false;" class="reserve-btn-large">
                    <span class="reserve-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                        </svg>
                    </span>
                    <span class="reserve-text">Request a Mentor</span>
                </a>
            </div>
        </section>

        <!-- Top Mentors -->
        <section class="reservations-side-card reservations-info-card">
            <div class="reservations-side-card-head">
                <h3>Traceability Leaderboard</h3>
            </div>
            <div class="mentor-list">
                {% for mentor in leaderboard|slice(0, 3) %}
                    <div class="mentor-item">
                        <div class="mentor-rank-icon">{{ loop.index == 1 ? 'â™•' : 'â™™' }}</div>
                        <div class="mentor-avatar">
                            <span>{{ mentor.displayName|first|upper }}</span>
                        </div>
                        <div class="mentor-info">
                            <div class="mentor-name">{{ mentor.displayName }}</div>
                            <div class="mentor-program">{{ mentor.specialization ?: 'General' }}</div>
                        </div>
                        <div class="mentor-points">
                            <span>Pts:</span> <strong>{{ mentor.engagementPoints }}</strong>
                        </div>
                    </div>
                {% else %}
                    <p style="font-size:12px;color:#6b7280;">No engagement points recorded yet. Points are earned when mentors complete sessions.</p>
                {% endfor %}
            </div>
        </section>

        <!-- Preferred Specializations -->
        <section class="mentoring-side-card mentoring-info-card" id="preferredSpecializationsPanel">
            {% include 'mentoring/_preferred_specializations.html.twig' with { specializations: specializations } only %}
        </section>
    </aside>
</div><!-- End Layout -->

    {% if canApplyAsMentor %}
        <div id="mentorApplicationModal" class="app-modal" aria-hidden="true">
            <div class="app-modal-backdrop" onclick="closeMentorApplication()"></div>
            <div class="app-modal-panel app-modal-large mentor-modal-panel" role="dialog" aria-modal="true" aria-labelledby="mentorApplicationTitle">
                <div class="app-modal-header mentor-modal-header">
                    <div>
                        <h3 id="mentorApplicationTitle" class="mentor-modal-title">Apply as Mentor</h3>
                        <p class="mentor-modal-subtitle">Your application will be reviewed by the Super Admin.</p>
                    </div>
                    <button type="button" class="icon-button mentor-modal-close" onclick="closeMentorApplication()" aria-label="Close">x</button>
                </div>

                <div class="mentor-application-layout mentor-application-layout-custom">
                    <aside class="mentor-application-summary mentor-application-summary-custom">
                        <div class="mentor-application-summary__eyebrow mentor-application-eyebrow">Mentor application</div>
                        <h4 class="mentor-application-heading">Share your strengths with the team</h4>
                        <p class="mentor-application-desc">Your application is reviewed by the Super Admin. Keep it clear, specific, and professional.</p>

                        <div class="mentor-application-points mentor-application-points-custom">
                            <div>
                                <strong class="mentor-point-title">Complete profile</strong>
                                <span class="mentor-point-desc">We use these details to review your background.</span>
                            </div>
                            <div>
                                <strong class="mentor-point-title">Professional proof</strong>
                                <span class="mentor-point-desc">Attach certificates, IDs, or samples if available.</span>
                            </div>
                            <div>
                                <strong class="mentor-point-title">Fast review</strong>
                                <span class="mentor-point-desc">Applications are kept organized for quick checking.</span>
                            </div>
                        </div>
                    </aside>

                    <form method="post" action="{{ path('mentoring_apply') }}" class="mentor-form" enctype="multipart/form-data">
                        <input type="hidden" name="_token" value="{{ csrf_token('mentor_application') }}">
                        {% include 'mentoring/_mentor_application_form_fields.html.twig' with { defaultUser: app.user, allSpecializations: allSpecializations } only %}
                        <div class="app-modal-actions mentor-modal-actions">
                            <button type="button" class="btn-secondary mentor-modal-cancel" onclick="closeMentorApplication()">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% endif %}

    <div id="mentorAssistanceModal" class="app-modal" aria-hidden="true">
        <div class="app-modal-backdrop" onclick="closeMentorAssistance()"></div>
        <div class="app-modal-panel app-modal-large" role="dialog" aria-modal="true" aria-labelledby="mentorAssistanceTitle">
            <div class="app-modal-header">
                <div>
                    <h3 id="mentorAssistanceTitle">Request a Mentor</h3>
                    <p>Can't find a mentor that matches your needs? Fill out this form and the admin will help you find the right mentor match.</p>
                </div>
                <button type="button" class="icon-button" onclick="closeMentorAssistance()" aria-label="Close">x</button>
            </div>

            <form method="post" action="{{ path('mentoring_assistance_request') }}" class="mentor-form mentor-assistance-form" data-loading-label="Submitting...">
                <input type="hidden" name="_token" value="{{ csrf_token('mentor_assistance_request') }}">
                <div class="form-section">
                    <h4>Request Details</h4>
                    <div class="form-grid form-grid-2">
                        <div class="form-group">
                            <label for="assistance_full_name">Full Name</label>
                            <input id="assistance_full_name" class="form-input" name="full_name" value="{{ (app.user.firstName ~ ' ' ~ app.user.lastName)|trim }}" required>
