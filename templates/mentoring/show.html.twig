{% extends 'layouts/app.html.twig' %}

{% block title %}{{ mentor.displayName }} - Mentor Profile | Reserva FTIC{% endblock %}

{% block content %}
<div class="mentor-page-container">
    <!-- Back Navigation -->
    <nav class="mentor-breadcrumb">
        <a href="{{ path('mentoring_index') }}" class="breadcrumb-link">
            <span class="breadcrumb-icon">←</span> Back to Mentors
        </a>
    </nav>

    <!-- Mentor Profile Hero Section -->
    <div class="mentor-hero-section">
        <div class="mentor-profile-card">
            <!-- Profile Picture -->
            <div class="mentor-profile-image">
                {% set user = mentor.user %}
                {% if user.profilePicture %}
                    <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" alt="{{ mentor.displayName }}" class="mentor-photo">
                {% else %}
                    <div class="mentor-avatar-placeholder">
                        <span>{{ mentor.displayName|first|upper }}</span>
                    </div>
                {% endif %}
                <div class="mentor-engagement-badge">
                    <span class="engagement-icon">⭐</span>
                    <strong>{{ mentor.engagementPoints }}</strong>
                    <p>Engagement Points</p>
                </div>
            </div>

            <!-- Mentor Information -->
            <div class="mentor-profile-info">
                <h1 class="mentor-name">{{ mentor.displayName }}</h1>
                    {% if app.user and app.user == mentor.user and 'ROLE_MENTOR' in app.user.roles %}
                        <div class="mentor-actions">
                            <a href="{{ path('app_profile') }}" class="btn-secondary">Edit public profile</a>
                        </div>
                    {% endif %}
                
                <div class="mentor-specialization-tag">
                    {{ mentor.specialization }} Mentor
                </div>

                <div class="mentor-credentials">
                    <div class="credential-item">
                        <span class="credential-label">Education</span>
                        <span class="credential-value">{{ mentor.education ?: (user.degreeName ?: user.degree ?: 'N/A') }}</span>
                    </div>
                    {% set availabilityDays = mentor.availabilityDays|default([]) %}
                    {% if availabilityDays|length > 0 or (mentor.availabilityStart and mentor.availabilityEnd) %}
                    <div class="credential-item">
                        <span class="credential-label">Schedule</span>
                        <span class="credential-value">
                            {% if availabilityDays|length > 0 %}
                                <strong style="color:#059669;">{{ availabilityDays|join(', ') }}</strong>
                            {% else %}
                                <span style="color:#d97706;">Days not specified</span>
                            {% endif %}
                            {% if mentor.availabilityStart and mentor.availabilityEnd %}
                                <br><span style="color:#64748b; font-size:0.9em;">
                                    {{ ('2000-01-01 ' ~ mentor.availabilityStart)|date('g:i A') }} – {{ ('2000-01-01 ' ~ mentor.availabilityEnd)|date('g:i A') }}
                                </span>
                            {% endif %}
                        </span>
                    </div>
                    {% endif %}
                    <div class="credential-item">
                        <span class="credential-label">Contact</span>
                        <span class="credential-value">{{ user.email }}</span>
                    </div>
                </div>

                <div class="mentor-bio-section">
                    <h3>About This Mentor</h3>
                    <p class="mentor-bio">{{ mentor.bio|default('This mentor hasn\'t added a bio yet. Contact them to learn more about their expertise and mentoring approach.') }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Custom Request Section -->
    <div class="custom-request-section">
        <div class="request-header">
            <h2>Schedule a Mentoring Session</h2>
            <p class="request-subtitle">Select an available date and time, then share your mentoring goals with {{ mentor.displayName }}.</p>
        </div>

        {% if canSendCustomRequest %}
            {% set availabilityDays = mentor.availabilityDays|default([]) %}
            {% set availabilityStart = mentor.availabilityStart|default('09:00') %}
            {% set availabilityEnd = mentor.availabilityEnd|default('17:00') %}
            
            <form method="post" action="{{ path('mentoring_custom_request', {'id': mentor.id}) }}" class="custom-request-form" id="customRequestForm">
                <input type="hidden" name="_token" value="{{ csrf_token('custom_request_' ~ mentor.id) }}" id="custom_request_token">
                
                {# Specialization Section #}
                <div class="form-section" style="margin-bottom:1.5rem;">
                    <label for="specialization" class="form-label" style="display:block; margin-bottom:.5rem; font-size:.95rem; font-weight:600; color:#374151;">
                        Your Specialization <span class="form-required">*</span>
                    </label>
                    <select name="specialization" 
                            id="specialization"
                            class="form-input"
                            required
                            onchange="toggleSpecializationOther(this, 'specialization_other')"
                            style="width:100%; padding:.75rem 1rem; border:1px solid #e5e7eb; border-radius:10px; font-size:1rem; color:#374151; background:#fff;">
                        <option value="">Select specialization…</option>
                        {% for specialization in allSpecializations %}
                        <option value="{{ specialization.name }}">{{ specialization.name }}</option>
                        {% endfor %}
                        <option value="Other">Other (specify below)</option>
                    </select>
                    <input type="text" 
                           name="specialization_other" 
                           id="specialization_other"
                           class="form-input"
                           placeholder="Please specify your specialization..."
                           style="width:100%; padding:.75rem 1rem; border:1px solid #e5e7eb; border-radius:10px; font-size:1rem; color:#374151; background:#fff; margin-top:.75rem; display:none;">
                </div>
                
                {# Calendar Scheduling Section #}
                <div class="scheduling-section" style="margin-bottom:1.5rem; padding:1.25rem; background:#f8fafc; border-radius:12px; border:1px solid #e2e8f0;">
                    <h4 style="margin:0 0 1rem 0; font-size:1rem; color:#1e293b; display:flex; align-items:center; gap:.5rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        Select Date
                    </h4>
                    
                    {# Date Picker #}
                    <div class="form-section" style="margin-bottom:1rem;">
                        <label for="scheduled_date" class="form-label">Select Date <span class="form-required">*</span></label>
                        <input type="date" 
                               name="scheduled_date" 
                               id="scheduled_date"
                               class="form-input scheduled-date-picker"
                               required
                               min="{{ "now"|date('Y-m-d') }}"
                               data-availability-days='{{ availabilityDays|json_encode|raw }}'
                               style="padding:0.75rem; font-size:1rem;{% if availabilityDays|length == 0 %}border-color:#f59e0b;{% endif %}">
                        {% if availabilityDays|length > 0 %}
                            <small class="form-hint" style="color:#059669; font-size:.875rem; margin-top:.25rem; display:block; font-weight:500;">
                                ✓ Mentor available on: {{ availabilityDays|join(', ') }}
                            </small>
                            <small class="form-hint" style="color:#64748b; font-size:.8rem; margin-top:.15rem; display:block;">
                                Please select one of these days. Other dates will be rejected.
                            </small>
                        {% else %}
                            <small class="form-hint" style="color:#d97706; font-size:.875rem; margin-top:.25rem; display:block; font-weight:500;">
                                ⚠ This mentor has not set specific available days. Any date can be selected.
                            </small>
                        {% endif %}
                        <div class="date-error" id="date_error" style="color:#dc2626; font-size:.875rem; margin-top:.25rem; display:none; background:#fef2f2; padding:0.5rem; border-radius:4px; border:1px solid #fecaca;"></div>
                    </div>
                    
                    <input type="hidden" name="scheduled_time" id="scheduled_time" value="{{ availabilityStart|default('09:00') }}">
                </div>
                
                {# Message Section #}
                <div class="form-section" style="margin-bottom:1.25rem;">
                    <label for="custom_message" class="form-label" style="display:flex; align-items:center; gap:.5rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                        </svg>
                        Your Message <span class="form-required">*</span>
                    </label>
                    <p class="form-helper-text" style="margin-top:.25rem; margin-bottom:.5rem; color:#64748b;">
                        Share your mentoring goals, preferred topics, and any specific questions you'd like to discuss.
                    </p>
                    <textarea 
                        name="message" 
                        id="custom_message" 
                        class="custom-textarea" 
                        rows="5" 
                        placeholder="Example: I'm interested in learning about AI and machine learning. I'd like to discuss career paths and get advice on building a portfolio..." 
                        required 
                        minlength="10"
                        maxlength="500"
                        style="padding:0.75rem; font-size:1rem;"></textarea>
                    <div class="character-count" style="text-align:right; margin-top:.25rem; font-size:.875rem; color:#64748b;">
                        <span id="char-count">0</span> / 500 characters
                        <span id="char-min" style="color:#dc2626; display:none;"> (minimum 10 characters)</span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary btn-lg" id="submitCustomRequest" style="display:flex; align-items:center; justify-content:center; gap:.5rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                        <span class="btn-text">Send Mentoring Request</span>
                    </button>
                    <p class="form-note" style="text-align:center; margin-top:.75rem; color:#64748b; font-size:.875rem;">
                        {{ mentor.displayName }} will review your request and confirm meeting details within 24-48 hours.
                    </p>
                </div>
            </form>
        {% else %}
            <div class="custom-request-disabled">
                <p class="alert alert-info" style="margin:0;">You cannot send a custom request to your own mentor profile.</p>
            </div>
        {% endif %}
    </div>

    <!-- Success Modal -->
    <div id="successModal" class="success-modal-overlay" style="display: none;">
        <div class="success-modal">
            <div class="success-modal-content">
                <div class="success-icon-container">
                    <div class="success-checkmark">
                        <svg viewBox="0 0 52 52" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="26" cy="26" r="25" fill="none" stroke="currentColor" stroke-width="2" class="checkmark-circle"/>
                            <path d="M15.5 26.5l7 7 14-15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="checkmark-mark"/>
                        </svg>
                    </div>
                </div>
                <h2 class="success-modal-title">Request Sent Successfully! ✨</h2>
                <p class="success-modal-message">
                    Your custom mentoring request has been sent to <strong>{{ mentor.displayName }}</strong>
                </p>
                <div class="success-modal-details">
                    <p>📧 They will receive your message via email and in-site notification</p>
                    <p>⏱️ You can expect a response within <strong>24-48 hours</strong></p>
                    <p>💬 Check your mentoring dashboard for updates</p>
                </div>
                <button class="btn-primary" onclick="closeSuccessModal()">Great, Thanks!</button>
            </div>
        </div>
    </div>

    <!-- Sessions Section -->
    <div class="sessions-section">
        <h2>Your Sessions with {{ mentor.displayName }}</h2>
        
        {% set hasSessions = myAppointments|length > 0 or myCustomRequests|length > 0 %}
        
        {% if hasSessions %}
            <div class="sessions-list">
                {# Show Custom Requests First #}
                {% for request in myCustomRequests %}
                    <div class="session-item session-custom">
                        <div class="session-datetime">
                            {% if request.scheduledDate %}
                                <span class="session-date">📅 {{ request.scheduledDate|date('M d, Y') }}</span>
                                {% if request.scheduledTime %}
                                    <span class="session-time">🕐 {{ request.scheduledTime|date('g:i A') }}</span>
                                {% endif %}
                            {% else %}
                                <span class="session-date">📅 Flexible Schedule</span>
                            {% endif %}
                        </div>
                        <div class="session-details">
                            <strong>{{ request.message|slice(0, 50) ~ (request.message|length > 50 ? '...' : '') }}</strong>
                            <small class="session-type">Custom Request</small>
                            {% if request.meetingType %}
                                <small class="session-meeting">
                                    📍 {{ request.meetingType }}
                                    {% if request.meetingLink %}
                                        <a href="{{ request.meetingLink }}" target="_blank" style="color:#3b82f6; text-decoration:underline;">Join Meeting</a>
                                    {% endif %}
                                    {% if request.facilityName %}
                                        | {{ request.facilityName }}
                                    {% endif %}
                                </small>
                            {% endif %}
                        </div>
                        <span class="status-badge status-{{ request.status|lower }}">{{ request.status|title }}</span>
                    </div>
                {% endfor %}
                
                {# Show Regular Appointments #}
                {% for appointment in myAppointments %}
                    <div class="session-item">
                        <div class="session-datetime">
                            <span class="session-date">📅 {{ appointment.scheduledAt|date('M d, Y') }}</span>
                            <span class="session-time">🕐 {{ appointment.scheduledAt|date('g:i A') }}</span>
                        </div>
                        <div class="session-details">
                            <strong>{{ appointment.topic ?: 'General Mentoring Session' }}</strong>
                            <small class="session-type">Scheduled Session</small>
                        </div>
                        <span class="status-badge status-{{ appointment.status|lower }}">{{ appointment.status }}</span>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-sessions">
                <p class="empty-icon">📅</p>
                <p class="empty-text">You haven't booked any sessions with this mentor yet.</p>
                <p class="empty-subtext">Send a custom request above to schedule your first mentoring session!</p>
            </div>
        {% endif %}
    </div>
</div>

<style>
    #custom_message {
        resize: vertical;
    }

    /* Success Modal Styles */
    .success-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(4px);
        animation: fadeIn 0.3s ease-out;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .success-modal {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
        max-width: 450px;
        width: 90%;
        overflow: hidden;
        animation: slideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes slideUp {
        from {
            transform: translateY(30px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .success-modal-content {
        padding: 40px 32px;
        text-align: center;
    }

    .success-icon-container {
        margin-bottom: 24px;
    }

    .success-checkmark {
        width: 80px;
        height: 80px;
        margin: 0 auto;
        color: #0D9B00;
        animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    }

    @keyframes scaleIn {
        from {
            transform: scale(0);
            opacity: 0;
        }
        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .success-checkmark svg {
        width: 100%;
        height: 100%;
    }

    .checkmark-circle {
        transform-origin: 50% 50%;
        stroke-dasharray: 157;
        stroke-dashoffset: 157;
        animation: strokeCircle 0.6s cubic-bezier(0.65, 0, 0.45, 1) 0.4s forwards;
    }

    @keyframes strokeCircle {
        to {
            stroke-dashoffset: 0;
        }
    }

    .checkmark-mark {
        transform-origin: 50% 50%;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: strokeMark 0.6s cubic-bezier(0.65, 0, 0.45, 1) 0.6s forwards;
    }

    @keyframes strokeMark {
        to {
            stroke-dashoffset: 0;
        }
    }

    .success-modal-title {
        font-size: 24px;
        font-weight: 700;
        color: #1f2937;
        margin: 0 0 12px 0;
        animation: fadeIn 0.5s ease-out 0.3s both;
    }

    .success-modal-message {
        font-size: 16px;
        color: #6b7280;
        margin: 0 0 24px 0;
        line-height: 1.5;
        animation: fadeIn 0.5s ease-out 0.4s both;
    }

    .success-modal-details {
        background: linear-gradient(135deg, rgba(13, 155, 0, 0.05) 0%, rgba(13, 155, 0, 0.08) 100%);
        border-radius: 12px;
        padding: 20px;
        margin: 0 0 24px 0;
        text-align: left;
        animation: fadeIn 0.5s ease-out 0.5s both;
    }

    .success-modal-details p {
        font-size: 14px;
        color: #4b5563;
        margin: 8px 0;
        line-height: 1.6;
    }

    .success-modal-details p:first-child {
        margin-top: 0;
    }

    .success-modal-details p:last-child {
        margin-bottom: 0;
    }

    .success-modal-details strong {
        color: #0D9B00;
        font-weight: 600;
    }

    .success-modal button {
        animation: fadeIn 0.5s ease-out 0.6s both;
    }

    /* Loading state for button */
    .submit-loading {
        opacity: 0.7;
        pointer-events: none;
    }

    .submit-loading .btn-text {
        display: none;
    }

    .submit-loading::after {
        content: '';
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top: 2px solid white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<script>
    // Toggle "Other" specialization text box
    function toggleSpecializationOther(select, otherInputId) {
        const otherInput = document.getElementById(otherInputId);
        if (otherInput) {
            otherInput.style.display = select.value === 'Other' ? 'block' : 'none';
            if (select.value !== 'Other') {
                otherInput.value = '';
            }
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const textarea = document.getElementById('custom_message');
        const charCount = document.getElementById('char-count');
        const charMin = document.getElementById('char-min');
        const customRequestForm = document.getElementById('customRequestForm');
        const datePicker = document.getElementById('scheduled_date');
        const dateError = document.getElementById('date_error');

        // Character counter with min validation
        if (textarea && charCount) {
            function updateCharCount() {
                const len = textarea.value.length;
                charCount.textContent = len;
                if (charMin) {
                    charMin.style.display = len > 0 && len < 10 ? 'inline' : 'none';
                }
                charCount.style.color = len < 10 ? '#dc2626' : (len > 450 ? '#d97706' : '#64748b');
            }
            textarea.addEventListener('input', updateCharCount);
            updateCharCount();
        }

        // Calendar scheduling functionality
        const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

        // Date validation based on mentor availability
        if (datePicker && dateError) {
            let availabilityDays = [];
            try {
                availabilityDays = JSON.parse(datePicker.dataset.availabilityDays || '[]');
            } catch (e) {
                console.error('Error parsing availability days:', e);
                availabilityDays = [];
            }
            
            console.log('Mentor availability days:', availabilityDays);
            
            datePicker.addEventListener('change', function() {
                if (!this.value) {
                    dateError.style.display = 'none';
                    return;
                }
                
                const selectedDate = new Date(this.value + 'T00:00:00');
                const dayName = dayNames[selectedDate.getDay()];
                
                console.log('Selected date:', this.value, 'Day:', dayName);
                
                // If mentor has specific available days, validate against them
                if (availabilityDays.length > 0) {
                    if (!availabilityDays.includes(dayName)) {
                        dateError.innerHTML = '<strong>⚠ Date not available</strong><br>This mentor only accepts requests for: <strong>' + availabilityDays.join(', ') + '</strong>. Please select a different date.';
                        dateError.style.display = 'block';
                        this.value = '';
                        // Scroll to error
                        dateError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    } else {
                        dateError.style.display = 'none';
                    }
                } else {
                    // No specific days set - any day is allowed
                    dateError.style.display = 'none';
                    console.log('No availability days set - allowing any date');
                }
            });
        }

        // Form validation before submit
        if (customRequestForm) {
            customRequestForm.addEventListener('submit', function(e) {
                const dateVal = datePicker ? datePicker.value : '';
                const messageVal = textarea ? textarea.value.trim() : '';
                
                if (!dateVal || !messageVal || messageVal.length < 10) {
                    e.preventDefault();
                    let errors = [];
                    if (!dateVal) errors.push('Please select a date');
                    if (!messageVal || messageVal.length < 10) errors.push('Please enter a message (minimum 10 characters)');
                    alert('Please fix the following:\n• ' + errors.join('\n• '));
                    return false;
                }
            });
        }
    });

    function showSuccessModal() {
        const modal = document.getElementById('successModal');
        if (modal) {
            modal.style.display = 'flex';
        }
    }

    function closeSuccessModal() {
        const modal = document.getElementById('successModal');
        if (modal) {
            modal.style.display = 'none';
        }
    }

    // Close modal when clicking outside
    document.addEventListener('click', function(e) {
        const modal = document.getElementById('successModal');
        if (modal && e.target === modal) {
            closeSuccessModal();
        }
    });
</script>
{% endblock %}

