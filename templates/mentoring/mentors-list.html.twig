{% extends 'layouts/app.html.twig' %}
{% block title %}Mentors | Reserva FTIC{% endblock %}
{% block stylesheets %}{{ parent() }}
<style>
.ml-page { display:flex; flex-direction:column; gap:18px; }
.ml-toolbar { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
.ml-search { flex:1; min-width:180px; display:flex; align-items:center; gap:8px; border:1px solid #e5e7eb; border-radius:9px; padding:0 14px; background:#fff; height:40px; }
.ml-search input { flex:1; border:none; outline:none; font-size:13px; color:#374151; background:transparent; }
.ml-search svg { color:#9ca3af; flex-shrink:0; }
.ml-filter { padding:9px 14px; border:1px solid #e5e7eb; border-radius:9px; font-size:13px; color:#374151; background:#fff; cursor:pointer; }
.ml-filter:focus { outline:none; border-color:#0D9B00; }
.ml-back { display:flex; align-items:center; gap:7px; padding:10px 16px; background:#fff; color:#374151; border:1px solid #e5e7eb; border-radius:9px; font-size:13px; font-weight:600; text-decoration:none; transition:background .15s; }
.ml-back:hover { background:#f9fafb; }
.ml-count { font-size:12px; color:#6b7280; white-space:nowrap; align-self:center; }

/* grid */
.ml-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; }

/* card */
.ml-card { background:#fff; border:1px solid #e5e7eb; border-radius:14px; padding:20px; display:flex; flex-direction:column; gap:12px; transition:box-shadow .15s; }
.ml-card:hover { box-shadow:0 4px 18px rgba(0,0,0,.07); }
.ml-card-top { display:flex; align-items:center; gap:12px; }
.ml-avatar { width:46px; height:46px; border-radius:50%; background:#e5e7eb; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:700; color:#374151; flex-shrink:0; }
.ml-avatar.green { background:#dcfce7; color:#166534; }
.ml-name { font-size:14px; font-weight:700; color:#111827; margin-bottom:2px; }
.ml-email { font-size:11.5px; color:#9ca3af; }
.ml-spec-badge { display:inline-flex; align-items:center; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:700; background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; width:fit-content; }
.ml-divider { height:1px; background:#f3f4f6; }
.ml-meta { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.ml-meta-item label { font-size:10px; color:#9ca3af; font-weight:600; display:block; margin-bottom:2px; }
.ml-meta-item p { font-size:12px; font-weight:600; color:#374151; margin:0; }
.ml-actions { display:flex; gap:8px; margin-top:2px; }
.ml-edit-btn { flex:1; display:flex; align-items:center; justify-content:center; gap:6px; padding:8px; background:#f9fafb; color:#374151; border:1px solid #e5e7eb; border-radius:8px; font-size:12px; font-weight:600; text-decoration:none; transition:background .15s; }
.ml-edit-btn:hover { background:#f3f4f6; }
.ml-pts { display:flex; align-items:center; gap:5px; font-size:12px; font-weight:700; color:#0D9B00; }

/* empty state */
.ml-empty { text-align:center; padding:60px 20px; color:#9ca3af; font-size:13px; }
.ml-empty svg { margin-bottom:12px; opacity:.4; }

/* no-result message */
#mlNoResult { display:none; text-align:center; padding:40px; color:#9ca3af; font-size:13px; }
</style>
{% endblock %}

{% block content %}
<div class="ml-page">

    <div class="ml-toolbar">
        <a href="{{ path('mentoring_superadmin_requests') }}" class="ml-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            Back
        </a>
        <div class="ml-search">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="mlSearch" placeholder="Search mentors by name, specialization…" oninput="mlFilter()">
        </div>
        <select class="ml-filter" id="mlSpecFilter" onchange="mlFilter()">
            <option value="">All Specializations</option>
            {% set specs = [] %}
            {% for m in mentors %}
                {% if m.specialization not in specs %}
                    {% set specs = specs|merge([m.specialization]) %}
                    <option value="{{ m.specialization|lower }}">{{ m.specialization }}</option>
                {% endif %}
            {% endfor %}
        </select>
        <span class="ml-count" id="mlCount">{{ mentors|length }} mentor{{ mentors|length != 1 ? 's' : '' }}</span>
    </div>

    {% if mentors is empty %}
    <div class="ml-empty">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        <div>No mentors found. Create one from the dashboard.</div>
    </div>
    {% else %}
    <div id="mlNoResult">No mentors match your search.</div>
    <div class="ml-grid" id="mlGrid">
        {% for mentor in mentors %}
        <div class="ml-card" data-name="{{ mentor.displayName|lower }}" data-spec="{{ mentor.specialization|lower }}">
            <div class="ml-card-top">
                <div class="ml-avatar green">{{ mentor.displayName|slice(0,1)|upper }}</div>
                <div>
                    <div class="ml-name">{{ mentor.displayName }}</div>
                    <div class="ml-email">{{ mentor.user ? mentor.user.email : '—' }}</div>
                </div>
            </div>
            <div class="ml-spec-badge">{{ mentor.specialization }}</div>
            <div class="ml-divider"></div>
            <div class="ml-meta">
                <div class="ml-meta-item">
                    <label>Program</label>
                    <p>{{ mentor.user ? (mentor.user.degreeName ?: mentor.user.degree ?: '—') : '—' }}</p>
                </div>
                <div class="ml-meta-item">
                    <label>Engagement</label>
                    <p class="ml-pts">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="#0D9B00" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        {{ mentor.engagementPoints }} pts
                    </p>
                </div>
                {% if mentor.availabilityStart and mentor.availabilityEnd %}
                <div class="ml-meta-item">
                    <label>Availability</label>
                    <p>{{ ('2000-01-01 ' ~ mentor.availabilityStart)|date('g:i A') }} – {{ ('2000-01-01 ' ~ mentor.availabilityEnd)|date('g:i A') }}</p>
                </div>
                {% endif %}
                {% if mentor.user %}
                <div class="ml-meta-item">
                    <label>Role</label>
                    <p>{{ mentor.user.roles|join(', ')|replace({'ROLE_':'','_':' '})|lower|capitalize }}</p>
                </div>
                {% endif %}
            </div>
            {% if mentor.bio %}
            <div style="font-size:11.5px;color:#6b7280;line-height:1.5;background:#f9fafb;border-radius:8px;padding:8px 11px;">{{ mentor.bio|slice(0,120) }}{% if mentor.bio|length > 120 %}…{% endif %}</div>
            {% endif %}
            <div class="ml-actions">
                <button type="button" class="ml-edit-btn" onclick="mlOpenEdit('{{ path('mentoring_edit_mentor', {'id': mentor.id}) }}', {{ mentor.id }})">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit
                </button>
                <form method="post" action="{{ path('mentoring_delete_mentor', {'id': mentor.id}) }}" onsubmit="return confirm('Delete {{ mentor.displayName }}?')" style="flex:1;display:flex;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_mentor_' ~ mentor.id) }}">
                    <button type="submit" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:8px;background:#fff;color:#ef4444;border:1px solid #fecaca;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s;" onmouseover="this.style.background='#fef2f2'" onmouseout="this.style.background='#fff'">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                        Delete
                    </button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

</div>
{# ── Edit Mentor Modal ── #}
<div id="mlEditModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:9200;align-items:center;justify-content:center;overflow-y:auto;padding:24px 16px;">
    <div id="mlEditBackdrop" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.35);backdrop-filter:blur(4px);z-index:0;" onclick="mlCloseEdit()"></div>
    <div style="position:relative;z-index:1;background:#fff;border-radius:16px;padding:32px 36px 28px;width:100%;max-width:620px;margin:auto;box-shadow:0 24px 64px rgba(0,0,0,.18);">
        <button onclick="mlCloseEdit()" style="position:absolute;top:14px;right:18px;background:none;border:none;font-size:22px;color:#9ca3af;cursor:pointer;line-height:1;">×</button>
        <h3 id="mlEditTitle" style="font-size:17px;font-weight:700;color:#111827;margin:0 0 22px;">Edit Mentor</h3>
        <div id="mlEditBody">
            <div style="padding:40px;text-align:center;color:#9ca3af;font-size:13px;">Loading…</div>
        </div>
    </div>
</div>

<script>
function mlOpenEdit(url, id) {
    var modal = document.getElementById('mlEditModal');
    var body  = document.getElementById('mlEditBody');
    modal.style.display = 'flex';
    body.innerHTML = '<div style="padding:40px;text-align:center;color:#9ca3af;font-size:13px;">Loading…</div>';

    fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r){ return r.ok ? r.text() : Promise.reject(r.status); })
        .then(function(html) {
            /* Parse the returned full page and extract form fields */
            var doc = new DOMParser().parseFromString(html, 'text/html');
            var form = doc.querySelector('form[action*="/edit"]') || doc.querySelector('form');
            if (!form) { body.innerHTML = '<div style="padding:20px;color:#ef4444;">Could not load edit form.</div>'; return; }

            /* Restyle form for modal context */
            form.style.cssText = '';
            /* Replace any btn-primary / btn-secondary styling */
            form.querySelectorAll('.btn-primary').forEach(function(b){ b.style.cssText='padding:10px 28px;background:#0D9B00;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;'; });
            form.querySelectorAll('.btn-secondary').forEach(function(b){ b.style.display='none'; });
            form.querySelectorAll('.form-input').forEach(function(i){ i.style.cssText='width:100%;padding:9px 12px;border:1px solid #e5e7eb;border-radius:8px;font-size:13px;color:#374151;background:#fff;box-sizing:border-box;font-family:inherit;'; });
            form.querySelectorAll('.form-group label').forEach(function(l){ l.style.cssText='display:block;margin-bottom:5px;font-size:11px;font-weight:600;color:#6b7280;'; });
            form.querySelectorAll('.form-group').forEach(function(g){ g.style.marginBottom='14px'; });
            /* Remove user-info read-only section to keep modal clean */
            form.querySelectorAll('.user-info').forEach(function(u){ u.closest('.form-group') && (u.closest('.form-group').style.display='none'); });

            body.innerHTML = '';
            body.appendChild(form);

            /* Intercept submit → AJAX */
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                var btn = form.querySelector('button[type="submit"]');
                var orig = btn ? btn.innerHTML : '';
                if (btn) { btn.disabled = true; btn.innerHTML = 'Saving…'; }
                fetch(form.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new FormData(form)
                })
                .then(function(r) {
                    /* Controller redirects on success — treat any 2xx/3xx as success */
                    if (r.ok || r.redirected) { mlCloseEdit(); window.location.reload(); }
                    else { throw new Error(); }
                })
                .catch(function() {
                    if (btn) { btn.disabled = false; btn.innerHTML = orig; }
                    mlToast('Could not save. Please try again.', false);
                });
            });
        })
        .catch(function(err) {
            body.innerHTML = '<div style="padding:20px;color:#ef4444;">Failed to load (' + err + '). <a href="' + url + '" style="color:#0D9B00;">Open in full page</a></div>';
        });
}
function mlCloseEdit() {
    document.getElementById('mlEditModal').style.display = 'none';
}
function mlToast(msg, ok) {
    var n = document.createElement('div');
    n.style.cssText = 'position:fixed;top:16px;right:16px;z-index:9999;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;box-shadow:0 4px 12px rgba(0,0,0,.12);transition:opacity .3s;';
    n.style.background = ok ? '#d1fae5' : '#fee2e2';
    n.style.color = ok ? '#065f46' : '#991b1b';
    n.textContent = msg;
    document.body.appendChild(n);
    setTimeout(function(){ n.style.opacity = '0'; setTimeout(function(){ n.remove(); }, 300); }, 3200);
}
document.addEventListener('keydown', function(e){ if (e.key === 'Escape') mlCloseEdit(); });

function mlFilter() {
    var q    = document.getElementById('mlSearch').value.toLowerCase();
    var spec = document.getElementById('mlSpecFilter').value.toLowerCase();
    var cards = document.querySelectorAll('#mlGrid .ml-card');
    var shown = 0;
    cards.forEach(function(c) {
        var nameMatch = !q || c.dataset.name.includes(q) || c.dataset.spec.includes(q);
        var specMatch = !spec || c.dataset.spec === spec;
        var ok = nameMatch && specMatch;
        c.style.display = ok ? '' : 'none';
        if (ok) shown++;
    });
    var nr = document.getElementById('mlNoResult');
    var cnt = document.getElementById('mlCount');
    if (nr) nr.style.display = shown === 0 ? '' : 'none';
    if (cnt) cnt.textContent = shown + ' mentor' + (shown !== 1 ? 's' : '');
}
</script>
{% endblock %}
