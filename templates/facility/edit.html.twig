{% extends 'layouts/app.html.twig' %}

{% block title %}Edit Facility | Reserva FTIC{% endblock %}

{% block content %}
    <div class="content-header">
        <a href="{{ path('app_facility_management') }}" class="btn-secondary" style="margin-right: 15px;">← Back</a>
        <h2>Edit Facility</h2>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}" style="padding: 10px; margin: 10px 0; border-radius: 4px; background-color: {{ label == 'error' ? '#fee2e2' : '#dcfce7' }}; color: {{ label == 'error' ? '#dc2626' : '#16a34a' }};">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card-panel">
        <form method="POST" enctype="multipart/form-data" style="max-width: 600px;">
            <div class="form-group">
                <label for="name">Facility Name <span style="color: #dc2626;">*</span></label>
                <input type="text" id="name" name="name" value="{{ facility.name }}" required>
            </div>

            <div class="form-group">
                <label for="capacity">Capacity (pax) <span style="color: #dc2626;">*</span></label>
                <input type="number" id="capacity" name="capacity" value="{{ facility.capacity }}" required min="1">
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5">{{ facility.description }}</textarea>
            </div>

            <div class="form-group">
                <label for="image">Facility Image</label>
                {% if facility.image %}
                    <div style="margin-bottom: 15px; padding: 15px; background: #f9f9f9; border-radius: 6px; text-align: center;">
                        <img src="{{ facility.image ~ '?v=' ~ facility.updatedAt|date('U') }}" alt="{{ facility.name }}" style="max-width: 200px; max-height: 200px; margin-bottom: 10px; border-radius: 6px; display: block; margin-left: auto; margin-right: auto;">
                        <p style="margin: 0; color: #666; font-size: 12px; margin-bottom: 8px;">Current Image</p>
                        <button type="button" onclick="deleteMainImage({{ facility.id }})" class="btn-secondary" style="font-size: 12px; padding: 6px 12px;">Delete Image</button>
                    </div>
                {% endif %}
                <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/webp,image/gif">
                <small style="color:#6b7280;">Accepted: JPEG, PNG, WebP (HEIC not supported by browsers)</small>
            </div>

            <div class="form-group">
                <label for="images">Add Gallery Images <span style="color: #666; font-size: 12px;">(Maximum: 5 gallery images - main facility image is separate)</span></label>
                <p style="font-size: 12px; color: #666; margin: 5px 0;">
                    Current gallery images: <span id="currentImageCount">{{ facility.images|length }}</span> / 5
                </p>
                
                <div style="position: relative;">
                    <div id="galleryUploadArea" style="display: block; border: 2px dashed #d1d5db; border-radius: 8px; padding: 2rem; text-align: center; cursor: pointer; transition: all 0.3s ease; background: #f9fafb;">
                        <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">📷</div>
                        <p style="margin: 0; color: #374151; font-weight: 500;">Click to add images</p>
                        <p style="margin: 0.25rem 0 0 0; color: #6b7280; font-size: 0.875rem;">or drag and drop files here</p>
                    </div>
                    <input type="file" id="images" name="images[]" accept="image/jpeg,image/png,image/webp,image/gif" multiple style="display: none;">
                </div>
                
                <div id="selectedImagesPreview" style="display: none; margin-top: 1rem;">
                    <p style="font-size: 0.875rem; color: #374151; font-weight: 500; margin-bottom: 0.5rem;">
                        Selected images: <span id="selectedCount">0</span>
                    </p>
                    <div id="selectedImagesList" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 0.75rem;"></div>
                </div>
            </div>

            <style>
                @keyframes slideIn {
                    from {
                        transform: translateY(-20px);
                        opacity: 0;
                    }
                    to {
                        transform: translateY(0);
                        opacity: 1;
                    }
                }
            </style>

            <div style="display: flex; gap: 12px;">
                <button type="submit" class="btn-primary">Update Facility</button>
                <a href="{{ path('app_facility_management') }}" class="btn-secondary">Cancel</a>
            </div>
        </form>

        {% if facility.images|length > 0 %}
            <div class="form-group" style="margin-top: 2rem;">
                <label>Gallery Management</label>
                <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap:12px;">
                    {% for image in facility.images %}
                        <div style="border:1px solid #e5e7eb; border-radius:8px; padding:8px;">
                            <img src="{{ image.path ~ '?v=' ~ image.createdAt|date('U') }}" alt="{{ facility.name }}" style="width:100%; height:100px; object-fit:cover; border-radius:6px;" loading="lazy">
                            <button type="button" onclick="deleteGalleryImage({{ image.id }}, '{{ csrf_token('delete_image' ~ image.id) }}')" class="btn-secondary" style="width:100%; margin-top:8px;">Remove</button>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>

    <!-- Delete Main Image Modal -->
    <div id="deleteImageModal" class="delete-schedule-modal">
        <div class="delete-schedule-dialog">
            <div class="delete-schedule-icon">!</div>
            <h3>Delete Facility Image?</h3>
            <p>This will permanently delete the facility image. This action cannot be undone.</p>
            <div class="delete-schedule-actions">
                <button type="button" id="cancelDeleteImage" class="delete-schedule-cancel">Cancel</button>
                <button type="button" id="confirmDeleteImage" class="delete-schedule-confirm">Yes, Delete Image</button>
            </div>
        </div>
    </div>

    <!-- Delete Gallery Image Modal -->
    <div id="deleteGalleryImageModal" class="delete-schedule-modal">
        <div class="delete-schedule-dialog">
            <div class="delete-schedule-icon">!</div>
            <h3>Delete Gallery Image?</h3>
            <p>This will permanently delete this gallery image. This action cannot be undone.</p>
            <div class="delete-schedule-actions">
                <button type="button" id="cancelDeleteGalleryImage" class="delete-schedule-cancel">Cancel</button>
                <button type="button" id="confirmDeleteGalleryImage" class="delete-schedule-confirm">Yes, Delete Image</button>
            </div>
        </div>
    </div>

    <style>
        .delete-schedule-modal { display:none; position:fixed; top:0; left:0; width:100vw; height:100vh; z-index:9999; align-items:center; justify-content:center; padding:1.5rem; background:rgba(15,23,42,.6); backdrop-filter:blur(8px); }
        .delete-schedule-modal.is-open { display:flex; }
        .delete-schedule-dialog { width:min(440px,100%); background:white; border-radius:20px; padding:2rem; text-align:center; box-shadow:0 24px 70px rgba(15,23,42,.28); animation:deleteModalIn .18s ease-out; }
        .delete-schedule-icon { width:56px; height:56px; margin:0 auto 1rem; border-radius:999px; display:flex; align-items:center; justify-content:center; color:#991b1b; background:#fee2e2; border:1px solid #fecaca; font-size:1.6rem; font-weight:800; }
        .delete-schedule-dialog h3 { margin:0 0 .75rem; color:#111827; font-size:1.25rem; }
        .delete-schedule-dialog p  { margin:0; color:#6b7280; line-height:1.55; font-size:.9rem; }
        .delete-schedule-actions { display:flex; gap:.75rem; justify-content:center; margin-top:1.5rem; }
        .delete-schedule-actions button { border:none; border-radius:10px; padding:.7rem 1.1rem; font-weight:800; cursor:pointer; font-size:.9rem; }
        .delete-schedule-cancel  { background:#f3f4f6; color:#374151; }
        .delete-schedule-confirm { background:#dc2626; color:white; }
        @keyframes deleteModalIn { from{opacity:0;transform:translateY(12px) scale(.98)} to{opacity:1;transform:translateY(0) scale(1)} }
    </style>

    <script>
        const maxImages = 5;
        const currentImageCount = {{ facility.images|length }};
        let selectedFiles = [];
        let deleteImageCallback = null;
        let deleteGalleryImageCallback = null;

        // Move modals to body to ensure they cover header/sidebar and center properly
        document.addEventListener('DOMContentLoaded', function() {
            const modal = document.getElementById('deleteImageModal');
            if (modal && modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
            const galleryModal = document.getElementById('deleteGalleryImageModal');
            if (galleryModal && galleryModal.parentElement !== document.body) {
                document.body.appendChild(galleryModal);
            }
        });

        function showModal(message) {
            // Simple alert for non-confirm messages
            alert(message);
        }

        function deleteMainImage(facilityId) {
            deleteImageCallback = function() {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '{{ path('app_facility_delete_main_image', {id: 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', facilityId);
                
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '_token';
                tokenInput.value = '{{ csrf_token('delete_image' ~ facility.id) }}';
                
                form.appendChild(tokenInput);
                document.body.appendChild(form);
                form.submit();
            };
            document.getElementById('deleteImageModal').classList.add('is-open');
        }

        function deleteGalleryImage(imageId, token) {
            deleteGalleryImageCallback = function() {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '{{ path('app_facility_image_delete', {id: 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', imageId);
                
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '_token';
                tokenInput.value = token;
                
                form.appendChild(tokenInput);
                document.body.appendChild(form);
                form.submit();
            };
            document.getElementById('deleteGalleryImageModal').classList.add('is-open');
        }

        document.getElementById('cancelDeleteImage').addEventListener('click', function() {
            document.getElementById('deleteImageModal').classList.remove('is-open');
            deleteImageCallback = null;
        });

        document.getElementById('confirmDeleteImage').addEventListener('click', function() {
            if (deleteImageCallback) {
                deleteImageCallback();
            }
            document.getElementById('deleteImageModal').classList.remove('is-open');
            deleteImageCallback = null;
        });

        document.getElementById('cancelDeleteGalleryImage').addEventListener('click', function() {
            document.getElementById('deleteGalleryImageModal').classList.remove('is-open');
            deleteGalleryImageCallback = null;
        });

        document.getElementById('confirmDeleteGalleryImage').addEventListener('click', function() {
            if (deleteGalleryImageCallback) {
                deleteGalleryImageCallback();
            }
            document.getElementById('deleteGalleryImageModal').classList.remove('is-open');
            deleteGalleryImageCallback = null;
        });

        // Close modals when clicking outside
        document.getElementById('deleteImageModal').addEventListener('click', function(e) {
            if (e.target.id === 'deleteImageModal') {
                document.getElementById('deleteImageModal').classList.remove('is-open');
                deleteImageCallback = null;
            }
        });

        document.getElementById('deleteGalleryImageModal').addEventListener('click', function(e) {
            if (e.target.id === 'deleteGalleryImageModal') {
                document.getElementById('deleteGalleryImageModal').classList.remove('is-open');
                deleteGalleryImageCallback = null;
            }
        });

        function updatePreview() {
            const previewContainer = document.getElementById('selectedImagesPreview');
            const imagesList = document.getElementById('selectedImagesList');
            const selectedCount = document.getElementById('selectedCount');
            const currentImageCountDisplay = document.getElementById('currentImageCount');

            if (selectedFiles.length === 0) {
                previewContainer.style.display = 'none';
                currentImageCountDisplay.textContent = currentImageCount;
                return;
            }

            previewContainer.style.display = 'block';
            selectedCount.textContent = selectedFiles.length;
            currentImageCountDisplay.textContent = currentImageCount + selectedFiles.length;
            imagesList.innerHTML = '';

            selectedFiles.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const imageContainer = document.createElement('div');
                    imageContainer.style.cssText = 'position: relative; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; aspect-ratio: 1;';
                    
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.cssText = 'width: 100%; height: 100%; object-fit: cover;';
                    
                    const removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.textContent = '✕';
                    removeBtn.style.cssText = 'position: absolute; top: 4px; right: 4px; width: 24px; height: 24px; border-radius: 50%; background: rgba(220, 38, 38, 0.9); color: white; border: none; cursor: pointer; font-size: 12px; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease;';
                    removeBtn.onmouseover = function() { this.style.background = '#dc2626'; };
                    removeBtn.onmouseout = function() { this.style.background = 'rgba(220, 38, 38, 0.9)'; };
                    removeBtn.onclick = function() {
                        selectedFiles.splice(index, 1);
                        updatePreview();
                        syncFileInput();
                    };
                    
                    imageContainer.appendChild(img);
                    imageContainer.appendChild(removeBtn);
                    imagesList.appendChild(imageContainer);
                };
                reader.readAsDataURL(file);
            });
        }

        function syncFileInput() {
            console.log('DEBUG: syncFileInput called, selectedFiles count:', selectedFiles.length);
            const fileInput = document.getElementById('images');
            const dataTransfer = new DataTransfer();
            selectedFiles.forEach(file => {
                console.log('DEBUG: Adding file to DataTransfer:', file.name);
                dataTransfer.items.add(file);
            });
            fileInput.files = dataTransfer.files;
            console.log('DEBUG: fileInput.files now has:', fileInput.files.length, 'files');
        }

        // Initialize drag and drop when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            const uploadArea = document.getElementById('galleryUploadArea');
            const fileInput = document.getElementById('images');
            
            // Click handler for upload area
            uploadArea.addEventListener('click', function() {
                fileInput.click();
            });

            // Show preview when files are selected - ADD to existing selection
            fileInput.addEventListener('change', function() {
                const files = fileInput.files;
                
                if (files.length === 0) {
                    return;
                }

                // Validate total count
                const totalAfterAdd = currentImageCount + selectedFiles.length + files.length;
                if (totalAfterAdd > maxImages) {
                    showModal(`Maximum ${maxImages} images allowed. You already have ${currentImageCount} existing and ${selectedFiles.length} selected. You can only add ${maxImages - currentImageCount - selectedFiles.length} more.`);
                    fileInput.value = '';
                    return;
                }

                // Add new files to selection
                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    if (file.type.startsWith('image/')) {
                        selectedFiles.push(file);
                    }
                }

                updatePreview();
                syncFileInput();
                fileInput.value = ''; // Clear input so same files can be selected again if needed
            });

            // Handle drag and drop
            uploadArea.addEventListener('dragover', function(e) {
                e.preventDefault();
                uploadArea.style.borderColor = '#3b82f6';
                uploadArea.style.backgroundColor = '#eff6ff';
            });

            uploadArea.addEventListener('dragleave', function(e) {
                e.preventDefault();
                uploadArea.style.borderColor = '#d1d5db';
                uploadArea.style.backgroundColor = '#f9fafb';
            });

            uploadArea.addEventListener('drop', function(e) {
                e.preventDefault();
                e.stopPropagation();
                uploadArea.style.borderColor = '#d1d5db';
                uploadArea.style.backgroundColor = '#f9fafb';
                
                const files = e.dataTransfer.files;
                const totalAfterAdd = currentImageCount + selectedFiles.length + files.length;
                
                if (totalAfterAdd > maxImages) {
                    showModal(`Maximum ${maxImages} images allowed. You already have ${currentImageCount} existing and ${selectedFiles.length} selected. You can only add ${maxImages - currentImageCount - selectedFiles.length} more.`);
                    return;
                }
                
                // Add dropped files to selection
                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    if (file.type.startsWith('image/')) {
                        selectedFiles.push(file);
                    }
                }
                
                updatePreview();
                syncFileInput();
            });

            // Form submission validation
            document.querySelector('form').addEventListener('submit', function(e) {
                const totalImages = currentImageCount + selectedFiles.length;
                if (totalImages > maxImages) {
                    e.preventDefault();
                    showModal(`Gallery cannot exceed ${maxImages} images. You have ${currentImageCount} existing and ${selectedFiles.length} new images.`);
                    return false;
                }
                syncFileInput(); // Ensure file input is synced before submission
            });
        });
    </script>

{% endblock %}
