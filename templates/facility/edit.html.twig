{% extends 'layouts/app.html.twig' %}

{% block title %}Edit Facility | Reserva FTIC{% endblock %}

{% block content %}
    <div class="content-header">
        <h2>Edit Facility</h2>
    </div>

    <div class="card-panel">
        <form method="POST" enctype="multipart/form-data" style="max-width: 600px;">
            <div class="form-group">
                <label for="name">Facility Name <span style="color: #dc2626;">*</span></label>
                <input type="text" id="name" name="name" value="{{ facility.name }}" required>
            </div>

            <div class="form-group">
                <label for="capacity">Capacity (pax) <span style="color: #dc2626;">*</span></label>
                <input type="number" id="capacity" name="capacity" value="{{ facility.capacity }}" required min="1">
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5">{{ facility.description }}</textarea>
            </div>

            <div class="form-group">
                <label for="image">Facility Image</label>
                {% if facility.image %}
                    <div style="margin-bottom: 15px; padding: 15px; background: #f9f9f9; border-radius: 6px; text-align: center;">
                        <img src="{{ facility.image }}" alt="{{ facility.name }}" style="max-width: 200px; max-height: 200px; margin-bottom: 10px; border-radius: 6px; display: block; margin-left: auto; margin-right: auto;">
                        <p style="margin: 0; color: #666; font-size: 12px;">Current Image</p>
                    </div>
                {% endif %}
                <input type="file" id="image" name="image" accept="image/*">
            </div>

            <div class="form-group">
                <label for="images">Add Gallery Images</label>
                <input type="file" id="images" name="images[]" accept="image/*" multiple>
            </div>

            {% if facility.images|length > 0 %}
                <div class="form-group">
                    <label>Gallery Management</label>
                    <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap:12px;">
                        {% for image in facility.images %}
                            <div style="border:1px solid #e5e7eb; border-radius:8px; padding:8px;">
                                <img src="{{ image.path }}" alt="{{ facility.name }}" style="width:100%; height:100px; object-fit:cover; border-radius:6px;">
                                <form action="{{ path('app_facility_image_delete', {id: image.id}) }}" method="POST" onsubmit="return confirm('Remove this image?');" style="margin-top:8px;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_image' ~ image.id) }}">
                                    <button type="submit" class="btn-secondary" style="width:100%;">Remove</button>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            <div style="display: flex; gap: 12px;">
                <button type="submit" class="btn-primary">Update Facility</button>
                <a href="{{ path('app_facility_management') }}" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>


{% endblock %}
