{% extends 'layouts/app.html.twig' %}

{% block content %}
<div class="content-header facility-management-page">
    <h2>Facility Management</h2>
    <div style="display: flex; gap: 12px;">
        <a href="{{ path('admin_calendar') }}" class="btn-secondary" style="text-decoration: none; display: inline-block; padding: 10px 16px; border-radius: 12px; border: 1px solid var(--feu-green); background: white; color: var(--feu-green); font-weight: 700; cursor: pointer;">📅 Calendar View</a>
        <a href="{{ path('app_facility_new') }}" class="btn-primary" style="text-decoration: none; display: inline-block; padding: 10px 16px; border-radius: 12px; background: linear-gradient(130deg, var(--feu-green) 0%, var(--feu-green-light) 100%); color: white; font-weight: 700;">+ Add New Facility</a>
    </div>
</div>
<style>
    .facility-management-page,
    .facility-management-page .management-grid,
    .facility-management-page .management-card,
    .facility-management-page .placeholder,
    .facility-management-page .no-facilities a,
    .facility-management-page .btn-primary,
    .facility-management-page .btn-secondary {
        --feu-green: #0d9b00;
        --feu-green-dark: #0d9b00;
        --feu-green-light: #0d9b00;
    }
    .facility-management-page .btn-primary {
        background: linear-gradient(130deg, #0d9b00 0%, #0d9b00 100%) !important;
        border-color: #0d9b00 !important;
    }
    .facility-management-page .btn-secondary {
        border-color: #0d9b00 !important;
        color: #0d9b00 !important;
    }
</style>

<script>
    const successMessage = '{{ success|default('') }}';
</script>

{% if facilities is empty %}
    <div class="no-facilities">
        <p>No facilities found. <a href="{{ path('app_facility_new') }}">Create one now</a></p>
    </div>
{% else %}
    <div class="management-grid">
        {% for facility in facilities %}
            <div class="management-card">
                <div class="card-image">
                    {% if facility.image %}
                        <img src="{{ facility.image ~ '?v=' ~ facility.updatedAt|date('U') }}" alt="{{ facility.name }}" loading="lazy">
                    {% else %}
                        <div class="placeholder">{{ facility.name | first }}</div>
                    {% endif %}
                </div>
                <div class="card-body">
                    <h3>{{ facility.name }}</h3>
                    <p class="capacity"><strong>Capacity:</strong> {{ facility.capacity }} pax</p>
                    {% if facility.description %}
                        <p class="desc">{{ facility.description | slice(0, 100) }}{% if facility.description | length > 100 %}...{% endif %}</p>
                    {% endif %}
                    <div class="reservation-status">
                        <span class="status-badge {% if facility.availableForReservation %}status-enabled{% else %}status-disabled{% endif %}">
                            {% if facility.availableForReservation %}✓ Available for Reservation{% else %}✗ Disabled for Reservation{% endif %}
                        </span>
                    </div>
                </div>
                <div class="card-actions">
                    <a href="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-link">View</a>
                    <a href="{{ path('app_facility_edit', {id: facility.id}) }}" class="btn-link">Edit</a>
                    <form action="{{ path('app_facility_toggle_reservation', {id: facility.id}) }}" method="POST" style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_reservation_' ~ facility.id) }}">
                        <button type="submit" class="btn-link {% if facility.availableForReservation %}btn-warning{% else %}btn-success{% endif %}">
                            {% if facility.availableForReservation %}Disable Reservations{% else %}Enable Reservations{% endif %}
                        </button>
                    </form>
                    <button type="button" onclick="deleteFacility({{ facility.id }}, '{{ csrf_token('delete' ~ facility.id) }}')" class="btn-link btn-danger">Delete</button>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}

<style>
    .management-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
    }

    .management-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px var(--feu-shadow);
        transition: all 0.3s;
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(0, 102, 51, 0.08);
    }

    .management-card:hover {
        box-shadow: 0 8px 20px rgba(0, 102, 51, 0.15);
        transform: translateY(-2px);
    }

    .card-image {
        width: 100%;
        height: 180px;
        background: #f0f0f0;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--feu-green) 0%, var(--feu-green-dark) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        color: white;
        font-weight: bold;
    }

    .card-body {
        padding: 15px;
        flex: 1;
    }

    .card-body h3 {
        margin: 0 0 10px 0;
        font-size: 16px;
        color: var(--feu-ink);
    }

    .capacity {
        margin: 5px 0;
        font-size: 13px;
        color: var(--feu-ink);
    }

    .desc {
        margin: 10px 0;
        font-size: 12px;
        color: #999;
        line-height: 1.4;
    }

    .card-actions {
        padding: 10px 15px;
        border-top: 1px solid #eee;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .card-actions .btn-link {
        flex: 1;
        text-align: center;
        min-width: 60px;
        padding: 6px 8px;
    }

    .no-facilities {
        text-align: center;
        padding: 60px 20px;
        background: rgba(0, 102, 51, 0.05);
        border-radius: 12px;
        color: #999;
    }

    .no-facilities a {
        color: var(--feu-green);
        text-decoration: none;
        font-weight: 600;
    }

    .no-facilities a:hover {
        text-decoration: underline;
    }

    .reservation-status {
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px solid #eee;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-enabled {
        background-color: #d4edda;
        color: #155724;
    }

    .status-disabled {
        background-color: #f8d7da;
        color: #721c24;
    }

    .btn-warning {
        color: #f39c12 !important;
    }

    .btn-warning:hover {
        color: #e67e22 !important;
    }

    .btn-success {
        color: #27ae60 !important;
    }

    .btn-success:hover {
        color: #229954 !important;
    }

    .flash-message {
        border-radius: 12px;
        padding: 16px 20px;
        animation: flashSlideIn 0.3s ease-out;
    }

    .flash-success {
        background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
        border: 1px solid #c3e6cb;
        color: #155724;
    }

    .flash-error {
        background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
        border: 1px solid #f5c6cb;
        color: #721c24;
    }

    .flash-content {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
        font-size: 14px;
    }

    .flash-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 800;
    }

    .flash-success .flash-icon {
        background: #155724;
        color: white;
    }

    .flash-error .flash-icon {
        background: #721c24;
        color: white;
    }

    @keyframes flashSlideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<!-- Delete Facility Modal -->
<div id="deleteFacilityModal" class="delete-schedule-modal">
    <div class="delete-schedule-dialog">
        <div class="delete-schedule-icon">!</div>
        <h3>Delete Facility?</h3>
        <p>This will permanently delete this facility and all its images. This action cannot be undone.</p>
        <div class="delete-schedule-actions">
            <button type="button" id="cancelDeleteFacility" class="delete-schedule-cancel">Cancel</button>
            <button type="button" id="confirmDeleteFacility" class="delete-schedule-confirm">Yes, Delete Facility</button>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div id="successModal" class="delete-schedule-modal">
    <div class="delete-schedule-dialog">
        <div class="delete-schedule-icon" style="color:#0d9b00; background:#dcfce7; border-color:#bbf7d0;">✓</div>
        <h3 id="successModalTitle">Success!</h3>
        <p id="successModalMessage">Action completed successfully.</p>
        <div class="delete-schedule-actions">
            <button type="button" id="closeSuccessModal" class="delete-schedule-confirm" style="background:#0d9b00;">OK</button>
        </div>
    </div>
</div>

<style>
    .delete-schedule-modal { display:none; position:fixed; top:0; left:0; width:100vw; height:100vh; z-index:9999; align-items:center; justify-content:center; padding:1.5rem; background:rgba(15,23,42,.6); backdrop-filter:blur(8px); }
    .delete-schedule-modal.is-open { display:flex; }
    .delete-schedule-dialog { width:min(440px,100%); background:white; border-radius:20px; padding:2rem; text-align:center; box-shadow:0 24px 70px rgba(15,23,42,.28); animation:deleteModalIn .18s ease-out; }
    .delete-schedule-icon { width:56px; height:56px; margin:0 auto 1rem; border-radius:999px; display:flex; align-items:center; justify-content:center; color:#991b1b; background:#fee2e2; border:1px solid #fecaca; font-size:1.6rem; font-weight:800; }
    .delete-schedule-dialog h3 { margin:0 0 .75rem; color:#111827; font-size:1.25rem; }
    .delete-schedule-dialog p  { margin:0; color:#6b7280; line-height:1.55; font-size:.9rem; }
    .delete-schedule-actions { display:flex; gap:.75rem; justify-content:center; margin-top:1.5rem; }
    .delete-schedule-actions button { border:none; border-radius:10px; padding:.7rem 1.1rem; font-weight:800; cursor:pointer; font-size:.9rem; }
    .delete-schedule-cancel  { background:#f3f4f6; color:#374151; }
    .delete-schedule-confirm { background:#dc2626; color:white; }
    @keyframes deleteModalIn { from{opacity:0;transform:translateY(12px) scale(.98)} to{opacity:1;transform:translateY(0) scale(1)} }
</style>

<script>
    let deleteFacilityCallback = null;

    // Move modals to body to ensure they cover header/sidebar and center properly
    document.addEventListener('DOMContentLoaded', function() {
        const deleteModal = document.getElementById('deleteFacilityModal');
        if (deleteModal && deleteModal.parentElement !== document.body) {
            document.body.appendChild(deleteModal);
        }
        const successModal = document.getElementById('successModal');
        if (successModal && successModal.parentElement !== document.body) {
            document.body.appendChild(successModal);
        }

        // Show success modal if success parameter exists
        console.log('Success message:', successMessage);
        if (successMessage && successMessage !== '') {
            const messageMap = {
                'edited': 'Edited',
                'deleted': 'Deleted'
            };
            const displayMessage = messageMap[successMessage] || successMessage;
            showSuccessModal(displayMessage);
            
            // Clear URL parameter to prevent popup showing on refresh
            const url = new URL(window.location);
            url.searchParams.delete('success');
            window.history.replaceState({}, '', url);
        }
    });

    function showSuccessModal(message) {
        document.getElementById('successModalMessage').textContent = message;
        document.getElementById('successModal').classList.add('is-open');
    }

    function deleteFacility(facilityId, token) {
        deleteFacilityCallback = function() {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '{{ path('app_facility_delete', {id: 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', facilityId);
            
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '_token';
            tokenInput.value = token;
            
            form.appendChild(tokenInput);
            document.body.appendChild(form);
            form.submit();
        };
        document.getElementById('deleteFacilityModal').classList.add('is-open');
    }

    document.getElementById('cancelDeleteFacility').addEventListener('click', function() {
        document.getElementById('deleteFacilityModal').classList.remove('is-open');
        deleteFacilityCallback = null;
    });

    document.getElementById('confirmDeleteFacility').addEventListener('click', function() {
        if (deleteFacilityCallback) {
            deleteFacilityCallback();
        }
        document.getElementById('deleteFacilityModal').classList.remove('is-open');
        deleteFacilityCallback = null;
    });

    document.getElementById('closeSuccessModal').addEventListener('click', function() {
        document.getElementById('successModal').classList.remove('is-open');
    });

    // Close modals when clicking outside
    document.getElementById('deleteFacilityModal').addEventListener('click', function(e) {
        if (e.target.id === 'deleteFacilityModal') {
            document.getElementById('deleteFacilityModal').classList.remove('is-open');
            deleteFacilityCallback = null;
        }
    });

    document.getElementById('successModal').addEventListener('click', function(e) {
        if (e.target.id === 'successModal') {
            document.getElementById('successModal').classList.remove('is-open');
        }
    });
</script>
{% endblock %}
