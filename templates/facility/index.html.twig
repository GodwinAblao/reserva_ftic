{% extends 'layouts/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/facility_cards.css') }}?v=20260522-1">
{% endblock %}

{% block content %}

    {% if facilities is empty %}
        <div class="no-facilities">
            <p>No facilities available at the moment.</p>
        </div>
    {% else %}
        <div class="facility-top-row">
            <div class="search-bar">
                <select id="facilityFilter" name="facilityFilter" aria-label="Filter facilities">
                    <option value="">All rooms</option>
                    <option value="COE room">COE room</option>
                    <option value="CS room">CS room</option>
                    <option value="Discussion room">Discussion room</option>
                    <option value="Presentation room">Presentation room</option>
                    <option value="Lounge">Lounge</option>
                </select>
            </div>
            <div class="facility-count" id="facilityCount" style="display:none;">{{ facilities|length }} facilities</div>
        </div>
        <div class="facilities-grid">
            {% for facility in facilities %}
                {% if facility.availableForReservation %}
                    <div class="facility-card-wrapper" data-name="{{ facility.name|lower }}">
                        <div class="facility-card facility-feature-card">
                            <div class="facility-image-holder">
                                {% if facility.image %}
                                    <img src="{{ facility.image }}" alt="{{ facility.name }}">
                                {% else %}
                                    <div class="placeholder-image">
                                        <span>{{ facility.name | first }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="facility-details">
                                <h3>{{ facility.name }}</h3>
                                <div class="facility-meta-row">
        
                                    <span class="facility-pill">{{ facility.capacity }} pax</span>
                                </div>
                                <p class="capacity">
                                    <strong>Capacity:</strong> {{ facility.capacity }} pax
                                </p>
                                {% if facility.description %}
                                    <p class="description">{{ facility.description }}</p>
                                {% endif %}
                                <a href="#" data-preview-url="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-view">
                                    View Details
                                </a>
                            </div>
                        </div>
                        
                        <!-- Hover Card -->
                        <div class="hover-card">
                            <div class="hover-card-content">
                                <div class="hover-card-image">
                                    {% if facility.image %}
                                        <img src="{{ facility.image }}" alt="{{ facility.name }}">
                                    {% else %}
                                        <div class="placeholder-image">
                                            <span>{{ facility.name | first }}</span>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="hover-card-details">
                                    <h4>{{ facility.name }}</h4>
                                    <p class="hover-capacity">
                                        <span>👥</span> {{ facility.capacity }} persons
                                    </p>
                                    {% if facility.description %}
                                        <p class="hover-description">{{ facility.description }}</p>
                                    {% endif %}
                                    <div class="hover-gallery">
                                        {% if facility.images|length > 0 %}
                                            <p><strong>Gallery:</strong></p>
                                            <div class="hover-gallery-images">
                                                {% for image in facility.images|slice(0, 4) %}
                                                    <img src="{{ image.path }}" alt="{{ facility.name }}">
                                                {% endfor %}
                                                {% if facility.images|length > 4 %}
                                                    <span class="more-images">+{{ facility.images|length - 4 }}</span>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <a href="#" data-preview-url="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-hover-view">
                                        View Facility
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

<!-- Facility preview modal -->
<div id="facilityPreviewOverlay" class="facility-preview-overlay" aria-hidden="true">
    <div class="facility-preview-body" id="facilityPreviewBody" role="document" aria-labelledby="facilityPreviewTitle"></div>
</div>

<script>
// Facility preview: prefetch previews to avoid click loading, inject close button inside card
(() => {
    window.__facilityPreviewCache = window.__facilityPreviewCache || new Map();
    const previewCache = window.__facilityPreviewCache;

    function getOverlay() {
        const overlays = document.querySelectorAll('#facilityPreviewOverlay');
        if (overlays.length > 1) {
            overlays.forEach((node, index) => {
                if (index > 0) node.remove();
            });
        }
        return document.getElementById('facilityPreviewOverlay');
    }

    function getBody() {
        return document.getElementById('facilityPreviewBody');
    }

    async function fetchPreview(url) {
        if (!url) return null;
        if (previewCache.has(url)) return previewCache.get(url);
        try {
            const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (!res.ok) return null;
            const html = await res.text();
            previewCache.set(url, html);
            return html;
        } catch (err) {
            return null;
        }
    }

    // Prefetch all previews on DOM ready (background, non-blocking)
    // Initialize filter on both DOMContentLoaded and turbo:load (for Turbo navigation)
    function initializeFacilityFilter() {
        const filter = document.getElementById('facilityFilter');
        const countEl = document.getElementById('facilityCount');
        
        if (!filter) return;
        
        // Remove existing listeners to prevent duplication
        const newFilter = filter.cloneNode(true);
        filter.parentNode.replaceChild(newFilter, filter);
        
        function updateCount() {
            const visible = document.querySelectorAll('.facility-card-wrapper:not([style*="display: none"])').length;
            if (countEl) countEl.textContent = visible + ' facilities';
        }
        
        // keyword mapping to handle variations in facility naming
        const mapping = {
            'COE room': ['coe', 'college of engineering', 'coeroom', 'coe '],
            'CS room': ['cs', 'computer science', 'csroom', 'cs '],
            'Discussion room': ['discussion', 'meeting', 'discussion room', 'discuss'],
            'Presentation room': ['presentation', 'presentation room', 'auditorium', 'present'],
            'Lounge': ['lounge', 'common room', 'commons']
        };

        const applyFilter = () => {
            const sel = (newFilter.value || '').trim();
            const q = sel.toLowerCase();
            const keywords = sel ? (mapping[sel] || [q]) : [];

            document.querySelectorAll('.facility-card-wrapper').forEach(w => {
                const name = (w.dataset.name || '').toLowerCase();
                let visible = true;
                if (sel) {
                    visible = keywords.some(k => name.includes(k));
                }
                w.style.display = visible ? '' : 'none';
            });
            updateCount();
        };

        newFilter.addEventListener('change', applyFilter);
        // initialize
        applyFilter();
    }

    // Prefetch previews
    function prefetchPreviews() {
        document.querySelectorAll('[data-preview-url]').forEach(el => {
            const url = el.dataset.previewUrl;
            if (url) fetchPreview(url);
        });
    }

    // Listen to both DOMContentLoaded and turbo:load
    if (!window.__facilityPreviewDomReadyBound) {
        document.addEventListener('DOMContentLoaded', () => {
            prefetchPreviews();
            initializeFacilityFilter();
        });
        window.__facilityPreviewDomReadyBound = true;
    }

    if (!window.__facilityPreviewTurboLoadBound) {
        document.addEventListener('turbo:load', () => {
            prefetchPreviews();
            initializeFacilityFilter();
        });
        window.__facilityPreviewTurboLoadBound = true;
    }

    // Close overlay helper
    function closeOverlay() {
        const overlay = getOverlay();
        const body = getBody();
        if (!overlay || !body) return;
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        body.innerHTML = '';
        document.body.style.overflow = '';
    }

    // Close on Escape
    if (!window.__facilityPreviewEscapeBound) {
        document.addEventListener('keydown', (e) => {
            const overlay = getOverlay();
            if (!overlay) return;
            if (e.key === 'Escape' && overlay.classList.contains('open')) {
                closeOverlay();
            }
        });
        window.__facilityPreviewEscapeBound = true;
    }

    // Delegate click to open preview (uses prefetched content when available)
    if (!window.__facilityPreviewOpenBound) {
        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('[data-preview-url]');
            if (!btn) return;
            e.preventDefault();
            const url = btn.dataset.previewUrl;
            if (!url) return;

            const overlay = getOverlay();
            const body = getBody();
            if (!overlay || !body) return;

            let html = previewCache.get(url) || null;
            if (!html) html = await fetchPreview(url);
            if (!html) return;

            if (overlay.parentElement !== document.body) {
                document.body.appendChild(overlay);
            }
            body.innerHTML = html;

            const cards = body.querySelectorAll('.facility-popup-card');
            if (cards.length > 1) {
                cards.forEach((node, index) => {
                    if (index > 0) node.remove();
                });
            }

            overlay.onclick = (event) => {
                if (event.target === overlay) closeOverlay();
            };

            // Ensure exactly one close button inside the card
            const card = body.querySelector('.facility-popup-card');
            const closeButtons = body.querySelectorAll('.facility-preview-close');
            if (closeButtons.length > 1) {
                closeButtons.forEach((node, index) => {
                    if (index > 0) node.remove();
                });
            }
            let closeBtn = body.querySelector('.facility-preview-close');
            if (!closeBtn) {
                closeBtn = document.createElement('button');
                closeBtn.type = 'button';
                closeBtn.className = 'facility-preview-close';
                closeBtn.setAttribute('aria-label', 'Close preview');
                closeBtn.innerHTML = '×';
                if (card) card.appendChild(closeBtn);
                else body.appendChild(closeBtn);
            }

            // Thumbnail click handling
            body.querySelectorAll('.thumbnail').forEach(t => {
                t.addEventListener('click', function () {
                    const src = this.dataset.imgSrc;
                    const main = body.querySelector('#mainImage');
                    if (main && src) main.src = src;
                    body.querySelectorAll('.thumbnail').forEach(x => x.classList.remove('active'));
                    this.classList.add('active');
                });
            });

            // One click always closes popup
            closeBtn.onclick = (ev) => {
                ev.preventDefault();
                ev.stopPropagation();
                closeOverlay();
            };

            overlay.classList.add('open');
            overlay.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            closeBtn.focus();
        });
        window.__facilityPreviewOpenBound = true;
    }

    // existing schedule revision polling (kept intact)
    const revisionUrl = '{{ path('facility_schedule_revision') }}';
    let knownRevision = null;

    async function pollScheduleRevision() {
        if (document.hidden) return;
        try {
            const response = await fetch(revisionUrl, {
                cache: 'no-store',
                headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            });
            if (!response.ok) return;
            const data = await response.json();
            if (knownRevision && data.revision && data.revision !== knownRevision) {
                try {
                    localStorage.setItem('classScheduleRevision', data.revision);
                    window.dispatchEvent(new CustomEvent('classScheduleUpdated', { detail: { revision: data.revision } }));
                } catch (error) {}
            }
            knownRevision = data.revision;
        } catch (error) {}
    }

    document.addEventListener('DOMContentLoaded', () => {
        pollScheduleRevision();
        window.setInterval(pollScheduleRevision, 5000);
    });
    document.addEventListener('turbo:load', () => {
        pollScheduleRevision();
    });
    window.addEventListener('classScheduleUpdated', (event) => {
        if (event.detail && event.detail.revision) {
            knownRevision = event.detail.revision;
        }
    });

})();
</script>
{% endblock %}
