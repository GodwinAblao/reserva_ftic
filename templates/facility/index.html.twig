{% extends 'layouts/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/facility_cards.css') }}?v=20260522-1">
{% endblock %}

{% block content %}

    {% if facilities is empty %}
        <div class="no-facilities">
            <p>No facilities available at the moment.</p>
        </div>
    {% else %}
        <div class="facility-top-row">
            <div class="search-bar">
                <select id="facilityFilter" name="facilityFilter" aria-label="Filter facilities">
                    <option value="">All rooms</option>
                    <option value="COE room">COE room</option>
                    <option value="CS room">CS room</option>
                    <option value="Discussion room">Discussion room</option>
                    <option value="Presentation room">Presentation room</option>
                    <option value="Lounge">Lounge</option>
                </select>
            </div>
            <div class="facility-count" id="facilityCount" style="display:none;">{{ facilities|length }} facilities</div>
        </div>
        <div class="facilities-grid">
            {% for facility in facilities %}
                {% if facility.availableForReservation %}
                    <div class="facility-card-wrapper" data-name="{{ facility.name|lower }}">
                        <div class="facility-card facility-feature-card">
                            <div class="facility-image-holder">
                                {% if facility.image %}
                                    <img src="{{ facility.image }}" alt="{{ facility.name }}">
                                {% else %}
                                    <div class="placeholder-image">
                                        <span>{{ facility.name | first }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="facility-details">
                                <h3>{{ facility.name }}</h3>
                                <div class="facility-meta-row">
        
                                    <span class="facility-pill">{{ facility.capacity }} pax</span>
                                </div>
                                <p class="capacity">
                                    <strong>Capacity:</strong> {{ facility.capacity }} pax
                                </p>
                                {% if facility.description %}
                                    <p class="description">{{ facility.description }}</p>
                                {% endif %}
                                <a href="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-view">
                                    View Details
                                </a>
                            </div>
                        </div>
                        
                        <!-- Hover Card -->
                        <div class="hover-card">
                            <div class="hover-card-content">
                                <div class="hover-card-image">
                                    {% if facility.image %}
                                        <img src="{{ facility.image }}" alt="{{ facility.name }}">
                                    {% else %}
                                        <div class="placeholder-image">
                                            <span>{{ facility.name | first }}</span>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="hover-card-details">
                                    <h4>{{ facility.name }}</h4>
                                    <p class="hover-capacity">
                                        <span>👥</span> {{ facility.capacity }} persons
                                    </p>
                                    {% if facility.description %}
                                        <p class="hover-description">{{ facility.description }}</p>
                                    {% endif %}
                                    <div class="hover-gallery">
                                        {% if facility.images|length > 0 %}
                                            <p><strong>Gallery:</strong></p>
                                            <div class="hover-gallery-images">
                                                {% for image in facility.images|slice(0, 4) %}
                                                    <img src="{{ image.path }}" alt="{{ facility.name }}">
                                                {% endfor %}
                                                {% if facility.images|length > 4 %}
                                                    <span class="more-images">+{{ facility.images|length - 4 }}</span>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <a href="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-hover-view">
                                        View Facility
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

<script>
(() => {
    function initializeFacilityFilter() {
        const filter = document.getElementById('facilityFilter');
        const countEl = document.getElementById('facilityCount');
        if (!filter) return;
        const newFilter = filter.cloneNode(true);
        filter.parentNode.replaceChild(newFilter, filter);
        function updateCount() {
            const visible = document.querySelectorAll('.facility-card-wrapper:not([style*="display: none"])').length;
            if (countEl) countEl.textContent = visible + ' facilities';
        }
        const mapping = {
            'COE room': ['coe', 'college of engineering', 'coeroom', 'coe '],
            'CS room': ['cs', 'computer science', 'csroom', 'cs '],
            'Discussion room': ['discussion', 'meeting', 'discussion room', 'discuss'],
            'Presentation room': ['presentation', 'presentation room', 'auditorium', 'present'],
            'Lounge': ['lounge', 'common room', 'commons']
        };
        const applyFilter = () => {
            const sel = (newFilter.value || '').trim();
            const keywords = sel ? (mapping[sel] || [sel.toLowerCase()]) : [];
            document.querySelectorAll('.facility-card-wrapper').forEach(w => {
                const name = (w.dataset.name || '').toLowerCase();
                w.style.display = (!sel || keywords.some(k => name.includes(k))) ? '' : 'none';
            });
            updateCount();
        };
        newFilter.addEventListener('change', applyFilter);
        applyFilter();
    }
    if (!window.__facilityFilterDomBound) {
        document.addEventListener('DOMContentLoaded', initializeFacilityFilter);
        window.__facilityFilterDomBound = true;
    }
    if (!window.__facilityFilterTurboBound) {
        document.addEventListener('turbo:load', initializeFacilityFilter);
        window.__facilityFilterTurboBound = true;
    }
})();
</script>
{% endblock %}
