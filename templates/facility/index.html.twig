{% extends 'layouts/app.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/facility_cards.css') }}?v=20260522-1">
{% endblock %}

{% block content %}

    {% if facilities is empty %}
        <div class="no-facilities">
            <p>No facilities available at the moment.</p>
        </div>
    {% else %}
        <div class="facility-top-row">
            <div class="search-bar">
                <input type="text" id="facilitySearch" placeholder="Search rooms..." aria-label="Search facilities" style="
                    padding: 10px 16px;
                    border: 1px solid #e5e7eb;
                    border-radius: 8px;
                    font-size: 14px;
                    width: 250px;
                    background: white;
                ">
            </div>
            <div class="facility-count" id="facilityCount" style="display:none;">{{ facilities|length }} facilities</div>
        </div>
        <div class="facilities-grid">
            {% for facility in facilities %}
                {% if facility.availableForReservation %}
                    <a href="{{ path('app_facility_view', {id: facility.id}) }}" class="facility-card-wrapper" data-name="{{ facility.name|lower }}" style="text-decoration: none; color: inherit;">
                        <div class="facility-card facility-feature-card">
                            <div class="facility-image-holder">
                                {% if facility.image %}
                                    <img src="{{ facility.image }}" alt="{{ facility.name }}">
                                {% else %}
                                    <div class="placeholder-image">
                                        <span>{{ facility.name | first }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="facility-details">
                                <h3 class="facility-name">{{ facility.name }}</h3>
                                <div class="facility-meta-row">
                                    <span class="facility-pill">{{ facility.capacity }} pax</span>
                                    {% if facility.images|length > 0 %}
                                        <span class="facility-pill facility-pill-photos">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                            {{ facility.images|length }}
                                        </span>
                                    {% endif %}
                                </div>
                                <p class="capacity">
                                    <strong>Capacity:</strong> {{ facility.capacity }} pax
                                </p>
                                {% if facility.description %}
                                    <p class="description">{{ facility.description }}</p>
                                {% endif %}
                                <span class="btn-view">View Details →</span>
                            </div>
                        </div>
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

<script>
(() => {
    function initializeFacilitySearch() {
        const searchInput = document.getElementById('facilitySearch');
        const countEl = document.getElementById('facilityCount');
        if (!searchInput) return;

        function updateCount() {
            const visible = document.querySelectorAll('.facility-card-wrapper:not([style*="display: none"])').length;
            if (countEl) {
                countEl.textContent = visible + ' facilities';
                countEl.style.display = visible > 0 ? 'block' : 'none';
            }
        }

        const applySearch = () => {
            const query = (searchInput.value || '').trim().toLowerCase();
            document.querySelectorAll('.facility-card-wrapper').forEach(w => {
                const name = (w.dataset.name || '').toLowerCase();
                const facilityName = w.querySelector('.facility-name');
                const cardText = facilityName ? facilityName.textContent.toLowerCase() : '';
                const match = !query || name.includes(query) || cardText.includes(query);
                w.style.display = match ? '' : 'none';
            });
            updateCount();
        };

        searchInput.addEventListener('input', applySearch);
        updateCount();
    }

    if (!window.__facilitySearchDomBound) {
        document.addEventListener('DOMContentLoaded', initializeFacilitySearch);
        window.__facilitySearchDomBound = true;
    }
    if (!window.__facilitySearchTurboBound) {
        document.addEventListener('turbo:load', initializeFacilitySearch);
        window.__facilitySearchTurboBound = true;
    }
})();
</script>
{% endblock %}
