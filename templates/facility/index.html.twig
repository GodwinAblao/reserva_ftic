{% extends 'layouts/app.html.twig' %}

{% block content %}
    <div class="content-header">
        <h2>Facilities</h2>
    </div>

    {% if facilities is empty %}
        <div class="no-facilities">
            <p>No facilities available at the moment.</p>
        </div>
    {% else %}
        <div class="facilities-grid">
            {% for facility in facilities %}
                <div class="facility-card">
                    <div class="facility-image-holder">
                        {% if facility.image %}
                            <img src="{{ facility.image }}" alt="{{ facility.name }}">
                        {% else %}
                            <div class="placeholder-image">
                                <span>{{ facility.name | first }}</span>
                            </div>
                        {% endif %}
                    </div>
                    <div class="facility-details">
                        <h3>{{ facility.name }}</h3>
                        <p class="capacity">
                            <strong>Capacity:</strong> {{ facility.capacity }} pax
                        </p>
                        {% if facility.description %}
                            <p class="description">{{ facility.description }}</p>
                        {% endif %}
                        <a href="{{ path('app_facility_view', {id: facility.id}) }}" class="btn-view">
                            View Details
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

<style>
    .facilities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
    }

    .facility-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px var(--feu-shadow);
        transition: all 0.3s;
        cursor: pointer;
        border: 1px solid rgba(0, 102, 51, 0.08);
    }

    .facility-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(0, 102, 51, 0.15);
    }

    .facility-image-holder {
        width: 100%;
        height: 200px;
        background: #f0f0f0;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .facility-image-holder img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .placeholder-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--feu-green) 0%, var(--feu-green-dark) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 60px;
        color: white;
        font-weight: bold;
    }

    .facility-details {
        padding: 20px;
    }

    .facility-details h3 {
        margin: 0 0 10px 0;
        font-size: 18px;
        color: var(--feu-ink);
    }

    .capacity {
        margin: 8px 0;
        font-size: 14px;
        color: var(--feu-ink);
    }

    .description {
        margin: 10px 0;
        font-size: 13px;
        color: #888;
        line-height: 1.5;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .btn-view {
        display: inline-block;
        margin-top: 12px;
        padding: 8px 16px;
        background: var(--feu-green);
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-view:hover {
        background: var(--feu-green-dark);
        box-shadow: 0 4px 12px rgba(0, 102, 51, 0.3);
    }

    .no-facilities {
        text-align: center;
        padding: 60px 20px;
        background: rgba(0, 102, 51, 0.05);
        border-radius: 12px;
        color: #999;
    }
</style>
{% endblock %}
