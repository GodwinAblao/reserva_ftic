{% extends 'layouts/app.html.twig' %}

{% block title %}Create Facility | Reserva FTIC{% endblock %}

{% block content %}
    <div class="content-header">
        <h2>Add New Facility</h2>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}" style="padding: 10px; margin: 10px 0; border-radius: 4px; background-color: {{ label == 'error' ? '#fee2e2' : '#dcfce7' }}; color: {{ label == 'error' ? '#dc2626' : '#16a34a' }};">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card-panel">
        <form method="POST" enctype="multipart/form-data" style="max-width: 600px;" data-turbo="false">
            <div class="form-group">
                <label for="name">Facility Name <span style="color: #dc2626;">*</span></label>
                <input type="text" id="name" name="name" required placeholder="Facility name">
            </div>

            <div class="form-group">
                <label for="capacity">Capacity (pax) <span style="color: #dc2626;">*</span></label>
                <input type="number" id="capacity" name="capacity" required min="1" placeholder="Number of persons">
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5" placeholder="Facility description"></textarea>
            </div>

            <div class="form-group">
                <label for="image">Facility Image</label>
                <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/webp,image/gif">
                <small style="color:#6b7280;">Accepted: JPEG, PNG, WebP (HEIC not supported by browsers)</small>
            </div>

            <div class="form-group">
                <label for="images">Gallery Images <span style="color: #666; font-size: 12px;">(Maximum: 5 gallery images - main facility image is separate)</span></label>
                <p style="font-size: 12px; color: #666; margin: 5px 0;">
                    Gallery images: 0 / 5
                </p>
                <input type="file" id="images" name="images[]" accept="image/jpeg,image/png,image/webp,image/gif" multiple
                       style="display: block; width: 100%; padding: 0.75rem; border: 2px solid #e5e7eb; border-radius: 6px; background: #f9fafb;">
                <small style="color:#6b7280;">Hold Ctrl/Cmd to select multiple images (Max: 5)</small>
            </div>

            <div style="display: flex; gap: 12px;">
                <button type="submit" class="btn-primary">Create Facility</button>
                <a href="{{ path('app_facility_management') }}" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <script>
        const maxImages = 5;
        const currentImageCount = 0;

        document.addEventListener('DOMContentLoaded', function() {
            // Simple form validation for gallery image count
            document.querySelector('form').addEventListener('submit', function(e) {
                const fileInput = document.getElementById('images');
                if (fileInput && fileInput.files) {
                    const newImagesCount = fileInput.files.length;
                    if (newImagesCount > maxImages) {
                        e.preventDefault();
                        alert(`Maximum ${maxImages} gallery images allowed. You selected ${newImagesCount} images.`);
                        return false;
                    }
                }
            });
        });
    </script>

{% endblock %}
