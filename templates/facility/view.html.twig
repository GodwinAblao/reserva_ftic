{% extends 'layouts/app.html.twig' %}

{% block title %}{{ facility.name }} | Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/facility_cards.css') }}">
{% endblock %}

{% block content %}
<div class="fv-page">

    <div class="fv-back-bar">
        <a href="{{ path('app_facility_index') }}" class="fv-back-btn">
            ← Back to Facilities
        </a>
    </div>

    <div class="fv-layout">

        <!-- LEFT: image gallery -->
        <div class="fv-gallery-col">
            <div class="fv-main-img-wrap">
                {% if facility.images|length > 0 %}
                    <img src="{{ facility.images[0].path }}" alt="{{ facility.name }}" id="fvMainImage" class="fv-main-img">
                {% elseif facility.image %}
                    <img src="{{ facility.image }}" alt="{{ facility.name }}" id="fvMainImage" class="fv-main-img">
                {% else %}
                    <div class="fv-main-placeholder">{{ facility.name|first|upper }}</div>
                {% endif %}
            </div>

            {% if facility.images|length > 1 %}
            <div class="fv-thumb-strip">
                {% for image in facility.images %}
                    <div class="fv-thumb {% if loop.first %}fv-thumb-active{% endif %}"
                         onclick="fvSetMain('{{ image.path }}', this)">
                        <img src="{{ image.path }}" alt="{{ facility.name }}">
                    </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>

        <!-- RIGHT: details panel -->
        <div class="fv-details-col">

            <h1 class="fv-title">{{ facility.name }}</h1>

            <div class="fv-status-row">
                {% if facility.isAvailableForReservation() %}
                    <span class="fv-badge fv-badge-available">✔ Available for Reservation</span>
                {% else %}
                    <span class="fv-badge fv-badge-unavailable">✗ Not Available</span>
                {% endif %}
            </div>

            {% if facility.description %}
            <p class="fv-description">{{ facility.description }}</p>
            {% endif %}

            <div class="fv-meta-table">
                <div class="fv-meta-row">
                    <span class="fv-meta-label">CAPACITY</span>
                    <span class="fv-meta-value fv-meta-green">{{ facility.capacity }} persons</span>
                </div>
                <div class="fv-meta-row">
                    <span class="fv-meta-label">STATUS</span>
                    <span class="fv-meta-value">
                        {% if facility.isAvailableForReservation() %}
                            <span class="fv-meta-green">Open for booking</span>
                        {% else %}
                            <span style="color:#9ca3af;">Unavailable</span>
                        {% endif %}
                    </span>
                </div>
            </div>

            <div class="fv-tags-row">
                <span class="fv-tag">{{ facility.capacity }} pax</span>
                {% if facility.images|length > 0 %}
                    <span class="fv-tag">{{ facility.images|length }} photos</span>
                {% endif %}
                <span class="fv-tag">FTIC Facility</span>
            </div>

            <div class="fv-actions">
                {% if is_granted('ROLE_SUPER_ADMIN') %}
                    <a href="{{ path('app_facility_edit', {id: facility.id}) }}" class="fv-btn fv-btn-primary">Edit Facility</a>
                    <a href="{{ path('app_facility_management') }}" class="fv-btn fv-btn-secondary">Management</a>
                {% else %}
                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        <a href="{{ path('facility_reserve', {id: facility.id}) }}" class="fv-btn fv-btn-primary">Reserve Now</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="fv-btn fv-btn-primary" data-turbo="false" target="_self">Sign In to Reserve</a>
                    {% endif %}
                {% endif %}
            </div>

        </div>
    </div>
</div>

<script>
function fvSetMain(src, thumb) {
    const img = document.getElementById('fvMainImage');
    if (img) img.src = src;
    document.querySelectorAll('.fv-thumb').forEach(t => t.classList.remove('fv-thumb-active'));
    if (thumb) thumb.classList.add('fv-thumb-active');
}
</script>

<style>
.fv-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 16px 40px;
}

.fv-back-bar {
    margin-bottom: 18px;
}
.fv-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--feu-green);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid var(--feu-green);
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
}
.fv-back-btn:hover {
    background: var(--feu-green);
    color: #fff;
}

/* Two-column layout */
.fv-layout {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 28px;
    align-items: start;
}

/* Gallery column */
.fv-gallery-col {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: 10px;
    overflow: hidden;
    background: #1a1a1a;
    box-shadow: 0 6px 28px rgba(0,0,0,0.18);
}

.fv-main-img-wrap {
    width: 100%;
    aspect-ratio: 16/9;
    background: #111;
    overflow: hidden;
    position: relative;
}
.fv-main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
}
.fv-main-img:hover { transform: scale(1.015); }

.fv-main-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 80px;
    font-weight: 900;
    color: rgba(255,255,255,0.2);
}

.fv-thumb-strip {
    display: flex;
    gap: 0;
    background: #111;
    padding: 6px 6px 6px;
    overflow-x: auto;
    gap: 6px;
}
.fv-thumb {
    flex-shrink: 0;
    width: 96px;
    height: 68px;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    border: 3px solid transparent;
    opacity: 0.7;
    transition: opacity 0.2s, border-color 0.2s;
}
.fv-thumb:hover { opacity: 1; border-color: rgba(255,255,255,0.5); }
.fv-thumb-active { opacity: 1; border-color: var(--feu-green) !important; }
.fv-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* Details column */
.fv-details-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 4px 0;
}

.fv-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #1f2937;
    margin: 0;
    line-height: 1.2;
}

.fv-status-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}
.fv-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 700;
}
.fv-badge-available {
    background: #dcfce7;
    color: #15803d;
    border: 1px solid #bbf7d0;
}
.fv-badge-unavailable {
    background: #f3f4f6;
    color: #6b7280;
    border: 1px solid #e5e7eb;
}

.fv-description {
    font-size: 0.92rem;
    color: #4b5563;
    line-height: 1.65;
    margin: 0;
}

.fv-meta-table {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
}
.fv-meta-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 9px 0;
    border-bottom: 1px solid #f3f4f6;
}
.fv-meta-row:last-child { border-bottom: none; }
.fv-meta-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #9ca3af;
    width: 100px;
    flex-shrink: 0;
}
.fv-meta-value {
    font-size: 0.88rem;
    color: #374151;
    font-weight: 600;
}
.fv-meta-green { color: var(--feu-green); }

.fv-tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
}
.fv-tag {
    padding: 4px 12px;
    background: #f3f4f6;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #374151;
    border: 1px solid #e5e7eb;
    cursor: default;
    transition: background 0.15s;
}
.fv-tag:hover { background: #e5e7eb; }

.fv-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 4px;
}
.fv-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
    flex: 1;
    min-width: 120px;
}
.fv-btn-primary {
    background: var(--feu-green);
    color: #fff;
    border: 2px solid var(--feu-green);
}
.fv-btn-primary:hover {
    background: var(--feu-green-dark, #166534);
    border-color: var(--feu-green-dark, #166534);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,100,0,0.25);
}
.fv-btn-secondary {
    background: #f3f4f6;
    color: #374151;
    border: 2px solid #e5e7eb;
}
.fv-btn-secondary:hover {
    background: #e5e7eb;
}

@media (max-width: 900px) {
    .fv-layout { grid-template-columns: 1fr; }
    .fv-thumb { width: 80px; height: 56px; }
}
@media (max-width: 560px) {
    .fv-title { font-size: 1.4rem; }
    .fv-thumb { width: 64px; height: 46px; }
    .fv-btn { flex: 1 1 100%; }
}
</style>
{% endblock %}
