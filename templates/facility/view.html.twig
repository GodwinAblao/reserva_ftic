{% extends 'layouts/app.html.twig' %}

{% block title %}{{ facility.name }} | Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/facility_cards.css') }}">
{% endblock %}

{% block content %}
<div class="fv-page">

    <div class="fv-back-bar">
        <a href="{{ is_granted('ROLE_SUPER_ADMIN') ? path('app_facility_management') : path('app_facility_index') }}" class="fv-back-btn">
            ← Back to Facilities
        </a>
    </div>

    <div class="fv-layout">

        <!-- LEFT: Steam-like image gallery -->
        <div class="fv-gallery-col">
            {% set allImages = [] %}
            {% if facility.images|length > 0 %}
                {% for image in facility.images %}
                    {% set allImages = allImages|merge([image.path]) %}
                {% endfor %}
            {% elseif facility.image %}
                {% set allImages = allImages|merge([facility.image]) %}
            {% endif %}

            <div class="fv-media-viewer" id="mediaViewer" data-image-count="{{ allImages|length }}">
                <div class="fv-media-stage">
                    {% if allImages|length > 0 %}
                        <img src="{{ allImages[0] }}" alt="{{ facility.name }}" id="fvMainImage" class="fv-media-img">
                        
                        {% if allImages|length > 1 %}
                        <button class="fv-nav-btn fv-nav-prev" onclick="fvPrevImage()" aria-label="Previous image">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
                        </button>
                        <button class="fv-nav-btn fv-nav-next" onclick="fvNextImage()" aria-label="Next image">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
                        </button>
                        {% endif %}
                        
                        <div class="fv-media-counter" id="imageCounter">1 / {{ allImages|length }}</div>
                        
                        {% if allImages|length > 1 %}
                        <button class="fv-fullscreen-btn" onclick="fvOpenLightbox()" aria-label="View fullscreen">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
                        </button>
                        {% endif %}
                    {% else %}
                        <div class="fv-main-placeholder">{{ facility.name|first|upper }}</div>
                    {% endif %}
                </div>
            </div>

            {% if facility.images|length > 0 %}
            <div class="fv-thumb-strip" id="thumbStrip">
                {% for image in facility.images %}
                    <div class="fv-thumb {% if loop.first %}fv-thumb-active{% endif %}"
                         data-index="{{ loop.index0 }}"
                         onclick="fvGoToImage({{ loop.index0 }}, this)">
                        <img src="{{ image.path }}" alt="{{ facility.name }} - {{ loop.index }}">
                    </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>

        <!-- RIGHT: details panel -->
        <div class="fv-details-col">

            <h1 class="fv-title">{{ facility.name }}</h1>

            <div class="fv-status-row">
                {% if facility.isAvailableForReservation() %}
                    <span class="fv-badge fv-badge-available">✔ Available for Reservation</span>
                {% else %}
                    <span class="fv-badge fv-badge-unavailable">✗ Not Available</span>
                {% endif %}
            </div>

            {% if facility.description %}
            <p class="fv-description">{{ facility.description }}</p>
            {% endif %}

            <div class="fv-meta-table">
                <div class="fv-meta-row">
                    <span class="fv-meta-label">CAPACITY</span>
                    <span class="fv-meta-value fv-meta-green">{{ facility.capacity }} persons</span>
                </div>
                <div class="fv-meta-row">
                    <span class="fv-meta-label">STATUS</span>
                    <span class="fv-meta-value">
                        {% if facility.isAvailableForReservation() %}
                            <span class="fv-meta-green">Open for booking</span>
                        {% else %}
                            <span style="color:#9ca3af;">Unavailable</span>
                        {% endif %}
                    </span>
                </div>
                {% if facility.images|length > 0 %}
                <div class="fv-meta-row">
                    <span class="fv-meta-label">GALLERY</span>
                    <span class="fv-meta-value">{{ facility.images|length }} image{{ facility.images|length > 1 ? 's' : '' }}</span>
                </div>
                {% endif %}
            </div>

            <div class="fv-tags-row">
                <span class="fv-tag">{{ facility.capacity }} pax</span>
                {% if facility.images|length > 0 %}
                    <span class="fv-tag">{{ facility.images|length }} photo{{ facility.images|length > 1 ? 's' : '' }}</span>
                {% endif %}
                <span class="fv-tag">FTIC Facility</span>
            </div>

            <div class="fv-actions">
                {% if is_granted('ROLE_SUPER_ADMIN') %}
                    <a href="{{ path('app_facility_edit', {id: facility.id}) }}" class="fv-btn fv-btn-primary">Edit Facility</a>
                    <a href="{{ path('app_facility_management') }}" class="fv-btn fv-btn-secondary">Management</a>
                {% else %}
                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        <a href="{{ path('facility_reserve', {id: facility.id}) }}" class="fv-btn fv-btn-primary">Reserve Now</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="fv-btn fv-btn-primary" data-turbo="false" target="_self">Sign In to Reserve</a>
                    {% endif %}
                {% endif %}
            </div>

        </div>
    </div>
</div>

<!-- Lightbox Overlay -->
<div class="fv-lightbox" id="fvLightbox" onclick="fvCloseLightbox(event)">
    <button class="fv-lightbox-close" onclick="fvCloseLightbox()">&times;</button>
    <button class="fv-lightbox-nav fv-lightbox-prev" onclick="fvPrevImage(); event.stopPropagation();">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <img src="" alt="{{ facility.name }}" id="lightboxImage" class="fv-lightbox-img">
    <button class="fv-lightbox-nav fv-lightbox-next" onclick="fvNextImage(); event.stopPropagation();">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    <div class="fv-lightbox-counter" id="lightboxCounter"></div>
</div>

<script>
// Gallery image URLs from Twig
const fvImageList = {{ allImages|json_encode|raw }};
let fvCurrentIndex = 0;

// Move lightbox to body to ensure it covers header/sidebar and centers properly
document.addEventListener('DOMContentLoaded', function() {
    const lightbox = document.getElementById('fvLightbox');
    if (lightbox && lightbox.parentElement !== document.body) {
        document.body.appendChild(lightbox);
    }
});

function fvUpdateImage(index) {
    if (!fvImageList.length || index < 0 || index >= fvImageList.length) return;
    fvCurrentIndex = index;
    
    const mainImg = document.getElementById('fvMainImage');
    const counter = document.getElementById('imageCounter');
    const lightboxImg = document.getElementById('lightboxImage');
    const lightboxCounter = document.getElementById('lightboxCounter');
    
    // Update main image with fade
    if (mainImg) {
        mainImg.style.opacity = '0.7';
        setTimeout(() => {
            mainImg.src = fvImageList[index];
            mainImg.style.opacity = '1';
        }, 120);
    }
    
    // Update counter
    if (counter) counter.textContent = (index + 1) + ' / ' + fvImageList.length;
    if (lightboxCounter) lightboxCounter.textContent = (index + 1) + ' / ' + fvImageList.length;
    if (lightboxImg) lightboxImg.src = fvImageList[index];
    
    // Update thumbnails
    document.querySelectorAll('.fv-thumb').forEach((t, i) => {
        t.classList.toggle('fv-thumb-active', i === index);
    });
    
    // Scroll active thumb into view
    const activeThumb = document.querySelector('.fv-thumb-active');
    if (activeThumb && activeThumb.scrollIntoView) {
        activeThumb.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }
}

function fvNextImage() {
    if (fvImageList.length <= 1) return;
    fvUpdateImage((fvCurrentIndex + 1) % fvImageList.length);
}

function fvPrevImage() {
    if (fvImageList.length <= 1) return;
    fvUpdateImage((fvCurrentIndex - 1 + fvImageList.length) % fvImageList.length);
}

function fvGoToImage(index, thumb) {
    fvUpdateImage(index);
}

function fvOpenLightbox() {
    const lightbox = document.getElementById('fvLightbox');
    const lightboxImg = document.getElementById('lightboxImage');
    if (lightbox && lightboxImg) {
        lightboxImg.src = fvImageList[fvCurrentIndex];
        lightbox.classList.add('is-open');
        document.body.style.overflow = 'hidden';
    }
}

function fvCloseLightbox(e) {
    if (e && e.target !== e.currentTarget) return;
    const lightbox = document.getElementById('fvLightbox');
    if (lightbox) {
        lightbox.classList.remove('is-open');
        document.body.style.overflow = '';
    }
}

// Keyboard navigation
document.addEventListener('keydown', function(e) {
    const lightbox = document.getElementById('fvLightbox');
    const isLightboxOpen = lightbox && lightbox.classList.contains('is-open');
    
    if (e.key === 'ArrowRight') fvNextImage();
    if (e.key === 'ArrowLeft') fvPrevImage();
    if (e.key === 'Escape' && isLightboxOpen) fvCloseLightbox();
});

// Touch/swipe support for mobile
let touchStartX = 0;
let touchEndX = 0;

const mediaStage = document.querySelector('.fv-media-stage');
if (mediaStage && fvImageList.length > 1) {
    mediaStage.addEventListener('touchstart', e => {
        touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    mediaStage.addEventListener('touchend', e => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
            if (diff > 0) fvNextImage();
            else fvPrevImage();
        }
    }, { passive: true });
}
</script>

<style>
.fv-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 16px 40px;
}

.fv-back-bar {
    margin-bottom: 18px;
}
.fv-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--feu-green);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid var(--feu-green);
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
}
.fv-back-btn:hover {
    background: var(--feu-green);
    color: #fff;
}

/* Two-column layout */
.fv-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    align-items: start;
}

/* Gallery column - Steam-like design */
.fv-gallery-col {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
    box-shadow: 0 8px 32px rgba(0,0,0,0.22);
}

.fv-media-viewer {
    position: relative;
    background: #111;
}

.fv-media-stage {
    width: 100%;
    aspect-ratio: 16/10;
    background: #111;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.fv-media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.25s ease, transform 0.4s ease;
    cursor: pointer;
}
.fv-media-img:hover { transform: scale(1.02); }

/* Navigation arrows */
.fv-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(0,0,0,0.55);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s, background 0.2s;
    z-index: 5;
    padding: 0;
}
.fv-media-stage:hover .fv-nav-btn { opacity: 1; }
.fv-nav-btn:hover { background: rgba(0,0,0,0.75); }
.fv-nav-btn svg { width: 22px; height: 22px; }
.fv-nav-prev { left: 12px; }
.fv-nav-next { right: 12px; }

/* Media counter */
.fv-media-counter {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: rgba(0,0,0,0.6);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    z-index: 5;
    backdrop-filter: blur(4px);
}

/* Fullscreen button */
.fv-fullscreen-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(0,0,0,0.5);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s, background 0.2s;
    z-index: 5;
    padding: 0;
}
.fv-media-stage:hover .fv-fullscreen-btn { opacity: 1; }
.fv-fullscreen-btn:hover { background: rgba(0,0,0,0.75); }
.fv-fullscreen-btn svg { width: 18px; height: 18px; }

.fv-main-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 80px;
    font-weight: 900;
    color: rgba(255,255,255,0.15);
}

/* Thumbnail strip */
.fv-thumb-strip {
    display: flex;
    gap: 0;
    background: #111;
    padding: 8px;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: #444 #222;
}
.fv-thumb-strip::-webkit-scrollbar { height: 6px; }
.fv-thumb-strip::-webkit-scrollbar-track { background: #222; }
.fv-thumb-strip::-webkit-scrollbar-thumb { background: #444; border-radius: 3px; }

.fv-thumb {
    flex-shrink: 0;
    width: 100px;
    height: 70px;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 3px solid transparent;
    opacity: 0.6;
    transition: opacity 0.2s, border-color 0.2s, transform 0.15s;
    margin-right: 8px;
}
.fv-thumb:hover { opacity: 0.85; transform: translateY(-2px); }
.fv-thumb-active { opacity: 1 !important; border-color: var(--feu-green) !important; transform: translateY(-2px); }
.fv-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* Details column */
.fv-details-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 4px 0;
}

.fv-title {
    font-size: 2rem;
    font-weight: 800;
    color: #1f2937;
    margin: 0;
    line-height: 1.2;
}

.fv-status-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}
.fv-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
}
.fv-badge-available {
    background: #dcfce7;
    color: #15803d;
    border: 1px solid #bbf7d0;
}
.fv-badge-unavailable {
    background: #f3f4f6;
    color: #6b7280;
    border: 1px solid #e5e7eb;
}

.fv-description {
    font-size: 0.95rem;
    color: #4b5563;
    line-height: 1.65;
    margin: 0;
}

.fv-meta-table {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
}
.fv-meta-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 10px 0;
    border-bottom: 1px solid #f3f4f6;
}
.fv-meta-row:last-child { border-bottom: none; }
.fv-meta-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    width: 100px;
    flex-shrink: 0;
}
.fv-meta-value {
    font-size: 0.9rem;
    color: #374151;
    font-weight: 600;
}
.fv-meta-green { color: var(--feu-green); }

.fv-tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.fv-tag {
    padding: 5px 14px;
    background: #f3f4f6;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 700;
    color: #374151;
    border: 1px solid #e5e7eb;
    cursor: default;
    transition: background 0.15s;
}
.fv-tag:hover { background: #e5e7eb; }

.fv-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 8px;
}
.fv-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
    flex: 1;
    min-width: 120px;
}
.fv-btn-primary {
    background: var(--feu-green);
    color: #fff;
    border: 2px solid var(--feu-green);
}
.fv-btn-primary:hover {
    background: var(--feu-green-dark, #166534);
    border-color: var(--feu-green-dark, #166534);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,100,0,0.25);
}
.fv-btn-secondary {
    background: #f3f4f6;
    color: #374151;
    border: 2px solid #e5e7eb;
}
.fv-btn-secondary:hover {
    background: #e5e7eb;
}

/* Lightbox */
.fv-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.92);
    align-items: center;
    justify-content: center;
    padding: 20px;
}
.fv-lightbox.is-open { display: flex; }

.fv-lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}

.fv-lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: none;
    color: white;
    font-size: 28px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 10;
}
.fv-lightbox-close:hover { background: rgba(255,255,255,0.3); }

.fv-lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 10;
    padding: 0;
}
.fv-lightbox-nav:hover { background: rgba(255,255,255,0.25); }
.fv-lightbox-nav svg { width: 24px; height: 24px; }
.fv-lightbox-prev { left: 20px; }
.fv-lightbox-next { right: 20px; }

.fv-lightbox-counter {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255,255,255,0.15);
    color: white;
    padding: 6px 18px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    backdrop-filter: blur(4px);
}

@media (max-width: 900px) {
    .fv-layout { grid-template-columns: 1fr; }
    .fv-title { font-size: 1.6rem; }
}
@media (max-width: 560px) {
    .fv-title { font-size: 1.4rem; }
    .fv-btn { flex: 1 1 100%; }
    .fv-nav-btn { opacity: 1; width: 38px; height: 38px; }
    .fv-thumb { width: 84px; height: 60px; }
    .fv-media-stage { aspect-ratio: 16/11; }
}
</style>
{% endblock %}
