<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Reserva FTIC{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        <!-- ═══════════════════════════════════════════════════════════════════════════════
             FONTS - Preconnect so DNS/TLS is resolved before app.css even downloads
             ═══════════════════════════════════════════════════════════════════════════════ -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Sans+3:wght@400;600;700&display=swap" media="all">

        <!-- ═══════════════════════════════════════════════════════════════════════════════
             CRITICAL CSS - Loaded synchronously (blocking) to prevent ANY FOUC
             ═══════════════════════════════════════════════════════════════════════════════ -->
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}" media="all">
        
        <!-- Critical inline styles to hide body until CSS is fully applied -->
        <style>
            /* Prevent FOUC - body starts invisible and becomes visible once CSS loads */
            html { visibility: hidden; opacity: 0; }
            html.css-loaded { visibility: visible; opacity: 1; transition: opacity 0.05s ease; }
        </style>
        <script>
            // Reveal content only once app.css is fully applied (probe --feu-green CSS variable).
            // DOMContentLoaded fires before CSS @imports finish — this probe is reliable.
            (function() {
                var html = document.documentElement;
                function reveal() { html.classList.add('css-loaded'); }
                function isCSSReady() {
                    return getComputedStyle(html).getPropertyValue('--feu-green').trim() !== '';
                }
                function checkAndReveal() {
                    if (isCSSReady()) { reveal(); } else { requestAnimationFrame(checkAndReveal); }
                }
                if (document.readyState !== 'loading') {
                    checkAndReveal();
                } else {
                    document.addEventListener('DOMContentLoaded', checkAndReveal);
                }
            })();
        </script>

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% block body %}{% endblock %}
    </body>
</html>
