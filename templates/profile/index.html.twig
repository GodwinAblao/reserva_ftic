{% extends 'layouts/app.html.twig' %}

{% block title %}Profile | Reserva FTIC{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ app.request.basepath }}/assets/styles/profile.css">
{% endblock %}

{% block content %}
{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-error">{{ message }}</div>
{% endfor %}

<div class="card-panel profile-editor">
    <div class="profile-summary">
        <div class="profile-picture-holder">
            {% if app.user.profilePicture %}
                <img src="{{ asset('uploads/profiles/' ~ app.user.profilePicture) }}" alt="Profile Picture">
            {% else %}
                <div class="profile-placeholder">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M6 21c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
                    </svg>
                </div>
            {% endif %}
        </div>
        <div>
            <h3>{{ app.user.firstName ~ ' ' ~ app.user.lastName|default(app.user.email) }}</h3>
            <p>{{ app.user.degreeName|default('Profile details not completed') }}</p>
            <div class="role-badges">
                {% for role in app.user.roles %}
                    {% if role != 'ROLE_USER' %}
                        <span class="role-badge">{{ role|replace({'ROLE_': ''}) }}</span>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="profile-main">
        <div class="profile-form-header">
            <div class="profile-tabs">
                <button type="button" class="tab-btn active">Personal Information</button>
                <button type="button" class="tab-btn">Mentor Public Profile</button>
            </div>
        </div>

        <form method="post" action="{{ path('app_profile') }}" enctype="multipart/form-data" class="profile-form" id="personalForm">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('profile') }}">

        <div class="form-section">
            <h3>Personal Information</h3>
            <p class="muted">Update your account details</p>

            {# Profile Photo #}
            <div class="form-group">
                <label for="profile_picture">Profile Photo</label>
                <input type="file" name="profile_picture" id="profile_picture" accept="image/*">
            </div>

            {# Name #}
            <div class="form-row">
                <div class="form-group">
                    <label for="first_name">First Name</label>
                    <input type="text" name="first_name" id="first_name" value="{{ app.user.firstName }}">
                </div>
                <div class="form-group">
                    <label for="middle_name">Middle Name</label>
                    <input type="text" name="middle_name" id="middle_name" value="{{ app.user.middleName }}">
                </div>
                <div class="form-group">
                    <label for="last_name">Last Name</label>
                    <input type="text" name="last_name" id="last_name" value="{{ app.user.lastName }}">
                </div>
            </div>

            {# Degree #}
            <div class="form-row">
                <div class="form-group">
                    <label for="degree">Course Code</label>
                    <input type="text" name="degree" id="degree" value="{{ app.user.degree }}" placeholder="BSIT">
                </div>
                <div class="form-group">
                    <label for="degree_name">Degree Name</label>
                    <input type="text" name="degree_name" id="degree_name" value="{{ app.user.degreeName }}">
                </div>
            </div>

            {# Login #}
            <div class="form-row">
                <div class="form-group">
                    <label for="email">Login Email</label>
                    <input type="email" name="email" id="email" value="{{ app.user.email }}">
                </div>
                <div class="form-group">
                    <label for="password">New Password</label>
                    <input type="password" name="password" id="password" placeholder="Leave blank">
                </div>
            </div>

            {# Mentor fields removed from personal form and moved to mentor form below #}

            <button type="submit" class="btn-primary">Save Personal Changes</button>
        </div>
    </form>

    {% if is_granted('ROLE_MENTOR') and mentorProfile %}
    <form method="post" action="{{ path('app_profile') }}" enctype="multipart/form-data" class="profile-form mentor-form" id="mentorForm" style="display:none;">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('profile') }}">
        <div class="form-section">
            <h3>Mentor Public Profile</h3>
            <p class="muted">This information is visible to all students</p>
            <div class="form-row">
                <div class="form-group">
                    <label>Display Name</label>
                    <input type="text" name="display_name" value="{{ mentorProfile.displayName }}" placeholder="How you want to be known">
                </div>
                <div class="form-group">
                    <label>Specialization</label>
                    <select name="specialization" class="form-input">
                        <option value="">Select specialization...</option>
                        <option value="BSITBA" {{ mentorProfile.specialization == 'BSITBA' ? 'selected' : '' }}>BSITBA (IT Business Analysis)</option>
                        <option value="BSCS" {{ mentorProfile.specialization == 'BSCS' ? 'selected' : '' }}>BSCS (Computer Science)</option>
                        <option value="Software Engineering" {{ mentorProfile.specialization == 'Software Engineering' ? 'selected' : '' }}>Software Engineering</option>
                        <option value="Data Science" {{ mentorProfile.specialization == 'Data Science' ? 'selected' : '' }}>Data Science</option>
                        <option value="Cybersecurity" {{ mentorProfile.specialization == 'Cybersecurity' ? 'selected' : '' }}>Cybersecurity</option>
                        <option value="Cloud Computing" {{ mentorProfile.specialization == 'Cloud Computing' ? 'selected' : '' }}>Cloud Computing</option>
                        <option value="Web Development" {{ mentorProfile.specialization == 'Web Development' ? 'selected' : '' }}>Web Development</option>
                        <option value="Mobile Development" {{ mentorProfile.specialization == 'Mobile Development' ? 'selected' : '' }}>Mobile Development</option>
                        <option value="UI/UX Design" {{ mentorProfile.specialization == 'UI/UX Design' ? 'selected' : '' }}>UI/UX Design</option>
                        <option value="Research" {{ mentorProfile.specialization == 'Research' ? 'selected' : '' }}>Research</option>
                        <option value="Other" {{ mentorProfile.specialization == 'Other' ? 'selected' : '' }}>Other</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Bio / Description</label>
                <textarea name="bio" rows="4" placeholder="Tell students about your expertise, experience, and what you can help with...">{{ mentorProfile.bio }}</textarea>
            </div>
            <button type="submit" class="btn-primary">Save Mentor Changes</button>
        </div>
    </form>
    {% endif %}

    </div>

    <script>
    (function(){
        // Tab switching for profile page
        const tabs = document.querySelectorAll('.tab-btn');
        const personalForm = document.getElementById('personalForm');
        const mentorForm = document.getElementById('mentorForm');
        if (!tabs.length) return;
        tabs.forEach(function(btn){
            btn.addEventListener('click', function(){
                tabs.forEach(b=>b.classList.remove('active'));
                btn.classList.add('active');
                if (btn.textContent.trim().toLowerCase().includes('mentor')){
                    if (personalForm) personalForm.style.display = 'none';
                    if (mentorForm) mentorForm.style.display = '';
                } else {
                    if (mentorForm) mentorForm.style.display = 'none';
                    if (personalForm) personalForm.style.display = '';
                }
            });
        });
        // ensure default state: show personal
        if (mentorForm) mentorForm.style.display = 'none';
    })();
    </script>
</div>

{% endblock %}
