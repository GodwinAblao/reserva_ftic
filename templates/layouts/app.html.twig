{% extends 'base.html.twig' %}

{% block body %}
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="{{ asset('images/R-Logo.png') }}" alt="R Logo">
            </div>

            <nav class="nav-list">
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard') }}">
                    Dashboard
                </a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_profile' ? 'active' : '' }}" href="{{ path('app_profile') }}">
                    Profile Account
                </a>
                {% if is_granted('ROLE_SUPER_ADMIN') %}
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_account_management' ? 'active' : '' }}" href="{{ path('app_account_management') }}">
                    Account Management
                </a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_facility_management' ? 'active' : '' }}" href="{{ path('app_facility_management') }}">
                    Facility Management
                </a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'admin_reservations' ? 'active' : '' }}" href="{{ path('admin_reservations') }}">
                    Reservations
                </a>
                {% else %}
                <a class="nav-link {{ app.request.attributes.get('_route') == 'app_facility_index' ? 'active' : '' }}" href="{{ path('app_facility_index') }}">
                    Facility
                </a>
                <a class="nav-link {{ app.request.attributes.get('_route') == 'user_reservations' ? 'active' : '' }}" href="{{ path('user_reservations') }}">
                    My Reservations
                </a>
                {% endif %}
            </nav>

            <div class="sidebar-footer">
                <div class="pill-role">
                    {{ is_granted('ROLE_SUPER_ADMIN') ? 'SUPER ADMIN' : 'USER' }}
                </div>
                <div>Signed in as {{ app.user ? app.user.userIdentifier : 'Guest' }}</div>
                <div><a href="{{ path('app_logout') }}">Log out</a></div>
            </div>
        </aside>

        <main class="content-area">
            {% block content %}{% endblock %}
        </main>
    </div>
{% endblock %}
